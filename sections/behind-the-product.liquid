{% comment %}
  The Science Behind It - Uniform Grid Spacing Alignment Section
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;700;800&display=swap" rel="stylesheet">

{% style %}
  .science-section {
    padding: 60px 4%;
    background-color: #ffffff;
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .science-main-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px; /* Standardized uniform gap */
    box-sizing: border-box;
    align-items: stretch; 
  }

  /* --- LEFT HERO BANNER PANEL --- */
  .science-left-hero {
    background-color: #f7cb4d; 
    border-radius: 28px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    height: 100%; 
    min-height: 500px; 
  }

  .science-hero-bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    mix-blend-mode: multiply;
    opacity: 0.9;
  }

  /* SVG Overlay for the continuous winding path line */
  .science-path-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .science-path-line {
    fill: none;
    stroke: #ffffff;
    stroke-width: 2.5px;
  }

  /* Circular Feature Node Points on Left Panel */
  .science-hero-node {
    position: absolute;
    z-index: 3;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background-color: transparent;
    border: 2px solid #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    box-sizing: border-box;
    text-align: center;
  }

  .science-hero-node p {
    color: #ffffff;
    font-size: 10px;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
    letter-spacing: -0.1px;
  }

  .node-mfc {
    left: 12%;
    bottom: 20%;
  }

  .node-retention {
    left: 40%;
    top: 42%;
  }

  .node-digestibility {
    right: 12%;
    top: 15%;
  }

  /* --- RIGHT SIDE GRID LAYOUT --- */
  .science-right-stack {
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 24px; /* Matches layout gap exactly */
  }

  /* Top nested row splitting header card and fresh meat card */
  .science-right-top-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px; /* Matches layout gap exactly */
  }

  .science-title-card {
    background-color: #90D7EE; 
    border-radius: 28px;
    padding: 40px 35px;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  .science-main-heading {
    color: #ffffff;
    font-size: 42px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.5px;
    text-transform: uppercase;
  }

  .science-image-card {
    border-radius: 28px;
    overflow: hidden;
    display: block;
  }

  .science-image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Bottom horizontal icon list feature row */
  .science-bottom-features-card {
    background-color: #d11e1e;
    border-radius: 28px;
    padding: 45px 35px;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px; /* Matches layout gap exactly */
  }

  .science-icon-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }

  .science-icon-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1.5px solid #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  .science-icon-circle svg,
  .science-icon-circle img {
    width: 24px;
    height: 24px;
    object-fit: contain;
    fill: currentColor;
  }

  .science-icon-label {
    color: #ffffff;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    max-width: 130px;
  }

  /* --- RESPONSIVE BREAKPOINTS --- */
  @media (max-width: 1024px) {
    .science-main-container {
      grid-template-columns: 1fr;
    }
    .science-left-hero {
      height: 450px;
      min-height: auto;
    }
    .science-main-heading {
      font-size: 36px;
    }
  }

  @media (max-width: 767px) {
    .science-section {
      padding: 40px 16px;
    }
    .science-main-container,
    .science-right-stack,
    .science-right-top-row {
      gap: 16px; /* Scaled down uniformly for compact mobile screens */
    }
    .science-left-hero {
      height: 380px;
    }
    .science-right-top-row {
      grid-template-columns: 1fr;
    }
    .science-bottom-features-card {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      padding: 35px 20px;
    }
    .science-title-card, .science-image-card {
      padding: 35px 25px;
    }
    .science-hero-node {
      width: 85px;
      height: 85px;
    }
    .science-hero-node p {
      font-size: 9px;
    }
  }
{% endstyle %}

<section class="science-section" id="ScienceSection-{{ section.id }}">
  <div class="science-main-container">
    
    <div class="science-left-hero">
      {%- if section.settings.dog_hero_image != blank -%}
        <img class="science-hero-bg-img" src="{{ section.settings.dog_hero_image | image_url: width: 800 }}" alt="Pet nutrition presentation framework close up">
      {%- else -%}
        <img class="science-hero-bg-img" src="https://cdn.shopify.com/s/files/1/0817/3990/7350/files/golden_retriever_feed.jpg?v=1710000100" alt="Default Content Layout Frame Asset">
      {%- endif -%}

      <svg class="science-path-overlay" viewBox="0 0 500 500" preserveAspectRatio="none">
        <path class="science-path-line" d="M 25,500 C 70,420 80,380 100,320 C 130,220 180,260 230,255 C 330,245 350,150 400,100 C 420,70 410,20 440,0" />
      </svg>

      <div class="science-hero-node node-mfc">
        <p>{{ section.settings.node_text_1 | default: "MFC<br>process" }}</p>
      </div>
      <div class="science-hero-node node-retention">
        <p>{{ section.settings.node_text_2 | default: "Better<br>nutrient<br>retention" }}</p>
      </div>
      <div class="science-hero-node node-digestibility">
        <p>{{ section.settings.node_text_3 | default: "Improved<br>digestibility<br>and<br>absorption" }}</p>
      </div>
    </div>

    <div class="science-right-stack">
      
      <div class="science-right-top-row">
        <div class="science-title-card">
          <h2 class="science-main-heading">
            {{ section.settings.heading_text | default: "The<br>Science<br>Behind It" }}
          </h2>
        </div>

        <div class="science-image-card">
          {%- if section.settings.raw_product_image != blank -%}
            <img src="{{ section.settings.raw_product_image | image_url: width: 500 }}" alt="Fresh raw grade whole recipe composition components">
          {%- else -%}
            <img src="https://cdn.shopify.com/s/files/1/0817/3990/7350/files/raw_chicken_drumsticks.jpg?v=1710000101" alt="Chicken base recipe design elements placeholder">
          {%- endif -%}
        </div>
      </div>

      <div class="science-bottom-features-card">
        <div class="science-icon-node">
          <div class="science-icon-circle">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M12 4v12M8 7v6M16 6v8M4 20h16"/></svg>
          </div>
          <p class="science-icon-label">{{ section.settings.feat_label_1 | default: "Controlled low-temperature dehydration" }}</p>
        </div>

        <div class="science-icon-node">
          <div class="science-icon-circle">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <p class="science-icon-label">{{ section.settings.feat_label_2 | default: "Preserves amino acids & micronutrients" }}</p>
        </div>

        <div class="science-icon-node">
          <div class="science-icon-circle">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><path d="m4.93 4.93 4.24 4.24M14.83 14.83l4.24 4.24"/></svg>
          </div>
          <p class="science-icon-label">{{ section.settings.feat_label_3 | default: "Reduced nutrient loss" }}</p>
        </div>

        <div class="science-icon-node">
          <div class="science-icon-circle">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none"><path d="m12 3-1.912 5.886H3.882l5.018 3.646L6.988 18.42 12 14.774l5.012 3.646-1.912-5.888 5.018-3.646h-6.206Z"/></svg>
          </div>
          <p class="science-icon-label">{{ section.settings.feat_label_4 | default: "Higher nutritional density" }}</p>
        </div>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Science Behind It",
  "settings": [
    {
      "type": "header",
      "content": "Image Media Assets"
    },
    {
      "type": "image_picker",
      "id": "dog_hero_image",
      "label": "Left Panel Hero Image"
    },
    {
      "type": "image_picker",
      "id": "raw_product_image",
      "label": "Right Row Product Image"
    },
    {
      "type": "header",
      "content": "Text Labels & Value Properties"
    },
    {
      "type": "html",
      "id": "heading_text",
      "label": "Main Red Card Heading",
      "default": "The<br>Science<br>Behind It"
    },
    {
      "type": "html",
      "id": "node_text_1",
      "label": "Path Overlay Circle Node 1",
      "default": "MFC<br>process"
    },
    {
      "type": "html",
      "id": "node_text_2",
      "label": "Path Overlay Circle Node 2",
      "default": "Better<br>nutrient<br>retention"
    },
    {
      "type": "html",
      "id": "node_text_3",
      "label": "Path Overlay Circle Node 3",
      "default": "Improved<br>digestibility<br>and<br>absorption"
    },
    {
      "type": "text",
      "id": "feat_label_1",
      "label": "Bottom Icon Feature 1 Text",
      "default": "Controlled low-temperature dehydration"
    },
    {
      "type": "text",
      "id": "feat_label_2",
      "label": "Bottom Icon Feature 2 Text",
      "default": "Preserves amino acids & micronutrients"
    },
    {
      "type": "text",
      "id": "feat_label_3",
      "label": "Bottom Icon Feature 3 Text",
      "default": "Reduced nutrient loss"
    },
    {
      "type": "text",
      "id": "feat_label_4",
      "label": "Bottom Icon Feature 4 Text",
      "default": "Higher nutritional density"
    }
  ],
  "presets": [
    {
      "name": "Science Behind It"
    }
  ]
}
{% endschema %}