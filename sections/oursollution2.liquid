{%- style -%}
  .matrix-section-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-dark: {{ section.settings.text_color_dark }};
    --text-accent: {{ section.settings.text_color_accent }};
    background-color: var(--bg-color);
    padding: 80px 0;
    overflow: hidden;
    font-family: inherit;
  }

  /* Desktop Locked Workspace Box matching canvas blueprint spec */
  .matrix-section-{{ section.id }} .matrix-desktop-canvas {
    max-width: 1347px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    box-sizing: border-box;
  }

  /* Core Alternating Composition Layout Layout */
  .matrix-section-{{ section.id }} .matrix-upper-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 50px;
    margin-bottom: 40px;
  }

  .matrix-section-{{ section.id }} .fresh-bowl-block {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    position: relative;
  }

  .matrix-section-{{ section.id }} .fresh-bowl-block img {
    max-width: 340px;
    height: auto;
    object-fit: contain;
  }

  .matrix-section-{{ section.id }} .top-right-text-block {
    flex: 1;
    max-width: 360px;
    color: var(--text-dark);
    font-size: 0.92rem;
    line-height: 1.6;
    font-weight: 500;
  }

  /* Central Focal Area (Arched text floating cleanly over center bowl) */
  .matrix-section-{{ section.id }} .matrix-middle-row {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    align-items: center;
    margin-top: -30px;
    margin-bottom: 60px;
  }

  .matrix-section-{{ section.id }} .mid-left-text-block {
    max-width: 280px;
    justify-self: end;
    text-align: right;
    color: var(--text-dark);
    font-size: 0.92rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .matrix-section-{{ section.id }} .center-bowl-showcase {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .matrix-section-{{ section.id }} .center-bowl-showcase img {
    max-width: 350px;
    height: auto;
    display: block;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  /* Precision Arched Typography Overlay Engine */
  .matrix-section-{{ section.id }} .center-bowl-showcase svg.heading-arch {
    position: absolute;
    top: {{ section.settings.arch_y_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    width: 130%;
    height: auto;
    z-index: 3;
    pointer-events: none;
  }

  .matrix-section-{{ section.id }} .center-bowl-showcase svg.heading-arch text {
    font-size: 30px;
    font-weight: 800;
    fill: var(--text-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Bottom Statement Blocks Stack */
  .matrix-section-{{ section.id }} .matrix-bottom-stack {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .matrix-section-{{ section.id }} .matrix-main-statement p {
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--text-dark);
    line-height: 1.4;
    margin: 0 0 30px 0;
    letter-spacing: -0.01em;
  }

  .matrix-section-{{ section.id }} .matrix-sub-statement p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-dark);
    font-weight: 500;
    max-width: 780px;
    margin: 0 auto;
    opacity: 0.95;
  }

  /* Decorative Directional Micro-Arrows Positioning */
  .matrix-section-{{ section.id }} .indicator-arrow-asset {
    position: absolute;
    width: 35px;
    height: auto;
    opacity: 0.85;
  }
  .matrix-section-{{ section.id }} .arrow-top {
    top: 45%;
    right: 52%;
  }
  .matrix-section-{{ section.id }} .arrow-mid {
    top: 42%;
    left: 28%;
  }

  /* Clean responsive scaling parameters */
  @media (max-width: 1024px) {
    .matrix-section-{{ section.id }} .matrix-desktop-canvas {
      max-width: 100%;
      padding: 0 20px;
    }
    .matrix-section-{{ section.id }} .matrix-middle-row {
      grid-template-columns: 1fr;
      gap: 40px;
      margin-top: 20px;
    }
    .matrix-section-{{ section.id }} .mid-left-text-block {
      text-align: center;
      justify-self: center;
    }
    .matrix-section-{{ section.id }} .matrix-upper-row {
      flex-direction: column;
      text-align: center;
      gap: 30px;
    }
    .matrix-section-{{ section.id }} .fresh-bowl-block {
      justify-content: center;
    }
    .matrix-section-{{ section.id }} .indicator-arrow-asset {
      display: none;
    }
  }
{%- endstyle -%}

<section class="matrix-section-{{ section.id }}">
  <div class="matrix-desktop-canvas">
    
    <div class="matrix-upper-row">
      <div class="fresh-bowl-block">
        {%- if section.settings.fresh_bowl_img != blank -%}
          {{ section.settings.fresh_bowl_img | image_url: width: 700 | image_tag: loading: 'eager', alt: 'Fresh Ingredients Plate Asset' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.arrow_graphic != blank -%}
          <img class="indicator-arrow-asset arrow-top" src="{{ section.settings.arrow_graphic | image_url: width: 100 }}" alt="Indicator Link Line">
        {%- endif -%}
      </div>

      <div class="top-right-text-block">
        {{ section.settings.top_right_text }}
      </div>
    </div>

    <div class="matrix-middle-row">
      <div class="mid-left-text-block">
        {{ section.settings.mid_left_text }}
      </div>

      <div class="center-bowl-showcase">
        <svg class="heading-arch" viewBox="0 0 600 240" xmlns="http://www.w3.org/2000/svg">
          <path id="archPathText-{{ section.id }}" d="M 60,210 Q 300,45 540,210" fill="transparent" />
          <text>
            <textPath href="#archPathText-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.arched_heading_text }}
            </textPath>
          </text>
        </svg>

        {%- if section.settings.center_bowl_img != blank -%}
          {{ section.settings.center_bowl_img | image_url: width: 700 | image_tag: loading: 'lazy', alt: 'Finished Pet Food Bowl Asset' }}
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.arrow_graphic != blank -%}
          <img class="indicator-arrow-asset arrow-mid" src="{{ section.settings.arrow_graphic | image_url: width: 100 }}" alt="Indicator Link Line">
        {%- endif -%}
      </div>

      <div class="empty-right-block" aria-hidden="true"></div>
    </div>

    <div class="matrix-bottom-stack">
      <div class="matrix-main-statement">
        {{ section.settings.bottom_headline }}
      </div>
      <div class="matrix-sub-statement">
        {{ section.settings.bottom_subtext }}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Perfection Matrix Layout",
  "settings": [
    {
      "type": "header",
      "content": "Image Component Asset Managers"
    },
    {
      "type": "image_picker",
      "id": "fresh_bowl_img",
      "label": "Top Left Fresh Food Bowl Image"
    },
    {
      "type": "image_picker",
      "id": "center_bowl_img",
      "label": "Center Pet Food Bowl Image"
    },
    {
      "type": "image_picker",
      "id": "arrow_graphic",
      "label": "Small Indicator Handdrawn Arrow Image"
    },
    {
      "type": "header",
      "content": "Typography Content Layouts"
    },
    {
      "type": "richtext",
      "id": "top_right_text",
      "label": "Top Right Description text",
      "default": "<p>Real foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease</p>"
    },
    {
      "type": "text",
      "id": "arched_heading_text",
      "label": "Arched Heading Text over center bowl",
      "default": "Our diets are made from real foods"
    },
    {
      "type": "richtext",
      "id": "mid_left_text",
      "label": "Middle Left Side Description Text",
      "default": "<p>Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food</p>"
    },
    {
      "type": "richtext",
      "id": "bottom_headline",
      "label": "Bottom Bold Focal Headline",
      "default": "<p>Our Formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system.</p>"
    },
    {
      "type": "richtext",
      "id": "bottom_subtext",
      "label": "Bottom Subtext Footnote Wording",
      "default": "<p>Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it.</p>"
    },
    {
      "type": "header",
      "content": "Layout Tuning Offsets"
    },
    {
      "type": "range",
      "id": "arch_y_offset",
      "min": -150,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Arched Typography Height Adjuster (Y Offset)",
      "default": -75
    },
    {
      "type": "header",
      "content": "Section Theme Canvas Styling Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Soft Color Tone",
      "default": "#fcd36a"
    },
    {
      "type": "color",
      "id": "text_color_dark",
      "label": "Primary Base Dark Wording",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_accent",
      "label": "Brand Custom Red Accent Accent Color",
      "default": "#d93829"
    }
  ],
  "presets": [
    {
      "name": "Perfection Matrix Layout"
    }
  ]
}
{% endschema %}