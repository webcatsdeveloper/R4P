{%- style -%}
  .sol-matrix-{{ section.id }} {
    --text-dark: {{ section.settings.text_color_dark }};
    --text-accent: {{ section.settings.text_color_accent }};
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    overflow: hidden;
    font-family: inherit;
    position: relative;
  }

  .sol-matrix-{{ section.id }} .matrix-workspace-canvas {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 3;
  }

  /* Asymmetric Desktop Layout Grid Configuration */
  .sol-matrix-{{ section.id }} .matrix-main-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: 40px;
    position: relative;
  }

  /* Left Column: Combined Graphic Asset & Bottom Left Paragraph */
  .sol-matrix-{{ section.id }} .matrix-left-col {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .sol-matrix-{{ section.id }} .combined-showcase-image {
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
  }

  .sol-matrix-{{ section.id }} .combined-showcase-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .sol-matrix-{{ section.id }} .para-bottom-left {
    max-width: 380px;
    align-self: flex-end;
    text-align: left;
  }

  /* Right Column: Top Right Paragraph & Middle Right Heading */
  .sol-matrix-{{ section.id }} .matrix-right-col {
    display: flex;
    flex-direction: column;
    gap: 80px;
    padding-top: 40px;
  }

  .sol-matrix-{{ section.id }} .para-top-right {
    max-width: 380px;
    text-align: left;
  }

  .sol-matrix-{{ section.id }} .heading-right-side {
    max-width: 460px;
    text-align: left;
  }

  /* Typography Styles matching image blueprints */
  .sol-matrix-{{ section.id }} .matrix-text-block p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-dark);
    font-weight: 500;
    margin: 0;
  }

  .sol-matrix-{{ section.id }} .heading-right-side h3,
  .sol-matrix-{{ section.id }} .heading-right-side p {
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1.4;
    color: var(--text-dark);
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* Center Aligned Baseline Paragraph Style */
  .sol-matrix-{{ section.id }} .center-aligned-baseline-para {
    max-width: 850px;
    margin: 60px auto 0 auto;
    text-align: center;
  }

  .sol-matrix-{{ section.id }} .center-aligned-baseline-para p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-dark);
    font-weight: 500;
    opacity: 0.95;
    margin: 0;
  }

  /* Position-Controlled Arrow Blocks */
  .sol-matrix-{{ section.id }} .controlled-arrow {
    position: absolute;
    z-index: 5;
    pointer-events: none;
  }

  .sol-matrix-{{ section.id }} .controlled-arrow img {
    display: block;
    height: auto;
  }

  .sol-matrix-{{ section.id }} .arrow-instance-1 {
    left: {{ section.settings.arrow_1_x }}%;
    top: {{ section.settings.arrow_1_y }}%;
    width: {{ section.settings.arrow_1_w }}px;
  }

  .sol-matrix-{{ section.id }} .arrow-instance-2 {
    left: {{ section.settings.arrow_2_x }}%;
    top: {{ section.settings.arrow_2_y }}%;
    width: {{ section.settings.arrow_2_w }}px;
  }

  /* Responsive Breakdown Stacking Rules */
  @media (max-width: 768px) {
    .sol-matrix-{{ section.id }} .matrix-main-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .sol-matrix-{{ section.id }} .matrix-right-col {
      gap: 40px;
      padding-top: 0;
    }
    .sol-matrix-{{ section.id }} .para-bottom-left,
    .sol-matrix-{{ section.id }} .para-top-right,
    .sol-matrix-{{ section.id }} .heading-right-side {
      max-width: 100%;
      text-align: center;
      align-self: center;
    }
    .sol-matrix-{{ section.id }} .heading-right-side h3,
    .sol-matrix-{{ section.id }} .heading-right-side p {
      font-size: 1.25rem;
    }
    .sol-matrix-{{ section.id }} .controlled-arrow {
      display: none; /* Hidden on mobile screen targets to avoid collision overlap layouts */
    }
  }
{%- endstyle -%}

<section class="sol-matrix-{{ section.id }}">
  <div class="matrix-workspace-canvas">
    
    {%- if section.settings.arrow_1_img != blank -%}
      <div class="controlled-arrow arrow-instance-1">
        <img src="{{ section.settings.arrow_1_img | image_url: width: 150 }}" alt="Indicator Pointer Link">
      </div>
    {%- endif -%}

    {%- if section.settings.arrow_2_img != blank -%}
      <div class="controlled-arrow arrow-instance-2">
        <img src="{{ section.settings.arrow_2_img | image_url: width: 150 }}" alt="Indicator Pointer Link">
      </div>
    {%- endif -%}

    <div class="matrix-main-grid">
      
      <div class="matrix-left-col">
        <div class="combined-showcase-image">
          {%- if section.settings.combined_image != blank -%}
            {{ section.settings.combined_image | image_url: width: 1100 | image_tag: loading: 'eager', alt: 'Our Diets Sourcing Showcase' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <div class="matrix-text-block para-bottom-left">
          {{ section.settings.bottom_left_para }}
        </div>
      </div>

      <div class="matrix-right-col">
        <div class="matrix-text-block para-top-right">
          {{ section.settings.top_right_para }}
        </div>

        <div class="heading-right-side">
          {{ section.settings.right_heading }}
        </div>
      </div>

    </div>

    <div class="center-aligned-baseline-para">
      {{ section.settings.center_baseline_para }}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Solution Matrix Blocks",
  "settings": [
    {
      "type": "header",
      "content": "Section Base Canvas Setup"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Top Spacing Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Bottom Spacing Padding",
      "default": 80
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Canvas Background Fill Color",
