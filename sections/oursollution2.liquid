{%- style -%}
  .perf-canvas-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    overflow: hidden;
    font-family: inherit;
    position: relative;
  }

  /* Main Workspace Container Box matching canvas space bounds */
  .perf-canvas-{{ section.id }} .canvas-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    min-height: 900px;
  }

  /* Base Styles for Absolute Canvas Layer Items */
  .perf-canvas-{{ section.id }} .canvas-item {
    position: absolute;
    z-index: 3;
    transition: none;
  }

  /* Typography Design Tokens */
  .perf-canvas-{{ section.id }} .canvas-para p {
    font-size: 1rem;
    line-height: 1.6;
    color: {{ section.settings.text_color_dark }};
    font-weight: 500;
    margin: 0;
  }

  .perf-canvas-{{ section.id }} .canvas-heading h3,
  .perf-canvas-{{ section.id }} .canvas-heading p,
  .perf-canvas-{{ section.id }} .canvas-heading {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.4;
    color: {{ section.settings.text_color_dark }};
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* --- DESKTOP POSITION ENGINE (All 5 Control Points mapped via % coords) --- */
  @media (min-width: 769px) {
    /* Point 1: Main Combined Image Controls */
    .perf-canvas-{{ section.id }} .item-main-image {
      left: {{ section.settings.img_x }}%;
      top: {{ section.settings.img_y }}%;
      width: {{ section.settings.img_w }}px;
    }

    /* Point 2: Arrow 1 Controls */
    .perf-canvas-{{ section.id }} .item-arrow-1 {
      left: {{ section.settings.arrow_1_x }}%;
      top: {{ section.settings.arrow_1_y }}%;
      width: {{ section.settings.arrow_1_w }}px;
    }

    /* Point 2: Arrow 2 Controls */
    .perf-canvas-{{ section.id }} .item-arrow-2 {
      left: {{ section.settings.arrow_2_x }}%;
      top: {{ section.settings.arrow_2_y }}%;
      width: {{ section.settings.arrow_2_w }}px;
    }

    /* Point 3: Top Right Paragraph Controls */
    .perf-canvas-{{ section.id }} .item-top-right-para {
      left: {{ section.settings.tr_para_x }}%;
      top: {{ section.settings.tr_para_y }}%;
      max-width: {{ section.settings.tr_para_w }}px;
      text-align: left;
    }

    /* Point 3: Bottom Left Paragraph Controls */
    .perf-canvas-{{ section.id }} .item-bottom-left-para {
      left: {{ section.settings.bl_para_x }}%;
      top: {{ section.settings.bl_para_y }}%;
      max-width: {{ section.settings.bl_para_w }}px;
      text-align: left;
    }

    /* Point 4: Right Side Heading Controls */
    .perf-canvas-{{ section.id }} .item-right-heading {
      left: {{ section.settings.r_heading_x }}%;
      top: {{ section.settings.r_heading_y }}%;
      max-width: {{ section.settings.r_heading_w }}px;
      text-align: left;
    }

    /* Point 5: Center Aligned Paragraph Controls */
    .perf-canvas-{{ section.id }} .item-center-para {
      left: {{ section.settings.c_para_x }}%;
      top: {{ section.settings.c_para_y }}%;
      max-width: {{ section.settings.c_para_w }}px;
      text-align: center;
      transform: translateX(-50%);
    }
  }

  /* --- MOBILE FALLBACK RESPONSIVE STACKING --- */
  @media (max-width: 768px) {
    .perf-canvas-{{ section.id }} .canvas-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 40px;
      min-height: auto;
      padding: 0 24px;
    }
    .perf-canvas-{{ section.id }} .canvas-item {
      position: relative !important;
      left: unset !important;
      top: unset !important;
      transform: none !important;
      max-width: 100% !important;
      text-align: center !important;
      width: 100% !important;
    }
    .perf-canvas-{{ section.id }} .canvas-item p {
      text-align: center !important;
    }
    .perf-canvas-{{ section.id }} .item-arrow-1,
    .perf-canvas-{{ section.id }} .item-arrow-2 {
      display: none !important;
    }
    .perf-canvas-{{ section.id }} .item-main-image {
      max-width: 320px !important;
    }
  }
{%- endstyle -%}

<section class="perf-canvas-{{ section.id }}">
  <div class="canvas-container">
    
    <div class="canvas-item item-main-image">
      {%- if section.settings.combined_image != blank -%}
        {{ section.settings.combined_image | image_url: width: 1000 | image_tag: loading: 'eager', alt: 'Food Composition Panel' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- if section.settings.arrow_1_img != blank -%}
      <div class="canvas-item item-arrow-1">
        <img src="{{ section.settings.arrow_1_img | image_url: width: 200 }}" style="width:100%; height:auto;" alt="Visual Path Arrow Link 1">
      </div>
    {%- endif -%}

    {%- if section.settings.arrow_2_img != blank -%}
      <div class="canvas-item item-arrow-2">
        <img src="{{ section.settings.arrow_2_img | image_url: width: 200 }}" style="width:100%; height:auto;" alt="Visual Path Arrow Link 2">
      </div>
    {%- endif -%}

    <div class="canvas-item canvas-para item-top-right-para">
      {{ section.settings.top_right_para }}
    </div>

    <div class="canvas-item canvas-para item-bottom-left-para">
      {{ section.settings.bottom_left_para }}
    </div>

    <div class="canvas-item canvas-heading item-right-heading">
      {{ section.settings.right_heading }}
    </div>

    <div class="canvas-item canvas-para item-center-para">
      {{ section.settings.center_para }}
    </div>

  </div>
</section>

