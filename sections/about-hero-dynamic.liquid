<style>
  #shopify-section-{{ section.id }} {
    --bg-color-top: {{ section.settings.bg_color_top }};
    --bg-color-bottom: {{ section.settings.bg_color_bottom }};
    --heading-color: {{ section.settings.heading_color }};
    --accent-color: {{ section.settings.accent_color }};
    --text-color: {{ section.settings.text_color }};
    --container-max-width: {{ section.settings.container_max_width }}px;
    
    /* Main Image Controls: Row 1 */
    --r1-img-w: {{ section.settings.row1_img_w }}%;
    --r1-img-x: {{ section.settings.row1_img_x }}px;
    --r1-img-y: {{ section.settings.row1_img_y }}px;

    /* Main Image Controls: Row 2 */
    --r2-img-w: {{ section.settings.row2_img_w }}%;
    --r2-img-x: {{ section.settings.row2_img_x }}px;
    --r2-img-y: {{ section.settings.row2_img_y }}px;

    /* Mobile Engine Core Defaults (Desktop Values inherited unless overridden in Media query) */
    --blob-w: {{ section.settings.blob_w }}%;
    --blob-x: {{ section.settings.blob_x }}%;
    --blob-y: {{ section.settings.blob_y }}%;

    --crown-w: {{ section.settings.crown_w }}px;
    --crown-x: {{ section.settings.crown_x }}%;
    --crown-y: {{ section.settings.crown_y }}%;

    --hearts-w: {{ section.settings.hearts_w }}px;
    --hearts-x: {{ section.settings.hearts_x }}%;
    --hearts-y: {{ section.settings.hearts_y }}%;

    --spring-w: {{ section.settings.spring_w }}px;
    --spring-x: {{ section.settings.spring_x }}%;
    --spring-y: {{ section.settings.spring_y }}%;

    --lines-w: {{ section.settings.lines_w }}px;
    --lines-x: {{ section.settings.lines_x }}%;
    --lines-y: {{ section.settings.lines_y }}%;

    --f-wave-l-w: {{ section.settings.f_wave_l_w }}px;
    --f-wave-l-x: {{ section.settings.f_wave_l_x }}%;
    --f-wave-l-y: {{ section.settings.f_wave_l_y }}%;

    --f-wave-r-w: {{ section.settings.f_wave_r_w }}px;
    --f-wave-r-x: {{ section.settings.f_wave_r_x }}%;
    --f-wave-r-y: {{ section.settings.f_wave_r_y }}%;

    --f-wave-b-w: {{ section.settings.f_wave_b_w }}px;
    --f-wave-b-x: {{ section.settings.f_wave_b_x }}%;
    --f-wave-b-y: {{ section.settings.f_wave_b_y }}%;
  }

  .combined-about-hero-section {
    width: 100%;
    position: relative;
    overflow: hidden;
    font-family: inherit;
    padding-top: {{ section.settings.global_padding_top }}px;
    padding-bottom: {{ section.settings.global_padding_bottom }}px;
  }

  /* Split Background System */
  .combined-about-hero-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: {{ section.settings.split_bg_ratio }}%;
    background-color: var(--bg-color-top);
    z-index: 1;
  }
  .combined-about-hero-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ 100 | minus: section.settings.split_bg_ratio }}%;
    background-color: var(--bg-color-bottom);
    z-index: 1;
  }

  .about-master-container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 {{ section.settings.container_padding_side }}px;
    position: relative;
    z-index: 2;
  }

  /* Row Structural System */
  .about-layout-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
    width: 100%;
  }
  
  .row-top {
    margin-bottom: {{ section.settings.row_gap }}px;
  }
  
  .row-bottom {
    flex-direction: row-reverse;
  }

  /* Column Scaling Engines */
  .about-col-text {
    flex: 0 0 {{ section.settings.text_col_width }}%;
    max-width: {{ section.settings.text_col_width }}%;
    position: relative;
    left: 80px;
    z-index: 3;
  }

  .about-col-text.act {
    margin-left: -60px;
  }
  
  .row-top .about-col-text { padding-top: {{ section.settings.top_row_text_offset }}px; }
  .row-bottom .about-col-text { padding-top: {{ section.settings.bottom_row_text_offset }}px; }

  .about-col-media {
    flex: 0 0 {{ 100 | minus: section.settings.text_col_width }}%;
    max-width: {{ 100 | minus: section.settings.text_col_width }}%;
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 3;
  }

  /* Typography Design Tokens */
  .about-master-heading {
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: {{ section.settings.heading_line_height }};
    font-weight: 700;
    color: var(--heading-color);
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px 0;
  }
  .about-master-heading span.accent-focus { color: var(--accent-color); }

  .about-master-desc {
    font-size: {{ section.settings.desc_font_size }}px;
    line-height: {{ section.settings.desc_line_height }};
    color: var(--text-color);
    max-width: {{ section.settings.desc_max_width }}px;
  }

  /* Composition Containers */
  .composition-box {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.media_box_max_width }}px;
  }

  /* Transform Metric Overrides via CSS Variables */
  .row-top .main-portrait-render {
    width: var(--r1-img-w) !important;
    transform: translate(var(--r1-img-x), var(--r1-img-y));
  }
  .row-bottom .main-portrait-render {
    width: var(--r2-img-w) !important;
    transform: translate(var(--r2-img-x), var(--r2-img-y));
  }

  .main-portrait-render {
    height: auto;
    display: block;
    position: relative;
    z-index: 5;
    transition: transform 0.3s ease-out;
  }

  /* Dynamic Coordinate Positional Layer Matrix */
  .pos-absolute-vector {
    position: absolute;
    pointer-events: none;
  }

  /* Vector Assignments Routed via Dynamic CSS Matrix */
  .v-blob-bg {
    z-index: 2;
    transform: translate(-50%, -50%);
    width: var(--blob-w);
    top: var(--blob-y);
    left: var(--blob-x);
  }
  .v-crown {
    z-index: 6;
    width: var(--crown-w);
    top: var(--crown-y);
    left: var(--crown-x);
  }
  .v-hearts {
    z-index: 6;
    width: var(--hearts-w);
    top: var(--hearts-y);
    left: var(--hearts-x);
  }
  .v-spring {
    z-index: 6;
    width: var(--spring-w);
    top: var(--spring-y);
    left: var(--spring-x);
  }
  .v-lines {
    z-index: 4;
    width: var(--lines-w);
    top: var(--lines-y);
    left: var(--lines-x);
  }

  /* Global Framing Structural Curve Waves */
  .v-frame-wave {
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }
  .f-wave-left {
    width: var(--f-wave-l-w);
    top: var(--f-wave-l-y);
    left: var(--f-wave-l-x);
  }
  .f-wave-right {
    width: var(--f-wave-r-w);
    top: var(--f-wave-r-y);
    right: var(--f-wave-r-x);
  }
  .f-wave-bottom {
    width: var(--f-wave-b-w);
    top: var(--f-wave-b-y);
    right: var(--f-wave-b-x);
  }

  /* Animations */
  @keyframes revealHero {
    0% { opacity: 0; transform: translateY(40px); filter: blur(8px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  @keyframes vectorFloat {
    0% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(2deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }

  .about-animate {
    opacity: 0;
  }
  .about-animate.is-revealed {
    animation: revealHero 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .about-animate.delay-1 { animation-delay: 0.15s; }
  .about-animate.delay-2 { animation-delay: 0.3s; }
  .about-animate.delay-vector { animation-delay: 0.5s; }

  .is-revealed .v-crown, .is-revealed .v-hearts {
    animation: vectorFloat 4s ease-in-out infinite alternate;
  }
  .is-revealed .v-spring, .is-revealed .v-lines {
    animation: vectorFloat 5s ease-in-out infinite alternate-reverse;
  }

  /* Mobile Responsive Engine Switch Overrides */
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} {
      /* Re-assigning Variable Hooks to Mobile Settings Fields */
      --blob-w: {{ section.settings.mobile_blob_w }}%;
      --blob-x: {{ section.settings.mobile_blob_x }}%;
      --blob-y: {{ section.settings.mobile_blob_y }}%;

      --crown-w: {{ section.settings.mobile_crown_w }}px;
      --crown-x: {{ section.settings.mobile_crown_x }}%;
      --crown-y: {{ section.settings.mobile_crown_y }}%;

      --hearts-w: {{ section.settings.mobile_hearts_w }}px;
      --hearts-x: {{ section.settings.mobile_hearts_x }}%;
      --hearts-y: {{ section.settings.mobile_hearts_y }}%;

      --spring-w: {{ section.settings.mobile_spring_w }}px;
      --spring-x: {{ section.settings.mobile_spring_x }}%;
      --spring-y: {{ section.settings.mobile_spring_y }}%;

      --lines-w: {{ section.settings.mobile_lines_w }}px;
      --lines-x: {{ section.settings.mobile_lines_x }}%;
      --lines-y: {{ section.settings.mobile_lines_y }}%;

      --f-wave-l-w: {{ section.settings.mobile_f_wave_l_w }}px;
      --f-wave-l-x: {{ section.settings.mobile_f_wave_l_x }}%;
      --f-wave-l-y: {{ section.settings.mobile_f_wave_l_y }}%;

      --f-wave-r-w: {{ section.settings.mobile_f_wave_r_w }}px;
      --f-wave-r-x: {{ section.settings.mobile_f_wave_r_x }}%;
      --f-wave-r-y: {{ section.settings.mobile_f_wave_r_y }}%;

      --f-wave-b-w: {{ section.settings.mobile_f_wave_b_w }}px;
      --f-wave-b-x: {{ section.settings.mobile_f_wave_b_x }}%;
      --f-wave-b-y: {{ section.settings.mobile_f_wave_b_y }}%;
    }

    .combined-about-hero-section {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .about-layout-row {
      flex-direction: column !important;
      align-items: center;
      text-align: center;
    }
    .row-top {
      margin-bottom: {{ section.settings.mobile_row_gap }}px;
    }
    .about-col-text, .about-col-media {
      flex: 0 0 100% !important;
      max-width: 100% !important;
    }
    .about-col-text, .about-col-text.act {
      left: 0 !important;
      margin-left: 0 !important;
      margin-bottom: 30px;
      padding-top: 0 !important;
    }
    .about-master-heading {
      font-size: {{ section.settings.mobile_heading_font_size }}px !important;
    }
    .about-master-desc { 
      margin: 0 auto; 
    }
    
    .row-top .main-portrait-render {
      width: {{ section.settings.mobile_row1_img_w }}% !important;
      transform: translate({{ section.settings.mobile_row1_img_x }}px, {{ section.settings.mobile_row1_img_y }}px) !important;
    }
    .row-bottom .main-portrait-render {
      width: {{ section.settings.mobile_row2_img_w }}% !important;
      transform: translate({{ section.settings.mobile_row2_img_x }}px, {{ section.settings.mobile_row2_img_y }}px) !important;
    }
  }
</style>

<div class="combined-about-hero-section">
  
  {%- if section.settings.f_wave_l_img != blank -%}
    <img src="{{ section.settings.f_wave_l_img | img_url: '500x' }}" class="v-frame-wave f-wave-left" alt="" loading="lazy">
  {%- endif -%}

  {%- if section.settings.f_wave_r_img != blank -%}
    <img src="{{ section.settings.f_wave_r_img | img_url: '500x' }}" class="v-frame-wave f-wave-right" alt="" loading="lazy">
  {%- endif -%}

  {%- if section.settings.f_wave_b_img != blank -%}
    <img src="{{ section.settings.f_wave_b_img | img_url: '500x' }}" class="v-frame-wave f-wave-bottom" alt="" loading="lazy">
  {%- endif -%}

  <div class="about-master-container">
    
    <div class="about-layout-row row-top about-animate">
      <div class="about-col-text act about-animate delay-1">
        <h1 class="about-master-heading">
          {{ section.settings.row1_heading_l1 }}<br>
          <span class="accent-focus">{{ section.settings.row1_heading_l2_accent }}</span>{{ section.settings.row1_heading_l2_end }}<br>
          {{ section.settings.row1_heading_l3 }}
        </h1>
        <div class="about-master-desc">
          {{ section.settings.row1_desc }}
        </div>
      </div>
      
      <div class="about-col-media about-animate delay-2">
        <div class="composition-box">
          {%- if section.settings.blob_img != blank -%}
            <img src="{{ section.settings.blob_img | img_url: '1000x' }}" class="pos-absolute-vector v-blob-bg about-animate delay-vector" alt="" loading="eager">
          {%- endif -%}

          {%- if section.settings.row1_main_img != blank -%}
            <img src="{{ section.settings.row1_main_img | img_url: '800x' }}" class="main-portrait-render" alt="Founder Story Portrait">
          {%- endif -%}

          {%- if section.settings.crown_img != blank -%}
            <img src="{{ section.settings.crown_img | img_url: '150x' }}" class="pos-absolute-vector v-crown" alt="" loading="lazy">
          {%- endif -%}
          
          {%- if section.settings.hearts_img != blank -%}
            <img src="{{ section.settings.hearts_img | img_url: '200x' }}" class="pos-absolute-vector v-hearts" alt="" loading="lazy">
          {%- endif -%}
          
          {%- if section.settings.spring_img != blank -%}
            <img src="{{ section.settings.spring_img | img_url: '150x' }}" class="pos-absolute-vector v-spring" alt="" loading="lazy">
          {%- endif -%}
          
          {%- if section.settings.lines_img != blank -%}
            <img src="{{ section.settings.lines_img | img_url: '150x' }}" class="pos-absolute-vector v-lines" alt="" loading="lazy">
          {%- endif -%}
        </div>
      </div>
    </div>

    <div class="about-layout-row row-bottom about-animate">
      <div class="about-col-text about-animate delay-1">
        <div class="about-master-desc">
          {{ section.settings.row2_desc }}
        </div>
      </div>
      
      <div class="about-col-media about-animate delay-2">
        <div class="composition-box">
          {%- if section.settings.row2_main_img != blank -%}
            <img src="{{ section.settings.row2_main_img | img_url: '800x' }}" class="main-portrait-render" alt="Founder Journey Continuation">
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.12
    };

    const targetSections = document.querySelectorAll('.about-animate');
    const scrollObserver = new IntersectionObserver(function(entries, observer) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    targetSections.forEach(section => {
      scrollObserver.observe(section);
    });
  });
</script>

