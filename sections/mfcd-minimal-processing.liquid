<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    aspect-ratio: 1920 / 900;
    {% if section.settings.bg_image %}
      background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% else %}
      background-color: #d72329;
    {% endif %}
  }

  .mfcd-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 80px;
    display: flex;
    flex-direction: row;
    align-items: center;
    height: 100%;
  }

  .mfcd-left {
    max-width: 600px; /* Widened so explicit line breaks control the wrap */
    display: flex;
    flex-direction: column;
    color: #ffffff;
  }

  .mfcd-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 40px;
  }

  .mfcd-text-1 {
    font-size: 18px; /* Increased font size slightly */
    line-height: 1.6;
    margin-bottom: 30px;
  }
  
  .mfcd-text-2 {
    font-size: 18px;
    line-height: 1.6;
    font-weight: 600;
  }

  .desktop-only-text {
    display: block !important;
  }
  .mobile-only-text {
    display: none !important;
  }

  @media screen and (max-width: 900px) {
    #shopify-section-{{ section.id }} {
      aspect-ratio: auto;
      min-height: auto;
      background-position: bottom center;
      background-color: #d92b2b;
      {% if section.settings.bg_image_mobile %}
        background-image: url('{{ section.settings.bg_image_mobile | img_url: 'master' }}');
        background-size: 100% auto;
        background-repeat: no-repeat;
      {% endif %}
    }

    .mfcd-container {
      flex-direction: column;
      padding: 0 20px;
      justify-content: flex-start;
      height: auto;
    }
    
    .mfcd-left {
      padding-top: 40px; 
      padding-bottom: 135vw; /* Dynamically reserve space for the dog so text NEVER overlaps */
      background: transparent;
      align-items: center;
      text-align: center;
      width: 100%;
    }

    .mfcd-heading {
      font-size: 42px; /* Matched Figma size */
      font-weight: 800;
      text-align: center;
      line-height: 1.2;
      margin-bottom: 25px;
    }

    .mfcd-text-1, .mfcd-text-2 {
      text-align: center;
      font-size: 16px; /* Matched Figma size */
      line-height: 1.5;
      max-width: 380px; /* Forces exact Figma natural wrap */
      margin-left: auto;
      margin-right: auto;
    }
    
    /* Disable desktop forced line-breaks on mobile */
    .mfcd-text-1 br, .mfcd-text-2 br, .desktop-only-br {
      display: none;
    }

    .desktop-only-text {
      display: none !important;
    }
    .mobile-only-text {
      display: block !important;
    }
  }
</style>

<div class="mfcd-container">
  <div class="mfcd-left">
    <!-- Desktop-only view of heading and text paragraphs -->
    <div class="desktop-only-text">
      <div class="mfcd-heading">
        {{ section.settings.heading | newline_to_br }}
      </div>
      <div class="mfcd-text-1">
        {{ section.settings.subtext_1 | newline_to_br }}
      </div>
      <div class="mfcd-text-2">
        {{ section.settings.subtext_2 | newline_to_br }}
      </div>
    </div>

    <!-- Mobile-only view of heading and text paragraphs -->
    <div class="mobile-only-text">
      <div class="mfcd-heading">
        {% assign clean_heading = section.settings.heading | newline_to_br | replace: '<br />', '[BR]' | replace: '<br>', '[BR]' | replace: '<br/>', '[BR]' %}
        {% assign heading_parts = clean_heading | split: '[BR]' %}
        {% for part in heading_parts %}
          {{ part | strip }}
          {% unless forloop.last %}
            {% if forloop.index == 1 %}
              <br>
            {% else %}
              {{ ' ' }}
            {% endif %}
          {% endunless %}
        {% endfor %}
      </div>
      <div class="mfcd-text-1">
        {{ section.settings.subtext_1 | newline_to_br | replace: '<br />', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' }}
      </div>
      <div class="mfcd-text-2">
        {{ section.settings.subtext_2 | newline_to_br | replace: '<br />', ' ' | replace: '<br>', ' ' | replace: '<br/>', ' ' }}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MFCD Minimal Processing",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "MFCD\nMinimal processing"
    },
    {
      "type": "textarea",
      "id": "subtext_1",
      "label": "First Paragraph",
      "default": "Our dry Flakes are 'Dehydrated Fresh Food' produced using our\nproprietary, patent-pending MFCD technology. By precisely controlling\ntemperature, airflow, humidity, and time during dehydration, we preserve\nnutritional integrity and enzymatic activity"
    },
    {
      "type": "textarea",
      "id": "subtext_2",
      "label": "Second Paragraph",
      "default": "The result? The unmatched nutrition of a raw diet with the ultimate\nconvenience of shelf-stable scoop-and-serve."
    }
  ],
  "presets": [
    {
      "name": "MFCD Minimal Processing"
    }
  ]
}
{% endschema %}
