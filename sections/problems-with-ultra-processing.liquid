<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign desktop_image = section.settings.main_image -%}
{%- if desktop_image == blank -%}
  {%- assign desktop_image = 'problems-ultra-processing-desktop.png' | asset_url -%}
{%- else -%}
  {%- assign desktop_image = desktop_image | img_url: 'master' -%}
{%- endif -%}

{%- assign mobile_image = section.settings.main_image_mobile -%}
{%- if mobile_image == blank -%}
  {%- assign mobile_image = 'problems-ultra-processing-mobile.png' | asset_url -%}
{%- else -%}
  {%- assign mobile_image = mobile_image | img_url: 'master' -%}
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    position: relative; /* Essential for relative positioning of the arrow and outer curve */
    background-image: url('{{ desktop_image }}');
    background-size: cover;
    background-position: right bottom;
    background-repeat: no-repeat;
  }

  .ultra-processing-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: row;
    align-items: flex-start; /* Fixed: align content to top to prevent heading from being pushed off-screen under the sticky header */
    gap: 60px;
    position: relative;
    padding-bottom: 220px; /* Pushes HTML content above the yellow wave text */
  }

  .ultra-processing-left {
    display: flex;
    flex-direction: column;
    z-index: 1; /* Keep content above arrow on mobile */
    padding-left: 80px;
    flex: 1.2;
    transition: padding-left 0.3s ease;
  }

  .ultra-processing-right {
    flex: 0.8;
    display: flex;
    justify-content: end !important;
    align-items: center;
    position: relative;
    z-index: 1; /* Keep content above arrow on mobile */
  }

  .ultra-processing-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 48px;
    letter-spacing: -0.02em;
    transition: font-size 0.3s ease, margin-bottom 0.3s ease;
  }

  .ultra-processing-heading .heading-black {
    color: #111111;
    display: inline;
    font-size:45px;
  }

  .ultra-processing-heading .heading-red {
    color: #d92b2b;
    display: inline;
    font-size:45px;
  }

  .ultra-processing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 70px 95px;
    margin-bottom: 48px;
    width: 90%;
    transition: gap 0.3s ease;
  }

  .ultra-processing-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ultra-processing-icon-wrapper {
    margin-bottom: 16px;
    height: 28px;
    display: flex;
    align-items: center;
  }

  .ultra-processing-icon-desktop {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: block;
  }

  .ultra-processing-icon-custom {
    width: 28px;
    height: auto;
    max-height: 28px;
    display: block;
    object-fit: contain;
  }

  .ultra-processing-icon-mobile {
    display: none;
  }

  .ultra-processing-item-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: #111111;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .ultra-processing-item-desc {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #555555;
    line-height: 1.45;
  }

  /* ******************************************
     Impact Module Below Arrow
     ****************************************** */
  .ultra-processing-impact {
    display: none; /* Hidden on desktop since text is embedded in background image */
  }

  .ultra-impact-black {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 25px;
    font-weight: 800;
    color: #111111;
    line-height: 1.2;
  }

  .ultra-impact-red {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 35px;
    font-weight: 800;
    color: #d92b2b;
    line-height: 1.2;
    position: relative;
    z-index: 1; /* Text above arrow */
    padding-left: 60px;
  }

  .ultra-processing-img-desktop {
    display: none !important; /* Hidden on desktop since background image contains the dog */
  }

  .ultra-processing-img-mobile {
    display: none !important;
  }

  /* ******************************************
     Isolated Green Curve Styling & Position
     ****************************************** */
  .ultra-processing-green-curve {
    display: none !important; /* Hidden to match new design */
  }

  /* ******************************************
     Desktop Arrow Positioning (Match Figma)
     ****************************************** */
  #shopify-section-{{ section.id }}::before {
    display: none !important; /* Hidden to match new design */
  }
  
  /* ******************************************
     Responsive Desktop/Tablet Breakpoints
     ****************************************** */
  @media screen and (max-width: 1400px) {
    .ultra-processing-container {
      padding-bottom: 260px;
    }
    .ultra-processing-left {
      padding-left: 120px;
    }
    .ultra-processing-heading {
      font-size: 52px;
      margin-bottom: 36px;
    }
    .ultra-processing-grid {
      gap: 40px 60px;
      width:100%;
    }
  }

  @media screen and (max-width: 1200px) {
    .ultra-processing-container {
      padding-bottom: 160px;
    }
    .ultra-processing-left {
      padding-left: 20px;
    }
    .ultra-processing-heading {
      font-size: 44px;
      margin-bottom: 28px;
    }
    .ultra-processing-grid {
      gap: 30px 40px;
      width: 100%;
    }
  }

  @media screen and (max-width: 991px) {
    .ultra-processing-container {
      gap: 40px;
      padding-bottom: 140px;
    }
    .ultra-processing-heading {
      font-size: 38px;
    }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      padding-top: 48px;
      padding-bottom: 0px; 
      background-image: none !important; /* Hide desktop background image */
    }

    .ultra-processing-container {
      flex-direction: column; 
      padding: 0 24px;
      gap: 0px;
      padding-bottom: 0px; /* Reset on mobile */
    }
    
    .ultra-processing-left {
      width: 100%;
      padding-left: 0px;
    }

    /* Fixed space around dog image by making the element flush against viewport edge boundaries */
    .ultra-processing-right {
      display: flex;
      width: 100vw;
      margin-left: -24px;
      margin-right: -24px;
      margin-top: 48px;
      padding-top: 0px;
    }

    .ultra-processing-heading {
      font-size: 34px;
      text-align: center;
      margin-bottom: 48px;
    }

    .ultra-processing-heading .heading-black,
    .ultra-processing-heading .heading-red {
      display: inline; 
    }
    .ultra-processing-heading .heading-red {
      display: block; 
      margin-top: 4px;
    }

    .ultra-processing-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      margin-bottom: 0px;
      width: 100%;
    }

    /* Fixed: Changed text alignment from center to left */
    .ultra-processing-item {
      align-items: flex-start;
      text-align: left;
    }

    .ultra-processing-icon-wrapper {
      margin-bottom: 12px;
      height: auto;
    }

    .has-mobile-icon .ultra-processing-icon-mobile {
      display: block;
      width: 44px;
      height: auto;
    }
    
    .has-mobile-icon .ultra-processing-icon-desktop,
    .has-mobile-icon .ultra-processing-icon-custom {
      display: none !important;
    }

    .ultra-processing-item-title {
      font-size: 24px;
      margin-bottom: 12px;
    }

    .ultra-processing-item-desc {
      font-size: 15px;
      color: #444444;
      line-height: 1.5;
      width: 92%;
    }

    /* ******************************************
       Mobile Bottom Yellow Background Area
       ****************************************** */
    .ultra-processing-impact {
      display: flex;
      position: relative;
      bottom: auto;
      left: auto;
      background-color: #FFCD68;
      width: 100vw; 
      padding: 25px 24px 60px 24px;
      align-items: center;
      text-align: center;
      box-sizing: border-box;
      top: -1px;
    }

    .ultra-impact-black {
      font-size: 28px;
      color: #111111;
      margin-bottom: 12px;
    }

    .ultra-impact-red {
      font-size: 50px;
      color: #d92b2b;
      padding-left: 0px; 
      font-weight: 800;
      line-height: 0.9;
    }

    .ultra-processing-img-mobile {
      display: block !important;
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      height: auto;
      z-index: 2;
      position: relative;
    }
  }
</style>

<div class="ultra-processing-container">
  <div class="ultra-processing-left">
    <h2 class="ultra-processing-heading">
      <span class="heading-black">{{ section.settings.heading_black }}</span>
      <span class="heading-red">{{ section.settings.heading_red }}</span>
    </h2>

    <div class="ultra-processing-grid">
      {% for block in section.blocks %}
        <div class="ultra-processing-item {% if block.settings.icon_image != blank %}has-mobile-icon{% endif %}" {{ block.shopify_attributes }}>
          <div class="ultra-processing-icon-wrapper">
            {% if block.settings.icon_image != blank %}
              <img class="ultra-processing-icon-mobile" src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.title }}" loading="lazy">
              <img class="ultra-processing-icon-custom" src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.title }}" loading="lazy">
            {% else %}
              <div class="ultra-processing-icon-desktop" style="background-color: {{ block.settings.icon_color }};"></div>
            {% endif %}
          </div>
          <div class="ultra-processing-item-title">{{ block.settings.title }}</div>
          <div class="ultra-processing-item-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ultra-processing-right">
    <img class="ultra-processing-img-desktop" src="{{ desktop_image }}" alt="{{ section.settings.heading_red }}" width="600" height="auto" loading="lazy">
    <img class="ultra-processing-img-mobile" src="{{ mobile_image }}" alt="{{ section.settings.heading_red }} Mobile" width="400" height="auto" loading="lazy">
  </div>

  <div class="ultra-processing-impact">
    <div class="ultra-impact-black">{{ section.settings.impact_black }}</div>
    <div class="ultra-impact-red">{{ section.settings.impact_red }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Ultra-Processing",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading (Black text)",
      "default": "Problems with"
    },
    {
      "type": "text",
      "id": "heading_red",
      "label": "Heading (Red text)",
      "default": "Ultra-Processing"
    },
    {
      "type": "text",
      "id": "impact_black",
      "label": "Impact Question Text",
      "default": "Whats the impact ?"
    },
    {
      "type": "text",
      "id": "impact_red",
      "label": "Impact Answer Text",
      "default": "The deficit shows up in your pet's health."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Right Image (Dog without Arrow)"
    },
    {
      "type": "image_picker",
      "id": "main_image_mobile",
      "label": "Mobile Main Image"
    },
    {
      "type": "header",
      "content": "Green Curve Isolation Controls"
    },
    {
      "type": "image_picker",
      "id": "green_curve",
      "label": "Green Curve Image Graphic"
    },
    {
      "type": "range",
      "id": "curve_x",
      "min": -100,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Green Curve X Position (Right Side)",
      "default": 0
    },
    {
      "type": "range",
      "id": "curve_y",
      "min": -100,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Green Curve Y Position (Top Side)",
      "default": 0
    },
    {
      "type": "range",
      "id": "curve_width",
      "min": 50,
      "max": 500,
      "step": 5,
      "unit": "px",
      "label": "Green Curve Width",
      "default": 180
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Bullet",
      "limit": 4,
      "settings": [
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#fcebb6"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ultra-Processing",
      "blocks": [
        { "type": "feature", "settings": { "title": "Loaded with Fillers", "description": "Extruded kibble and processed treats often contain high levels of starch and binders that add bulk, not meaningful nutrition." } },
        { "type": "feature", "settings": { "title": "Calories That Actually Nourish", "description": "Calories from protein and healthy fats support growth, repair, and vitality, whereas calories from starch and filler just fill the bowl" } },
        { "type": "feature", "settings": { "title": "Created Under Extreme Heat", "description": "The high heat and pressure used during extrusion can form Advanced Glycation End Products (AGEs), compounds linked to chronic health issues." } },
        { "type": "feature", "settings": { "title": "Nature Over Synthetic", "description": "Ultra-processing destroys natural nutrients and replaces them with synthetic alternatives that may not be absorbed as effectively by the body." } }
      ]
    }
  ]
}
{% endschema %}