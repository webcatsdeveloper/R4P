<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign desktop_image = section.settings.main_image -%}
{%- if desktop_image == blank -%}
  {%- assign desktop_image = 'problems-ultra-processing-desktop.png' | asset_url -%}
{%- else -%}
  {%- assign desktop_image = desktop_image | img_url: 'master' -%}
{%- endif -%}

{%- assign mobile_image = section.settings.main_image_mobile -%}
{%- if mobile_image == blank -%}
  {%- assign mobile_image = 'problems-ultra-processing-mobile.png' | asset_url -%}
{%- else -%}
  {%- assign mobile_image = mobile_image | img_url: 'master' -%}
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    position: relative; 
    background-image: url('{{ desktop_image }}');
    background-size: cover;
    background-position: right bottom;
    background-repeat: no-repeat;
    min-height: 720px;
  }

  .ultra-processing-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 40px;
    position: relative;
    padding-bottom: 160px; 
  }

  .ultra-processing-left {
    display: flex;
    flex-direction: column;
    z-index: 2; 
    padding-left: 60px;
    flex: 1.3;
  }

  .ultra-processing-right {
    flex: 0.7;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    position: relative;
    z-index: 1; 
  }

  .ultra-processing-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 56px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 40px;
    letter-spacing: -0.01em;
  }

  .ultra-processing-heading .heading-black {
    color: #111111;
    display: inline;
  }

  .ultra-processing-heading .heading-red {
    color: #d92b2b;
    display: inline;
  }

  .ultra-processing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 64px;
    width: 100%;
  }

  .ultra-processing-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ultra-processing-icon-wrapper {
    margin-bottom: 12px;
    height: 32px;
    display: flex;
    align-items: center;
  }

  .ultra-processing-icon-desktop {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: block;
  }

  .ultra-processing-icon-custom {
    width: auto;
    height: 28px;
    display: block;
    object-fit: contain;
  }

  .ultra-processing-icon-mobile {
    display: none;
  }

  .ultra-processing-item-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: #111111;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .ultra-processing-item-desc {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #555555;
    line-height: 1.4;
  }

  /* ******************************************
     Impact Text Layout (Tilted over Wave)
     ****************************************** */
  .ultra-processing-impact {
    display: flex; 
    flex-direction: column;
    position: absolute;
    bottom: 85px;
    left: 100px;
    transform: rotate(-10deg);
    transform-origin: left center;
    z-index: 3;
    max-width: 500px;
  }

  .ultra-impact-black {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: #111111;
    line-height: 1.1;
    margin-bottom: 0px;
  }

  .ultra-impact-red {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: #d92b2b;
    line-height: 1.1;
  }

  .ultra-processing-img-desktop {
    display: none !important; 
  }

  .ultra-processing-img-mobile {
    display: none !important;
  }

  /* ******************************************
     Responsive Breakpoints
     ****************************************** */
  @media screen and (max-width: 1400px) {
    .ultra-processing-left {
      padding-left: 20px;
    }
    .ultra-processing-heading {
      font-size: 48px;
    }
    .ultra-processing-impact {
      bottom: 75px;
      left: 60px;
    }
  }

  @media screen and (max-width: 1200px) {
    .ultra-processing-heading {
      font-size: 42px;
    }
    .ultra-processing-grid {
      gap: 36px 40px;
    }
    .ultra-processing-impact {
      bottom: 60px;
      left: 40px;
    }
    .ultra-impact-black { font-size: 26px; }
    .ultra-impact-red { font-size: 30px; }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      padding-top: 48px;
      padding-bottom: 0px; 
      background-image: none !important; 
    }

    .ultra-processing-container {
      flex-direction: column; 
      padding: 0 24px;
      gap: 0px;
      padding-bottom: 0px;
    }
    
    .ultra-processing-left {
      width: 100%;
      padding-left: 0px;
    }

    .ultra-processing-right {
      display: flex;
      width: 100vw;
      margin-left: -24px;
      margin-right: -24px;
      margin-top: 32px;
    }

    .ultra-processing-heading {
      font-size: 36px;
      text-align: center;
      margin-bottom: 40px;
    }

    .ultra-processing-heading .heading-red {
      display: block; 
      margin-top: 4px;
    }

    .ultra-processing-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ultra-processing-item {
      align-items: flex-start;
      text-align: left;
    }

    .has-mobile-icon .ultra-processing-icon-mobile {
      display: block;
      width: 40px;
      height: auto;
    }
    
    .has-mobile-icon .ultra-processing-icon-desktop,
    .has-mobile-icon .ultra-processing-icon-custom {
      display: none !important;
    }

    .ultra-processing-item-title {
      font-size: 22px;
    }

    .ultra-processing-item-desc {
      font-size: 15px;
      width: 100%;
    }

    .ultra-processing-impact {
      display: flex;
      position: relative;
      transform: none;
      bottom: auto;
      left: auto;
      background-color: #FFCD68;
      width: 100vw; 
      margin-left: -24px;
      padding: 40px 24px 60px 24px;
      align-items: center;
      text-align: center;
      box-sizing: border-box;
    }

    .ultra-impact-black {
      font-size: 28px;
      margin-bottom: 8px;
    }

    .ultra-impact-red {
      font-size: 34px;
      line-height: 1.2;
    }

    .ultra-processing-img-mobile {
      display: block !important;
      width: 100%;
      height: auto;
    }
  }
</style>

<div class="ultra-processing-container">
  <div class="ultra-processing-left">
    <h2 class="ultra-processing-heading">
      <span class="heading-black">{{ section.settings.heading_black }}</span>
      <span class="heading-red">{{ section.settings.heading_red }}</span>
    </h2>

    <div class="ultra-processing-grid">
      {% for block in section.blocks %}
        <div class="ultra-processing-item {% if block.settings.icon_image != blank %}has-mobile-icon{% endif %}" {{ block.shopify_attributes }}>
          <div class="ultra-processing-icon-wrapper">
            {% if block.settings.icon_image != blank %}
              <img class="ultra-processing-icon-mobile" src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.title }}" loading="lazy">
              <img class="ultra-processing-icon-custom" src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.title }}" loading="lazy">
            {% else %}
              <div class="ultra-processing-icon-desktop" style="background-color: {{ block.settings.icon_color }};"></div>
            {% endif %}
          </div>
          <div class="ultra-processing-item-title">{{ block.settings.title }}</div>
          <div class="ultra-processing-item-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ultra-processing-right">
    <img class="ultra-processing-img-desktop" src="{{ desktop_image }}" alt="{{ section.settings.heading_red }}" width="600" height="auto" loading="lazy">
    <img class="ultra-processing-img-mobile" src="{{ mobile_image }}" alt="{{ section.settings.heading_red }} Mobile" width="400" height="auto" loading="lazy">
  </div>

  <div class="ultra-processing-impact">
    <div class="ultra-impact-black">{{ section.settings.impact_black }}</div>
    <div class="ultra-impact-red">{{ section.settings.impact_red }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Ultra-Processing",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading (Black text)",
      "default": "Problems with"
    },
    {
      "type": "text",
      "id": "heading_red",
      "label": "Heading (Red text)",
      "default": "Ultra-Processing"
    },
    {
      "type": "text",
      "id": "impact_black",
      "label": "Impact Question Text",
      "default": "Whats the impact ?"
    },
    {
      "type": "text",
      "id": "impact_red",
      "label": "Impact Answer Text",
      "default": "The deficit shows up in your pet's health."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Right Image (Dog with Curve)"
    },
    {
      "type": "image_picker",
      "id": "main_image_mobile",
      "label": "Mobile Main Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Bullet",
      "limit": 4,
      "settings": [
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#fcebb6"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ultra-Processing",
      "blocks": [
        { "type": "feature", "settings": { "title": "Loaded with Fillers", "description": "Extruded kibble and processed treats often contain high levels of starch and binders that add bulk, not meaningful nutrition." } },
        { "type": "feature", "settings": { "title": "Calories That Actually Nourish", "description": "Calories from protein and healthy fats support growth, repair, and vitality, whereas calories from starch and filler just fill the bowl" } },
        { "type": "feature", "settings": { "title": "Created Under Extreme Heat", "description": "The high heat and pressure used during extrusion can form Advanced Glycation End Products (AGEs), compounds linked to chronic health issues." } },
        { "type": "feature", "settings": { "title": "Nature Over Synthetic", "description": "Ultra-processing destroys natural nutrients and replaces them with synthetic alternatives that may not be absorbed as effectively by the body." } }
      ]
    }
  ]
}
{% endschema %}