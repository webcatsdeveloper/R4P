<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .certifications-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .certifications-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 32px;
    font-weight: 500;
    color: #111111;
    line-height: 1.4;
    max-width: 900px;
    margin-bottom: 40px;
  }

  .certifications-heading strong {
    font-weight: 700;
    color: #d92b2b;
  }

  .certifications-subtext {
    font-family: var(--font-primary--family), sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #444444;
    line-height: 1.6;
    max-width: 1000px;
    margin-bottom: 80px;
  }

  .certifications-logo-strip {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 60px;
    width: 100%;
  }

  .certifications-logo-item {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 150px;
  }

  .certifications-logo-item img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .certifications-button {
    display: none; /* Hidden on desktop */
    background-color: #000;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 15px 40px;
    border-radius: 50px;
    text-decoration: none;
    margin-top: 40px;
  }

  .certifications-logo-item.dup {
    display: none;
  }

  .certifications-logo-full-width {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 20px;
  }

  .certifications-logo-full-width img {
    width: 100%;
    max-width: 1920px;
    height: auto;
    object-fit: contain;
  }

  @media screen and (max-width: 900px) {
    .certifications-heading {
      font-size: 20px;
    }
    .certifications-heading br {
      display: none; /* Let text wrap naturally on mobile */
    }
    .certifications-subtext {
      font-size: 11px;
      line-height: 1.5;
      margin-bottom: 40px;
    }
    .certifications-logo-strip {
      flex-wrap: nowrap;
      width: max-content;
      gap: 40px;
      animation: marquee 15s linear infinite;
    }
    
    .certifications-logo-item.dup {
      display: flex;
    }
    
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 20px)); } /* Half width + half gap */
    }

    .certifications-container {
      overflow-x: hidden; /* Hide scrollbar */
      padding: 0 20px;
    }

    .certifications-button {
      display: inline-block; /* Shown on mobile */
      font-size: 12px;
      padding: 12px 30px;
      margin-top: 30px;
    }
  }
</style>

<div class="certifications-container">
  {% if section.settings.heading != blank %}
    <div class="certifications-heading">
      {{ section.settings.heading }}
    </div>
  {% endif %}

  {% if section.settings.subtext != blank %}
    <div class="certifications-subtext">
      {{ section.settings.subtext }}
    </div>
  {% endif %}

  {% if section.settings.single_logo_image == blank %}
    <div style="width: 100%; overflow: hidden; display: flex; justify-content: center;">
      <div class="certifications-logo-strip">
        {% for block in section.blocks %}
          <div class="certifications-logo-item" {{ block.shopify_attributes }}>
            {% if block.settings.logo_image %}
              <img src="{{ block.settings.logo_image | img_url: '400x' }}" alt="Certification Logo" loading="lazy">
            {% else %}
              <div style="width: 120px; height: 120px; background-color: #f0f0f0; border-radius: 50%; display:flex; align-items:center; justify-content:center; font-size: 12px; color: #888;">Logo {{ forloop.index }}</div>
            {% endif %}
          </div>
        {% endfor %}
        <!-- Duplicated for seamless mobile marquee -->
        {% for block in section.blocks %}
          <div class="certifications-logo-item dup">
            {% if block.settings.logo_image %}
              <img src="{{ block.settings.logo_image | img_url: '400x' }}" alt="Certification Logo" loading="lazy">
            {% else %}
              <div style="width: 120px; height: 120px; background-color: #f0f0f0; border-radius: 50%; display:flex; align-items:center; justify-content:center; font-size: 12px; color: #888;">Logo {{ forloop.index }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.button_label != blank %}
    <a href="{{ section.settings.button_link }}" class="certifications-button">
      {{ section.settings.button_label }}
    </a>
  {% endif %}
</div>

{% if section.settings.single_logo_image != blank %}
  <div class="certifications-logo-full-width">
    <img src="{{ section.settings.single_logo_image | img_url: 'master' }}" alt="Certification Logos" loading="lazy">
  </div>
{% endif %}

{% schema %}
{
  "name": "Certifications",
  "settings": [
    {
      "type": "image_picker",
      "id": "single_logo_image",
      "label": "Single Full-Width Logo Image (Overrides blocks)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>The meats we use are from <strong>HACCP approved, ISO certified plants</strong><br>with full traceability and are <strong>anti-biotic residue free</strong><br>The fish we use are <strong>wild caught</strong></p>"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Safety is non-negotiable, which is why we enforce a strict kill step at every stage of our process including Bacteriophages, traditional Curing agents (vinegar/citric acid), low temperature long duration pasteurization and UV exposure before packing. As a final protective barrier, the packs are vacuum-sealed and flushed with modified atmospheric gases."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "READ THE DOGRISK REPORT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Certification Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certifications",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
