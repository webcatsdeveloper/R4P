{%- style -%}
  .sol-header-{{ section.id }} {
    --text-dark: {{ section.settings.text_color_dark }};
    --text-accent: {{ section.settings.text_color_accent }};
    background-color: #ffffff;
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    font-family: inherit;
  }

  .sol-header-{{ section.id }} .sol-header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 3;
  }

  /* SVG Character Path Control Wrapper Container */
  .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    display: block;
    transform: translate({{ section.settings.global_x_offset }}px, {{ section.settings.global_y_offset }}px);
    transform-origin: center center;
  }
  
  .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper svg text {
    font-size: 86px;
    font-weight: 900;
    font-family: inherit;
    letter-spacing: {{ section.settings.global_letter_spacing }}px;
  }

  /* Absolute Positioned Decorative Grey Curve with dynamic X/Y coordinates */
  .sol-header-{{ section.id }} .grey-loop-decorator {
    position: absolute;
    z-index: 4;
    pointer-events: none;
    left: {{ section.settings.loop_x_pos }}%;
    top: {{ section.settings.loop_y_pos }}px;
    width: {{ section.settings.loop_width }}px;
    height: auto;
  }
  .sol-header-{{ section.id }} .grey-loop-decorator img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Layered Adaptive Wave Background Graphic Base */
  .sol-header-{{ section.id }} .wavy-bg-canvas {
    width: 100%;
    position: relative;
    z-index: 2;
    margin-top: -30px;
  }
  .sol-header-{{ section.id }} .wavy-bg-canvas img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content Wrapper floating safely inside the yellow wave territory (Strict Left-Aligned) */
  .sol-header-{{ section.id }} .wavy-inner-content {
    position: absolute;
    bottom: 18%;
    right: 8%;
    max-width: 520px;
    text-align: left;
    z-index: 5;
  }

  .sol-header-{{ section.id }} .sol-intro-text p {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--text-dark);
    margin-top: 20px;
    text-align: left;
  }
  .sol-header-{{ section.id }} .sol-intro-text strong {
    color: var(--text-accent);
    font-weight: 700;
  }

  /* Mobile Layout Adaptations */
  @media (max-width: 768px) {
    .sol-header-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}px * 0.7);
      padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.7);
    }
    .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper {
      transform: translate({{ section.settings.global_x_offset_mobile }}px, {{ section.settings.global_y_offset_mobile }}px);
    }
    .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper svg text {
      font-size: 50px;
      letter-spacing: calc({{ section.settings.global_letter_spacing }}px * 0.6);
    }
    .sol-header-{{ section.id }} .wavy-bg-canvas {
      margin-top: 10px;
    }
    .sol-header-{{ section.id }} .wavy-inner-content {
      position: relative;
      right: unset;
      bottom: unset;
      margin: -40px auto 0 auto;
      padding: 0 24px 20px 24px;
      text-align: left;
      max-width: 100%;
    }
    .sol-header-{{ section.id }} .sol-intro-text p {
      font-size: 1.15rem;
    }
    .sol-header-{{ section.id }} .grey-loop-decorator {
      left: {{ section.settings.loop_x_pos_mobile }}%;
      top: {{ section.settings.loop_y_pos_mobile }}px;
      width: {{ section.settings.loop_width_mobile }}px;
    }
  }
{%- endstyle -%}

<section class="sol-header-{{ section.id }}">
  
  <!-- Manual Position-Controlled Grey Loop Curve Utility Graphic -->
  {%- if section.settings.grey_loop_image != blank -%}
    <div class="grey-loop-decorator">
      {{ section.settings.grey_loop_image | image_url: width: 400 | image_tag: loading: 'eager', alt: 'Decorative Contour Line' }}
    </div>
  {%- endif -%}

  <div class="sol-header-container">
    <!-- Fluid Wave Text Path Mapping Positioner Block -->
    <div class="sol-header-svg-alignment-wrapper">
      <svg viewBox="0 0 1100 160" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
        <!-- Re-engineered bezier baseline path flowing downward to align perfectly with the background graphic vector -->
        <path id="headingWavePath-{{ section.id }}" d="M 50,75 Q 380,122 1050,105" fill="transparent" />
        <text>
          <textPath href="#headingWavePath-{{ section.id }}" startOffset="{{ section.settings.global_start_offset }}%">
            
            {%- for block in section.blocks -%}
              {%- if block.type == 'letter' -%}
                <tspan 
                  fill="{% if block.settings.color_accent %}var(--text-accent){% else %}var(--text-dark){% endif %}"
                  dx="{{ block.settings.x_shift }}"
                  dy="{{ block.settings.y_shift }}"
                  rotate="{{ block.settings.rotation }}"
                  {{ block.shopify_attributes }}>
                  {%- if block.settings.char != blank -%}
                    {{ block.settings.char }}
                  {%- else -%}
                    &nbsp;<!-- Preserves clean breaking layout space character values -->
                  {%- endif -%}
                </tspan>
              {%- endif -%}
            {%- endfor -%}

          </textPath>
        </text>
      </svg>
    </div>
  </div>

  <!-- Responsive Wave Matrix Layer -->
  <div class="wavy-bg-canvas">
    <picture>
      {%- if section.settings.wave_bg_mobile != blank -%}
        <source media="(max-width: 768px)" srcset="{{ section.settings.wave_bg_mobile | image_url: width: 768 }}">
      {%- endif -%}
      {%- if section.settings.wave_bg_desktop != blank -%}
        <img src="{{ section.settings.wave_bg_desktop | image_url: width: 2200 }}" loading="eager" alt="Wave Background Trim">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </picture>

    <!-- Anchored Left-Aligned Subtext Box Container -->
    <div class="wavy-inner-content">
      <div class="sol-intro-text">
        {{ section.settings.intro_richtext }}
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Solution Header Workspace",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Graphic Core Assets"
    },
    {
      "type": "image_picker",
      "id": "wave_bg_desktop",
      "label": "Yellow Wave Background (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "wave_bg_mobile",
      "label": "Yellow Wave Background (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "grey_loop_image",
      "label": "Grey Loop Graphic Asset"
    },
    {
      "type": "header",
      "content": "Global Word Matrix Tracking Controls"
    },
    {
      "type": "range",
      "id": "global_start_offset",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Global Slide Along Path (X Shift)",
      "default": 25
    },
    {
      "type": "range",
      "id": "global_letter_spacing",
      "min": -10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Global Text tracking Space",
      "default": 2
    },
    {
      "type": "range",
      "id": "global_x_offset",
      "min": -150,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Desktop Global Move Right/Left",
      "default": 0
    },
    {
      "type": "range",
      "id": "global_y_offset",
      "min": -50,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Desktop Global Move Up/Down",
      "default": 10
    },
    {
      "type": "range",
      "id": "global_x_offset_mobile",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Global Move Right/Left",
      "default": 0
    },
    {
      "type": "range",
      "id": "global_y_offset_mobile",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Global Move Up/Down",
      "default": 0
    },
    {
      "type": "header",
      "content": "Grey Curve Positioning Coordinates"
    },
    {
      "type": "range",
      "id": "loop_x_pos",
      "min": -10,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Desktop X Position (From Left Edge)",
      "default": -2
    },
    {
      "type": "range",
      "id": "loop_y_pos",
      "min": -50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Desktop Y Position (From Top Edge)",
      "default": 115
    },
    {
      "type": "range",
      "id": "loop_width",
      "min": 50,
      "max": 350,
      "step": 5,
      "unit": "px",
      "label": "Desktop Loop Scale Width",
      "default": 140
    },
    {
      "type": "range",
      "id": "loop_x_pos_mobile",
      "min": -20,
      "max": 80,
      "step": 1,
      "unit": "%",
      "label": "Mobile X Position",
      "default": -5
    },
    {
      "type": "range",
      "id": "loop_y_pos_mobile",
      "min": -50,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Mobile Y Position",
      "default": 65
    },
    {
      "type": "range",
      "id": "loop_width_mobile",
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Mobile Loop Scale Width",
      "default": 90
    },
    {
      "type": "header",
      "content": "Paragraph Copy Elements"
    },
    {
      "type": "richtext",
      "id": "intro_richtext",
      "label": "Right Sub-Banner Text Content",
      "default": "<p>We feed your pet <strong>real food</strong>,<br>not processed science experiments</p>"
    },
    {
      "type": "header",
      "content": "Global Theme Colors"
    },
    {
      "type": "color",
      "id": "text_color_dark",
      "label": "Primary Base Dark Wording",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_accent",
      "label": "Brand Focal Accent Red",
      "default": "#d93829"
    }
  ],
  "blocks": [
    {
      "type": "letter",
      "name": "Individual Character",
      "settings": [
        {
          "type": "text",
          "id": "char",
          "label": "Letter Wording (Leave blank for Space)",
          "default": "A"
        },
        {
          "type": "checkbox",
          "id": "color_accent",
          "label": "Turn Accent Color (Red)",
          "default": false
        },
        {
          "type": "range",
          "id": "x_shift",
          "min": -40,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Horizontal Micro-Shift (X)",
          "default": 0
        },
        {
          "type": "range",
          "id": "y_shift",
          "min": -50,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "Vertical Baseline Shift (Y)",
          "default": 0
        },
        {
          "type": "range",
          "id": "rotation",
          "min": -50,
          "max": 50,
          "step": 1,
          "unit": "deg",
          "label": "Character Micro-Rotation",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Solution Header Workspace",
      "blocks": [
        { "type": "letter", "settings": { "char": "O" } },
        { "type": "letter", "settings": { "char": "u" } },
        { "type": "letter", "settings": { "char": "r" } },
        { "type": "letter", "settings": { "char": "" } },
        { "type": "letter", "settings": { "char": "S", "color_accent": true } },
        { "type": "letter", "settings": { "char": "o", "color_accent": true } },
        { "type": "letter", "settings": { "char": "l", "color_accent": true } },
        { "type": "letter", "settings": { "char": "u", "color_accent": true } },
        { "type": "letter", "settings": { "char": "t", "color_accent": true } },
        { "type": "letter", "settings": { "char": "i", "color_accent": true } },
        { "type": "letter", "settings": { "char": "o", "color_accent": true } },
        { "type": "letter", "settings": { "char": "n", "color_accent": true } }
      ]
    }
  ]
}
{% endschema %}