{%- style -%}
  .sol-header-{{ section.id }} {
    --text-dark: {{ section.settings.text_color_dark }};
    --text-accent: {{ section.settings.text_color_accent }};
    background-color: #ffffff;
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    font-family: inherit;
  }

  .sol-header-{{ section.id }} .sol-header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 3;
  }

  /* Position Wrapper for independent X and Y control matching image_232166.png */
  .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper {
    width: 100%;
    max-width: 950px;
    margin: 0 auto;
    display: block;
    transform: translate({{ section.settings.heading_x_offset }}px, {{ section.settings.heading_y_offset }}px);
    transform-origin: center center;
  }
  
  .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper svg text {
    font-size: 84px;
    font-weight: 900;
    font-family: inherit;
    letter-spacing: -0.01em;
  }

  /* Absolute Positioned Decorative Grey Curve with dynamic X/Y coordinates */
  .sol-header-{{ section.id }} .grey-loop-decorator {
    position: absolute;
    z-index: 4;
    pointer-events: none;
    left: {{ section.settings.loop_x_pos }}%;
    top: {{ section.settings.loop_y_pos }}px;
    width: {{ section.settings.loop_width }}px;
    height: auto;
  }
  .sol-header-{{ section.id }} .grey-loop-decorator img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Layered Adaptive Wave Background Graphic Base */
  .sol-header-{{ section.id }} .wavy-bg-canvas {
    width: 100%;
    position: relative;
    z-index: 2;
    margin-top: -30px;
  }
  .sol-header-{{ section.id }} .wavy-bg-canvas img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content Wrapper floating safely inside the yellow wave territory (Strict Left-Aligned) */
  .sol-header-{{ section.id }} .wavy-inner-content {
    position: absolute;
    bottom: 18%;
    right: 8%;
    max-width: 520px;
    text-align: left;
    z-index: 5;
  }

  .sol-header-{{ section.id }} .sol-intro-text p {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--text-dark);
    margin: 0;
    text-align: left;
  }
  .sol-header-{{ section.id }} .sol-intro-text strong {
    color: var(--text-accent);
    font-weight: 700;
  }

  /* Mobile Layout Adaptations */
  @media (max-width: 768px) {
    .sol-header-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}px * 0.7);
      padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.7);
    }
    .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper {
      transform: translate({{ section.settings.heading_x_offset_mobile }}px, {{ section.settings.heading_y_offset_mobile }}px);
    }
    .sol-header-{{ section.id }} .sol-header-svg-alignment-wrapper svg text {
      font-size: 54px;
    }
    .sol-header-{{ section.id }} .wavy-bg-canvas {
      margin-top: 10px;
    }
    .sol-header-{{ section.id }} .wavy-inner-content {
      position: relative;
      right: unset;
      bottom: unset;
      margin: -40px auto 0 auto;
      padding: 0 24px 20px 24px;
      text-align: left;
      max-width: 100%;
    }
    .sol-header-{{ section.id }} .sol-intro-text p {
      font-size: 1.15rem;
    }
    .sol-header-{{ section.id }} .grey-loop-decorator {
      left: {{ section.settings.loop_x_pos_mobile }}%;
      top: {{ section.settings.loop_y_pos_mobile }}px;
      width: {{ section.settings.loop_width_mobile }}px;
    }
  }
{%- endstyle -%}

<section class="sol-header-{{ section.id }}">
  
  <!-- Manual Position-Controlled Grey Loop Curve Utility Graphic -->
  {%- if section.settings.grey_loop_image != blank -%}
    <div class="grey-loop-decorator">
      {{ section.settings.grey_loop_image | image_url: width: 400 | image_tag: loading: 'eager', alt: 'Decorative Contour Line' }}
    </div>
  {%- endif -%}

  <div class="sol-header-container">
    <!-- Fluid Wave Text Path Mapping Positioner Block -->
    <div class="sol-header-svg-alignment-wrapper">
      <svg viewBox="0 0 1000 150" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
        <!-- Re-engineered bezier baseline path flowing downward to align perfectly with the background graphic vector -->
        <path id="headingWavePath-{{ section.id }}" d="M 100,75 Q 380,118 880,105" fill="transparent" />
        <text>
          <textPath href="#headingWavePath-{{ section.id }}" startOffset="45%" text-anchor="middle">
            <tspan fill="var(--text-dark)">{{ section.settings.title_part_1 }} </tspan>
            <tspan fill="var(--text-accent)">{{ section.settings.title_part_2 }}</tspan>
          </textPath>
        </text>
      </svg>
    </div>
  </div>

  <!-- Responsive Wave Matrix Layer -->
  <div class="wavy-bg-canvas">
    <picture>
      {%- if section.settings.wave_bg_mobile != blank -%}
        <source media="(max-width: 768px)" srcset="{{ section.settings.wave_bg_mobile | image_url: width: 768 }}">
      {%- endif -%}
      {%- if section.settings.wave_bg_desktop != blank -%}
        <img src="{{ section.settings.wave_bg_desktop | image_url: width: 2200 }}" loading="eager" alt="Wave Background Trim">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </picture>

    <!-- Anchored Left-Aligned Subtext Box Container -->
    <div class="wavy-inner-content">
      <div class="sol-intro-text">
        {{ section.settings.intro_richtext }}
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Solution Header Workspace",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Graphic Core Assets"
    },
    {
      "type": "image_picker",
      "id": "wave_bg_desktop",
      "label": "Yellow Wave Background (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "wave_bg_mobile",
      "label": "Yellow Wave Background (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "grey_loop_image",
      "label": "Grey Loop Graphic Asset"
    },
    {
      "type": "header",
      "content": "Heading Fine Positioning (X & Y Control)"
    },
    {
      "type": "range",
      "id": "heading_x_offset",
      "min": -150,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Desktop Move Horizontal (Right/Left)",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_y_offset",
      "min": -50,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Desktop Move Vertical (Up/Down)",
      "default": 10
    },
    {
      "type": "range",
      "id": "heading_x_offset_mobile",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Move Horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_y_offset_mobile",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Move Vertical",
      "default": 0
    },
    {
      "type": "header",
      "content": "Grey Curve Positioning Coordinates"
    },
    {
      "type": "range",
      "id": "loop_x_pos",
      "min": -10,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Desktop X Position (From Left Edge)",
      "default": -2
    },
    {
      "type": "range",
      "id": "loop_y_pos",
      "min": -50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Desktop Y Position (From Top Edge)",
      "default": 115
    },
    {
      "type": "range",
      "id": "loop_width",
      "min": 50,
      "max": 350,
      "step": 5,
      "unit": "px",
      "label": "Desktop Loop Scale Width",
      "default": 140
    },
    {
      "type": "range",
      "id": "loop_x_pos_mobile",
      "min": -20,
      "max": 80,
      "step": 1,
      "unit": "%",
      "label": "Mobile X Position",
      "default": -5
    },
    {
      "type": "range",
      "id": "loop_y_pos_mobile",
      "min": -50,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Mobile Y Position",
      "default": 65
    },
    {
      "type": "range",
      "id": "loop_width_mobile",
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Mobile Loop Scale Width",
      "default": 90
    },
    {
      "type": "header",
      "content": "Typography Copy Elements"
    },
    {
      "type": "text",
      "id": "title_part_1",
      "label": "Main Title Wording 1",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_part_2",
      "label": "Main Title Wording 2",
      "default": "Solution"
    },
    {
      "type": "richtext",
      "id": "intro_richtext",
      "label": "Right Sub-Banner Text Content",
      "default": "<p>We feed your pet <strong>real food</strong>,<br>not processed science experiments</p>"
    },
    {
      "type": "header",
      "content": "Global Theme Colors"
    },
    {
      "type": "color",
      "id": "text_color_dark",
      "label": "Primary Base Dark Wording",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_accent",
      "label": "Brand Focal Accent Red",
      "default": "#d93829"
    }
  ],
  "presets": [
    {
      "name": "Solution Header Workspace"
    }
  ]
}
{% endschema %}