<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .pet-benefits-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .pet-benefits-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 48px;
    font-weight: 800;
    color: #000000;
    margin-bottom: 80px;
    line-height: 1.2;
  }

  .pet-benefits-heading span {
    color: #d92b2b; /* Red color for 'Pet' */
  }

  .pet-benefits-grid {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    width: 100%;
    max-width: 800px; /* Centered narrow group like Figma */
    margin: 0 auto;
  }

  .pet-benefits-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 250px;
  }

  .pet-benefits-icon-wrapper {
    width: 70px; /* Reduced icon size to match Figma */
    height: 70px;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .pet-benefits-icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .pet-benefits-text {
    font-size: 16px;
    line-height: 1.6;
    color: #333333;
    font-weight: 500;
  }

  @media screen and (max-width: 768px) {
    .pet-benefits-heading {
      font-size: 36px;
      margin-bottom: 50px;
    }
    
    .pet-benefits-grid {
      flex-direction: column;
      align-items: center;
      gap: 60px;
    }
  }
</style>

<div class="pet-benefits-container">
  <div class="pet-benefits-heading">
    {{ section.settings.heading | replace: 'Pet', '<span>Pet</span>' }}
  </div>

  <div class="pet-benefits-grid">
    {% for block in section.blocks %}
      <div class="pet-benefits-item" {{ block.shopify_attributes }}>
        <div class="pet-benefits-icon-wrapper">
          {% if block.settings.icon %}
            <img src="{{ block.settings.icon | img_url: 'master' }}" alt="{{ block.settings.text | escape }}" loading="lazy">
          {% endif %}
        </div>
        <div class="pet-benefits-text">
          {{ block.settings.text | newline_to_br }}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Pet Benefits",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What does this mean for your Pet?"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Benefit text here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pet Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Best nutrition\nabsorption, Just as\nnature intended."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Vibrant energy,\nbetter Immunity and\nlesser sick days."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Food that works\nwith their biology,\nnot against it."
          }
        }
      ]
    }
  ]
}
{% endschema %}
