<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    position: relative;
  }

  .ultra-processing-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 60px;
    position: relative;
    padding-bottom: 120px; 
  }

  .ultra-processing-left {
    display: flex;
    flex-direction: column;
    z-index: 2;
    padding-left: 80px;
    flex: 1.2;
  }

  .ultra-processing-right {
    flex: 0.8;
    display: flex;
    justify-content: end !important;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Fixed Canvas Wrapper keeping the dog and curve tightly coupled together */
  .ultra-processing-right .dog-illustration-canvas {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin-left: auto;
    display: block;
  }

  .ultra-processing-heading {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 48px;
    letter-spacing: -0.02em;
  }

  .ultra-processing-heading .heading-black {
    color: #111111;
    display: block;
  }

  .ultra-processing-heading .heading-red {
    color: #d92b2b;
    display: block;
  }

  .ultra-processing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 70px 95px;
    margin-bottom: 48px;
    width: 90%;
  }

  .ultra-processing-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ultra-processing-icon-wrapper {
    margin-bottom: 16px;
    height: 28px;
    display: flex;
    align-items: center;
  }

  .ultra-processing-icon-desktop {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: block;
  }

  .ultra-processing-icon-mobile {
    display: none;
  }

  .ultra-processing-item-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: #111111;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .ultra-processing-item-desc {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #555555;
    line-height: 1.45;
  }

  .ultra-processing-impact {
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: absolute;
    bottom: 50px;
    left: 120px; 
    z-index: 3;
  }

  .ultra-impact-black {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 25px;
    font-weight: 800;
    color: #111111;
    line-height: 1.2;
  }

  .ultra-impact-red {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 35px;
    font-weight: 800;
    color: #d92b2b;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    padding-left: 60px;
  }

  .ultra-processing-img-desktop {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  .ultra-processing-img-mobile {
    display: none;
  }

  .ultra-processing-green-curve {
    position: absolute;
    top: {{ section.settings.curve_y }}px;
    right: {{ section.settings.curve_x }}px;
    width: {{ section.settings.curve_width }}px;
    height: auto;
    z-index: 1;
    pointer-events: none;
    display: block;
  }

  #shopify-section-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: {{ section.settings.padding_top }}px;
    left: 45%;
    width: calc(100% - 45% + 40px);
    height: calc(100% - {{ section.settings.padding_top }}px - 140px);
    background-image: url('{{ "thick_black_arrow.png" | asset_url }}');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: top center;
    z-index: 0;
  }
  
  @media screen and (max-width: 991px) {
    .ultra-processing-container {
      gap: 40px;
      padding-bottom: 0px;
    }
    .ultra-processing-heading {
      font-size: 52px;
    }
    #shopify-section-{{ section.id }}::before,
    .ultra-processing-green-curve {
      display: none !important;
    }
    .ultra-processing-impact {
      position: relative;
      bottom: auto;
      left: auto;
    }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      padding-top: 48px;
      padding-bottom: 0px; 
    }
    
    #shopify-section-{{ section.id }}::before {
      display: none !important;
    }

    .ultra-processing-container {
      flex-direction: column; 
      padding: 0 24px;
      gap: 0px;
    }
    
    .ultra-processing-left {
      width: 100%;
      padding-left: 0px;
    }

    .ultra-processing-container .matrix-right-col {
      gap: 40px;
      padding-top: 0;
    }

    .sol-header-{{ section.id }} .wavy-inner-content {
      position: relative;
      right: unset;
      bottom: unset;
      margin: -60px auto 0 auto;
      padding: 0 20px 40px 20px;
      text-align: center;
      max-width: 100%;
    }

    .sol-header-{{ section.id }} .sol-intro-text p {
      font-size: 1.15rem;
    }

    .perf-canvas-{{ section.id }} .canvas-item p {
      text-align: center !important;
    }

    .perf-canvas-{{ section.id }} .item-main-image {
      max-width: 320px !important;
    }

    .perf-canvas-{{ section.id }} .item-arrow-1,
    .perf-canvas-{{ section.id }} .item-arrow-2 {
      display: none !important;
    }

    .perf-canvas-{{ section.id }} .canvas-item {
      position: relative !important;
      left: unset !important;
      top: unset !important;
      transform: none !important;
      max-width: 100% !important;
      text-align: center !important;
      width: 100% !important;
    }

    .perf-canvas-{{ section.id }} .canvas-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 40px;
      min-height: auto;
      padding: 0 24px;
    }

    .sol-header-{{ section.id }} .grey-loop-decorator {
      display: none !important;
    }

    .sol-header-{{ section.id }} .wavy-bg-canvas {
      display: none !important;
    }

    .sol-header-{{ section.id }} .wavy-inner-content {
      display: none !important;
    }

    .sol-header-{{ section.id }} .sol-mobile-title-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 20px;
      width: 100%;
    }

    .sol-header-{{ section.id }} .sol-mobile-title-wrapper span {
      font-size: 4.6rem;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.02em;
      display: block;
    }

    .sol-header-{{ section.id }} .sol-mobile-title-wrapper .sol-mob-dark {
      color: var(--text-dark);
      margin-bottom: 5px;
    }

    .sol-header-{{ section.id }} .sol-mobile-title-wrapper .sol-mob-accent {
      color: var(--text-accent);
    }

    .sol-header-{{ section.id }} .sol-header-container {
      display: none !important;
    }

    .sol-header-{{ section.id }} {
      padding-top: 0;
      padding-bottom: 0;
      background-color: {{ section.settings.mobile_bg_color }};
    }

    .ultra-processing-right {
      width: 100vw;
      margin-left: -24px;
      margin-right: -24px;
      margin-top: 48px;
      padding-top: 0px;
    }

    .ultra-processing-right .dog-illustration-canvas {
      max-width: 100%;
      margin: 0 auto;
    }

    .ultra-processing-heading {
      font-size: 34px;
      text-align: center;
      margin-bottom: 48px;
    }

    .ultra-processing-heading .heading-black,
    .ultra-processing-heading .heading-red {
      display: inline; 
    }
    .ultra-processing-heading .heading-red {
      display: block; 
      margin-top: 4px;
    }

    .ultra-processing-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      margin-bottom: 0px;
      width: 100%;
    }

    .ultra-processing-item {
      align-items: flex-start;
      text-align: left;
    }

    .ultra-processing-icon-wrapper {
      margin-bottom: 12px;
      height: auto;
    }

    .has-mobile-icon .ultra-processing-icon-mobile {
      display: block;
      width: 44px;
      height: auto;
    }
    
    .has-mobile-icon .ultra-processing-icon-desktop {
      display: none;
    }

    .ultra-processing-item-title {
      font-size: 24px;
      margin-bottom: 12px;
    }

    .ultra-processing-item-desc {
      font-size: 15px;
      color: #444444;
      line-height: 1.5;
      width: 92%;
    }

    .ultra-processing-impact {
      position: relative;
      bottom: auto;
      left: auto;
      background-color: #FFCD68;
      width: 100vw; 
      padding: 25px 24px 60px 24px;
      align-items: center;
      text-align: center;
      box-sizing: border-box;
      top: -1px;
    }

    .ultra-impact-black {
      font-size: 28px;
      color: #111111;
      margin-bottom: 12px;
    }

    .perf-canvas-{{ section.id }} .canvas-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 40px;
      min-height: auto;
      padding: 0 24px;
    }

    .perf-canvas-{{ section.id }} .canvas-item {
      position: relative !important;
      left: unset !important;
      top: unset !important;
      transform: none !important;
      max-width: 100% !important;
      text-align: center !important;
      width: 100% !important;
    }

    .perf-canvas-{{ section.id }} .canvas-item p {
      text-align: center !important;
    }

    .perf-canvas-{{ section.id }} .item-arrow-1,
    .perf-canvas-{{ section.id }} .item-arrow-2 {
      display: none !important;
    }

    .perf-canvas-{{ section.id }} .item-main-image {
      max-width: 320px !important;
    }

    .ultra-processing-img-desktop {
      display: none !important;
    }

    .ultra-processing-img-mobile {
      display: block !important;
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      height: auto;
      z-index: 2;
      position: relative;
    }
  }
{%- endstyle -%}

<div class="ultra-processing-container">
  <div class="ultra-processing-left">
    <h2 class="ultra-processing-heading">
      <span class="heading-black">{{ section.settings.heading_black }}</span>
      <span class="heading-red">{{ section.settings.heading_red }}</span>
    </h2>

    <div class="ultra-processing-grid">
      {% for block in section.blocks %}
        <div class="ultra-processing-item {% if block.settings.icon_image != blank %}has-mobile-icon{% endif %}" {{ block.shopify_attributes }}>
          <div class="ultra-processing-icon-wrapper">
            {% if block.settings.icon_image != blank %}
              <img class="ultra-processing-icon-mobile" src="{{ block.settings.icon_image | img_url: 'master' }}" alt="{{ block.settings.title }}" loading="lazy">
            {% endif %}
            <div class="ultra-processing-icon-desktop" style="background-color: {{ block.settings.icon_color }};"></div>
          </div>
          <div class="ultra-processing-item-title">{{ block.settings.title }}</div>
          <div class="ultra-processing-item-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ultra-processing-right">
    <div class="dog-illustration-canvas">
      {% if section.settings.green_curve != blank %}
        <img class="ultra-processing-green-curve" src="{{ section.settings.green_curve | img_url: 'master' }}" alt="Green Curve background" loading="lazy">
      {% endif %}

      {% if section.settings.main_image != blank %}
        <img class="ultra-processing-img-desktop" src="{{ section.settings.main_image | img_url: 'master' }}" alt="{{ section.settings.heading_red }}" width="600" height="auto" loading="lazy">
      {% endif %}
    </div>
    
    {% if section.settings.main_image_mobile != blank %}
      <img class="ultra-processing-img-mobile" src="{{ section.settings.main_image_mobile | img_url: 'master' }}" alt="{{ section.settings.heading_red }} Mobile" width="400" height="auto" loading="lazy">
    {% elsif section.settings.main_image != blank %}
      <img class="ultra-processing-img-mobile fallback" src="{{ section.settings.main_image | img_url: 'master' }}" alt="{{ section.settings.heading_red }} Mobile" width="400" height="auto" loading="lazy">
    {% endif %}
  </div>

  <div class="ultra-processing-impact">
    <div class="ultra-impact-black">{{ section.settings.impact_black }}</div>
    <div class="ultra-impact-red">{{ section.settings.impact_red }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Ultra-Processing",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "heading_black",
      "label": "Heading (Black text)",
      "default": "Problems with"
    },
    {
      "type": "text",
      "id": "heading_red",
      "label": "Heading (Red text)",
      "default": "Ultra-Processing"
    },
    {
      "type": "text",
      "id": "impact_black",
      "label": "Impact Question Text",
      "default": "Whats the impact ?"
    },
    {
      "type": "text",
      "id": "impact_red",
      "label": "Impact Answer Text",
      "default": "The deficit shows up in your pet's health."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Right Image (Dog without Arrow)"
    },
    {
      "type": "image_picker",
      "id": "main_image_mobile",
      "label": "Mobile Main Image"
    },
    {
      "type": "header",
      "content": "Green Curve Isolation Controls"
    },
    {
      "type": "image_picker",
      "id": "green_curve",
      "label": "Green Curve Image Graphic"
    },
    {
      "type": "range",
      "id": "curve_x",
      "min": -300,
      "max": 300,
      "step": 6,
      "unit": "px",
      "label": "Green Curve Horizontal Position (X)",
      "default": -60
    },
    {
      "type": "range",
      "id": "curve_y",
      "min": -200,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Green Curve Vertical Position (Y)",
      "default": -40
    },
    {
      "type": "range",
      "id": "curve_width",
      "min": 50,
      "max": 450,
      "step": 4,
      "unit": "px",
      "label": "Green Curve Width",
      "default": 178
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Bullet",
      "limit": 4,
      "settings": [
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon Color",
          "default": "#fcebb6"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image (Mobile only)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ultra-Processing",
      "blocks": [
        { "type": "feature", "settings": { "title": "Loaded with Fillers", "description": "Extruded kibble and processed treats often contain high levels of starch and binders that add bulk, not meaningful nutrition." } },
        { "type": "feature", "settings": { "title": "Calories That Actually Nourish", "description": "Calories from protein and healthy fats support growth, repair, and vitality, whereas calories from starch and filler just fill the bowl" } },
        { "type": "feature", "settings": { "title": "Created Under Extreme Heat", "description": "The high heat and pressure used during extrusion can form Advanced Glycation End Products (AGEs), compounds linked to chronic health issues." } },
        { "type": "feature", "settings": { "title": "Nature Over Synthetic", "description": "Ultra-processing destroys natural nutrients and replaces them with synthetic alternatives that may not be absorbed as effectively by the body." } }
      ]
    }
  ]
}
{% endschema %}