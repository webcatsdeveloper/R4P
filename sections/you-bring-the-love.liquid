{% schema %}
{
  "name": "Science Feeding",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFCD6B"
    },
    {
      "type": "text",
      "id": "heading_top",
      "label": "Top Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext",
      "id": "subtext_top",
      "label": "Top Subtext",
      "default": "<p><a href=\"#\">A way of feeding that's built around what their bodies actually need, made practical for everyday life.</a></p><p><a href=\"#\">So what actually makes it different?</a></p>"
    },
    {
      "type": "text",
      "id": "heading_left",
      "label": "Left Heading",
      "default": "Preserving\nwhat\nmatters."
    },
    {
      "type": "image_picker",
      "id": "bowl_image",
      "label": "Center Image (Bowl)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Feature Text",
          "default": "<p>Feature description here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Feeding Section",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .science-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding: 100px 20px;
    font-family: inherit;
    overflow: hidden;
  }
  .science-container-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* Top Content */
  .science-top-{{ section.id }} {
    text-align: center;
    margin-bottom: 90px;
  }
  .science-top-{{ section.id }} h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 20px;
    color: #000;
  }
  .science-top-{{ section.id }} .subtext {
    font-size: 1.1rem;
    color: #333;
  }
  .science-top-{{ section.id }} .subtext a {
    color: #0047AB; /* Standard hyperlink blue */
    text-decoration: underline;
    font-weight: 500;
    display: block;
    margin-bottom: 5px;
    text-underline-offset: 4px;
  }

  /* Main Graphic Area */
  .science-main-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    gap: 40px;
  }
  
  /* Left Heading */
  .science-left-{{ section.id }} {
    flex: 0 0 30%;
    z-index: 2;
  }
  .science-left-{{ section.id }} h3 {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    color: #000;
    margin: 0;
  }

  /* Center Graphic (Bowl + Arc) */
  .science-center-{{ section.id }} {
    flex: 0 0 40%;
    display: flex;
    justify-content: center;
    position: relative;
  }
  .science-bowl-wrapper {
    position: relative;
    width: 100%;
    max-width: 450px;
    z-index: 2;
  }
  .science-bowl-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
  }

  /* The Perfect Right-Sided Arc */
  .science-arc {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 125%; 
    aspect-ratio: 1 / 1;
    border: 2px solid transparent;
    border-right-color: #fff;
    border-radius: 50%;
    z-index: 1;
  }

  /* Feature Positioning on the Arc */
  .science-feature-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 15px;
    width: 280px; 
    transform: translate(-25px, -25px); /* Centers the 50px icon exactly onto the line */
  }

  /* Exact trigonometric mapping to match the curve */
  .science-feature-item:nth-child(1) { top: 15%; left: 85%; }
  .science-feature-item:nth-child(2) { top: 38%; left: 98.5%; }
  .science-feature-item:nth-child(3) { top: 62%; left: 98.5%; }
  .science-feature-item:nth-child(4) { top: 85%; left: 85%; }

  .feature-icon-{{ section.id }} {
    flex: 0 0 50px;
    height: 50px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    padding: 12px;
  }
  .feature-icon-{{ section.id }} img, 
  .feature-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .feature-text-{{ section.id }} {
    font-size: 0.95rem;
    line-height: 1.4;
    color: #222;
  }
  .feature-text-{{ section.id }} p { margin: 0; }

  /* Responsive Mobile Breakpoint */
  @media (max-width: 1100px) {
    .science-main-{{ section.id }} {
      flex-direction: column;
      text-align: center;
    }
    .science-left-{{ section.id }} h3 {
      text-align: center;
    }
    .science-center-{{ section.id }} {
      width: 100%;
      margin-top: 40px;
    }
    .science-arc {
      display: none; 
    }
    .science-mobile-features {
      display: flex;
      flex-direction: column;
      gap: 24px;
      margin-top: 40px;
      width: 100%;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }
    .science-feature-item {
      position: relative;
      top: auto !important;
      left: auto !important;
      transform: none;
      width: 100%;
      text-align: left;
    }
  }
  @media (min-width: 1101px) {
     .science-mobile-features { display: none; }
  }
</style>

<div class="science-section-{{ section.id }}">
  <div class="science-container-{{ section.id }}">
    
    <div class="science-top-{{ section.id }}">
      <h2>{{ section.settings.heading_top | newline_to_br }}</h2>
      <div class="subtext">
        {{ section.settings.subtext_top }}
      </div>
    </div>

    <div class="science-main-{{ section.id }}">
      <div class="science-left-{{ section.id }}">
        <h3>{{ section.settings.heading_left | newline_to_br }}</h3>
      </div>

      <div class="science-center-{{ section.id }}">
        <div class="science-bowl-wrapper">
          {% if section.settings.bowl_image %}
            <img src="{{ section.settings.bowl_image | image_url: width: 600 }}" alt="{{ section.settings.bowl_image.alt | escape }}" loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          
          <div class="science-arc">
            {% for block in section.blocks %}
              <div class="science-feature-item" {{ block.shopify_attributes }}>
                <div class="feature-icon-{{ section.id }}">
                  {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="" loading="lazy">
                  {% else %}
                     <div style="width:20px;height:20px;background:#e0e0e0;border-radius:50%;"></div>
                  {% endif %}
                </div>
                <div class="feature-text-{{ section.id }}">
                  {{ block.settings.text }}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    <div class="science-mobile-features">
       {% for block in section.blocks %}
         <div class="science-feature-item" {{ block.shopify_attributes }}>
           <div class="feature-icon-{{ section.id }}">
             {% if block.settings.icon %}
               <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="" loading="lazy">
             {% else %}
               <div style="width:20px;height:20px;background:#e0e0e0;border-radius:50%;"></div>
             {% endif %}
           </div>
           <div class="feature-text-{{ section.id }}">
             {{ block.settings.text }}
           </div>
         </div>
       {% endfor %}
    </div>

  </div>
</div>