{% comment %} Touch to sync wide arc 4 {% endcomment %}
{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 80px 100px;
    overflow: hidden;
    font-family: inherit;
    color: {{ section.settings.text_color }};
  }
  #section-{{ section.id }} .pcf-title,
  #section-{{ section.id }} .pcf-intro-title {
    color: {{ section.settings.title_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="pcf-wrapper">

  <div class="pcf-intro-block pcf-animate fade-up">
    {% if section.settings.intro_heading != blank %}
      <h2 class="pcf-intro-title">
        {%- assign heading_html = section.settings.intro_heading | newline_to_br -%}
        {%- if heading_html contains '<br />' -%}
          {%- assign heading_lines = heading_html | split: '<br />' -%}
        {%- elsif heading_html contains '<br>' -%}
          {%- assign heading_lines = heading_html | split: '<br>' -%}
        {%- else -%}
          {%- assign heading_lines = heading_html | split: '
' -%}
        {%- endif -%}
        {%- if heading_lines.size > 1 -%}
          <span class="heading-line-1">{{ heading_lines[0] | strip_html | strip }}</span>
          <span class="heading-line-2">{{ heading_lines[1] | strip_html | strip }}</span>
        {%- else -%}
          {{ section.settings.intro_heading | newline_to_br }}
        {%- endif -%}
      </h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="pcf-intro-subtext">{{ section.settings.intro_subtext }}</div>
    {% endif %}
  </div>

  <div class="pcf-main-grid">

    <div class="pcf-left-col pcf-animate fade-right delay-1">
      <h2 class="pcf-title">{{ section.settings.main_title | newline_to_br }}</h2>
    </div>

    <div class="pcf-diagram-col pcf-animate fade-in delay-2">
      <div class="pcf-diagram-container">

        <div class="pcf-bowl-wrapper pcf-animate scale-in delay-3">
          {% if section.settings.center_image != blank %}
            {{ section.settings.center_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Main bowl image', class: 'pcf-bowl-img' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'pcf-placeholder' }}
          {% endif %}
        </div>

        <!--
          Arc math (viewBox 0 0 100 80, aspect-ratio 1.25/1 → isotropic):
          Bowl center: (40, 40). Arc radius: 31.5 SVG units = 31.5cqw.
          Angles: -55°, -18°, +18°, +55° (clockwise from 3-o'clock).
          Start: (40 + 31.5·cos(-55°), 40 + 31.5·sin(-55°)) = (58.07, 14.20)
          End:   (40 + 31.5·cos(+55°), 40 + 31.5·sin(+55°)) = (58.07, 65.80)
          Small arc (flag=0), clockwise (flag=1) → right-side arc only.
        -->
        <svg class="pcf-arc-svg" viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path
            d="M 58.07 14.20 A 31.5 31.5 0 0 1 58.07 65.80"
            stroke="{{ section.settings.arc_color | default: '#ffffff' }}"
            stroke-width="0.45"
            fill="none"
          />
        </svg>

        {% for block in section.blocks %}
          {% case forloop.index %}
            {% when 1 %} {% assign angle = '-55deg' %}
            {% when 2 %} {% assign angle = '-18deg' %}
            {% when 3 %} {% assign angle = '18deg' %}
            {% when 4 %} {% assign angle = '55deg' %}
            {% else %}   {% assign angle = '0deg' %}
          {% endcase %}

          <div class="pcf-feature-point" style="--angle: {{ angle }};" {{ block.shopify_attributes }}>
            <div class="pcf-feature-content pcf-animate fade-left" style="transition-delay: 0.{{ forloop.index | plus: 3 }}s;">
              <div class="pcf-icon-circle">
                {% if block.settings.custom_icon != blank %}
                  {{ block.settings.custom_icon | image_url: width: 80 | image_tag: class: 'pcf-custom-img' }}
                {% else %}
                  {% case block.settings.icon_type %}
                    {% when 'drop' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                        <line x1="12" y1="11" x2="12" y2="15"/>
                        <circle cx="12" cy="16.5" r="0.6" fill="#222"/>
                      </svg>
                    {% when 'shield' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <polyline points="9,12 11,14 15,10"/>
                      </svg>
                    {% when 'heat' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 3c0 2 2 2 2 4s-2 2-2 4 2 2 2 4"/>
                        <path d="M12 3c0 2 2 2 2 4s-2 2-2 4 2 2 2 4"/>
                        <path d="M16 3c0 2 2 2 2 4s-2 2-2 4 2 2 2 4"/>
                        <line x1="6" y1="19" x2="18" y2="19"/>
                      </svg>
                    {% when 'molecule' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/>
                        <circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/>
                        <circle cx="12" cy="12" r="3"/>
                        <line x1="8.12" y1="8.12" x2="9.88" y2="9.88"/>
                        <line x1="14.12" y1="9.88" x2="15.88" y2="8.12"/>
                        <line x1="9.88" y1="14.12" x2="8.12" y2="15.88"/>
                        <line x1="15.88" y1="14.12" x2="14.12" y2="15.88"/>
                      </svg>
                  {% endcase %}
                {% endif %}
              </div>
              <div class="pcf-feature-text">{{ block.settings.text | newline_to_br }}</div>
            </div>
          </div>
        {% endfor %}

      </div>
    </div>

  </div>
</div>

<style>
  /* ─── Intro block ─────────────────────────────────── */
  .pcf-intro-block {
    max-width: 1012px;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .pcf-intro-title {
    font-size: clamp(32px, 3.5vw, 46px);
    line-height: 1.15;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pcf-intro-title .heading-line-1 { font-weight: 900; }
  .pcf-intro-title .heading-line-2 { font-weight: 800; }
  .pcf-intro-subtext {
    font-size: 23px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
    padding: 0 16px;
  }
  .pcf-intro-subtext p { margin: 0; }
  .pcf-intro-subtext strong { font-weight: 700; color: #000; opacity: 1; }

  /* ─── Main 2-col grid ────────────────────────────── */
  .pcf-main-grid {
    /* No max-width cap — fills full 1720px content area at 1920px screen */
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 3.5rem;
  }
  @media (min-width: 990px) {
    .pcf-main-grid {
      grid-template-columns: 3.5fr 8.5fr;
      gap: 2rem;
    }
  }

  /* ─── Left col – giant title ─────────────────────── */
  .pcf-left-col {
    z-index: 5;
  }
  .pcf-title {
    font-size: clamp(3rem, 6.5vw, 7.5rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin: 0;
  }

  /* ─── Right col – circular diagram ──────────────── */
  .pcf-diagram-col { width: 100%; }
  .pcf-diagram-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1.25 / 1;
    container-type: inline-size;
  }

  /*
    Bowl center anchor:
      left: 40%  → 40/100 = 40% of container width  = SVG cx=40
      top:  50%  → 40/80  = 50% of container height = SVG cy=40
  */
  .pcf-bowl-wrapper {
    position: absolute;
    top: 50%;
    left: 40%;
    transform: translate(-50%, -50%);
    width: 46cqw;          /* ~46% of right col width — matches Figma bowl size */
    z-index: 5;
  }
  .pcf-bowl-img,
  .pcf-placeholder {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.14));
  }

  /* ─── SVG arc (desktop only) ─────────────────────── */
  .pcf-arc-svg { display: none; }
  @media (min-width: 990px) {
    .pcf-arc-svg {
      display: block;
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 1;
    }
  }

  /*
    Icon orbit — same math as SVG arc:
    center (40%, 50%), radius 31.5cqw, angles via --angle.
    rotate(angle) → translateX(radius) → rotate(-angle)
    puts the icon exactly ON the arc line.
  */
  .pcf-feature-point {
    position: absolute;
    top: 50%;
    left: 40%;
    transform:
      translate(-50%, -50%)
      rotate(var(--angle))
      translateX(31.5cqw)
      rotate(calc(var(--angle) * -1));
    z-index: 10;
  }

  /* Icon circle centered on arc, text label to its right */
  .pcf-feature-content {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-26px, -50%);   /* -26px = half icon width, centering it on arc */
    display: flex;
    align-items: center;
    gap: 14px;
    width: max-content;
  }

  .pcf-icon-circle {
    width: 52px;
    height: 52px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 4px 16px rgba(0,0,0,0.09);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 2;
  }
  .pcf-icon-circle svg { width: 22px; height: 22px; }
  .pcf-custom-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    border-radius: 50%;
  }

  .pcf-feature-text {
    font-size: 15px;
    line-height: 1.4;
    font-weight: 500;
    color: #2b2b2b;
    max-width: 220px;
  }

  /* ─── Scroll animations ──────────────────────────── */
  .pcf-animate { opacity: 0; will-change: opacity, transform; }
  .fade-up    { transform: translateY(30px);  transition: opacity .8s ease, transform .8s ease; }
  .fade-right { transform: translateX(-30px); transition: opacity .8s ease, transform .8s ease; }
  .fade-left  { transform: translateX(30px);  transition: opacity .8s ease, transform .8s ease; }
  .fade-in    {                                transition: opacity 1s ease; }
  .scale-in   {
    transform: translate(-50%, -50%) scale(0.85);
    transition: opacity .8s ease, transform .8s cubic-bezier(.2,.8,.2,1);
  }
  .pcf-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }
  .scale-in.is-visible    { transform: translate(-50%, -50%) scale(1); }
  .delay-1 { transition-delay: .1s; }
  .delay-2 { transition-delay: .2s; }
  .delay-3 { transition-delay: .3s; }

  /* ─── Mobile (≤ 1024px) ──────────────────────────── */
  @media screen and (max-width: 1024px) {
    #section-{{ section.id }} {
      padding: 60px 20px !important;
    }
    .pcf-intro-block { margin-bottom: 3.5rem; }
    .pcf-intro-title { font-size: 28px; }

    .pcf-main-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }
    .pcf-left-col { text-align: center; }
    .pcf-title {
      font-size: 35px;
      text-align: left;
      margin-bottom: 1.5rem;
      padding-left: 35px;
    }

    .pcf-diagram-container {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      position: relative;
      --bowl-width: min(280px, 70vw);
    }

    /* Vertical connector line aligned to left edge of bowl */
    .pcf-diagram-container::before {
      content: "";
      position: absolute;
      top: -30px;
      bottom: 23px;
      left: calc(50% - var(--bowl-width) / 2);
      width: 2px;
      background-color: {{ section.settings.arc_color | default: '#ffffff' }};
      z-index: 1;
    }

    .pcf-bowl-wrapper {
      position: relative;
      top: auto; left: auto;
      transform: none !important;
      width: var(--bowl-width) !important;
      max-width: 280px !important;
      margin: 0 auto;
      z-index: 5;
    }
    .scale-in.is-visible { transform: scale(1) !important; }
    .pcf-arc-svg { display: none; }

    .pcf-feature-point {
      position: relative;
      top: auto; left: auto;
      transform: none !important;
      width: 100%;
      padding-left: calc(50% - var(--bowl-width) / 2 - 23px);
      box-sizing: border-box;
      z-index: 3;
    }
    .pcf-feature-content {
      position: relative;
      top: auto; left: auto;
      transform: none !important;
      width: 100% !important;
      text-align: left;
      gap: 1.2rem;
      display: flex;
      align-items: center;
    }
    .pcf-icon-circle {
      width: 46px; height: 46px;
      min-width: 46px;
      z-index: 5;
    }
    .pcf-feature-text {
      font-size: .95rem;
      max-width: 280px;
    }
    .heading-line-1 { font-weight: 900 !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0.15 });

    document.querySelectorAll('#section-{{ section.id }} .pcf-animate')
      .forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Circular Arc Features",
  "settings": [
    { "type": "color", "id": "bg_color",    "label": "Background Color", "default": "#F9CE69" },
    { "type": "color", "id": "title_color", "label": "Heading Text Color", "default": "#000000" },
    { "type": "color", "id": "text_color",  "label": "Body Text Color",    "default": "#333333" },
    { "type": "color", "id": "arc_color",   "label": "Arc Line Color",     "default": "#ffffff" },
    { "type": "header", "content": "Top Intro" },
    {
      "type": "textarea", "id": "intro_heading", "label": "Intro Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext", "id": "intro_subtext", "label": "Intro Subtext",
      "default": "<p>A way of feeding that's built around what their bodies actually need, made practical for everyday life.<br><strong>So what actually makes it different?</strong></p>"
    },
    { "type": "header", "content": "Main Split Block" },
    {
      "type": "textarea", "id": "main_title", "label": "Left Bold Title",
      "default": "Preserving\nwhat\nmatters."
    },
    { "type": "image_picker", "id": "center_image", "label": "Center Bowl Image" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select", "id": "icon_type", "label": "Built-in Icon",
          "options": [
            { "value": "drop",     "label": "Drop / Dehydration" },
            { "value": "shield",   "label": "Shield / Retain" },
            { "value": "heat",     "label": "Heat / Vapor" },
            { "value": "molecule", "label": "Molecule / Structure" }
          ],
          "default": "drop"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Or upload a custom icon" },
        {
          "type": "textarea", "id": "text", "label": "Feature Description",
          "default": "Controlled low-\ntemperature dehydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Arc Features",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop",     "text": "Controlled low-\ntemperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield",   "text": "Helps retain essential amino\nacids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat",     "text": "Avoids nutrient degradation\ncaused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural\nintegrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}
