{% comment %} Touch to sync wide arc 2 {% endcomment %}
{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 120px 0;
    overflow: hidden;
    font-family: inherit;
    color: {{ section.settings.text_color }};
  }

  /* Typography Colors */
  #section-{{ section.id }} .pcf-title, 
  #section-{{ section.id }} .pcf-intro-title {
    color: {{ section.settings.title_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="pcf-wrapper">
  
  <div class="pcf-intro-block pcf-animate fade-up">
    {% if section.settings.intro_heading != blank %}
      <h2 class="pcf-intro-title">
        {%- assign heading_html = section.settings.intro_heading | newline_to_br -%}
        {%- if heading_html contains '<br />' -%}
          {%- assign heading_lines = heading_html | split: '<br />' -%}
        {%- elsif heading_html contains '<br>' -%}
          {%- assign heading_lines = heading_html | split: '<br>' -%}
        {%- else -%}
          {%- assign heading_lines = heading_html | split: '\n' -%}
        {%- endif -%}
        {%- if heading_lines.size > 1 -%}
          <span class="heading-line-1">{{ heading_lines[0] | strip_html | strip }}</span>
          <span class="heading-line-2">{{ heading_lines[1] | strip_html | strip }}</span>
        {%- else -%}
          {{ section.settings.intro_heading | newline_to_br }}
        {%- endif -%}
      </h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="pcf-intro-subtext">
        {{ section.settings.intro_subtext }}
      </div>
    {% endif %}
  </div>

  <div class="pcf-canvas-container">
    
    <div class="pcf-left-col pcf-animate fade-right delay-1">
      <h2 class="pcf-title">{{ section.settings.main_title | newline_to_br }}</h2>
    </div>

    <div class="pcf-diagram-viewport pcf-animate fade-in delay-2">
      
      <div class="pcf-bowl-wrapper pcf-animate scale-in delay-3">
        {% if section.settings.center_image != blank %}
          {{ section.settings.center_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Main bowl image', class: 'pcf-bowl-img' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'pcf-placeholder' }}
        {% endif %}
      </div>

      <div class="pcf-svg-arc-wrapper">
        <svg viewBox="0 0 368 735" fill="none" xmlns="http://www.w3.org/2000/svg" class="pcf-native-svg">
          <path d="M0 733C201.86 733 365.5 569.36 365.5 367.5C365.5 165.64 201.86 2 0 2" stroke="{{ section.settings.arc_color | default: '#ffffff' }}" stroke-width="4"/>
        </svg>
      </div>

      {% for block in section.blocks %}
        <div class="pcf-node node-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="pcf-icon-circle">
            <div class="pcf-icon-inner-content">
              {% if block.settings.custom_icon != blank %}
                {{ block.settings.custom_icon | image_url: width: 80 | image_tag: class: 'pcf-custom-img' }}
              {% else %}
                {% case block.settings.icon_type %}
                  {% when 'drop' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path><path d="M12 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M4.93 4.93l2.83 2.83"></path><path d="M19.07 4.93l-2.83 2.83"></path></svg>
                  {% when 'shield' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  {% when 'heat' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8c0-2-2-2-2-4"></path><path d="M12 8c0-2-2-2-2-4"></path><path d="M7 8c0-2-2-2-2-4"></path><path d="M5 12h14v2a7 7 0 0 1-14 0v-2z"></path><path d="M12 22a7 7 0 0 0 7-7"></path></svg>
                  {% when 'molecule' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><circle cx="12" cy="12" r="3"></circle><line x1="8.12" y1="8.12" x2="9.88" y2="9.88"></line><line x1="14.12" y1="9.88" x2="15.88" y2="8.12"></line><line x1="9.88" y1="14.12" x2="8.12" y2="15.88"></line><line x1="15.88" y1="14.12" x2="14.12" y2="15.88"></line></svg>
                {% endcase %}
              {% endif %}
            </div>
          </div>

          <div class="pcf-feature-text">
            {{ block.settings.text | newline_to_br }}
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</div>

<style>
  /* --- Intro Header --- */
  .pcf-intro-block {
    max-width: 1012px;
    margin: 0 auto 4rem auto;
    text-align: center;
  }
  .pcf-intro-title {
    font-size: clamp(32px, 3.5vw, 46px);
    line-height: 1.15;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pcf-intro-title .heading-line-1 { font-weight: 900; }
  .pcf-intro-title .heading-line-2 { font-weight: 800; }
  .pcf-intro-subtext {
    font-size: 23px;
    line-height: 1.6;
    margin: 0;
    color: inherit;
    opacity: 0.85;
    padding: 0 16px;
  }
  .pcf-intro-subtext strong { font-weight: 700; color: #000; }

  /* --- Main Canvas Frame Setup --- */
  .pcf-canvas-container {
    position: relative;
    width: 100%;
    max-width: 1440px;
    height: 740px;
    margin: 0 auto;
  }

  /* --- Left Heading Column --- */
  .pcf-left-col {
    position: absolute;
    width: 550px;
    left: 50px;
    top: 20px;
    z-index: 5;
  }
  .pcf-title {
    font-size: 112px;
    font-weight: 700;
    line-height: 101px;
    letter-spacing: -0.04em;
    margin: 0;
    color: #000000;
  }

  /* --- Right Layout Graphic Viewport Area --- */
  .pcf-diagram-viewport {
    position: absolute;
    width: 890px;
    height: 740px;
    right: 0;
    top: 0;
  }

  /* --- Pet Food Bowl Wrapper --- */
  .pcf-bowl-wrapper {
    position: absolute;
    width: 580px;
    height: 580px;
    left: 0;
    top: 75px;
    z-index: 2;
  }
  .pcf-bowl-img, .pcf-placeholder {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.12));
  }

  /* --- FIXED: Integrated Your Figma SVG Half-Arc Element --- */
  .pcf-svg-arc-wrapper {
    position: absolute;
    width: 368px;
    height: 735px;
    left: 468px; /* Perfectly aligns relative to your bowl radius */
    top: -2px;
    z-index: 3;
    pointer-events: none;
  }
  .pcf-native-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* --- Base Interactive Node Framework --- */
  .pcf-node {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 20px;
    z-index: 10;
  }
  .pcf-icon-circle {
    width: 76px;
    height: 76px;
    background: #FFFFFF;
    border-radius: 50%;
    box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
  }
  .pcf-icon-inner-content {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 5;
  }
  .pcf-icon-circle svg {
    width: 32px;
    height: 32px;
  }
  .pcf-custom-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14px;
    border-radius: 50%;
  }
  .pcf-feature-text {
    font-size: 24px;
    line-height: 32px;
    font-weight: 400;
    color: #1E1E1E;
    white-space: nowrap;
  }

  /* --- FIXED: Precision Node Positions Mapped to Your Custom Arc path --- */
  
  /* Node 1: Top Feature Point */
  .pcf-node.node-1 {
    left: 659px; /* 468px start + figma horizontal path delta */
    top: -4px;
  }
  /* Node 2: Upper Middle Feature Point */
  .pcf-node.node-2 {
    left: 795.5px;
    top: 165px;
  }
  /* Node 3: Lower Middle Feature Point */
  .pcf-node.node-3 {
    left: 807px;
    top: 361px;
  }
  /* Node 4: Bottom Feature Point */
  .pcf-node.node-4 {
    left: 698px;
    top: 551px;
  }

  /* --- Animations --- */
  .pcf-animate { opacity: 0; will-change: opacity, transform; }
  .fade-up { transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-right { transform: translateX(-30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-in { transition: opacity 1s ease; }
  .scale-in { transform: scale(0.9); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
  
  .pcf-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }

  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  /* --- Fully Responsive Mobile Overrides --- */
  @media screen and (max-width: 1200px) {
    #section-{{ section.id }} {
      padding: 60px 20px !important;
    }
    .pcf-canvas-container {
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }
    .pcf-left-col {
      position: relative;
      width: 100%;
      left: auto; top: auto;
      text-align: left;
    }
    .pcf-title {
      font-size: 54px;
      line-height: 58px;
    }
    .pcf-diagram-viewport {
      position: relative;
      width: 100%;
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }
    .pcf-bowl-wrapper {
      position: relative;
      left: auto; top: auto;
      width: min(280px, 75vw);
      height: min(280px, 75vw);
      margin: 0 auto;
    }
    .pcf-svg-arc-wrapper {
      position: absolute;
      width: 2px;
      height: calc(100% - 200px);
      left: calc(50% - min(280px, 75vw)/2);
      top: 140px;
      border-left: 2px solid #FFFFFF;
    }
    .pcf-native-svg { display: none; }
    
    .pcf-node {
      position: relative;
      left: auto !important; top: auto !important;
      width: 100%;
      padding-left: calc(50% - min(280px, 75vw)/2 - 38px);
      box-sizing: border-box;
      gap: 15px;
    }
    .pcf-icon-circle {
      width: 56px;
      height: 56px;
    }
    .pcf-icon-circle svg {
      width: 22px;
      height: 22px;
    }
    .pcf-feature-text {
      font-size: 16px;
      line-height: 22px;
      white-space: normal;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0.1 });

    document.querySelectorAll('#section-{{ section.id }} .pcf-animate').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Circular Arc Features",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9CE69"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Top Intro"
    },
    {
      "type": "textarea",
      "id": "intro_heading",
      "label": "Intro Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext",
      "id": "intro_subtext",
      "label": "Intro Subtext",
      "default": "<p>A way of feeding that's built around what their bodies actually need, made practical for everyday life.<br><strong>So what actually makes it different?</strong></p>"
    },
    {
      "type": "header",
      "content": "Main Split Block"
    },
    {
      "type": "textarea",
      "id": "main_title",
      "label": "Left Bold Title",
      "default": "Preserving\nwhat\nmatters."
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Bowl Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon",
          "options": [
            { "value": "drop", "label": "Drop/Dehydration" },
            { "value": "shield", "label": "Shield" },
            { "value": "heat", "label": "Heat/Vapor" },
            { "value": "molecule", "label": "Molecule" }
          ],
          "default": "drop"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Or Custom Icon Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature Description",
          "default": "Controlled low-\ntemperature dehydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Arc Features",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop", "text": "Controlled low-\ntemperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield", "text": "Helps retain essential amino\nacids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat", "text": "Avoids nutrient degradation\ncaused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural\nintegrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}