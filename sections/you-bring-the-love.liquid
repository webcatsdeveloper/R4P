{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 100px 20px 120px 20px;
    overflow: hidden;
    font-family: inherit;
  }

  /* Text Colors */
  #section-{{ section.id }} .sci-text-dark {
    color: {{ section.settings.text_color }};
  }

  #section-{{ section.id }} .sci-arc {
    border-color: {{ section.settings.arc_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="sci-section">
  
  <div class="sci-intro-container sci-animate fade-up stagger-1">
    {% if section.settings.intro_heading != blank %}
      <h2 class="sci-intro-heading sci-text-dark">{{ section.settings.intro_heading | newline_to_br }}</h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="sci-intro-subtext sci-text-dark">
        {{ section.settings.intro_subtext }}
      </div>
    {% endif %}
  </div>

  <div class="sci-grid-container">
    
    <div class="sci-col-left sci-animate fade-right stagger-2">
      <h2 class="sci-main-title sci-text-dark">
        {{ section.settings.main_title | newline_to_br }}
      </h2>
    </div>

    <div class="sci-col-center sci-animate scale-in stagger-3">
      <div class="sci-image-wrapper">
        {% if section.settings.center_image != blank %}
          {{ section.settings.center_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Dog food bowl', class: 'sci-bowl-img' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'sci-placeholder-img' }}
        {% endif %}
      </div>
    </div>

    <div class="sci-col-right sci-animate fade-left stagger-4">
      
      <div class="sci-arc"></div>

      <div class="sci-features-list">
        {% for block in section.blocks %}
          
          {% assign pos_class = 'sci-pos-mid' %}
          {% if forloop.first or forloop.last %}
            {% assign pos_class = 'sci-pos-edge' %}
          {% endif %}

          <div class="sci-feature-item {{ pos_class }}" {{ block.shopify_attributes }}>
            
            <div class="sci-icon-circle">
              {% if block.settings.custom_icon != blank %}
                {{ block.settings.custom_icon | image_url: width: 100 | image_tag: class: 'sci-custom-icon' }}
              {% else %}
                {% case block.settings.icon_type %}
                  {% when 'drop' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"></path><line x1="6" y1="6" x2="18" y2="18"></line><circle cx="16" cy="8" r="1.5"></circle></svg>
                  {% when 'shield' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  {% when 'heat' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8c0-2-2-2-2-4"></path><path d="M12 8c0-2-2-2-2-4"></path><path d="M7 8c0-2-2-2-2-4"></path><path d="M5 12h14v2a7 7 0 0 1-14 0v-2z"></path><path d="M12 22a7 7 0 0 0 7-7"></path></svg>
                  {% when 'molecule' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><circle cx="12" cy="12" r="3"></circle><line x1="8.12" y1="8.12" x2="9.88" y2="9.88"></line><line x1="14.12" y1="9.88" x2="15.88" y2="8.12"></line><line x1="9.88" y1="14.12" x2="8.12" y2="15.88"></line><line x1="15.88" y1="14.12" x2="14.12" y2="15.88"></line></svg>
                {% endcase %}
              {% endif %}
            </div>

            <div class="sci-feature-text sci-text-dark">
              {{ block.settings.text }}
            </div>

          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</div>

<style>
  /* --- Intro Layout --- */
  .sci-intro-container {
    max-width: 850px;
    margin: 0 auto 100px auto;
    text-align: center;
  }
  .sci-intro-heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 25px 0;
    letter-spacing: -0.02em;
  }
  .sci-intro-subtext {
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
  }
  .sci-intro-subtext p { margin: 0; }
  .sci-intro-subtext strong { font-weight: 800; }

  /* --- 3 Column Main Grid --- */
  .sci-grid-container {
    max-width: 1250px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(250px, 1fr) auto minmax(300px, 1fr);
    align-items: center;
    gap: 40px;
    position: relative;
  }

  /* --- Left Column: Bold Title --- */
  .sci-col-left {
    z-index: 2;
  }
  .sci-main-title {
    font-size: clamp(40px, 6vw, 76px);
    font-weight: 800;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.03em;
  }

  /* --- Center Column: Bowl Image --- */
  .sci-col-center {
    position: relative;
    z-index: 5;
    margin: 0 -30px; /* Pulls adjacent columns closer behind the image */
  }
  .sci-image-wrapper {
    width: 440px;
    max-width: 100%;
    position: relative;
    border-radius: 50%;
  }
  .sci-bowl-img, .sci-placeholder-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    /* Optional: adds a subtle shadow to make the bowl pop against the background */
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15)); 
  }

  /* --- Right Column: Arc & Features --- */
  .sci-col-right {
    position: relative;
    padding: 20px 0;
    z-index: 2;
  }

  /* The dynamic CSS connecting line */
  .sci-arc {
    position: absolute;
    left: 20px; /* Centers behind the 40px icon */
    top: 30px;  /* Pin to center of first icon */
    bottom: 30px; /* Pin to center of last icon */
    width: 60px;
    border: 2px solid white;
    border-right: none;
    border-radius: 200px 0 0 200px; /* Creates the perfect leftward bowing ellipse */
    z-index: 1;
  }

  .sci-features-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 45px;
    z-index: 2;
  }

  .sci-feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
    position: relative;
  }
  
  /* Positions the top/bottom items outward, and middle items inward along the arc */
  .sci-pos-edge { margin-left: 55px; }
  .sci-pos-mid { margin-left: 0px; }

  .sci-icon-circle {
    width: 42px;
    height: 42px;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 5px 15px rgba(0,0,0,0.08);
  }
  .sci-icon-circle svg {
    width: 20px;
    height: 20px;
  }
  .sci-custom-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    padding: 6px;
  }

  .sci-feature-text {
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
    max-width: 220px;
  }

  /* --- Scroll Animations Engine --- */
  .sci-animate {
    opacity: 0;
    will-change: opacity, transform;
  }
  .fade-up { transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-right { transform: translateX(-40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-left { transform: translateX(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .scale-in { transform: scale(0.9); transition: opacity 0.8s ease, transform 0.8s ease; }
  
  .sci-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }
  
  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.2s; }
  .stagger-3 { transition-delay: 0.4s; }
  .stagger-4 { transition-delay: 0.6s; }

  /* --- Mobile Optimization --- */
  @media screen and (max-width: 989px) {
    #section-{{ section.id }} {
      padding: 60px 20px 80px 20px;
    }
    .sci-intro-container {
      margin-bottom: 60px;
    }
    .sci-grid-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 50px;
    }
    .sci-col-center {
      margin: 0 auto;
    }
    .sci-image-wrapper {
      width: 320px;
    }
    .sci-main-title {
      font-size: 48px;
    }
    
    /* Remove the arc and reset icon alignment for clean mobile reading */
    .sci-col-right {
      padding: 0;
    }
    .sci-arc {
      display: none;
    }
    .sci-pos-edge, .sci-pos-mid {
      margin-left: 0;
      justify-content: center;
      text-align: left;
    }
    .sci-feature-text {
      max-width: 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('#section-{{ section.id }} .sci-animate').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Science Features Split",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8C86A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arc_color",
      "label": "Connecting Curve Line Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Top Intro Section"
    },
    {
      "type": "textarea",
      "id": "intro_heading",
      "label": "Top Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext",
      "id": "intro_subtext",
      "label": "Top Subtext",
      "default": "<p>A way of feeding that's built around what their bodies actually need, made practical for everyday life.<br><strong>So what actually makes it different?</strong></p>"
    },
    {
      "type": "header",
      "content": "Left Side Element"
    },
    {
      "type": "textarea",
      "id": "main_title",
      "label": "Left Bold Title",
      "default": "Preserving\nwhat\nmatters."
    },
    {
      "type": "header",
      "content": "Center Element"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Bowl Image",
      "info": "Use a transparent PNG of a top-down bowl for best results."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon Selection",
          "options": [
            { "value": "drop", "label": "Dehydration Drop" },
            { "value": "shield", "label": "Protection Shield" },
            { "value": "heat", "label": "Heat/Processing" },
            { "value": "molecule", "label": "Molecular Structure" }
          ],
          "default": "drop"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Or Upload Custom Icon Image",
          "info": "Overrides the built-in SVG selected above."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Description",
          "default": "Controlled low-temperature dehydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Features Split",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop", "text": "Controlled low-temperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield", "text": "Helps retain essential amino acids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat", "text": "Avoids nutrient degradation caused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural integrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}