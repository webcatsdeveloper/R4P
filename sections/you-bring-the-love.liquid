{% comment %} Touch to sync wide arc 2 {% endcomment %}
{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 100px 20px 100px 20px;
    overflow: hidden;
    font-family: inherit;
    color: {{ section.settings.text_color }};
  }

  /* Typography Colors */
  #section-{{ section.id }} .pcf-title, 
  #section-{{ section.id }} .pcf-intro-title {
    color: {{ section.settings.title_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="pcf-wrapper">
  
  {% if section.settings.intro_heading != blank or section.settings.intro_subtext != blank %}
  <div class="pcf-intro-block pcf-animate fade-up">
    {% if section.settings.intro_heading != blank %}
      <h2 class="pcf-intro-title">
        {{ section.settings.intro_heading | newline_to_br }}
      </h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="pcf-intro-subtext">
        {{ section.settings.intro_subtext }}
      </div>
    {% endif %}
  </div>
  {% endif %}

  <div class="pcf-main-grid">
    
    <div class="pcf-left-col pcf-animate fade-right delay-1">
      <h2 class="pcf-title">{{ section.settings.main_title | newline_to_br }}</h2>
    </div>

    <div class="pcf-diagram-col pcf-animate fade-in delay-2">
      <div class="pcf-diagram-container">
        
        <div class="pcf-bowl-wrapper pcf-animate scale-in delay-3">
          {% if section.settings.center_image != blank %}
            {{ section.settings.center_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: 'Main bowl image', class: 'pcf-bowl-img' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'pcf-placeholder' }}
          {% endif %}
        </div>

        <svg class="pcf-arc-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Adjusted arc to be a cleaner semi-circle for the features -->
          <path d="M 50 15 A 35 35 0 0 1 50 85" stroke="{{ section.settings.arc_color | default: '#ffffff' }}" stroke-width="0.3" fill="none"/>
        </svg>

        {% for block in section.blocks %}
          {% case forloop.index %}
            {% when 1 %} {% assign angle = '-45deg' %}
            {% when 2 %} {% assign angle = '-15deg' %}
            {% when 3 %} {% assign angle = '15deg' %}
            {% when 4 %} {% assign angle = '45deg' %}
            {% else %} {% assign angle = '0deg' %}
          {% endcase %}

          <div class="pcf-feature-point" style="--angle: {{ angle }};" {{ block.shopify_attributes }}>
            <div class="pcf-feature-content pcf-animate fade-left" style="transition-delay: 0.{{ forloop.index | plus: 3 }}s;">
              
              <div class="pcf-icon-circle">
                {% if block.settings.custom_icon != blank %}
                  {{ block.settings.custom_icon | image_url: width: 80 | image_tag: class: 'pcf-custom-img' }}
                {% else %}
                  {% case block.settings.icon_type %}
                    {% when 'drop' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path><path d="M12 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M4.93 4.93l2.83 2.83"></path><path d="M19.07 4.93l-2.83 2.83"></path></svg>
                    {% when 'shield' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    {% when 'heat' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8c0-2-2-2-2-4"></path><path d="M12 8c0-2-2-2-2-4"></path><path d="M7 8c0-2-2-2-2-4"></path><path d="M5 12h14v2a7 7 0 0 1-14 0v-2z"></path><path d="M12 22a7 7 0 0 0 7-7"></path></svg>
                    {% when 'molecule' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><circle cx="12" cy="12" r="3"></circle><line x1="8.12" y1="8.12" x2="9.88" y2="9.88"></line><line x1="14.12" y1="9.88" x2="15.88" y2="8.12"></line><line x1="9.88" y1="14.12" x2="8.12" y2="15.88"></line><line x1="15.88" y1="14.12" x2="14.12" y2="15.88"></line></svg>
                  {% endcase %}
                {% endif %}
              </div>

              <div class="pcf-feature-text">
                {{ block.settings.text | newline_to_br }}
              </div>
            </div>
          </div>
        {% endfor %}

      </div>
    </div>

  </div>
</div>

<style>
  /* --- Shared Styles --- */
  .pcf-intro-block {
    max-width: 800px;
    margin: 0 auto 4rem auto;
    text-align: center;
  }
  .pcf-animate { opacity: 0; will-change: opacity, transform; }
  .pcf-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }

  /* --- Desktop Specific Design (To match Figma) --- */
  @media (min-width: 990px) {
    .pcf-main-grid {
      max-width: 1400px; /* Wider container for the hero look */
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr; /* Balanced split for title and diagram */
      align-items: center;
      gap: 20px;
    }

    .pcf-title {
      font-size: clamp(5rem, 8.5vw, 9.5rem); /* Massive bold text */
      font-weight: 800;
      line-height: 0.9;
      letter-spacing: -0.04em;
      margin: 0;
      text-align: left;
    }

    .pcf-diagram-container {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      container-type: inline-size;
    }

    /* Center the bowl in its half of the grid */
    .pcf-bowl-wrapper {
      position: absolute;
      top: 50%;
      left: 35%; /* Centered relative to the arc circle */
      transform: translate(-50%, -50%);
      width: 60cqw; 
      z-index: 5;
    }
    
    .pcf-bowl-img {
      width: 100%;
      height: auto;
      filter: drop-shadow(0 25px 50px rgba(0,0,0,0.15));
    }

    .pcf-arc-svg {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* Trigonometric Positioning for Arc Points */
    .pcf-feature-point {
      position: absolute;
      top: 50%;
      left: 35%; /* Matches bowl center */
      transform: translate(-50%, -50%) rotate(var(--angle)) translateX(35cqw) rotate(calc(var(--angle) * -1));
      z-index: 10;
    }

    .pcf-feature-content {
      position: absolute;
      top: 50%;
      left: 0;
      transform: translate(-30px, -50%); /* Centers the icon on the line */
      display: flex;
      align-items: center;
      gap: 20px;
      width: 350px; /* Room for description text */
    }

    .pcf-icon-circle {
      width: 64px;
      height: 64px;
      background: #ffffff;
      border-radius: 50%;
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .pcf-feature-text {
      font-size: 18px;
      line-height: 1.3;
      font-weight: 500;
      color: #333;
    }

    /* Animation States for Desktop */
    .fade-right { transform: translateX(-50px); transition: opacity 1s ease, transform 1s ease; }
    .fade-left { transform: translateX(50px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .scale-in { transform: translate(-50%, -50%) scale(0.8); transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .scale-in.is-visible { transform: translate(-50%, -50%) scale(1); }
  }

  /* --- Mobile Layout (UNTOLD/UNCHANGED as requested) --- */
  @media screen and (max-width: 989px) {
    #section-{{ section.id }} {
      padding: 60px 20px !important;
    }
    .pcf-title {
        font-size: 35px;
        text-align: left;
        margin-bottom: 1.5rem;
    }
    .pcf-diagram-container {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      position: relative;
      --bowl-width: min(280px, 70vw);
    }
    .pcf-diagram-container::before {
      content: "";
      position: absolute;
      top: -30px; bottom: 23px;
      left: calc(50% - var(--bowl-width) / 2);
      width: 2px;
      background-color: {{ section.settings.arc_color | default: '#ffffff' }};
      z-index: 1;
    }
    .pcf-bowl-wrapper {
      position: relative;
      width: var(--bowl-width) !important;
      margin: 0 auto;
      z-index: 5;
    }
    .pcf-arc-svg { display: none; }
    .pcf-feature-point {
      position: relative;
      width: 100%;
      padding-left: calc(50% - var(--bowl-width) / 2 - 23px);
      box-sizing: border-box;
    }
    .pcf-feature-content {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }
    .pcf-icon-circle {
      width: 46px; height: 46px;
      background: #fff; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .pcf-feature-text { font-size: 0.95rem; max-width: 280px; }
    .fade-up { transform: translateY(30px); transition: 0.8s ease; }
    .is-visible { opacity: 1; transform: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('#section-{{ section.id }} .pcf-animate').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Circular Arc Features",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F9CE69" },
    { "type": "color", "id": "title_color", "label": "Heading Text Color", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Body Text Color", "default": "#333333" },
    { "type": "textarea", "id": "intro_heading", "label": "Intro Heading (Optional)" },
    { "type": "richtext", "id": "intro_subtext", "label": "Intro Subtext (Optional)" },
    { "type": "textarea", "id": "main_title", "label": "Left Bold Title", "default": "Preserving\nwhat\nmatters." },
    { "type": "image_picker", "id": "center_image", "label": "Center Bowl Image" },
    { "type": "color", "id": "arc_color", "label": "Arc Line Color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon",
          "options": [
            { "value": "drop", "label": "Drop/Dehydration" },
            { "value": "shield", "label": "Shield" },
            { "value": "heat", "label": "Heat/Vapor" },
            { "value": "molecule", "label": "Molecule" }
          ],
          "default": "drop"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Or Custom Icon Image" },
        { "type": "textarea", "id": "text", "label": "Feature Description", "default": "Controlled low-\ntemperature dehydration" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Arc Features",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop", "text": "Controlled low-\ntemperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield", "text": "Helps retain essential amino\nacids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat", "text": "Avoids nutrient degradation\ncaused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural\nintegrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}