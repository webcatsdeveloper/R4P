{% comment %} Touch to sync wide arc 2 {% endcomment %}
{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 100px;
    overflow: hidden;
    font-family: inherit;
    color: {{ section.settings.text_color }};
  }

  /* Typography Colors */
  #section-{{ section.id }} .pcf-title, 
  #section-{{ section.id }} .pcf-intro-title {
    color: {{ section.settings.title_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="pcf-wrapper">
  
  <div class="pcf-intro-block pcf-animate fade-up">
    {% if section.settings.intro_heading != blank %}
      <h2 class="pcf-intro-title">
        {%- assign heading_html = section.settings.intro_heading | newline_to_br -%}
        {%- if heading_html contains '<br />' -%}
          {%- assign heading_lines = heading_html | split: '<br />' -%}
        {%- elsif heading_html contains '<br>' -%}
          {%- assign heading_lines = heading_html | split: '<br>' -%}
        {%- else -%}
          {%- assign heading_lines = heading_html | split: '
' -%}
        {%- endif -%}
        {%- if heading_lines.size > 1 -%}
          <span class="heading-line-1">{{ heading_lines[0] | strip_html | strip }}</span>
          <span class="heading-line-2">{{ heading_lines[1] | strip_html | strip }}</span>
        {%- else -%}
          {{ section.settings.intro_heading | newline_to_br }}
        {%- endif -%}
      </h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="pcf-intro-subtext">
        {{ section.settings.intro_subtext }}
      </div>
    {% endif %}
  </div>

  <div class="pcf-main-grid">
    
    <div class="pcf-left-col pcf-animate fade-right delay-1">
      <h2 class="pcf-title">{{ section.settings.main_title | newline_to_br }}</h2>
    </div>

    <div class="pcf-diagram-col pcf-animate fade-in delay-2">
      <div class="pcf-diagram-container">
        
        <div class="pcf-bowl-wrapper pcf-animate scale-in delay-3">
          {% if section.settings.center_image != blank %}
            {{ section.settings.center_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Main bowl image', class: 'pcf-bowl-img' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'pcf-placeholder' }}
          {% endif %}
        </div>

        <svg class="pcf-arc-svg" viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M 48 12.29 A 32 32 0 0 1 48 67.71" stroke="{{ section.settings.arc_color | default: '#ffffff' }}" stroke-width="0.4" fill="none"/>
        </svg>

        {% for block in section.blocks %}
          {% case forloop.index %}
            {% when 1 %} {% assign angle = '-52deg' %}
            {% when 2 %} {% assign angle = '-15deg' %}
            {% when 3 %} {% assign angle = '18deg' %}
            {% when 4 %} {% assign angle = '52deg' %}
            {% else %} {% assign angle = '0deg' %}
          {% endcase %}

          <div class="pcf-feature-point" style="--angle: {{ angle }};" {{ block.shopify_attributes }}>
            <div class="pcf-feature-content pcf-animate fade-left" style="transition-delay: 0.{{ forloop.index | plus: 3 }}s;">
              
              <div class="pcf-icon-circle">
                {% if block.settings.custom_icon != blank %}
                  {{ block.settings.custom_icon | image_url: width: 80 | image_tag: class: 'pcf-custom-img' }}
                {% else %}
                  {%- assign current_icon_type = block.settings.icon_type -%}
                  {%- if current_icon_type == 'drop' and forloop.index == 2 -%}
                    {%- assign current_icon_type = 'shield' -%}
                  {%- elsif current_icon_type == 'drop' and forloop.index == 3 -%}
                    {%- assign current_icon_type = 'heat' -%}
                  {%- elsif current_icon_type == 'drop' and forloop.index == 4 -%}
                    {%- assign current_icon_type = 'molecule' -%}
                  {%- endif -%}

                  {% case current_icon_type %}
                    {% when 'drop' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <circle cx="8" cy="8" r="1.5" fill="#222"></circle>
                        <circle cx="16" cy="16" r="1.5" fill="#222"></circle>
                      </svg>
                    {% when 'shield' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      </svg>
                    {% when 'heat' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 8a2 2 0 0 1 2-2 2 2 0 0 0 2-2 2 2 0 0 0-2-2M12 8a2 2 0 0 1 2-2 2 2 0 0 0 2-2 2 2 0 0 0-2-2M16 8a2 2 0 0 1 2-2 2 2 0 0 0 2-2 2 2 0 0 0-2-2" />
                        <path d="M10 16a1.5 1.5 0 0 1-3 0c0-1.5 1.5-3 1.5-3s1.5 1.5 1.5 3z" />
                        <path d="M17 16a1.5 1.5 0 0 1-3 0c0-1.5 1.5-3 1.5-3s1.5 1.5 1.5 3z" />
                        <path d="M12 19a1 1 0 0 1-2 0c0-1 1-2 1-2s1 1 1 2z" />
                      </svg>
                    {% when 'molecule' %}
                      <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="18" r="2.5"></circle>
                        <circle cx="6" cy="6" r="2.5"></circle>
                        <circle cx="18" cy="6" r="2.5"></circle>
                        <circle cx="6" cy="18" r="2.5"></circle>
                        <circle cx="12" cy="12" r="3"></circle>
                        <line x1="8.12" y1="8.12" x2="9.88" y2="9.88"></line>
                        <line x1="14.12" y1="9.88" x2="15.88" y2="8.12"></line>
                        <line x1="9.88" y1="14.12" x2="8.12" y2="15.88"></line>
                        <line x1="15.88" y1="14.12" x2="14.12" y2="15.88"></line>
                      </svg>
                  {% endcase %}
                {% endif %}
              </div>

              <div class="pcf-feature-text">
                {{ block.settings.text | newline_to_br }}
              </div>
            </div>
          </div>
        {% endfor %}

      </div>
    </div>

  </div>
</div>

<style>
  /* --- Intro Header --- */
  .pcf-intro-block {
    max-width: 1012px;
    margin: 0 auto 3rem auto;
    text-align: center;
  }
  .pcf-intro-title {
    font-size: clamp(32px, 3.5vw, 46px);
    line-height: 1.15;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pcf-intro-title .heading-line-1 {
    font-weight: 900;
  }
  .pcf-intro-title .heading-line-2 {
    font-weight: 800;
  }
  .pcf-intro-subtext {
    font-size: 23px;
    line-height: 1.6;
    margin: 0;
    color: inherit;
    opacity: 0.85;
    padding:0 16px;
  }
  .pcf-intro-subtext p { margin: 0; }
  .pcf-intro-subtext strong { font-weight: 700; color: #000; opacity: 1; }

  /* --- Main Grid Layout --- */
  .pcf-main-grid {
    max-width: 1340px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 3.5rem;
  }

  @media (min-width: 990px) {
    .pcf-main-grid {
      grid-template-columns: 4.8fr 7.2fr;
      gap: 0;
    }
  }

  /* --- Left Column --- */
  .pcf-left-col {
    padding-left: 0;
    z-index: 5;
    margin-top: 0 !important;
  }
  .pcf-title {
    font-size: clamp(3rem, 6.5vw, 7.5rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    margin-top: 0 !important;
  }

  /* --- Right Circular Diagram --- */
  .pcf-diagram-col {
    width: 100%;
  }
  .pcf-diagram-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1.25 / 1; 
    container-type: inline-size;
    --center-x: 32%;
    --center-y: 50%;
    --bowl-size: 54cqw;
    --arc-radius: 32cqw;
  }

  /* Center Anchor */
  .pcf-bowl-wrapper {
    position: absolute;
    top: var(--center-y);
    left: var(--center-x);
    transform: translate(-50%, -50%);
    width: var(--bowl-size);
    z-index: 5;
  }
  .pcf-bowl-img, .pcf-placeholder {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));
  }

  /* SVG Concentric Arc */
  .pcf-arc-svg {
    display: none;
  }
  @media (min-width: 990px) {
    .pcf-arc-svg {
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }
  }

  /* Precise Trigonometric Positioning */
  .pcf-feature-point {
    position: absolute;
    top: var(--center-y);
    left: var(--center-x);
    transform: translate(-50%, -50%) rotate(var(--angle)) translateX(var(--arc-radius)) rotate(calc(var(--angle) * -1));
    z-index: 10;
  }

  /* Wrapper to align Icon exactly on the arc line, text to the right */
  .pcf-feature-content {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-26px, -50%);
    display: flex;
    align-items: center;
    gap: 15px;
    width: max-content;
  }

  .pcf-icon-circle {
    width: 52px;
    height: 52px;
    background: #ffffff;
    border-radius: 50%;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 2;
  }
  .pcf-icon-circle svg {
    width: 22px;
    height: 22px;
  }
  .pcf-custom-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    border-radius: 50%;
  }

  .pcf-feature-text {
    font-size: 15px;
    line-height: 1.35;
    font-weight: 500;
    color: #1e1e1e;
  }

  /* --- Animations --- */
  .pcf-animate { opacity: 0; will-change: opacity, transform; }
  .fade-up { transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-right { transform: translateX(-30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-left { transform: translateX(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-in { transition: opacity 1s ease; }
  .scale-in { transform: translate(-50%, -50%) scale(0.85); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
  
  .pcf-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }
  .scale-in.is-visible { transform: translate(-50%, -50%) scale(1); }

  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  /* --- Mobile Optimization --- */
  @media screen and (max-width: 1024px) {
    #section-{{ section.id }} {
      padding: 60px 20px !important;
    }
    .pcf-intro-block {
      margin-bottom: 3.5rem;
    }
    .pcf-intro-title {
      font-size: 28px;
    }
    .pcf-main-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }
    .pcf-left-col {
      padding-left: 0;
      text-align: center;
    }
    .pcf-title {
        font-size: 35px;
        text-align: left;
        margin-bottom: 1.5rem;
        padding-left: 35px;
         margin-top: -40px!important;
    }
    
    .pcf-diagram-container {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      position: relative;
      --bowl-width: min(280px, 70vw);
    }

    /* Vertical connector line on mobile, tangent to the left edge of the bowl */
    .pcf-diagram-container::before {
      content: "";
      position: absolute;
      top: -30px;
      bottom: 23px;
      left: calc(50% - var(--bowl-width) / 2);
      width: 2px;
      background-color: {{ section.settings.arc_color | default: '#ffffff' }};
      z-index: 1;
    }

    .pcf-bowl-wrapper {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: var(--bowl-width) !important;
      max-width: 280px !important;
      margin: 0 auto;
      z-index: 5;
    }
    .scale-in.is-visible { transform: scale(1) !important; }

    .pcf-arc-svg { display: none; }

    .pcf-feature-point {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: 100%;
      padding-left: calc(50% - var(--bowl-width) / 2 - 23px);
      box-sizing: border-box;
      z-index: 3;
    }
    .pcf-feature-content {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: 100% !important;
      text-align: left;
      gap: 1.2rem;
      display: flex;
      align-items: center;
    }
    .pcf-icon-circle {
      width: 46px;
      height: 46px;
      min-width: 46px;
      z-index: 5;
    }
    .pcf-feature-text {
      font-size: 0.95rem;
      line-height: 1.35;
      font-weight: 500;
      color: #1e1e1e;
      max-width: 280px;
    }
    .heading-line-1{
      font-weight:900 !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0.15 });

    document.querySelectorAll('#section-{{ section.id }} .pcf-animate').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Circular Arc Features",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9CE69"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Top Intro"
    },
    {
      "type": "textarea",
      "id": "intro_heading",
      "label": "Intro Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext",
      "id": "intro_subtext",
      "label": "Intro Subtext",
      "default": "<p>A way of feeding that's built around what their bodies actually need, made practical for everyday life.<br><strong>So what actually makes it different?</strong></p>"
    },
    {
      "type": "header",
      "content": "Main Split Block"
    },
    {
      "type": "textarea",
      "id": "main_title",
      "label": "Left Bold Title",
      "default": "Preserving\nwhat\nmatters."
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Bowl Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon",
          "options": [
            { "value": "drop", "label": "Drop/Dehydration" },
            { "value": "shield", "label": "Shield" },
            { "value": "heat", "label": "Heat/Vapor" },
            { "value": "molecule", "label": "Molecule" }
          ],
          "default": "drop"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Or Custom Icon Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature Description",
          "default": "Controlled low-\ntemperature dehydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Arc Features",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop", "text": "Controlled low-\ntemperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield", "text": "Helps retain essential amino\nacids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat", "text": "Avoids nutrient degradation\ncaused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural\nintegrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}