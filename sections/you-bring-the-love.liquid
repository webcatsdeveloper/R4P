{% comment %} Touch to sync wide arc 2 {% endcomment %}
{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 120px 0 140px 0;
    overflow: hidden;
    font-family: 'Degular Demo', sans-serif;
    color: {{ section.settings.text_color }};
  }

  /* Typography Colors */
  #section-{{ section.id }} .pcf-title, 
  #section-{{ section.id }} .pcf-intro-title {
    color: {{ section.settings.title_color }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="pcf-outer-wrapper">
  
  <div class="pcf-intro-block pcf-animate fade-up">
    {% if section.settings.intro_heading != blank %}
      <h2 class="pcf-intro-title">
        {%- assign heading_html = section.settings.intro_heading | newline_to_br -%}
        {%- if heading_html contains '<br />' -%}
          {%- assign heading_lines = heading_html | split: '<br />' -%}
        {%- elsif heading_html contains '<br>' -%}
          {%- assign heading_lines = heading_html | split: '<br>' -%}
        {%- else -%}
          {%- assign heading_lines = heading_html | split: '
' -%}
        {%- endif -%}
        {%- if heading_lines.size > 1 -%}
          <span class="heading-line-1">{{ heading_lines[0] | strip_html | strip }}</span>
          <span class="heading-line-2">{{ heading_lines[1] | strip_html | strip }}</span>
        {%- else -%}
          {{ section.settings.intro_heading | newline_to_br }}
        {%- endif -%}
      </h2>
    {% endif %}
    {% if section.settings.intro_subtext != blank %}
      <div class="pcf-intro-subtext">
        {{ section.settings.intro_subtext }}
      </div>
    {% endif %}
  </div>

  <div class="pcf-content-centering-box">
    <div class="pcf-main-grid">
      
      <div class="pcf-left-col pcf-animate fade-right delay-1">
        <h2 class="pcf-title">{{ section.settings.main_title | newline_to_br }}</h2>
      </div>

      <div class="pcf-diagram-col pcf-animate fade-in delay-2">
        <div class="pcf-diagram-container">
          
          <div class="pcf-bowl-wrapper pcf-animate scale-in delay-3">
            {% if section.settings.center_image != blank %}
              {{ section.settings.center_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: 'Main bowl image', class: 'pcf-bowl-img' }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'pcf-placeholder' }}
            {% endif %}
          </div>

          <svg class="pcf-arc-svg" viewBox="0 0 731 731" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 365.5 4 A 361.5 361.5 0 0 1 365.5 727" stroke="#FFFFFF" stroke-width="4" fill="none"/>
          </svg>

          {% for block in section.blocks %}
            {% case forloop.index %}
              {% when 1 %} {% assign angle = '-48deg' %}
              {% when 2 %} {% assign angle = '-16deg' %}
              {% when 3 %} {% assign angle = '16deg' %}
              {% when 4 %} {% assign angle = '48deg' %}
              {% else %} {% assign angle = '0deg' %}
            {% endcase %}

            <div class="pcf-feature-point" style="--angle: {{ angle }};" {{ block.shopify_attributes }}>
              <div class="pcf-feature-content pcf-animate fade-left" style="transition-delay: 0.{{ forloop.index | plus: 3 }}s;">
                
                <div class="pcf-icon-circle">
                  {% if block.settings.custom_icon != blank %}
                    {{ block.settings.custom_icon | image_url: width: 80 | image_tag: class: 'pcf-custom-img' }}
                  {% else %}
                    {% case block.settings.icon_type %}
                      {% when 'drop' %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path><path d="M12 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path><path d="M4.93 4.93l2.83 2.83"></path><path d="M19.07 4.93l-2.83 2.83"></path></svg>
                      {% when 'shield' %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                      {% when 'heat' %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8c0-2-2-2-2-4"></path><path d="M12 8c0-2-2-2-2-4"></path><path d="M7 8c0-2-2-2-2-4"></path><path d="M5 12h14v2a7 7 0 0 1-14 0v-2z"></path><path d="M12 22a7 7 0 0 0 7-7"></path></svg>
                      {% when 'molecule' %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><circle cx="12" cy="12" r="3"></circle><line x1="8.12" y1="8.12" x2="9.88" y2="9.88"></line><line x1="14.12" y1="9.88" x2="15.88" y2="8.12"></line><line x1="9.88" y1="14.12" x2="8.12" y2="15.88"></line><line x1="15.88" y1="14.12" x2="14.12" y2="15.88"></line></svg>
                    {% endcase %}
                  {% endif %}
                </div>

                <div class="pcf-feature-text">
                  {{ block.settings.text | newline_to_br }}
                </div>
              </div>
            </div>
          {% endfor %}

        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* --- Global Resets & Layout Locks --- */
  .pcf-outer-wrapper {
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* --- Intro Top Copy Layout --- */
  .pcf-intro-block {
    max-width: 1086px;
    margin: 0 auto 5rem auto;
    text-align: center;
    padding: 0 40px;
    box-sizing: border-box;
  }
  .pcf-intro-title {
    font-size: 62px;
    line-height: 67px;
    font-weight: 700;
    margin: 0 0 20px 0;
    letter-spacing: -0.01em;
  }
  .pcf-intro-title span {
    display: block;
  }
  .pcf-intro-subtext {
    max-width: 1012px;
    margin: 0 auto;
    font-size: 24px;
    line-height: 32px;
    font-weight: 400;
    color: #1E1E1E;
  }
  .pcf-intro-subtext p { margin: 0; }
  .pcf-intro-subtext strong { font-weight: 700; color: #000; display: block; margin-top: 8px; }

  /* --- Inner Alignment Container --- */
  .pcf-content-centering-box {
    width: 100%;
    max-width: 1420px; /* Snaps the grid system bounds to keep spacing clean on wide screens */
    margin: 0 auto;
    padding: 0 60px;
    box-sizing: border-box;
  }
  
  .pcf-main-grid {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 4rem;
  }

  @media (min-width: 990px) {
    .pcf-main-grid {
      grid-template-columns: 460px 1fr; /* Fixed left text column width */
      gap: 30px;
    }
  }

  /* --- Left Sidebar Headline Sizing --- */
  .pcf-left-col {
    z-index: 5;
    box-sizing: border-box;
  }
  .pcf-title {
    font-size: 110px; 
    font-weight: 700;
    line-height: 96px;
    letter-spacing: -0.03em;
    margin: 0;
    color: #000000;
  }

  /* --- Right Side Component Column --- */
  .pcf-diagram-col {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-start;
  }
  
  .pcf-diagram-container {
    position: relative;
    width: 100%;
    max-width: 820px; 
    height: 680px; 
    margin: 0;
  }

  /* Proportional Bowl Component Matrix */
  .pcf-bowl-wrapper {
    position: absolute;
    top: 50%;
    left: 210px; /* Locks the dynamic bowl focal point */
    transform: translate(-50%, -50%);
    width: 440px;  
    height: 440px;
    z-index: 5;
  }
  .pcf-bowl-img, .pcf-placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 50%;
  }

  /* Concentric SVG Arc Line */
  .pcf-arc-svg {
    display: none;
  }
  @media (min-width: 990px) {
    .pcf-arc-svg {
        display: block;
        position: absolute;
        top: 50%;
        left: 210px;
        width: 610px; 
        height: 610px;
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 1;
    }
  }

  /* Mathematical Absolute Radius Point Coordinates */
  .pcf-feature-point {
    position: absolute;
    top: 50%;
    left: 210px;
    /* Translate elements perfectly across path line splits */
    transform: translate(-50%, -50%) rotate(var(--angle)) translateX(305px) rotate(calc(var(--angle) * -1));
    z-index: 10;
  }

  .pcf-feature-content {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-30px, -50%); /* Centers the node circle direct on the line path stroke */
    display: flex;
    align-items: center;
    gap: 20px;
    width: max-content;
  }

  .pcf-icon-circle {
    width: 66px;
    height: 66px;
    background: #ffffff;
    border-radius: 50%;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 2;
  }
  .pcf-icon-circle svg {
    width: 30px;
    height: 30px;
  }
  .pcf-custom-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14px;
    border-radius: 50%;
  }

  .pcf-feature-text {
    font-size: 20px;
    line-height: 26px;
    font-weight: 500;
    color: #1E1E1E;
    max-width: 280px; 
    text-align: left;
  }

  /* --- Animation Inits --- */
  .pcf-animate { opacity: 0; will-change: opacity, transform; }
  .fade-up { transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-right { transform: translateX(-30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-left { transform: translateX(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .fade-in { transition: opacity 1s ease; }
  .scale-in { transform: translate(-50%, -50%) scale(0.85); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
  
  .pcf-animate.is-visible { opacity: 1; transform: translate(0) scale(1); }
  .scale-in.is-visible { transform: translate(-50%, -50%) scale(1); }

  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  /* --- Mobile Optimization --- */
  @media screen and (max-width: 1024px) {
    #section-{{ section.id }} {
      padding: 60px 0 !important;
    }
    .pcf-intro-block {
      margin-bottom: 2.5rem;
      padding: 0 20px;
    }
    .pcf-intro-title {
      font-size: 34px;
      line-height: 40px;
    }
    .pcf-intro-subtext {
      font-size: 17px;
      line-height: 23px;
    }
    .pcf-content-centering-box {
      padding: 0 20px;
    }
    .pcf-main-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .pcf-title {
        font-size: 52px;
        line-height: 48px;
        text-align: center;
    }
    
    .pcf-diagram-container {
      aspect-ratio: auto;
      width: 100%;
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      position: relative;
      --bowl-width: min(290px, 75vw);
    }

    .pcf-diagram-container::before {
      content: "";
      position: absolute;
      top: 0px;
      bottom: 30px;
      left: calc(50% - var(--bowl-width) / 2 + 15px);
      width: 3px;
      background-color: #FFFFFF;
      z-index: 1;
    }

    .pcf-bowl-wrapper {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: var(--bowl-width) !important;
      height: var(--bowl-width) !important;
      margin: 0 auto;
      z-index: 5;
    }
    .scale-in.is-visible { transform: scale(1) !important; }

    .pcf-arc-svg { display: none; }

    .pcf-feature-point {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: 100%;
      padding-left: calc(50% - var(--bowl-width) / 2 - 15px);
      box-sizing: border-box;
      z-index: 3;
    }
    .pcf-feature-content {
      position: relative;
      top: auto; left: auto; transform: none !important;
      width: 100% !important;
      gap: 15px;
      display: flex;
      align-items: center;
    }
    .pcf-icon-circle {
      width: 52px;
      height: 52px;
      min-width: 52px;
    }
    .pcf-icon-circle svg {
      width: 24px;
      height: 24px;
    }
    .pcf-feature-text {
      font-size: 16px;
      line-height: 22px;
      max-width: 70%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { root: null, threshold: 0.15 });

    document.querySelectorAll('#section-{{ section.id }} .pcf-animate').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Circular Arc Features",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9CE69"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Top Intro"
    },
    {
      "type": "textarea",
      "id": "intro_heading",
      "label": "Intro Heading",
      "default": "You bring the love.\nWe bring the science."
    },
    {
      "type": "richtext",
      "id": "intro_subtext",
      "label": "Intro Subtext",
      "default": "<p>A way of feeding that's built around what their bodies actually need, made practical for everyday life.<br><strong>So what actually makes it different?</strong></p>"
    },
    {
      "type": "header",
      "content": "Main Split Block"
    },
    {
      "type": "textarea",
      "id": "main_title",
      "label": "Left Bold Title",
      "default": "Preserving\nwhat\nmatters."
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Bowl Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon",
          "options": [
            { "value": "drop", "label": "Drop/Dehydration" },
            { "value": "shield", "label": "Shield" },
            { "value": "heat", "label": "Heat/Vapor" },
            { "value": "molecule", "label": "Molecule" }
          ],
          "default": "drop"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Or Custom Icon Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature Description",
          "default": "Controlled low-\ntemperature dehydration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Circular Arc Features",
      "blocks": [
        { "type": "feature", "settings": { "icon_type": "drop", "text": "Controlled low-\ntemperature dehydration" } },
        { "type": "feature", "settings": { "icon_type": "shield", "text": "Helps retain essential amino\nacids and micronutrients" } },
        { "type": "feature", "settings": { "icon_type": "heat", "text": "Avoids nutrient degradation\ncaused by high-heat processing" } },
        { "type": "feature", "settings": { "icon_type": "molecule", "text": "Maintains structural\nintegrity of ingredients" } }
      ]
    }
  ]
}
{% endschema %}