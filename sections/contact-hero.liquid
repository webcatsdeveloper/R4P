{%- style -%}
  #shopify-section-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --card-bg: {{ section.settings.card_bg }};
    --card-text: {{ section.settings.card_text }};
    --input-border: {{ section.settings.input_border }};
    --input-bg: {{ section.settings.input_bg }};
    --button-bg: {{ section.settings.button_bg }};
    --button-text: {{ section.settings.button_text }};
    
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: var(--bg-color);
    position: relative;
    overflow: hidden;
  }

  /* Premium Desktop Background Image Engine mapping to custom_curve_image setting */
  {%- if section.settings.custom_curve_image != blank -%}
    #shopify-section-{{ section.id }} .contact-hero-section {
      background-image: url('{{ section.settings.custom_curve_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: {{ section.settings.bg_position_desktop }};
      background-repeat: no-repeat;
    }
  {%- endif -%}

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: 0 !important;
    }
    
    /* Force reset mobile background to allow the background image to stack naturally in the content flow */
    #shopify-section-{{ section.id }} .contact-hero-section,
    .contact-hero-section {
      background-image: none !important;
    }
  }
{%- endstyle -%}

<div class="contact-hero-section contact-hero__animate">
  <div class="contact-hero__container">
    <div class="contact-hero__grid">
      
      <!-- Info Column (Left on Desktop, Top on Mobile - 1st in mobile stack) -->
      <div class="contact-hero__info-col contact-hero__animate-fade delay-1">
        <div class="contact-hero__info-list">
          
          <!-- Office Block -->
          <div class="contact-hero__info-item">
            <div class="contact-hero__icon-circle">
              <svg class="contact-hero__icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2ZM12 11.5C10.62 11.5 9.5 10.38 9.5 9C9.5 7.62 10.62 6.5 12 6.5C13.38 6.5 14.5 7.62 14.5 9C14.5 10.38 13.38 11.5 12 11.5Z" fill="currentColor"/>
              </svg>
            </div>
            <div class="contact-hero__info-content">
              {%- if section.settings.office_title != blank -%}
                <h3 class="contact-hero__info-title">{{ section.settings.office_title }}</h3>
              {%- endif -%}
              {%- if section.settings.office_address != blank -%}
                <p class="contact-hero__info-text text-block">{{ section.settings.office_address }}</p>
              {%- endif -%}
            </div>
          </div>

          <!-- Email Block -->
          <div class="contact-hero__info-item">
            <div class="contact-hero__icon-circle">
              <svg class="contact-hero__icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 4H4C2.9 4 2.01 4.9 2.01 6L2 18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4ZM20 8L12 13L4 8V6L12 11L20 6V8Z" fill="currentColor"/>
              </svg>
            </div>
            <div class="contact-hero__info-content inline-style">
              {%- if section.settings.email_title != blank -%}
                <strong class="contact-hero__info-inline-label">{{ section.settings.email_title }}</strong>
              {%- endif -%}
              <div class="contact-hero__info-inline-value">
                {{ section.settings.email_values }}
              </div>
            </div>
          </div>

          <!-- Phone Block -->
          <div class="contact-hero__info-item">
            <div class="contact-hero__icon-circle">
              <svg class="contact-hero__icon-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.62 10.79C8.06 13.62 10.38 15.94 13.21 17.38L15.41 15.18C15.69 14.9 16.08 14.82 16.43 14.93C17.55 15.3 18.75 15.5 20 15.5C20.55 15.5 21 16.5V20C21 20.55 20.55 21 20 21C10.61 21 3 13.39 3 4C3 3.45 3.45 3 4 3H7.5C8.05 3 8.5 3.45 8.5 4C8.5 5.25 8.7 6.45 9.07 7.57C9.18 7.92 9.1 8.31 8.82 8.59L6.62 10.79Z" fill="currentColor"/>
              </svg>
            </div>
            <div class="contact-hero__info-content inline-style">
              {%- if section.settings.phone_title != blank -%}
                <strong class="contact-hero__info-inline-label">{{ section.settings.phone_title }}</strong>
              {%- endif -%}
              <div class="contact-hero__info-inline-value">
                {{ section.settings.phone_values }}
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Mobile-only Graphic Image Stack (Hidden on Desktop, 2nd in mobile stack - full width) -->
      {%- if section.settings.custom_curve_image != blank -%}
        <div class="contact-hero__mobile-image-wrap contact-hero__animate-fade delay-2">
          <img src="{{ section.settings.custom_curve_image | image_url: width: 1200 }}" alt="Right4Paws Contact" class="contact-hero__mobile-image" loading="lazy">
        </div>
      {%- endif -%}

      <!-- Form Column (Right on Desktop, Bottom on Mobile - 3rd in mobile stack - full width flush) -->
      <div class="contact-hero__form-col contact-hero__animate-fade delay-3">
        <div class="contact-hero__card">
          {%- if section.settings.card_title != blank -%}
            <h2 class="contact-hero__card-title">{{ section.settings.card_title }}</h2>
          {%- endif -%}

          {%- assign form_id = 'ContactForm-' | append: section.id -%}
          {%- form 'contact', id: form_id, class: 'contact-hero__form' -%}
            
            {%- if form.posted_successfully? -%}
              <div class="contact-hero__success-alert" tabindex="-1" autofocus>
                <svg viewBox="0 0 24 24" class="alert-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="currentColor"/>
                </svg>
                <p class="alert-message">{{ 'templates.contact.form.post_success' | t | default: 'Thank you! Your message has been sent successfully.' }}</p>
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="contact-hero__error-alert" tabindex="-1" autofocus>
                <svg viewBox="0 0 24 24" class="alert-icon" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="currentColor"/>
                </svg>
                <div class="alert-message">
                  {{ form.errors | default_errors }}
                </div>
              </div>
            {%- endif -%}

            <div class="contact-hero__field">
              <input
                type="text"
                id="{{ form_id }}-name"
                name="contact[name]"
                class="contact-hero__input"
                placeholder="Name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                autocomplete="name"
              >
            </div>

            <div class="contact-hero__field">
              <input
                type="email"
                id="{{ form_id }}-email"
                name="contact[email]"
                class="contact-hero__input"
                placeholder="Email"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                required
                aria-required="true"
              >
            </div>

            <div class="contact-hero__field">
              <input
                type="tel"
                id="{{ form_id }}-phone"
                name="contact[phone]"
                class="contact-hero__input"
                placeholder="Phone"
                value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                autocomplete="tel"
                pattern="[0-9\- \+\(\)]*"
              >
            </div>

            <div class="contact-hero__field">
              <textarea
                id="{{ form_id }}-message"
                name="contact[body]"
                rows="6"
                class="contact-hero__input contact-hero__textarea"
                placeholder="Message"
                required
                aria-required="true"
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>

            <button type="submit" class="contact-hero__submit-btn">
              SUBMIT
            </button>

          {%- endform -%}
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* --- Structural Layout Baseline --- */
  .contact-hero-section {
    width: 100%;
    position: relative;
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .contact-hero__container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    z-index: 2;
  }

  .contact-hero__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 40px 130px;
    align-items: start; /* Align to the top to prevent background overlap */
    padding:150px 0 0 0;
  }

  /* --- Left Column Info Boxes --- */
  .contact-hero__info-col {
    width: 100%;
    padding-top: 40px; /* Breathing space at the top of the grid to sit cleanly below the header */
  }

  .contact-hero__info-list {
    display: flex;
    flex-direction: column;
    gap: 22px; /* Compact spacing */
  }

  .contact-hero__info-item {
    display: flex;
    align-items: flex-start; /* Aligns icons neatly to the top line of text */
    gap: 16px;
    color: var(--text-color);
  }

  .contact-hero__icon-circle {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border-radius: 50%;
    background-color: var(--accent-color);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-hero__icon-svg {
    width: 16px;
    height: 16px;
  }

  .contact-hero__info-content {
    font-family: 'Outfit', sans-serif;
    text-align: left;
  }

  .contact-hero__info-content.inline-style {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px;
    line-height: 1.4;
  }

  .contact-hero__info-title {
    margin: 0 0 4px 0;
    font-size: 15px; /* Clean, smaller headers */
    font-weight: 700;
    line-height: 1.25;
    color: var(--text-color);
  }

  .contact-hero__info-text {
    margin: 0;
    font-size: 13px; /* Compact, readable text */
    line-height: 1.45;
    font-weight: 400;
    opacity: 0.95;
  }

  .contact-hero__info-text.text-block {
    max-width: 420px;
  }

  .contact-hero__info-inline-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-color);
  }

  .contact-hero__info-inline-value {
    font-size: 13px;
    color: var(--text-color);
  }

  .contact-hero__info-inline-value p {
    margin: 0;
    display: inline;
  }

  .contact-hero__info-inline-value a {
    color: var(--text-color);
    text-decoration: none;
    font-weight: 700;
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .contact-hero__info-inline-value a:hover {
    color: var(--accent-color);
    border-bottom-color: var(--accent-color);
  }

  /* --- Mobile Image Stack (Hidden on desktop) --- */
  .contact-hero__mobile-image-wrap {
    display: none;
  }

  /* --- Right Column Form Card --- */
  .contact-hero__form-col {
    width: 100%;
  }

  .contact-hero__card {
    background-color: var(--card-bg);
    color: var(--card-text);
    border-radius: 40px;
    padding: 40px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.04);
    box-sizing: border-box;
    margin:-100px 0 300px 0;
  }

  .contact-hero__card-title {
    margin: 0 0 32px 0;
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--card-text);
  }

  .contact-hero__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .contact-hero__field {
    width: 100%;
  }

  .contact-hero__input {
    width: 100%;
    box-sizing: border-box;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    color: var(--card-text);
    background-color: var(--input-bg);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--input-border);
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    height:40px;
  }

  .contact-hero__input::placeholder {
    color: rgba(0, 0, 0, 0.35);
    opacity: 1;
  }

  .contact-hero__input:focus {
    border-color: #000000;
    box-shadow: 0 0 0 1px #000000;
  }

  .contact-hero__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-hero__submit-btn {
    align-self: flex-start;
    margin-top: 10px;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background-color: var(--button-bg);
    color: var(--button-text);
    border: none;
    border-radius: 50px;
    padding: 18px 48px;
    cursor: pointer;
    transition: background-color 0.25s ease, transform 0.20s ease;
  }

  .contact-hero__submit-btn:hover {
    background-color: #222222;
    transform: translateY(-2px);
  }

  .contact-hero__submit-btn:active {
    transform: translateY(0);
  }

  /* --- Alerts Structural Styling --- */
  .contact-hero__success-alert,
  .contact-hero__error-alert {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 12px;
    margin-bottom: 16px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    line-height: 1.4;
  }

  .contact-hero__success-alert {
    background-color: #e6f9ed;
    color: #1e7e34;
    border: 1px solid #c3e6cb;
  }

  .contact-hero__error-alert {
    background-color: #fdf2f2;
    color: #c53030;
    border: 1px solid #f8b4b4;
  }

  .alert-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .alert-message {
    margin: 0;
  }

  .alert-message ul {
    margin: 0;
    padding-left: 20px;
  }

  /* --- Elements Fade-in Animations --- */
  .contact-hero__animate-fade {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .contact-hero-section.is-revealed .contact-hero__animate-fade {
    opacity: 1;
    transform: translateY(0);
    padding:150px 20px;
  }

  /* Delay alignments for Text (1st), Image (2nd), and Form (3rd) */
  .delay-1 { transition-delay: 0.15s; }
  .delay-2 { transition-delay: 0.3s; }
  .delay-3 { transition-delay: 0.45s; }

  /* --- Responsive Breakpoints (Mobile Engine) --- */
  @media screen and (max-width: 989px) {
    .contact-hero__container {
      padding: 0;
    }

    .contact-hero__grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0; /* Override desktop padding: 150px 0 0 0 */
    }

    .contact-hero-section.is-revealed .contact-hero__animate-fade {
      padding: 0 !important; /* Override desktop padding: 150px 20px */
    }

    /* 1. Details column sits at top with inset padding */
    .contact-hero__info-col {
      order: 1;
      width: 100%;
      padding-top: 0;
      padding-left: 24px;
      padding-right: 24px;
      margin-bottom: 32px;
      box-sizing: border-box;
    }

    /* 2. Mobile Image stacks in the middle (full bleed, zoomed in on girl & dog) */
    .contact-hero__mobile-image-wrap {
      display: block;
      width: 100%;
      height: 95vw; /* Perfectly matches mobile aspect ratio */
      order: 2;
      margin: 0;
      overflow: hidden;
    }

    .contact-hero__mobile-image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover; /* Zooms/crops to fill the portrait area */
      object-position: center bottom; /* Aligns bottom containing the bowl */
    }

    /* 3. Form column stacks at the bottom (flush to screen edges) */
    .contact-hero__form-col {
      order: 3;
      width: 100%;
      margin: 0;
    }

    .contact-hero__card {
      padding: 40px 24px 60px 24px;
      margin: 0 !important; /* Override desktop margin: -100px 0 300px 0 */
      border-radius: 40px 40px 0 0; /* Match desktop corner curves consistently */
      box-shadow: none; /* Shadow removed since it spans full bleed */
      width: 100%;
      box-sizing: border-box;
    }

    .contact-hero__card-title {
      font-size: 28px;
      margin-bottom: 24px;
    }

    .contact-hero__info-list {
      gap: 24px;
    }

    .contact-hero__info-item {
      gap: 16px;
    }

    .contact-hero__icon-circle {
      width: 40px;
      height: 40px;
    }

    .contact-hero__icon-svg {
      width: 18px;
      height: 18px;
    }

    .contact-hero__info-title {
      font-size: 16px;
    }

    .contact-hero__info-text {
      font-size: 14px;
    }

    .contact-hero__info-inline-label {
      font-size: 15px;
    }

    .contact-hero__info-inline-value {
      font-size: 14px;
    }

    .contact-hero__submit-btn {
      width: 100%;
      align-self: stretch;
      text-align: center;
      padding: 16px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const contactSection = document.querySelector('#shopify-section-{{ section.id }} .contact-hero-section');
    if (!contactSection) return;

    const contactSectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          contactSectionObserver.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      threshold: 0.08
    });

    contactSectionObserver.observe(contactSection);
  });
</script>

{% schema %}
{
