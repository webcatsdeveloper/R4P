{% comment %}
  Community Banner Section - Exact Figma Recreation
{% endcomment %}

{%- style -%}
  .community-banner-{{ section.id }} {
    padding: 120px 0 80px 0;
    overflow: hidden; 
    font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .community-container {
    max-width: 1380px;
    width: 90%; /* FIX: Ensures section is constrained to 90% width on widescreen, matching Figma layout bounds */
    margin: 0 auto;
    padding: 0;
    position: relative;
  }

  .community-box {
    background-color: #7670B3;
    border-radius: 60px;
    height: 472px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end; /* Keeps content box right-aligned structurally */
    padding-right: 90px;
    overflow: visible; /* FIX: Allows the absolute image wrapper to pop out of the top/bottom boundaries exactly like Figma */
  }

  /* Decorative Curve */
  .community-curvy-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transform: scale(1.1);
    transition: opacity 1.2s ease, transform 1.2s ease;
  }

  .community-curvy-line img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
  }

  /* Person Image */
  .community-person-wrap {
    position: absolute;
    bottom: 0;
    left: 60px; /* FIX: Adjust left spacing to match layout composition precisely */
    width: 630px;
    height: 580px; /* FIX: Proportional height balancing to maintain image bounds */
    z-index: 10;
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 1s ease, transform 1s ease;
  }

  .community-person-img {
    width: auto;
    height: 100%;
    object-fit: contain;
    display: block;
    object-position: bottom left;
  }

  /* Content */
  .community-content {
    position: relative;
    z-index: 20;
    max-width: 540px;
    text-align: left; /* FIX: Changed from right to left to layout beautifully against the curve graphic */
    font-family: 'Degular Demo', sans-serif !important;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 1s ease, transform 1s ease;
  }

  .community-heading {
    font-size: 56px; /* Optimized scale for desktop containment */
    line-height: 1.1;
    font-weight: 700;
    color: #fff;
    margin: 0 0 20px 0;
    letter-spacing: 0;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .community-heading span {
    color: #FECC66;
    display: block;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .community-subtext {
    font-size: 20px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 32px 0; /* FIX: Reset auto margins that pushed placement alignment off */
    max-width: 440px;
    font-weight: 400;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .community-btn {
    display: inline-block;
    background-color: #000;
    color: #fff;
    padding: 18px 44px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.3s ease, background-color 0.3s ease;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .community-btn:hover {
    transform: scale(1.04);
  }

  /* ACTIVE ANIMATION */
  .community-banner-{{ section.id }}.animate .community-curvy-line {
    opacity: 1;
    transform: scale(1);
  }

  .community-banner-{{ section.id }}.animate .community-person-wrap {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.1s;
  }

  .community-banner-{{ section.id }}.animate .community-content {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
  }

  @media (max-width: 1200px) {
    .community-box {
      padding-right: 40px;
    }
    .community-person-wrap {
      width: 480px;
      left: 20px;
    }
    .community-heading {
      font-size: 44px;
    }
  }

  @media (max-width: 1024px) {
    .community-banner-{{ section.id }} {
      padding: 60px 0 !important;
      overflow: visible !important; 
    }

    .community-container {
      width: calc(100% - 48px) !important;
      max-width: 100% !important;
      margin: 0 24px !important;
      border-radius: 40px !important;
      overflow: hidden !important;
    }

    .community-box {
      width: 100% !important;
      height: auto !important;
      min-height: 680px !important;
      border-radius: 40px !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-start !important;
      padding: 48px 24px 380px !important; /* Created room below for mobile overlap layout */
      text-align: center !important;
      box-sizing: border-box !important;
    }

    .community-person-wrap {
      position: absolute !important;
      bottom: 0 !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      width: 100% !important;
      max-width: 340px !important;
      height: 360px !important;
      z-index: 10 !important;
      opacity: 1 !important;
    }

    .community-person-img {
      width: 100% !important;
      height: 100% !important;
      object-fit: contain !important;
      object-position: bottom center !important;
    }

    .community-banner-{{ section.id }}.animate .community-person-wrap {
      transform: translateX(-50%) !important;
    }

    .community-content {
      text-align: center !important;
      max-width: 100% !important;
      margin: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .community-heading {
      font-size: 34px !important;
      line-height: 1.2 !important;
      margin-bottom: 16px !important;
    }

    .community-subtext {
      font-size: 15px !important;
      margin: 12px auto 24px !important;
      text-align: center !important;
    }
  }
{%- endstyle -%}

<section class="community-banner-{{ section.id }}">
  <div class="community-container">
    <div class="community-box">
      
      <div class="community-curvy-line">
        {% if section.settings.curve_image != blank %}
          <img
            src="{{ section.settings.curve_image | img_url: 'master' }}"
            alt="Background Curve"
          >
        {% else %}
          <svg width="100%" height="100%" viewBox="0 0 1000 500" preserveAspectRatio="none">
            <path
              d="M-100 400 Q 100 50, 400 350 T 900 100"
              stroke="#F8B426"
              stroke-width="12"
              stroke-linecap="round"
              fill="none"
              opacity="0.4"
            />
          </svg>
        {% endif %}
      </div>

      <div class="community-person-wrap">
        {% if section.settings.person_image != blank %}
          <img
            class="community-person-img"
            src="{{ section.settings.person_image | img_url: '1000x' }}"
            alt="Pet Parent"
          >
        {% else %}
          <img
            class="community-person-img"
            src="https://ais-dev-us76jjassfjamgylbqzewq-898880156449.asia-southeast1.run.app/person-placeholder.png"
            alt="Pet Parent"
          >
        {% endif %}
      </div>

      <div class="community-content">
        <h2 class="community-heading">
          {{ section.settings.heading | replace: 'do things right.', '<span>do things right.</span>' }}
        </h2>

        <p class="community-subtext">
          {{ section.settings.subtext }}
        </p>

        <a href="{{ section.settings.btn_link }}" class="community-btn">
          {{ section.settings.btn_label }}
        </a>
      </div>

    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const section = document.querySelector(".community-banner-{{ section.id }}");
  if (!section) return;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          section.classList.add("animate");
        }
      });
    },
    { threshold: 0.15 }
  );
  observer.observe(section);
});
</script>

{% schema %}
{
  "name": "Community Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person + Pet Image"
    },
    {
      "type": "image_picker",
      "id": "curve_image",
      "label": "Background Curve Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For pet parents who want to do things right."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be a part of a space where pet parents come together to learn, share, and care better."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "JOIN OUR COMMUNITY"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Community Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}