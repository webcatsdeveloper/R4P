{% comment %}
  Community Banner Section - Exact Figma Recreation
{% endcomment %}

{%- style -%}
  .community-banner-{{ section.id }} {
    padding: 100px 0 60px 0;
    overflow: visible;
    font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .community-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .community-box {
    background-color: #7670B3;
    border-radius: 60px;
    height: 472px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 90px;
    overflow: hidden;
  }

  /* Decorative Curve */
  .community-curvy-line {
    position: absolute;
    top: 0;
    left: 0 !important;
    width: 100% !important;
    height: 100%;
    pointer-events: none;
    z-index: 1;

    opacity: 0;
    transform: scale(1.1);
    transition:
      opacity 1.2s ease,
      transform 1.2s ease;
  }

  .community-curvy-line img {
    width: 60%;
    height: 100%;
    object-position: left;
  }

  /* Person Image */
  .community-person-wrap {
    position: absolute;
    bottom: 0;
    left: 150px;
    width: 630px;
    height: 786px;
    z-index: 10;

    opacity: 0;
    transform: translateX(-120px);
    transition:
      opacity 1s ease,
      transform 1s ease;
  }

  .community-person-img {
    width: 80%;
    height: 100%;
    object-fit: contain;
    display: block;
    object-position: bottom;
  }

  /* Content */
  .community-content {
    position: relative;
    z-index: 20;
    max-width: 592px;
    text-align: right;
    font-family:'Degular Demo'!important;

    opacity: 0;
    transform: translateX(120px);
    transition:
      opacity 1s ease,
      transform 1s ease;
  }

  .community-heading {
    font-size: 64px;
    line-height: 59px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 24px 0;
    letter-spacing: 0;
    font-family:'Degular Demo'!important;
  }

  .community-heading span {
    color: #FECC66;
    display: block;
    font-family:'Degular Demo'!important;
  }

  .community-subtext {
    font-size: 23px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    margin: 30px 0 45px auto;
    max-width: 440px;
    font-weight: 400;
    font-family:'Degular Demo'!important;
  }

  .community-btn {
    display: inline-block;
    background-color: #000;
    color: #fff;
    padding: 20px 48px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      opacity 1s ease;
    font-family:'Degular Demo'!important;
  }

  .community-btn:hover {
    transform: scale(1.04);
  }

  /* ACTIVE ANIMATION */
  .community-banner-{{ section.id }}.animate .community-curvy-line {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.1s;
  }

  .community-banner-{{ section.id }}.animate .community-person-wrap {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
  }

  .community-banner-{{ section.id }}.animate .community-content {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.4s;
  }

  @media (max-width: 1440px) {
    .community-box {
      padding-right: 60px;
    }

    .community-person-wrap {
      width: 500px;
      left: 40px;
    }
  }

  @media (max-width: 1024px) {
    .community-banner-{{ section.id }} {
      padding: 180px 0 60px;
    }

    .community-box {
      height: auto;
      flex-direction: column;
      padding: 300px 40px 60px;
      text-align: center;
      justify-content: center;
    }

    .community-person-wrap {
      width: 400px;
      height: auto;
      left: 50%;
      transform: translateX(-50%);
      bottom: auto;
      top: -150px;
    }

    .community-banner-{{ section.id }}.animate .community-person-wrap {
      transform: translateX(-50%);
    }

    .community-content {
      text-align: center;
      max-width: 100%;
    }

    .community-heading {
      font-size: 42px;
      line-height: 1.1;
    }

    .community-subtext {
      margin-inline: auto;
    }
  }

  @media (max-width: 480px) {
    .community-person-wrap {
      width: 100%;
      top: -120px;
    }

    .community-heading {
      font-size: 32px;
    }
  }
{%- endstyle -%}

<section class="community-banner-{{ section.id }}">
  <div class="community-container">

    <div class="community-person-wrap">
      {% if section.settings.person_image != blank %}
        <img
          class="community-person-img"
          src="{{ section.settings.person_image | img_url: '1000x' }}"
          alt="Pet Parent"
        >
      {% else %}
        <img
          class="community-person-img"
          src="https://ais-dev-us76jjassfjamgylbqzewq-898880156449.asia-southeast1.run.app/person-placeholder.png"
          alt="Pet Parent"
        >
      {% endif %}
    </div>

    <div class="community-box">

      <!-- Curve -->
      <div class="community-curvy-line">
        {% if section.settings.curve_image != blank %}
          <img
            src="{{ section.settings.curve_image | img_url: 'master' }}"
            alt="Background Curve"
          >
        {% else %}
          <svg width="100%" height="100%" viewBox="0 0 1000 500" preserveAspectRatio="none">
            <path
              d="M-100 400 Q 100 50, 400 350 T 900 100"
              stroke="#F8B426"
              stroke-width="12"
              fill="none"
              opacity="0.4"
            />
          </svg>
        {% endif %}
      </div>

      <!-- Content -->
      <div class="community-content">
        <h2 class="community-heading">
          {{ section.settings.heading | replace: 'do things right.', '<span>do things right.</span>' }}
        </h2>

        <p class="community-subtext">
          {{ section.settings.subtext }}
        </p>

        <a href="{{ section.settings.btn_link }}" class="community-btn">
          {{ section.settings.btn_label }}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const section = document.querySelector(".community-banner-{{ section.id }}");

  if (!section) return;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          section.classList.add("animate");
        }
      });
    },
    {
      threshold: 0.25,
    }
  );

  observer.observe(section);
});
</script>

{% schema %}
{
  "name": "Community Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person + Pet Image"
    },
    {
      "type": "image_picker",
      "id": "curve_image",
      "label": "Background Curve Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "For pet parents who want to do things right."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be a part of a space where pet parents come together to learn, share, and care better."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "JOIN OUR COMMUNITY"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Community Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}