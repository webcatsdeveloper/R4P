{% comment %}
  Pet Brand Hero Section - Updated Button
{% endcomment %}

{% style %}

.pet-hero-{{ section.id }} {
  position: relative;
  width: 100%;
  background: #ffffff;
  overflow: hidden;
  margin: 0 auto;
  padding-left: 50px;
  padding-right: 50px;
}

/* MAIN WRAPPER */
.pet-hero-wrapper {
  width: 100%;
  max-width: 1400px !important;
  margin: 0 auto;
  padding: 0px 180px 130px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 60px;
  position: relative;
  z-index: 3;
  box-sizing: border-box;
}

/* ========================= */
/* LEFT CONTENT */
/* ========================= */

.pet-hero-content {
  width: 538px;
  min-width: 538px;
  position: relative;
  z-index: 5;
  opacity: 0;
}

/* HEADING */
.pet-hero-heading {
  display: flex;
  flex-direction: column;
  margin: 0;
  font-size: 88px;
  line-height: 0.92;
  font-weight: 700;
  letter-spacing: -4px;
  color: #000;
  font-family: 'Degular Demo', sans-serif !important;
}

.pet-hero-heading span {
  display: block;
}

.pet-hero-heading .accent {
  color: {{ section.settings.accent_color }};
}

/* DESCRIPTION */
.pet-hero-subtext-box {
  width: 483px;
  margin-top: 42px;
}

.pet-hero-description {
  font-size: 22px;
  line-height: 1.55;
  color: #2B2B2B;
  margin: 0 0 24px;
  font-family:'Degular Demo'!important;
}

.pet-hero-bold-text {
  font-size: 22px;
  line-height: 1.25;
  font-weight: 600;
  color: #000;
  margin: 0;
  font-family:'Degular Demo'!important;
}

/* UPDATED BUTTON */
.pet-hero-button {
  min-width: 250px;
  height: 66px;
  border-radius: 999px;

  background: #000;
  color: #fff;

  text-decoration: none;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;

  font-family:'Degular Demo'!important;

  margin-top: 42px;

  transition:
    transform 0.25s ease,
    background 0.25s ease;
}

.pet-hero-button:hover {
  transform: scale(1.04);
  background: {{ section.settings.accent_color }};
}

/* ========================= */
/* RIGHT IMAGE */
/* ========================= */

.pet-hero-image-side {
  width: 708px;
  max-width: 708px;
  height: 668px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: -90px;

  opacity: 0;
}

.pet-main-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  position: relative;
  z-index: 4;
}

/* HEART */
.pet-heart-doodle {
  position: absolute;
  top: 120px;
  left: 140px;
  width: 120px;
  z-index: 6;

  opacity: 0;
}

/* ========================= */
/* BACKGROUND WAVE */
/* ========================= */

.pet-hero-wave-asset {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 100vw;
  height: auto;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
  display: block;

  opacity: 0;
}

.pet-hero-wave-asset img {
  width: 100%;
  height: auto;
  object-fit: cover;
  display: block;
}

/* ========================= */
/* LEFT CURVE */
/* ========================= */

.pet-left-curve {
  position: absolute;
  left: -180px;
  bottom: 0;
  width: 520px;
  z-index: 1;
  pointer-events: none;

  opacity: 0;
}

.pet-left-curve img {
  width: 100%;
  display: block;
}

/* ========================= */
/* SCROLL ACTIVE ANIMATIONS */
/* ========================= */

.pet-hero-animate .pet-hero-content {
  animation: fadeUp 1s ease forwards;
}

.pet-hero-animate .pet-hero-image-side {
  animation: rightSlideIn 1.2s cubic-bezier(.22,.61,.36,1) forwards;
}

.pet-hero-animate .pet-left-curve {
  animation: leftSlideIn 1.2s cubic-bezier(.22,.61,.36,1) forwards;
}

.pet-hero-animate .pet-heart-doodle {
  animation: fadeUp 1s ease forwards;
  animation-delay: .4s;
}

.pet-hero-animate .pet-hero-wave-asset {
  animation: waveFadeIn 1.5s ease forwards;
}

/* ========================= */
/* ANIMATIONS */
/* ========================= */

@keyframes leftSlideIn {
  from {
    transform: translateX(-140px);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes rightSlideIn {
  from {
    transform: translateX(140px);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes fadeUp {
  from {
    transform: translateY(40px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes waveFadeIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(60px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

/* ========================= */
/* LAPTOP */
/* ========================= */

@media screen and (max-width: 1600px) {

  .pet-hero-wrapper {
    padding-left: 100px;
    padding-right: 120px !important;
  }

  .pet-hero-content {
    width: 480px;
    min-width: 480px;
  }

  .pet-hero-heading {
    font-size: 76px;
    max-width: 480px;
  }

  .pet-hero-subtext-box {
    width: 440px;
  }

  .pet-hero-image-side {
    width: 660px;
    min-width: 660px;
    height: 620px;
  }
}

/* ========================= */
/* TABLET */
/* ========================= */

@media screen and (max-width: 1100px) {

  .pet-hero-wrapper {
    flex-direction: column;
    text-align: center;
    padding: 80px 24px 100px;
    gap: 60px;
  }

  .pet-hero-content {
    width: 100%;
    min-width: unset;
  }

  .pet-hero-heading {
    font-size: 62px;
    max-width: 100%;
  }

  .pet-hero-subtext-box {
    width: 100%;
    max-width: 540px;
    margin-inline: auto;
  }

  .pet-hero-image-side {
    width: 100%;
    min-width: unset;
    max-width: 760px;
    height: auto;
    margin-left: 0;
  }

  .pet-main-image {
    height: auto;
  }

  .pet-heart-doodle {
    width: 90px;
    top: 60px;
    left: 80px;
  }
}

/* ========================= */
/* MOBILE */
/* ========================= */

@media screen and (max-width: 768px) {

  .pet-hero-wrapper {
    padding: 70px 20px 90px;
    gap: 40px;
  }

  .pet-hero-heading {
    font-size: 52px;
    line-height: 0.95;
    letter-spacing: -2px;
  }

  .pet-hero-description,
  .pet-hero-bold-text {
    font-size: 18px;
  }

  .pet-hero-button {
    min-width: 220px;
    height: 58px;
    font-size: 15px;
    margin-top: 34px;
  }

  .pet-heart-doodle {
    width: 60px;
    top: 30px;
    left: 30px;
  }

  .pet-left-curve {
    width: 320px;
    left: -120px;
  }
}

{% endstyle %}

<section class="pet-hero-{{ section.id }}">

  {% if section.settings.wave_image != blank %}
    <div class="pet-hero-wave-asset">
      <img src="{{ section.settings.wave_image | img_url: '3000x' }}" alt="background wave">
    </div>
  {% endif %}

  <div class="pet-hero-wrapper">

    <div class="pet-hero-content">

      <h1 class="pet-hero-heading">
        <span>We all</span>
        <span>want to do</span>
        <span class="accent">right by</span>
        <span class="accent">them.</span>
      </h1>

      <div class="pet-hero-subtext-box">
        <p class="pet-hero-description">
          {{ section.settings.subtext }}
        </p>

        <p class="pet-hero-bold-text">
          {{ section.settings.subtext_bold }}
        </p>
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="pet-hero-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>

    <div class="pet-hero-image-side">

      {% if section.settings.heart_image != blank %}
        <img
          src="{{ section.settings.heart_image | img_url: '400x' }}"
          class="pet-heart-doodle"
          alt="heart">
      {% endif %}

      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | img_url: '1800x' }}"
          class="pet-main-image"
          alt="{{ section.settings.heading }}"
          loading="eager">
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}

    </div>

  </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const heroSection = document.querySelector(".pet-hero-{{ section.id }}");

  if (!heroSection) return;

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(entry => {

      if (entry.isIntersecting) {
        heroSection.classList.add("pet-hero-animate");
      }

    });

  }, {
    threshold: 0.25
  });

  observer.observe(heroSection);

});
</script>

{% schema %}
{
  "name": "Pet Brand Hero",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Part 1",
      "default": "We all want to do"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Part 2 (Highlight)",
      "default": "right by them."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Description",
      "default": "But when it comes to food, it's not always clear what \"right\" really means."
    },
    {
      "type": "text",
      "id": "subtext_bold",
      "label": "Bold Line",
      "default": "You bring the love. We bring the science."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "HERE'S OUR STORY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Visual Assets"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image (Pets + Product)"
    },
    {
      "type": "image_picker",
      "id": "heart_image",
      "label": "Heart Doodle Image"
    },
    {
      "type": "image_picker",
      "id": "wave_image",
      "label": "Background Wave Asset"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D12B2B"
    }
  ],
  "presets": [
    {
      "name": "Pet Brand Hero"
    }
  ]
}
{% endschema %}