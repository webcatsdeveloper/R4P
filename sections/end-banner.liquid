{%- style -%}
  .cta-banner-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 130px {{ section.settings.padding_bottom }}px 130px;
    background-color: transparent;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cta-banner-wrapper {
    width: 100%;
    max-width: 1200px;
    background-color: {{ section.settings.bg_color }};
    border-radius: 40px;
    position: relative;
    margin-top: 60px; 
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 380px;
    padding: 40px 60px;
    overflow: visible; 
  }

  .cta-banner-ribbon {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
    border-radius: 40px;
  }

  .cta-banner-ribbon img {
    position: absolute;
    right: -40px;
    top: 55px;
    width: 950px;
    max-width: none;
    height: auto;
    object-fit: contain;
  }

  .cta-content-column {
    width: 50%;
    position: relative;
    z-index: 3;
  }

  .cta-banner-heading {
    color: #ffffff;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 35px 0;
    letter-spacing: -0.02em;
    max-width: 500px;
  }

  .cta-buttons-group {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .cta-pill-button {
    background-color: #000000;
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 50px;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, background-color 0.2s ease;
    display: inline-block;
  }

  .cta-pill-button:hover {
    background-color: #1a1a1a;
    transform: translateY(-2px);
  }

  .cta-image-column {
    width: 55%;
    position: absolute;
    right: 0;
    bottom: 0;
    height: calc(100% + 280px); 
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .cta-image-column img {
    height: 100%;
    width: auto;
    object-fit: contain;
    object-position: bottom right;
  }

  /* Visibility classes for Mobile/Desktop Image Separation */
  .mobile-image-only { display: none !important; }
  .desktop-image-only { display: block; }

  /* ==========================================================================
     MOBILE RESPONSIVE HANDLING
     ========================================================================== */
  @media (max-width: 991px) {
    .cta-banner-section-{{ section.id }} {
      padding: 20px 15px; 
    }

    .cta-banner-wrapper {
      margin-top: 0;
      flex-direction: column;
      padding: 50px 0 0 0; /* Removed side/bottom padding, shifted to content block */
      text-align: center;
      min-height: auto;
      overflow: hidden; 
      border-radius: 36px;
    }

    .cta-content-column {
      width: 100%;
      margin-bottom: 30px; /* Space between buttons and image */
      padding: 0 24px; /* Inner spacing applied here instead of wrapper */
      display: flex;
      flex-direction: column;
      align-items: center;
      z-index: 3;
    }

    .cta-banner-heading {
      font-size: 2.1rem;
      max-width: 100%;
      margin: 0 auto 30px auto;
      line-height: 1.2;
    }

    .cta-buttons-group {
      flex-direction: column;
      width: 100%;
      gap: 12px;
      max-width: 210px;
    }

    .cta-pill-button {
      width: 100%;
      box-sizing: border-box;
      padding: 16px 20px;
      font-size: 0.8rem;
      text-align: center;
    }

    /* Fixed Ribbon Background for Mobile */
    .cta-banner-ribbon img {
      width: 150%;
      top: 15%;
      right: -25%;
      object-fit: contain;
    }

    /* Fixed Gap & Image Layout */
    .cta-image-column {
      position: relative;
      width: 100%;
      height: auto; /* Natural height removes the gap */
      max-width: none;
      right: auto;
      bottom: 0;
      display: block; /* Switch from flex to block */
      line-height: 0; /* Removes phantom bottom margin */
      z-index: 2;
    }

    .cta-image-column img {
      width: 100%;
      height: auto; /* Image dictates container height perfectly */
      object-fit: cover;
      object-position: bottom center;
      display: block;
    }

    /* Toggle visibility for separate images */
    .mobile-image-only { display: block !important; }
    .desktop-image-only { display: none !important; }
  }
{%- endstyle -%}

<div class="cta-banner-section-{{ section.id }}">
  <div class="cta-banner-wrapper">
    
   {% if section.settings.ribbon_image != blank %}
      <div class="cta-banner-ribbon">
        <img
          src="{{ section.settings.ribbon_image | image_url: width: 2000 }}"
          alt="Ribbon"
          loading="lazy"
        >
      </div>
   {% endif %}

    <div class="cta-content-column">
      <h2 class="cta-banner-heading">{{ section.settings.heading }}</h2>
      <div class="cta-buttons-group">
        {% if section.settings.btn1_text != blank %}
          <a href="{{ section.settings.btn1_link }}" class="cta-pill-button">
            {{ section.settings.btn1_text }}
          </a>
        {% endif %}
        {% if section.settings.btn2_text != blank %}
          <a href="{{ section.settings.btn2_link }}" class="cta-pill-button">
            {{ section.settings.btn2_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="cta-image-column">
      {% if section.settings.model_image_mobile != blank %}
        <img src="{{ section.settings.model_image_mobile | image_url: width: 600 }}" class="mobile-image-only" alt="Mobile Banner Image" loading="lazy">
        <img src="{{ section.settings.model_image | image_url: width: 800 }}" class="desktop-image-only" alt="Desktop Banner Image" loading="lazy">
      {% elsif section.settings.model_image != blank %}
        <img src="{{ section.settings.model_image | image_url: width: 800 }}" alt="Banner Image" loading="lazy">
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "CTA Overlap Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Card Color",
      "default": "#7d75b3"
    },
    {
      "type": "color",
      "id": "ribbon_color",
      "label": "Ribbon Vector Line Color",
      "default": "#f4cb55"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Banner Headline Text",
      "default": "So, ready to find what’s right for them?"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text Label",
      "default": "Start With Your Pet"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Web Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text Label",
      "default": "Explore Products"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Web Link"
    },
    {
      "type": "image_picker",
      "id": "model_image",
      "label": "Desktop Character Image"
    },
    {
      "type": "image_picker",
      "id": "model_image_mobile",
      "label": "Mobile Character Image (Optional)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Outer Layout Top Margin Spacer",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Outer Layout Bottom Margin Spacer",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "CTA Overlap Banner"
    }
  ]
}
{% endschema %}