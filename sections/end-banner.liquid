{% comment %}
  Community Banner Section - Image Right, Text & Two Buttons Left
  Ribbon positioned on right side with FULL HEIGHT - no gaps
{% endcomment %}

{%- style -%}
  .community-banner-{{ section.id }} {
    padding: 100px 0 60px 0;
    overflow: visible;
    font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .community-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .community-box {
    background-color: {{ section.settings.bg_color | default: '#7D75B3' }};
    border-radius: 60px;
    height: 472px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-left: 90px;
    overflow: hidden;
  }

  /* Decorative Curve / Ribbon - FULL HEIGHT, no gaps */
  .community-curvy-line {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: auto;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;

    opacity: 0;
    transform: scale(1.05);
    transition:
      opacity 1.2s ease,
      transform 1.2s ease;
  }

  .community-curvy-line img,
  .community-curvy-line svg {
    height: 100%;
    width: auto;
    min-width: 200px;
    max-width: none;
    object-fit: cover;
    object-position: right center;
    display: block;
  }

  /* Person Image - On RIGHT side, overlapping the ribbon */
  .community-person-wrap {
    position: absolute;
    bottom: 0;
    right: 60px;
    width: 500px;
    height: 100%;
    max-height: 472px;
    z-index: 10;

    opacity: 0;
    transform: translateX(120px);
    transition:
      opacity 1s ease,
      transform 1s ease;
  }

  .community-person-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    object-position: bottom;
  }

  /* Content - On LEFT side */
  .community-content {
    position: relative;
    z-index: 20;
    max-width: 520px;
    text-align: left;

    opacity: 0;
    transform: translateX(-120px);
    transition:
      opacity 1s ease,
      transform 1s ease;
  }

  .community-heading {
    font-size: 56px;
    line-height: 1.15;
    font-weight: 700;
    color: #fff;
    margin: 0 0 20px 0;
    letter-spacing: -0.02em;
    font-family:'Degular Demo'!important;
  }

  .community-heading span {
    color: #FECC66;
    display: inline;
    font-family:'Degular Demo'!important;
  }

  .community-subtext {
    font-size: 20px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    margin: 20px 0 40px 0;
    max-width: 460px;
    font-weight: 400;
    font-family:'Degular Demo'!important;
  }

  /* Button Group - Two Buttons */
  .community-buttons-group {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .community-btn {
    display: inline-block;
    background-color: #000;
    color: #fff;
    padding: 16px 40px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition:
      transform 0.3s ease,
      background-color 0.3s ease;
    font-family:'Degular Demo'!important;
  }

  .community-btn:hover {
    transform: scale(1.04);
    background-color: #1a1a1a;
  }

  .community-btn-outline {
    display: inline-block;
    background-color: transparent;
    color: #fff;
    padding: 16px 40px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.03em;
    border: 2px solid #fff;
    transition:
      transform 0.3s ease,
      background-color 0.3s ease,
      color 0.3s ease;
    font-family:'Degular Demo'!important;
  }

  .community-btn-outline:hover {
    transform: scale(1.04);
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* ACTIVE ANIMATION */
  .community-banner-{{ section.id }}.animate .community-curvy-line {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0.1s;
  }

  .community-banner-{{ section.id }}.animate .community-person-wrap {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
  }

  .community-banner-{{ section.id }}.animate .community-content {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.4s;
  }

  /* Tablet Styles */
  @media (max-width: 1280px) {
    .community-person-wrap {
      width: 420px;
      right: 40px;
    }
    
    .community-heading {
      font-size: 48px;
    }
    
    .community-box {
      padding-left: 60px;
    }
  }

  @media (max-width: 1024px) {
    .community-banner-{{ section.id }} {
      padding: 60px 0;
    }

    .community-box {
      height: auto;
      min-height: 550px;
      flex-direction: column;
      padding: 280px 30px 50px 30px;
      text-align: center;
      justify-content: center;
      padding-left: 30px;
      overflow: hidden;
    }

    .community-person-wrap {
      width: 380px;
      height: auto;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      bottom: auto;
      top: -100px;
      max-height: none;
    }

    .community-banner-{{ section.id }}.animate .community-person-wrap {
      transform: translateX(-50%);
    }

    /* Ribbon covers full width & height on mobile */
    .community-curvy-line {
      right: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
    
    .community-curvy-line img,
    .community-curvy-line svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    .community-content {
      text-align: center;
      max-width: 100%;
    }

    .community-heading {
      font-size: 36px;
    }

    .community-subtext {
      margin-left: auto;
      margin-right: auto;
      font-size: 18px;
    }

    .community-buttons-group {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .community-buttons-group {
      flex-direction: column;
      align-items: center;
      gap: 14px;
    }
    
    .community-btn,
    .community-btn-outline {
      width: 100%;
      max-width: 260px;
      text-align: center;
      padding: 14px 24px;
      font-size: 14px;
    }
    
    .community-heading {
      font-size: 32px;
    }
  }

  @media (max-width: 480px) {
    .community-person-wrap {
      width: 90%;
      top: -80px;
    }

    .community-heading {
      font-size: 28px;
    }
    
    .community-subtext {
      font-size: 16px;
    }
    
    .community-box {
      padding: 240px 20px 40px 20px;
    }
  }
{%- endstyle -%}

<section class="community-banner-{{ section.id }}">
  <div class="community-container">

    <div class="community-box">

      <!-- Curve / Ribbon - FULL HEIGHT, no gaps -->
      <div class="community-curvy-line">
        {% if section.settings.curve_image != blank %}
          <img
            src="{{ section.settings.curve_image | img_url: 'master' }}"
            alt="Background Ribbon"
            loading="lazy"
          >
        {% else %}
          <svg width="auto" height="100%" viewBox="0 0 300 500" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path
              d="M250 0 C300 100 200 200 250 300 C300 400 200 450 250 500"
              stroke="#FECC66"
              stroke-width="80"
              stroke-linecap="butt"
              fill="none"
            />
          </svg>
        {% endif %}
      </div>

      <!-- Person Image -->
      <div class="community-person-wrap">
        {% if section.settings.person_image != blank %}
          <img
            class="community-person-img"
            src="{{ section.settings.person_image | img_url: '800x' }}"
            alt="Pet Parent"
            loading="lazy"
          >
        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <!-- Content - Left Side -->
      <div class="community-content">
        <h2 class="community-heading">
          {{ section.settings.heading | replace: 'what’s right for them?', '<span>what’s right for them?</span>' }}
        </h2>

        <p class="community-subtext">
          {{ section.settings.subtext }}
        </p>

        <div class="community-buttons-group">
          {% if section.settings.btn1_label != blank %}
            <a href="{{ section.settings.btn1_link }}" class="community-btn">
              {{ section.settings.btn1_label }}
            </a>
          {% endif %}
          {% if section.settings.btn2_label != blank %}
            <a href="{{ section.settings.btn2_link }}" class="community-btn-outline">
              {{ section.settings.btn2_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const section = document.querySelector(".community-banner-{{ section.id }}");

  if (!section) return;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          section.classList.add("animate");
        }
      });
    },
    {
      threshold: 0.2,
    }
  );

  observer.observe(section);
});
</script>

{% schema %}
{
  "name": "CTA Overlap Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#7D75B3"
    },
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person + Pet Image",
      "info": "Transparent PNG recommended for best overlap effect"
    },
    {
      "type": "image_picker",
      "id": "curve_image",
      "label": "Background Ribbon Image",
      "info": "Will stretch to FULL HEIGHT of purple background - no gaps at top or bottom"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "So, ready to find what's right for them?"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be a part of a space where pet parents come together to learn, share, and care better."
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button 1 Label",
      "default": "JOIN OUR COMMUNITY"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 Label",
      "default": "LEARN MORE"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "CTA Overlap Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}