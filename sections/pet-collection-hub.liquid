{% comment %}
  Pet Collection Hub - Production-Ready Responsive Section
  Matches Desktop layout with a nested subcategory tree sidebar.
{% endcomment %}

{% style %}
  .pet-hub-section {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    padding: 50px 100px;
    max-width: 1400px;
    margin: 0 auto;
    color: #333;
  }

  @media screen and (max-width: 767px) {
    .pet-hub-section {
      padding: 30px 20px;
    }
  }

  /* --- Top Desktop Banner --- */
  .pet-hub-desktop-banner {
    width: 100%;
    display: block;
    overflow: hidden;
    position: relative;
    margin-bottom: 20px;
  }
  .pet-hub-desktop-banner img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- Top Tabs Navigation --- */
  .pet-hub-tabs-wrapper {
    padding: 40px 20px 0 20px;
  }
  .pet-hub-tabs {
    display: flex;
    justify-content: center;
    gap: 70px;
    margin-bottom: 40px;
  }
  .pet-tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-weight: 700;
    font-size: 15px;
    color: #222;
    transition: transform 0.2s ease;
  }
  .pet-tab-item:hover {
    transform: translateY(-2px);
  }
  .pet-tab-image-wrapper {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #d9231d;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }
  .pet-tab-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pet-tab-item.is-active .pet-tab-image-wrapper {
    outline: 3px solid #d9231d;
    outline-offset: 3px;
  }

  /* --- Mobile Filter Bar Selector --- */
  .pet-mobile-filter-bar {
    display: none;
    padding: 15px 20px;
    border-bottom: 1px solid #000;
    margin-bottom: 30px;
    cursor: pointer;
  }
  .pet-mobile-filter-bar span {
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.5px;
  }

  /* --- Main Layout Container Grid --- */
  .pet-hub-container {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
    padding: 0 20px;
  }

  /* --- Tree Sidebar Subcategories Navigation --- */
  .pet-hub-sidebar {
    padding-right: 10px;
  }
  .pet-sidebar-nav {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pet-nav-parent-item {
    margin-bottom: 15px;
  }
  .pet-nav-parent-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 600;
    color: #444;
    padding: 6px 0;
    cursor: pointer;
    user-select: none;
  }
  .pet-nav-parent-header:hover {
    color: #111;
  }
  .pet-icon-arrow {
    width: 12px;
    height: 12px;
    transition: transform 0.2s ease;
    fill: currentColor;
  }
  .pet-nav-parent-item.is-open .pet-icon-arrow {
    transform: rotate(90deg);
  }
  .pet-icon-doc {
    width: 16px;
    height: 16px;
    opacity: 0.7;
    flex-shrink: 0;
  }
  
  /* Child Dropdown lists */
  .pet-nav-child-list {
    list-style: none;
    padding: 4px 0 4px 16px;
    margin: 0;
    display: none;
  }
  .pet-nav-parent-item.is-open .pet-nav-child-list {
    display: block;
  }
  .pet-nav-child-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    margin: 2px 0;
    font-size: 15px;
    font-weight: 500;
    color: #444;
    text-decoration: none;
    border-radius: 20px;
    transition: background 0.2s ease;
  }
  .pet-nav-child-link .link-left-content {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pet-nav-child-link:hover {
    background-color: #f5f5f5;
    color: #111;
  }
  
  /* Active Subcategory Highlight (Matches Image State) */
  .pet-nav-child-link.is-active {
    background-color: #d8eaff; /* Light Blue background block */
    color: #0b57d0; /* Darker Blue text standard layout */
    font-weight: 600;
  }
  .pet-nav-child-link.is-active .pet-icon-doc {
    color: #0b57d0;
    opacity: 1;
  }
  .pet-icon-more {
    display: none;
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  .pet-nav-child-link.is-active .pet-icon-more {
    display: block;
  }

  /* --- Product Grid Styling --- */
  .pet-products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px;
  }

  /* --- Product Card Styling --- */
  .pet-product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .pet-product-image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #a4e4fc;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    margin-bottom: 15px;
    overflow: hidden;
  }
  .pet-product-image-container img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .pet-product-card:hover .pet-product-image-container img {
    transform: scale(1.04);
  }
  .pet-product-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    margin: 5px 0;
    color: #111;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pet-product-price {
    font-size: 18px;
    font-weight: 500;
    color: #444;
    margin-bottom: 12px;
  }
  .pet-product-btn {
    background-color: #d9231d;
    color: #fff;
    border: none;
    border-radius: 20px;
    padding: 8px 24px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  /* Utilities */
  .hidden { display: none !important; }
  .no-products-msg {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px;
    font-size: 18px;
    color: #777;
  }

  @media (max-width: 768px) {
    .pet-hub-tabs { gap: 20px; margin-bottom: 25px; }
    .pet-tab-image-wrapper { width: 65px; height: 65px; }
    .pet-tab-item span { font-size: 12px; }
    .pet-mobile-filter-bar { display: block; }
    .pet-hub-container { grid-template-columns: 1fr; padding: 0 15px; }
    .pet-hub-sidebar {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: #fff; z-index: 9999; padding: 30px 20px; overflow-y: auto;
    }
    .pet-hub-sidebar.is-open { display: block; }
    .pet-sidebar-close-btn {
      display: block !important; background: #000; color: #fff; border: none;
      padding: 10px; width: 100%; font-weight: 700; margin-bottom: 20px; border-radius: 4px;
    }
    .pet-products-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
  }
{% endstyle %}

<section class="pet-hub-section" id="PetHub-{{ section.id }}">
  
  <div class="pet-hub-tabs-wrapper">
    <div class="pet-hub-tabs">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_tab' -%}
          {%- assign collection_handle = block.settings.collection -%}
          {%- assign current_collection = collections[collection_handle] -%}
          
          <button class="pet-tab-item {% if forloop.first %}is-active{% endif %}" data-target-collection="{{ collection_handle | default: 'all-products' }}" {{ block.shopify_attributes }}>
            <div class="pet-tab-image-wrapper">
              {%- if block.settings.tab_image != blank -%}
                <img src="{{ block.settings.tab_image | image_url: width: 160 }}" alt="{{ block.settings.tab_title | escape }}" loading="lazy">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            <span>{{ block.settings.tab_title | default: current_collection.title }}</span>
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="pet-mobile-filter-bar" onclick="toggleMobileSidebar(true)">
    <span>Categories & Filters <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg></span>
  </div>

  <div class="pet-hub-container">
    
    <aside class="pet-hub-sidebar" id="PetHubSidebar">
      <button class="pet-sidebar-close-btn" type="button" style="display:none;" onclick="toggleMobileSidebar(false)">✕ Close Categories</button>
      
      <ul class="pet-sidebar-nav">
        {%- assign sidebar_menu = section.settings.sidebar_linklist -%}
        {%- if sidebar_menu != blank and linklists[sidebar_menu].links.size > 0 -%}
          {%- for link in linklists[sidebar_menu].links -%}
            
            <li class="pet-nav-parent-item {% if forloop.first or link.child_active %}is-open{% endif %}">
              <div class="pet-nav-parent-header" onclick="this.parentElement.classList.toggle('is-open')">
                <svg class="pet-icon-arrow" viewBox="0 0 24 24"><path d="M8.59,16.59L13.17,12L8.59,7.41L10,6l6,6l-6,6L8.59,16.59z"/></svg>
                <svg class="pet-icon-doc" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <span>{{ link.title }}</span>
              </div>

              {%- if link.links.size > 0 -%}
                <ul class="pet-nav-child-list">
                  {%- for child_link in link.links -%}
                    {%- assign is_active_sub = false -%}
                    {%- if child_link.active or window.location.href contains child_link.url -%}
                      {%- assign is_active_sub = true -%}-
                    {%- endif -%}
                    <li>
                      <a href="{{ child_link.url }}" class="pet-nav-child-link {% if forloop.first and forloop.parentloop.first %}is-active{% endif %}" data-collection-url="{{ child_link.url }}">
                        <div class="link-left-content">
                          <svg class="pet-icon-doc" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                          <span>{{ child_link.title }}</span>
                        </div>
                        <svg class="pet-icon-more" viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>

          {%- endfor -%}
        {%- else -%}
          <p style="font-size:13px; color:#999; padding-left:10px;">Assign a Navigation Menu under theme customize settings.</p>
        {%- endif -%}
      </ul>
    </aside>

    <div class="pet-products-grid" id="PetProductGrid">
      {%- assign collections_to_render = "" -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_tab' and block.settings.collection != blank -%}
          {%- assign collections_to_render = collections_to_render | append: block.settings.collection | append: "," -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign collection_array = collections_to_render | split: "," -%}

      {%- for collection_handle in collection_array -%}
        {%- assign selected_collection = collections[collection_handle] -%}
        {%- for product in selected_collection.products limit: 40 -%}
          
          <div class="pet-product-card mix-target-item" data-collections='["{{ collection_handle }}"]'>
            <a href="{{ product.url }}" class="pet-product-image-container">
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
            </a>
            <h4 class="pet-product-title">{{ product.title }}</h4>
            <div class="pet-product-price">{{ product.price | money }}</div>
            <a href="{{ product.url }}" class="pet-product-btn">Shop Now</a>
          </div>

        {%- endfor -%}
      {%- endfor -%}
      
      <div class="no-products-msg hidden" id="PetNoProducts">No products found matching those choices.</div>
    </div>

  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Subcategory selection highlights logic
    const subLinks = document.querySelectorAll('.pet-nav-child-link');
    subLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Remove active state color from others
        subLinks.forEach(item => item.classList.remove('is-active'));
        this.classList.add('is-active');
      });
    });

    // Top Tabs selection logic 
    const tabs = document.querySelectorAll('#PetHub-{{ section.id }} .pet-tab-item');
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        tabs.forEach(t => t.classList.remove('is-active'));
        this.classList.add('is-active');
        filterProductsByTab();
      });
    });

    filterProductsByTab();
  });

  function toggleMobileSidebar(open) {
    const sidebar = document.getElementById('PetHubSidebar');
    if(sidebar) {
      if(open) sidebar.classList.add('is-open');
      else sidebar.classList.remove('is-open');
    }
  }

  function filterProductsByTab() {
    const activeTab = document.querySelector('#PetHub-{{ section.id }} .pet-tab-item.is-active');
    const activeCollection = activeTab ? activeTab.getAttribute('data-target-collection') : 'all-products';
    const products = document.querySelectorAll('#PetHub-{{ section.id }} .mix-target-item');
    let visibleCount = 0;

    products.forEach(product => {
      const pCollections = JSON.parse(product.getAttribute('data-collections') || '[]');
      if (activeCollection === 'all-products' || pCollections.includes(activeCollection)) {
        product.classList.remove('hidden');
        visibleCount++;
      } else {
        product.classList.add('hidden');
      }
    });

    const emptyMsg = document.getElementById('PetNoProducts');
    if (visibleCount === 0) emptyMsg.classList.remove('hidden');
    else emptyMsg.classList.add('hidden');
  }
</script>

{% schema %}
{
  "name": "Pet Collection Hub",
  "settings": [
    {
      "type": "link_list",
      "id": "sidebar_linklist",
      "label": "Sidebar Nested Category Menu",
      "info": "Select a multi-level navigation menu created in Online Store > Navigation that matches your Category > Subcategory structure."
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title"
        },
        {
          "type": "image_picker",
          "id": "tab_image",
          "label": "Tab Vector Circle Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Target Collection Data"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pet Collection Hub",
      "blocks": [
        { "type": "collection_tab", "settings": { "tab_title": "All" } },
        { "type": "collection_tab", "settings": { "tab_title": "Dogs" } },
        { "type": "collection_tab", "settings": { "tab_title": "Cats" } }
      ]
    }
  ]
}
{% endschema %}