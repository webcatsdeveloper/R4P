{%- style -%}
  .pet-benefits-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  /* Section Title styling */
  .pet-benefits-title-wrap {
    text-align: center;
    margin-bottom: 50px;
    padding: 0 20px;
  }

  .pet-benefits-main-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #000000;
    margin: 0 0 40px 0;
    letter-spacing: -0.02em;
  }

  /* Inline Icons Grid row matching your mockup exactly */
  .pet-benefits-icons-badge-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    max-width: 900px;
    margin: 0 auto;
    gap: 20px;
  }

  .pet-benefits-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .pet-benefits-icon-circle {
    width: 48px;
    height: 48px;
    background-color: {{ section.settings.icon_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .pet-benefits-icon-item:hover .pet-benefits-icon-circle {
    transform: scale(1.15) rotate(5deg);
  }

  .pet-benefits-icon-circle img {
    width: 35px;
    height: 35px;
    object-fit: contain;
  }

  .pet-benefits-icon-circle svg {
    width: 22px;
    height: 22px;
    color: #ffffff;
    fill: currentColor;
  }

  .pet-benefits-icon-label {
    font-size: 0.85rem;
    line-height: 1.3;
    font-weight: 500;
    color: #333333;
    max-width: 160px;
  }

  /* Slider Canvas Container - Matches layout container perfectly */
  .pet-benefits-slider-canvas {
    position: relative;
    width: 100%;
    margin-top: 60px;
    padding: 30px 0;
  }

  /* The Connecting Purple Wave Line Layer */
  .pet-benefits-wave-background {
    position: absolute;
    top: 55%;
    left: 0;
    width: 100%;
    height: 180px;
    transform: translateY(-50%);
    z-index: 1;
    pointer-events: none;
  }

  .pet-benefits-wave-background svg path {
    stroke: {{ section.settings.wave_color }};
    stroke-width: 6;
    stroke-linecap: round;
    fill: none;
  }

  /* Swiper Carousel Alignment Overrides */
  .pet-benefits-swiper {
    width: 100%;
    padding: 20px 0 40px 0 !important;
    overflow: visible !important;
    z-index: 2;
  }

  /* Linear seamless scrolling transition override */
  .pet-benefits-swiper .swiper-wrapper {
    transition-timing-function: linear !important;
  }

  .pet-benefits-card-slide {
    width: 440px; /* Exact proportional width */
    height: 300px;
    background-color: {{ section.settings.card_bg_color }};
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    border: 1px solid rgba(0, 0, 0, 0.03);
  }

  .pet-benefits-card-slide:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .pet-benefits-card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .pet-benefits-card-image img,
  .pet-benefits-card-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pet-benefits-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    z-index: 2;
  }

  .pet-benefits-card-text {
    position: relative;
    z-index: 3;
    padding: 25px;
    color: #ffffff;
  }

  .pet-benefits-card-text h4 {
    margin: 0 0 8px 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .pet-benefits-card-text p {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.9;
    line-height: 1.4;
  }

  /* ==========================================================================
     MOBILE RESPONSIVE HANDLING - UPDATED FOR EXACT ALIGNMENT TO image_36dbc6.png
     ========================================================================== */
  @media (max-width: 767px) {
    .pet-benefits-{{ section.id }} {
      padding-top: 50px;
      padding-bottom: 50px;
    }

    .pet-benefits-title-wrap {
      margin-bottom: 35px;
    }

    .pet-benefits-main-title {
      font-size: 1.95rem;
      font-weight: 800;
      line-height: 1.2;
      margin: 0 0 45px 0;
      max-width: 290px;
      margin-left: auto;
      margin-right: auto;
    }

    .pet-benefits-icons-badge-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 16px;
      padding: 0 24px;
      max-width: 340px;
    }

    .pet-benefits-icon-circle {
      width: 54px;
      height: 54px;
      margin-bottom: 12px;
    }

    .pet-benefits-icon-label {
      font-size: 0.82rem;
      line-height: 1.35;
      font-weight: 500;
      color: #444444;
      max-width: 140px;
    }

    .pet-benefits-slider-canvas {
      margin-top: 45px;
      padding: 20px 0;
    }

    /* Keep wave active but reposition seamlessly across small displays */
    .pet-benefits-wave-background {
      display: block;
      top: 50%;
      height: 60px;
    }

    .pet-benefits-wave-background svg path {
      stroke-width: 4.5;
    }

    .pet-benefits-card-slide {
      width: 260px;
      height: 180px;
      border-radius: 12px;
    }

    .pet-benefits-card-text {
      padding: 16px;
    }

    .pet-benefits-card-text h4 {
      font-size: 1.05rem;
      margin-bottom: 4px;
    }
  }
{%- endstyle -%}

<!-- Include Swiper Assets from CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<div class="pet-benefits-{{ section.id }}">
  <div class="pet-benefits-title-wrap">
    <h2 class="pet-benefits-main-title">{{ section.settings.title }}</h2>
    
    <div class="pet-benefits-icons-badge-row">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge_icon' -%}
          <div class="pet-benefits-icon-item" {{ block.shopify_attributes }}>
            <div class="pet-benefits-icon-circle">
              {%- if block.settings.icon_img != blank -%}
                <img src="{{ block.settings.icon_img | img_url: '60x60' }}" alt="{{ block.settings.label }}" loading="lazy">
              {%- else -%}
                {%- case forloop.index -%}
                  {%- when 1 -%}
                    <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                  {%- when 2 -%}
                    <svg viewBox="0 0 24 24"><path d="M11 7h2v2h-2zm0 4h2v6h-2zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                  {%- when 3 -%}
                    <svg viewBox="0 0 24 24"><path d="M11 7h2v2h-2zm0 4h2v6h-2zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24"><path d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            <div class="pet-benefits-icon-label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="pet-benefits-slider-canvas">
    <!-- Continuous Wave Background -->
    <div class="pet-benefits-wave-background">
      <svg width="100%" height="100%" viewBox="0 0 1440 80" preserveAspectRatio="none">
        <path d="M0,40 C120,5 240,75 360,40 C480,5 600,75 720,40 C840,5 960,75 1080,40 C1200,5 1320,75 1440,40" />
      </svg>
    </div>

    <!-- Swiper Container -->
    <div class="swiper pet-benefits-swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide_card' -%}
            <div class="swiper-slide" style="width: auto;">
              <div class="pet-benefits-card-slide" {{ block.shopify_attributes }}>
                <div class="pet-benefits-card-image">
                  {%- if block.settings.card_img != blank -%}
                    <img src="{{ block.settings.card_img | img_url: '600x450' }}" alt="{{ block.settings.card_title }}" loading="lazy">
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                <div class="pet-benefits-card-overlay"></div>
                <div class="pet-benefits-card-text">
                  {%- if block.settings.card_title != blank -%}
                    <h4>{{ block.settings.card_title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.card_desc != blank -%}
                    <p>{{ block.settings.card_desc }}</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const initPetSwiper = () => {
      const isMobile = window.innerWidth < 768;
      new Swiper('.pet-benefits-swiper', {
        slidesPerView: 'auto',
        centeredSlides: false,
        slidesOffsetBefore: isMobile ? 24 : 60,
        slidesOffsetAfter: isMobile ? 24 : 60,
        spaceBetween: isMobile ? 20 : 40,
        loop: true,
        grabCursor: true,
        allowTouchMove: true,
        speed: 7000,
        autoplay: {
          delay: 0,
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        }
      });
    };

    if (typeof Swiper === 'undefined') {
      const swiperScript = document.querySelector('script[src*="swiper"]');
      if (swiperScript) {
        swiperScript.addEventListener('load', initPetSwiper);
      }
    } else {
      initPetSwiper();
    }
  });
</script>

{% schema %}
{
  "name": "Pet Benefits Slider",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
