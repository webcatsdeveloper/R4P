<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .naturally-fresh-container {
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .naturally-fresh-text {
    max-width: 1000px;
    padding: 0 40px;
    font-size: 22px;
    line-height: 1.6;
    color: #1E1E1E;
    margin-bottom: 60px;
    font-weight: 600;
  }

  .naturally-fresh-image-container {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0;
  }

  .naturally-fresh-bg-wave {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    z-index: 0;
  }

  .naturally-fresh-bg-wave img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .naturally-fresh-image-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0;
  }

  .naturally-fresh-image-wrapper img {
    width: 100%;
    max-width: 1000px;
    height: auto;
    object-fit: contain;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  @media screen and (max-width: 768px) {
    .naturally-fresh-text {
      font-size: 26px; /* Match large Figma size */
      line-height: 1.4;
      margin-bottom: 40px;
      padding: 0 40px;
      color: #1E1E1E;
    }
    .naturally-fresh-container {
      padding: 0;
    }
    .naturally-fresh-image-wrapper {
      padding: 0 20px;
    }
    .naturally-fresh-image-wrapper img {
      border-radius: 24px;
    }
  }
</style>

<div class="naturally-fresh-container">
  {% if section.settings.top_text != blank %}
    <div class="naturally-fresh-text">
      {{ section.settings.top_text | newline_to_br }}
    </div>
  {% endif %}

  <div class="naturally-fresh-image-container">
    {% if section.settings.bg_wave %}
      <div class="naturally-fresh-bg-wave">
        <img src="{{ section.settings.bg_wave | img_url: 'master' }}" alt="Background Wave" loading="lazy">
      </div>
    {% endif %}

    <div class="naturally-fresh-image-wrapper">
      {% if section.settings.main_image %}
        <img src="{{ section.settings.main_image | img_url: 'master' }}" alt="Flakes not a pellet" loading="lazy">
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Naturally Fresh",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "textarea",
      "id": "top_text",
      "label": "Top Text",
      "default": "Naturally fresh, scientifically preserved food made use smart, clean technology to\nlock in a long shelf life—with absolutely zero synthetic preservatives"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image block"
    },
    {
      "type": "image_picker",
      "id": "bg_wave",
      "label": "Background Wave Image (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Naturally Fresh"
    }
  ]
}
{% endschema %}
