<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .naturally-fresh-container {
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .naturally-fresh-text {
    max-width: 1000px;
    padding: 0px;
    font-size: 28px;
    line-height: 1.6;
    color: #1E1E1E;
    margin-bottom: 60px;
    font-weight: 100;
  }

  .naturally-fresh-image-container {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0;
  }

  .naturally-fresh-bg-wave {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    z-index: 0;
  }

  .naturally-fresh-bg-wave img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .naturally-fresh-image-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0;
  }

  .naturally-fresh-media-wrap {
    width: 100%;
    max-width: 1000px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #0000000a;
  }

  .naturally-fresh-media-wrap img,
  .naturally-fresh-media-wrap video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .naturally-fresh-media-wrap iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    border: none;
  }

  @media screen and (max-width: 768px) {
    .naturally-fresh-text {
      font-size: 26px; /* Match large Figma size */
      line-height: 1.4;
      margin-bottom: 40px;
      padding: 0 40px;
      color: #1E1E1E;
    }
    .naturally-fresh-container {
      padding: 0;
    }
    .naturally-fresh-image-wrapper {
      padding: 0 20px;
    }
    .naturally-fresh-media-wrap {
      border-radius: 24px;
    }
  }
</style>

<div class="naturally-fresh-container">
  {% if section.settings.top_text != blank %}
    <div class="naturally-fresh-text">
      {{ section.settings.top_text | newline_to_br }}
    </div>
  {% endif %}

  <div class="naturally-fresh-image-container">
    {% if section.settings.bg_wave %}
      <div class="naturally-fresh-bg-wave">
        <img src="{{ section.settings.bg_wave | img_url: 'master' }}" alt="Background Wave" loading="lazy">
      </div>
    {% endif %}

    <div class="naturally-fresh-image-wrapper">
      {% if section.settings.video_url != blank or section.settings.native_video != blank or section.settings.main_image != blank %}
        <div class="naturally-fresh-media-wrap">
          {%- if section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=0&rel=0&playsinline=1" 
                      allowfullscreen 
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      loading="lazy"></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=0&title=0&byline=0&portrait=0" 
                      allowfullscreen 
                      allow="autoplay; fullscreen; picture-in-picture"
                      loading="lazy"></iframe>
            {%- endif -%}
          {%- elsif section.settings.native_video != blank -%}
            {%- if section.settings.main_image != blank -%}
              {{ section.settings.native_video | video_tag: controls: true, image_size: '1200x', preload: 'metadata', autoplay: false, loop: false, poster: (section.settings.main_image | img_url: 'master') }}
            {%- else -%}
              {{ section.settings.native_video | video_tag: controls: true, image_size: '1200x', preload: 'metadata', autoplay: false, loop: false }}
            {%- endif -%}
          {%- elsif section.settings.main_image != blank -%}
            <img src="{{ section.settings.main_image | img_url: 'master' }}" alt="Flakes not a pellet" loading="lazy">
          {%- endif -%}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Naturally Fresh",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "textarea",
      "id": "top_text",
      "label": "Top Text",
      "default": "Naturally fresh, scientifically preserved food made use smart, clean technology to\nlock in a long shelf life—with absolutely zero synthetic preservatives"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image block"
    },
    {
      "type": "video",
      "id": "native_video",
      "label": "Option 1: Shopify Video Upload",
      "info": "Upload your file directly to Shopify Files for premium performance."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Option 2: External Video Link",
      "accept": ["youtube", "vimeo"],
      "info": "Or paste a Youtube/Vimeo link here."
    },
    {
      "type": "image_picker",
      "id": "bg_wave",
      "label": "Background Wave Image (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Naturally Fresh"
    }
  ]
}
{% endschema %}
