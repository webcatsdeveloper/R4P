<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .naturally-fresh-container {
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .naturally-fresh-text {
    max-width: 800px;
    padding: 0 40px;
    font-size: 20px;
    line-height: 1.6;
    color: #333333;
    margin-bottom: 60px;
    font-weight: 500;
  }

  .naturally-fresh-image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0;
  }

  .naturally-fresh-image-wrapper img {
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 20px; /* To match the rounded corners in the design */
  }

  @media screen and (max-width: 768px) {
    .naturally-fresh-text {
      font-size: 16px;
      margin-bottom: 40px;
    }
    .naturally-fresh-container {
      padding: 0 20px;
    }
  }
</style>

<div class="naturally-fresh-container">
  {% if section.settings.top_text != blank %}
    <div class="naturally-fresh-text">
      {{ section.settings.top_text | newline_to_br }}
    </div>
  {% endif %}

  <div class="naturally-fresh-image-wrapper">
    {% if section.settings.main_image %}
      <img src="{{ section.settings.main_image | img_url: 'master' }}" alt="Flakes not a pellet" loading="lazy">
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Naturally Fresh",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "textarea",
      "id": "top_text",
      "label": "Top Text",
      "default": "Naturally fresh, scientifically preserved food made use smart, clean technology to\nlock in a long shelf life—with absolutely zero synthetic preservatives"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image block"
    }
  ],
  "presets": [
    {
      "name": "Naturally Fresh"
    }
  ]
}
{% endschema %}
