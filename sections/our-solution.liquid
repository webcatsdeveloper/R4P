<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  .our-solution-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }
  .our-solution-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: top center;
  }

  .our-solution-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  .os-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 72px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 20px;
    line-height: 1.1;
    color: #111111;
  }
  .os-title-red {
    color: #d92b2b;
  }

  /* Top Right Text perfectly aligned */
  .os-top-right-text {
    width: 100%;
    max-width: 820px;
    margin: 0 auto 10px auto;
    display: flex;
    justify-content: flex-end;
  }
  .os-top-right-text .os-bold-text {
    max-width: 380px;
    text-align: right;
    font-size: 24px;
    line-height: 1.25;
    font-weight: 700;
    color: #111111;
  }
  .os-bold-text-red {
    color: #d92b2b;
  }

  /* Middle Section Flex Layout */
  .os-middle-section {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto 10px auto;
  }

  .os-middle-image-wrapper {
    position: relative;
    width: 480px;
    max-width: 100%;
    flex-shrink: 0;
    z-index: 2;
  }
  .os-middle-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Desktop Position for side texts */
  @media screen and (min-width: 901px) {
    .os-side-text-left {
      position: absolute;
      right: 104%;
      bottom: 22%;
      width: 250px;
      text-align: left;
      z-index: 3;
    }

    .os-side-text-right {
      position: absolute;
      left: 104%;
      top: 22%;
      width: 250px;
      text-align: left;
      z-index: 3;
    }
  }

  .os-sub-text {
    font-size: 15px;
    line-height: 1.5;
    font-weight: 500;
    color: #111111;
  }

  /* Bottom Text Area */
  .os-bottom-text-area {
    text-align: center;
    max-width: 720px;
    margin: 20px auto 15px auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .os-bottom-text-area .os-bold-text {
    font-size: 22px;
    font-weight: 800;
    line-height: 1.35;
    color: #111111;
  }

  /* Bottom Section Flex Layout */
  .os-bottom-section {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .os-bottom-image-wrapper {
    width: 380px;
    max-width: 100%;
    flex-shrink: 0;
    z-index: 2;
    margin-bottom: -30px; /* Overlaps bottom wave curve */
  }
  .os-bottom-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .os-bottom-left-text {
    position: absolute;
    left: 20px;
    bottom: 10px;
    max-width: 260px;
    text-align: left;
    z-index: 3;
  }
  .os-bottom-left-text .os-sub-text {
    font-size: 12px;
    line-height: 1.4;
    color: #444444;
  }

  @media screen and (max-width: 900px) {
    .os-title { font-size: 50px; }
    
    .os-top-right-text {
      justify-content: center;
    }
    .os-top-right-text .os-bold-text {
      text-align: center;
      font-size: 20px;
    }
    
    .os-middle-image-wrapper {
      width: 100%;
      max-width: 380px;
      margin: 20px auto;
    }
    
    .os-side-text-left, .os-side-text-right {
      position: static;
      width: 100%;
      text-align: center;
      margin: 20px auto;
      padding: 0 10px;
    }
    
    .os-bottom-section {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    
    .os-bottom-image-wrapper {
      margin-bottom: 0;
    }
    
    .os-bottom-left-text {
      position: static;
      text-align: center;
      margin: 10px auto;
    }
  }
</style>

{% if section.settings.bg_image %}
  <img class="our-solution-bg" src="{{ section.settings.bg_image | img_url: 'master' }}" alt="Background">
{% endif %}

<div class="our-solution-container">
  <div class="os-title">
    <span class="os-title-black">{{ section.settings.title_black }}</span>
    <span class="os-title-red">{{ section.settings.title_red }}</span>
  </div>

  <div class="os-top-right-text">
    <div class="os-bold-text">{{ section.settings.top_right_heading }}</div>
  </div>

  <div class="os-middle-section">
    <div class="os-middle-image-wrapper">
      {% if section.settings.mid_image %}
        <img src="{{ section.settings.mid_image | img_url: 'master' }}" alt="Middle Graphic">
      {% endif %}
      
      <div class="os-side-text-left">
        <div class="os-sub-text">{{ section.settings.mid_left_text }}</div>
      </div>
      
      <div class="os-side-text-right">
        <div class="os-sub-text">{{ section.settings.top_right_subtext }}</div>
      </div>
    </div>
  </div>

  <div class="os-bottom-text-area">
    <div class="os-bold-text">{{ section.settings.bot_heading }}</div>
    <div class="os-sub-text">{{ section.settings.bot_subtext }}</div>
  </div>

  <div class="os-bottom-section">
    <div class="os-bottom-image-wrapper">
      {% if section.settings.bot_image %}
        <img src="{{ section.settings.bot_image | img_url: 'master' }}" alt="Bottom Bowl">
      {% endif %}
    </div>
    
    <div class="os-bottom-left-text">
      <div class="os-sub-text">{{ section.settings.bot_left_text }}</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Yellow shape)"
    },
    {
      "type": "text",
      "id": "title_black",
      "label": "Title (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_red",
      "label": "Title (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Middle Section (Image + Text)"
    },
    {
      "type": "textarea",
      "id": "top_right_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class='os-bold-text-red'>real food</span>, <br>not processed science experiments"
    },
    {
      "type": "textarea",
      "id": "top_right_subtext",
      "label": "Top Right Subtext",
      "default": "Real foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "header",
      "content": "Middle Grid"
    },
    {
      "type": "textarea",
      "id": "mid_left_text",
      "label": "Middle Left Text",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Middle Image (Kibble bowl)"
    },
    {
      "type": "header",
      "content": "Bottom Text Area"
    },
    {
      "type": "textarea",
      "id": "bot_heading",
      "label": "Bottom Heading",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "bot_subtext",
      "label": "Bottom Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "header",
      "content": "Bottom Grid"
    },
    {
      "type": "image_picker",
      "id": "bot_image",
      "label": "Bottom Center Image (Divided raw bowl)"
    },
    {
      "type": "textarea",
      "id": "bot_left_text",
      "label": "Bottom Left Text",
      "default": "No GMO, No Fillers, No Synthetic Chemicals, No Preservatives, No Binders"
    }
  ],
  "presets": [
    {
      "name": "Our Solution"
    }
  ]
}
{% endschema %}
