<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  .our-solution-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    object-fit: cover;
  }

  .our-solution-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Typography */
  .os-font {
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  .os-title {
    font-size: 80px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
    line-height: 1.1;
  }

  .os-title-black { color: #111111; }
  .os-title-red { color: #d92b2b; }

  .os-bold-text {
    font-weight: 700;
    font-size: 24px;
    color: #111111;
    line-height: 1.3;
  }

  .os-bold-text-red {
    color: #d92b2b;
  }

  .os-sub-text {
    font-weight: 500;
    font-size: 16px;
    color: #111111;
    line-height: 1.5;
  }

  /* Specific Blocks Layout using Grid/Flex */
  .os-grid-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    align-items: center;
    margin-bottom: 20px;
  }

  .os-top-left {
    display: flex;
    justify-content: center;
    position: relative;
  }
  
  .os-top-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-left: 40px;
    max-width: 450px;
  }

  .os-grid-middle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    align-items: center;
    margin-bottom: 60px;
  }

  .os-mid-left {
    display: flex;
    justify-content: flex-end;
    padding-right: 40px;
    text-align: right;
    max-width: 400px;
    margin-left: auto;
  }

  .os-mid-right {
    display: flex;
    justify-content: flex-start;
  }

  .os-bottom-text-area {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .os-grid-bottom {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    width: 100%;
    align-items: end;
  }

  .os-bot-left {
    padding-bottom: 40px;
  }

  .os-bot-center {
    display: flex;
    justify-content: center;
  }

  .our-solution-container img {
    max-width: 100%;
    height: auto;
  }

  @media screen and (max-width: 900px) {
    .os-grid-top, .os-grid-middle, .os-grid-bottom {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
    .os-top-right, .os-mid-left, .os-bot-left {
      padding: 0;
      text-align: center;
      margin: 0 auto;
    }
    .os-title { font-size: 50px; }
  }
</style>

{% if section.settings.bg_image %}
  <img class="our-solution-bg" src="{{ section.settings.bg_image | img_url: 'master' }}" alt="Background">
{% endif %}

<div class="our-solution-container os-font">
  <div class="os-title">
    <span class="os-title-black">{{ section.settings.title_black }}</span>
    <span class="os-title-red">{{ section.settings.title_red }}</span>
  </div>

  <div class="os-grid-top">
    <div class="os-top-left">
      {% if section.settings.top_left_image %}
        <img src="{{ section.settings.top_left_image | img_url: 'master' }}" alt="Fresh Food">
      {% endif %}
    </div>
    <div class="os-top-right">
      <div class="os-bold-text">{{ section.settings.top_right_heading }}</div>
      <div class="os-sub-text">{{ section.settings.top_right_subtext }}</div>
    </div>
  </div>

  <div class="os-grid-middle">
    <div class="os-mid-left">
      <div class="os-sub-text">{{ section.settings.mid_left_text }}</div>
    </div>
    <div class="os-mid-right">
      {% if section.settings.mid_image %}
        <img src="{{ section.settings.mid_image | img_url: 'master' }}" alt="Kibble">
      {% endif %}
    </div>
  </div>

  <div class="os-bottom-text-area">
    <div class="os-bold-text">{{ section.settings.bot_heading }}</div>
    <div class="os-sub-text">{{ section.settings.bot_subtext }}</div>
  </div>

  <div class="os-grid-bottom">
    <div class="os-bot-left">
      <div class="os-sub-text" style="font-size: 14px;">{{ section.settings.bot_left_text }}</div>
    </div>
    <div class="os-bot-center">
      {% if section.settings.bot_image %}
        <img src="{{ section.settings.bot_image | img_url: 'master' }}" alt="Divided Bowl">
      {% endif %}
    </div>
    <div></div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Yellow shape)"
    },
    {
      "type": "text",
      "id": "title_black",
      "label": "Title (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_red",
      "label": "Title (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Top Grid"
    },
    {
      "type": "image_picker",
      "id": "top_left_image",
      "label": "Top Left Image (Fresh food + curve text + arrow)"
    },
    {
      "type": "textarea",
      "id": "top_right_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class='os-bold-text-red'>real food</span>, <br>not processed science experiments"
    },
    {
      "type": "textarea",
      "id": "top_right_subtext",
      "label": "Top Right Subtext",
      "default": "Real foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "header",
      "content": "Middle Grid"
    },
    {
      "type": "textarea",
      "id": "mid_left_text",
      "label": "Middle Left Text",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Middle Image (Kibble bowl)"
    },
    {
      "type": "header",
      "content": "Bottom Text Area"
    },
    {
      "type": "textarea",
      "id": "bot_heading",
      "label": "Bottom Heading",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "bot_subtext",
      "label": "Bottom Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "header",
      "content": "Bottom Grid"
    },
    {
      "type": "image_picker",
      "id": "bot_image",
      "label": "Bottom Center Image (Divided raw bowl)"
    },
    {
      "type": "textarea",
      "id": "bot_left_text",
      "label": "Bottom Left Text",
      "default": "No GMO, No Fillers, No Synthetic Chemicals, No Preservatives, No Binders"
    }
  ],
  "presets": [
    {
      "name": "Our Solution"
    }
  ]
}
{% endschema %}
