<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  .our-solution-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }
  .our-solution-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .our-solution-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .os-title {
    font-size: 72px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 20px;
    line-height: 1.1;
    color: #000;
  }
  .os-title span {
    color: #E22128;
  }

  /* Top Right Text perfectly aligned */
  .os-top-right-text {
    width: 100%;
    max-width: 820px;
    margin: 0 auto 20px auto;
    display: flex;
    justify-content: flex-end;
  }
  .os-top-right-text > div {
    max-width: 280px;
    text-align: right;
  }

  .os-sub-text {
    font-size: 15px;
    line-height: 1.5;
    font-weight: 500;
    color: #000;
  }

  .os-bold-text {
    font-size: 20px;
    line-height: 1.3;
    font-weight: 700;
    color: #000;
  }

  /* Middle Section Flex Layout */
  .os-middle-section {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto 30px auto;
  }

  .os-side-text-left {
    width: 180px;
    text-align: left;
    margin-right: -10px;
    margin-top: 180px; /* Push down to exactly align with bottom bowl arrow */
    z-index: 3;
  }

  .os-middle-image-wrapper {
    width: 480px;
    flex-shrink: 0;
    z-index: 2;
  }
  .os-middle-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .os-side-text-right {
    width: 190px;
    text-align: left;
    margin-left: -5px;
    margin-bottom: 180px; /* Push up to exactly align with top bowl arrow */
    z-index: 3;
  }

  /* Bottom Text Area */
  .os-bottom-text-area {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 40px auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Bottom Section Flex Layout */
  .os-bottom-section {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
  }

  .os-bottom-left-text {
    width: 150px;
    text-align: left;
    margin-right: -40px; /* Pull closer to bowl */
    margin-bottom: 40px; /* Align slightly above bottom */
    z-index: 3;
  }

  .os-bottom-image-wrapper {
    width: 380px;
    flex-shrink: 0;
    z-index: 2;
  }
  .os-bottom-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 900px) {
    .os-title { font-size: 50px; }
    .os-middle-section, .os-bottom-section {
      flex-direction: column;
    }
    .os-side-text-left, .os-side-text-right, .os-bottom-left-text {
      width: 100%;
      text-align: center;
      margin: 20px auto;
    }
    .os-top-right-text {
      justify-content: center;
    }
    .os-top-right-text > div {
      text-align: center;
    }
  }
</style>

{% if section.settings.bg_image %}
  <img class="our-solution-bg" src="{{ section.settings.bg_image | img_url: 'master' }}" alt="Background">
{% endif %}

<div class="our-solution-container os-font">
  <div class="os-title">
    <span class="os-title-black">{{ section.settings.title_black }}</span>
    <span class="os-title-red">{{ section.settings.title_red }}</span>
  </div>

  <div class="os-top-right-text">
    <div class="os-bold-text" style="font-size: 24px;">{{ section.settings.top_right_heading }}</div>
  </div>

  <div class="os-middle-section">
    <div class="os-middle-image-wrapper">
      {% if section.settings.mid_image %}
        <img src="{{ section.settings.mid_image | img_url: 'master' }}" alt="Middle Graphic">
      {% endif %}
      
      <div class="os-side-text-left">
        <div class="os-sub-text">{{ section.settings.mid_left_text }}</div>
      </div>
      
      <div class="os-side-text-right">
        <div class="os-sub-text">{{ section.settings.top_right_subtext }}</div>
      </div>
    </div>
  </div>

  <div class="os-bottom-text-area">
    <div class="os-bold-text">{{ section.settings.bot_heading }}</div>
    <div class="os-sub-text">{{ section.settings.bot_subtext }}</div>
  </div>

  <div class="os-bottom-section">
    <div class="os-bottom-image-wrapper">
      {% if section.settings.bot_image %}
        <img src="{{ section.settings.bot_image | img_url: 'master' }}" alt="Bottom Bowl">
      {% endif %}
      
      <div class="os-bottom-left-text">
        <div class="os-sub-text" style="font-size: 11px; line-height: 1.4;">{{ section.settings.bot_left_text }}</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Yellow shape)"
    },
    {
      "type": "text",
      "id": "title_black",
      "label": "Title (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_red",
      "label": "Title (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Middle Section (Image + Text)"
    },
    {
      "type": "textarea",
      "id": "top_right_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class='os-bold-text-red'>real food</span>, <br>not processed science experiments"
    },
    {
      "type": "textarea",
      "id": "top_right_subtext",
      "label": "Top Right Subtext",
      "default": "Real foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "header",
      "content": "Middle Grid"
    },
    {
      "type": "textarea",
      "id": "mid_left_text",
      "label": "Middle Left Text",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Middle Image (Kibble bowl)"
    },
    {
      "type": "header",
      "content": "Bottom Text Area"
    },
    {
      "type": "textarea",
      "id": "bot_heading",
      "label": "Bottom Heading",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "bot_subtext",
      "label": "Bottom Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "header",
      "content": "Bottom Grid"
    },
    {
      "type": "image_picker",
      "id": "bot_image",
      "label": "Bottom Center Image (Divided raw bowl)"
    },
    {
      "type": "textarea",
      "id": "bot_left_text",
      "label": "Bottom Left Text",
      "default": "No GMO, No Fillers, No Synthetic Chemicals, No Preservatives, No Binders"
    }
  ],
  "presets": [
    {
      "name": "Our Solution"
    }
  ]
}
{% endschema %}
