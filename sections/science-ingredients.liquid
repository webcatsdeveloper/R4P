{%- style -%}
.sci-ing-section-{{ section.id }} {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 80px 40px;
  box-sizing: border-box;
  background-color: #ffffff;
}

.sci-ing-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 40px;
  align-items: stretch;
}

/* LEFT COLUMN LAYOUT */
.sci-ing-left-col {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.sci-ing-small-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 0.85;
  border-radius: 24px;
  overflow: hidden;
  background-color: #e52d27;
}

.sci-ing-small-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.sci-ing-small-card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 40px 30px 30px 40px; /* Generous padding pushing text down and right to match image frame layout */
  box-sizing: border-box;
  display: flex;
  align-items: flex-end; /* Pin text to the bottom-left corner zone */
  justify-content: flex-start;
}

/* TYPOGRAPHY SPECIFICATIONS MATCHING FIGMA (image_f1a5fa.jpg) */
.sci-ing-small-card-text {
  margin: 0;
  font-family: 'Neusa Next Std', 'Degular Demo', -apple-system, sans-serif !important;
  font-weight: 500;
  font-style: normal;
  font-size: 48px; /* Balanced scale desktop fit based on canvas metrics */
  line-height: 1.0;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0%;
}

.sci-ing-bottom-text {
  font-family: 'Neusa Next Std', 'Degular Demo', -apple-system, sans-serif !important;
  font-weight: 500;
  font-style: normal;
  font-size: 36px;
  line-height: 1.1;
  color: #b83227; 
  text-align: right;
  text-transform: uppercase;
  margin-top: 40px;
  letter-spacing: 0%;
}

/* RIGHT COLUMN LAYOUT */
.sci-ing-large-card {
  width: 100%;
  border-radius: 24px;
  overflow: hidden;
  box-sizing: border-box;
}

.sci-ing-large-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* MOBILE ARCHITECTURE: ROW 1 IMAGE, ROW 2 ELEMENTS SIDE-BY-SIDE */
@media screen and (max-width: 991px) {
  .sci-ing-section-{{ section.id }} {
    padding: 40px 20px;
  }
  
  .sci-ing-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  
  /* Row 1 placement for the wide image */
  .sci-ing-large-card {
    order: 1;
  }
  
  /* Row 2 side-by-side horizontal alignment container split */
  .sci-ing-left-col {
    order: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
  }
  
  .sci-ing-small-card {
    aspect-ratio: 1.2 / 1;
  }
  
  .sci-ing-small-card-text {
    font-size: 22px;
  }

  .sci-ing-bottom-text {
    text-align: left;
    margin-top: 0;
    font-size: 24px;
    line-height: 1.2;
  }
}
{%- endstyle -%}

<section class="sci-ing-section-{{ section.id }}">
  <div class="sci-ing-grid">
    
    <!-- LEFT PANEL SIDE -->
    <div class="sci-ing-left-col">
      
      <!-- TOP INTERACTIVE SMALL CARD -->
      <div class="sci-ing-small-card">
        {%- if section.settings.small_card_image != blank -%}
          <img src="{{ section.settings.small_card_image | image_url: width: 600 }}" class="sci-ing-small-card-img" alt="Science Icon Frame">
        {%- endif -%}
        
        <div class="sci-ing-small-card-overlay">
          {%- if section.settings.small_card_text != blank -%}
            <h3 class="sci-ing-small-card-text">
              {{ section.settings.small_card_text | newline_to_br }}
            </h3>
          {%- endif -%}
        </div>
      </div>

      <!-- LOWER EDITABLE TEXT UNIT -->
      {%- if section.settings.lower_left_text != blank -%}
        <div class="sci-ing-bottom-text">
          {{ section.settings.lower_left_text | newline_to_br }}
        </div>
      {%- endif -%}

    </div>

    <!-- RIGHT PANEL DISPLAY FRAME -->
    <div class="sci-ing-large-card">
      {%- if section.settings.large_card_image != blank -%}
        <img src="{{ section.settings.large_card_image | image_url: width: 1600 }}" alt="Ingredients Composition Grid Summary Layout">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Science & Ingredients",
  "settings": [
    {
      "type": "header",
      "content": "Small Card Settings (Top Left)"
    },
    {
      "type": "image_picker",
      "id": "small_card_image",
      "label": "Small Card Background Image"
    },
    {
      "type": "textarea",
      "id": "small_card_text",
      "label": "Small Card Text Content",
      "default": "THE\nSCIENCE\nBEHIND IT"
    },
    {
      "type": "header",
      "content": "Bottom Text Settings (Bottom Left)"
    },
    {
      "type": "textarea",
      "id": "lower_left_text",
      "label": "Lower Left Text Alignment Block",
      "default": "SPECIES\nAPPROPRIATE"
    },
    {
      "type": "header",
      "content": "Main Large Image (Right Side)"
    },
    {
      "type": "image_picker",
      "id": "large_card_image",
      "label": "Main Ingredients Wide Image"
    }
  ],
  "presets": [
    {
      "name": "Science & Ingredients"
    }
  ]
}
{% endschema %}