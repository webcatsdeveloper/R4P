{%- style -%}
.product-selection-{{ section.id }} {
  background-color: #FEEDDE;
  padding: 75px 0;
  font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  text-align: center;
  overflow: hidden;
}

.ps-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 40px;
}

/* =========================
   HEADING
========================= */

.ps-heading {
  font-size: clamp(32px, 5vw, 62px);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: #000;
  margin: 0 0 72px;
  font-family: 'Neusa Next Std' !important;
}

.ps-heading span {
  color: #EE3E34;
}

/* =========================
   TABS
========================= */

.ps-tabs {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto 72px;
  display: flex;
  align-items: flex-end;
  position: relative;
  border-bottom: 3px solid #EBC8BE;
}

.ps-tab-btn {
  width: 33.333%;
  height: 58px;

  position: relative;

  background: transparent;
  border: none;
  cursor: pointer;

  padding: 0 0 14px 0;
  margin: 0;

  display: flex;
  align-items: flex-start;
  justify-content: center;

  font-family: 'Degular Demo' !important;
  font-size: 24px;
  font-weight: 700;
  line-height: 18px;
  letter-spacing: -0.01em;

  color: #111111;
  transition: color 0.25s ease;

  text-align: center;
}

.ps-tab-icon {
  display: none;
}

.ps-tab-mobile-text {
  display: none;
}

.ps-tab-btn.active {
  color: #EE3E34;
}

.ps-tab-btn::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -3px;

  width: 0;
  height: 3px;

  background: #EE3E34;
  transition: width 0.3s ease;
}

.ps-tab-btn.active::after {
  width: 100%;
}

/* =========================
   GRID
========================= */

.ps-grid-container {
  display: none;
}

.ps-grid-container.active {
  display: flex;
  justify-content: center;
  gap: 56px;
  flex-wrap: wrap;
  margin-bottom: 72px;
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =========================
   PRODUCT CARD
========================= */

.ps-card {
  width: 220px;
  text-decoration: none;
  color: #000;

  display: flex;
  flex-direction: column;
  align-items: center;

  transition:
    transform 0.35s ease,
    opacity 0.9s ease;
}

.ps-card:hover {
  transform: translateY(-4px);
}

.ps-image-box {
  position: relative;

  width: 220px;
  height: 220px;

  display: flex;
  align-items: center;
  justify-content: center;

  margin-bottom: 26px;
}

.ps-prod-img {
  position: relative;
  z-index: 2;

  width: 88%;
  height: 88%;

  object-fit: contain;
  transition: transform 0.25s ease;
}

.ps-card:hover .ps-prod-img {
  transform: scale(1.04);
}

/* =========================
   PRODUCT INFO
========================= */

.ps-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0 !important;
}

/* TITLE */

.ps-title {
  width: 220px;
  min-height: 78px;

  margin: -6px 0 14px 0 !important;

  text-align: center;

  font-family: 'Degular Demo' !important;
  font-size: 24px;
  font-weight: 700;
  line-height: 28px;
  letter-spacing: -0.02em;

  color: #111111;

  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* PRICE */

.ps-price {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 2px;

  margin: 0 0 18px 0;

  font-family: 'Degular Demo' !important;
  color: #1E1E1E;
}

.ps-price .rupee {
  font-size: 22px;
  line-height: 1;
  transform: translateY(6px);
}

.ps-price .amount {
  font-size: 34px;
  line-height: 1;
  font-weight: 400;
  letter-spacing: -0.03em;
}

/* =========================
   SHOP BUTTON
========================= */

.ps-shop-btn {
  width: 112px;
  height: 34px;

  background-color: #EE3E34;
  color: #fff;

  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.02em;

  border-radius: 100px;

  display: flex;
  align-items: center;
  justify-content: center;

  transition: all 0.25s ease;
  font-family: 'Degular Demo' !important;
}

.ps-card:hover .ps-shop-btn {
  background: #000;
}

/* =========================
   VIEW ALL BUTTON
========================= */

.ps-view-all {
  min-width: 250px;
  height: 66px;
  border-radius: 999px;

  background: #000;
  color: #fff;

  text-decoration: none;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;

  font-family: 'Degular Demo' !important;

  transition:
    transform 0.25s ease,
    background 0.25s ease;
}

.ps-view-all:hover {
  transform: scale(1.04);
  background: #EE3E34;
}



/* =========================
   MOBILE
========================= */

@media (max-width: 768px) {

  .product-selection-{{ section.id }} {
    padding: 72px 0;
  }

  .ps-container {
    padding: 0 20px;
  }

  .ps-heading {
    font-size: 40px !important;
    line-height: 47px !important;
    max-width: 335px;
    margin-inline: auto;
    margin-bottom: 24px;
  }

  .ps-tabs {
    margin-bottom: 46px;
    border-bottom: none;
    justify-content: center;
    gap: 16px;
    align-items: flex-start;
  }

  .ps-tab-btn {
    height: auto;
    padding: 0;
    flex-direction: column;
    align-items: center;
    width: auto;
    flex: 1;
    max-width: 75px;
  }

  .ps-tab-btn::after {
    display: none;
  }

  .ps-tab-desktop-text {
    display: none;
  }

  .ps-tab-icon {
    display: flex;
    width: 60px;
    height: 60px;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    transition: transform 0.2s ease;
  }

  .ps-tab-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ps-tab-icon-placeholder {
    background-color: #eee;
    border-radius: 50%;
  }

  .ps-tab-btn.active .ps-tab-icon {
    transform: scale(1.1);
  }

  .ps-tab-mobile-text {
    display: block;
    font-family: 'Degular Demo' !important;
    font-weight: 400;
    font-size: 12px;
    line-height: 16px;
    color: #1E1E1E;
  }

  .ps-grid-container.active {
    gap: 36px;
  }

  .ps-card {
    width: calc(50% - 18px);
  }

  .ps-image-box {
    width: 160px;
    height: 160px;
    margin-bottom: 20px;
  }

  .ps-title {
    width: 100%;
    min-height: 52px;

    font-size: 16px;
    line-height: 26px;
  }

  .ps-price .rupee {
    font-size: 16px;
    transform: translateY(4px);
  }

  .ps-price .amount {
    font-size: 28px;
  }

  .ps-view-all {
    min-width: 220px;
    height: 58px;
    font-size: 15px;
  }
}
{%- endstyle -%}

<section class="product-selection-{{ section.id }}" id="ShoppingGrid">
  <div class="ps-container">

    <h2 class="ps-heading">
      {{ section.settings.heading | replace: 'shopping', '<br><span>shopping</span>' | replace: 'for today?', 'for<br>today?' }}
    </h2>

    <div class="ps-tabs">
      {% for block in section.blocks %}
        <button
          class="ps-tab-btn {% if forloop.first %}active{% endif %}"
          data-tab="tab-{{ block.id }}"
        >
          <span class="ps-tab-desktop-text">{{ block.settings.title }}</span>
          
          <div class="ps-tab-icon {% if block.settings.icon == blank %}ps-tab-icon-placeholder{% endif %}">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 100 }}" alt="{{ block.settings.title }}">
            {% endif %}
          </div>
          
          <span class="ps-tab-mobile-text">{{ block.settings.title_mobile | default: block.settings.title }}</span>
        </button>
      {% endfor %}
    </div>

    <div class="ps-content-wrapper">

      {% for block in section.blocks %}
        <div
          class="ps-grid-container {% if forloop.first %}active{% endif %}"
          id="tab-{{ block.id }}"
        >

          {% assign collection = block.settings.collection %}

          {% if collection != blank %}

            {% for product in collection.products limit: 4 %}

              <a href="{{ product.url }}" class="ps-card">

                <div class="ps-image-box">
                  <img
                    src="{{ product.featured_image | img_url: '600x600' }}"
                    alt="{{ product.title }}"
                    class="ps-prod-img"
                    loading="lazy"
                  >
                </div>

                <div class="ps-info">

                  <h3 class="ps-title">

                    {% assign words = product.title | split: ' ' %}

                    {% for word in words %}
                      {% if forloop.index == 3 %}
                        <br>
                      {% endif %}
                      {{ word }}
                    {% endfor %}

                  </h3>

                  <p class="ps-price">
                    <span class="rupee">₹</span>

                    <span class="amount">
                      {{ product.price | divided_by: 100.0 | strip_trailing_zeros }}
                    </span>
                  </p>

                  <div class="ps-shop-btn">
                    SHOP NOW
                  </div>

                </div>

              </a>

            {% endfor %}

          {% endif %}

        </div>
      {% endfor %}

    </div>

    <a
      href="{{ section.settings.view_all_link | default: '#' }}"
      class="ps-view-all"
    >
      VIEW ALL PRODUCTS
    </a>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const tabs = document.querySelectorAll('.ps-tab-btn');
  const grids = document.querySelectorAll('.ps-grid-container');

  tabs.forEach(tab => {

    tab.addEventListener('click', () => {

      const tabId = tab.getAttribute('data-tab');

      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      grids.forEach(grid => {

        if (grid.id === tabId) {
          grid.classList.add('active');
        } else {
          grid.classList.remove('active');
        }

      });

    });

  });



});
</script>

{% schema %}
{
  "name": "Product Grid Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Who are we shopping for today?"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Products Link"
    }
  ],
  "blocks": [
    {
      "type": "category_tab",
      "name": "Category Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Label",
          "default": "For Dogs"
        },
        {
          "type": "text",
          "id": "title_mobile",
          "label": "Tab Label (Mobile)"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Tab Icon (Mobile)"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Grid Tabs",
      "blocks": [
        {
          "type": "category_tab",
          "settings": {
            "title": "All"
          }
        },
        {
          "type": "category_tab",
          "settings": {
            "title": "For Dogs"
          }
        },
        {
          "type": "category_tab",
          "settings": {
            "title": "For Cats"
          }
        }
      ]
    }
  ]
}
{% endschema %}