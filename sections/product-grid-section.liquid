{%- style -%}
.product-selection-{{ section.id }} {
  background-color: #FEEDDE;
  padding: 75px 0;
  font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  text-align: center;
  overflow: hidden;
}

.ps-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 40px;
}

/* =========================
   HEADING
========================= */

.ps-heading {
  font-size: clamp(32px, 5vw, 62px);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: #000;
  margin: 0 0 72px;
  font-family: 'Degular Demo', sans-serif !important;
}

.ps-heading span {
  color: #EE3E34;
}

.ps-heading-desktop {
  display: block;
}

.ps-heading-mobile {
  display: none;
}

/* =========================
   TABS
========================= */

.ps-tabs {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto 72px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 56px;
  position: relative;
  border-bottom: none;
}

.ps-tab-icon-wrap {
  display: flex;
  width: 90px;
  height: 90px;
  border-radius: 50%;
  align-items: center;
  justify-content: center;
  background: #EADCD6;
  transition: all 0.25s ease;
  overflow: hidden;
}

.ps-tab-btn.active .ps-tab-icon-wrap {
  background: #EE3E34;
}

.ps-tab-icon-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ps-tab-icon-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.1;
}

.ps-tab-btn {
  width: auto;
  height: auto;
  position: relative;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  font-family: 'Degular Demo' !important;
  color: #111111;
  transition: color 0.25s ease;
  text-align: center;
}

.ps-tab-btn.active {
  color: #EE3E34;
}

.ps-tab-text {
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

/* =========================
   GRID
========================= */

.ps-grid-container {
  display: none;
}

.ps-grid-container.active {
  display: flex;
  justify-content: center;
  gap: 56px;
  flex-wrap: wrap;
  margin-bottom: 72px;
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =========================
   PRODUCT CARD
========================= */

.ps-card {
  width: 220px;
  text-decoration: none;
  color: #000;

  display: flex;
  flex-direction: column;
  align-items: center;

  transition:
    transform 0.35s ease,
    opacity 0.9s ease;
}

.ps-card:hover {
  transform: translateY(-4px);
}

.ps-image-box {
  position: relative;

  width: 220px;
  height: 220px;

  display: flex;
  align-items: center;
  justify-content: center;

  margin-bottom: 26px;
}

.ps-prod-img {
  position: relative;
  z-index: 2;

  width: 88%;
  height: 88%;

  object-fit: contain;
  transition: transform 0.25s ease;
  border-radius: 16px;
  overflow: hidden;
}

.ps-card:hover .ps-prod-img {
  transform: scale(1.04);
}

/* =========================
   PRODUCT INFO
========================= */

.ps-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0 !important;
}

/* TITLE */

.ps-title {
  width: 220px;
  min-height: 78px;

  margin: -6px 0 14px 0 !important;

  text-align: center;

  font-family: 'Degular Demo' !important;
  font-size: 24px;
  font-weight: 700;
  line-height: 28px;
  letter-spacing: -0.02em;

  color: #111111;

  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* PRICE */

.ps-price {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 2px;

  margin: 0 0 18px 0;

  font-family: 'Degular Demo' !important;
  color: #1E1E1E;
}

.ps-price .rupee {
  font-size: 22px;
  line-height: 1;
  transform: translateY(6px);
}

.ps-price .amount {
  font-size: 34px;
  line-height: 1;
  font-weight: 400;
  letter-spacing: -0.03em;
}

/* =========================
   SHOP BUTTON
========================= */

.ps-shop-btn {
  width: 112px;
  height: 34px;

  background-color: #EE3E34;
  color: #fff;

  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.02em;

  border-radius: 100px;

  display: flex;
  align-items: center;
  justify-content: center;

  transition: all 0.25s ease;
  font-family: 'Degular Demo' !important;
}

.ps-card:hover .ps-shop-btn {
  background: #000;
}

/* =========================
   VIEW ALL BUTTON
========================= */

.ps-view-all {
  min-width: 250px;
  height: 66px;
  border-radius: 999px;

  background: #000;
  color: #fff;

  text-decoration: none;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;

  font-family: 'Degular Demo' !important;

  transition:
    transform 0.25s ease,
    background 0.25s ease;
}

.ps-view-all:hover {
  transform: scale(1.04);
  background: #EE3E34;
}

/* =========================
   SCROLL ANIMATION
========================= */

.ps-heading,
.ps-tabs,
.ps-card,
.ps-view-all {
  opacity: 0;
  transform: translateY(60px);

  transition:
    opacity 0.9s ease,
    transform 0.9s ease;

  will-change: transform, opacity;
}

.product-selection-{{ section.id }}.ps-show .ps-heading,
.product-selection-{{ section.id }}.ps-show .ps-tabs,
.product-selection-{{ section.id }}.ps-show .ps-card,
.product-selection-{{ section.id }}.ps-show .ps-view-all {
  opacity: 1;
  transform: translateY(0);
}

/* =========================
   MOBILE
========================= */

@media (max-width: 768px) {

  .product-selection-{{ section.id }} {
    padding: 72px 0;
  }

  .ps-container {
    padding: 0 20px;
  }

  .ps-heading {
    margin-bottom: 52px;
  }

  .ps-heading-desktop {
    display: none !important;
  }

  .ps-heading-mobile {
    display: block !important;
    font-size: 56px !important;
    line-height: 1;
  }

  .ps-tabs {
    margin-bottom: 46px;
    border-bottom: none !important;
    justify-content: center !important;
    gap: 12px !important;
    align-items: flex-start !important;
  }

  .ps-tab-btn {
    width: auto !important;
    height: auto !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 0 !important;
    margin: 0 !important;
    border-bottom: none !important;
    color: #555555 !important;
  }

  .ps-tab-btn.active {
    color: #EE3E34 !important;
  }

  .ps-tab-btn::after {
    display: none !important;
  }

  .ps-tab-icon-wrap {
    display: flex !important;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    background: #EADCD6;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .ps-tab-btn.active .ps-tab-icon-wrap {
    background: #EE3E34;
  }

  .ps-tab-icon-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ps-tab-icon-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.1;
  }

  .ps-tab-text {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
  }

  .ps-grid-container.active {
    gap: 36px;
  }

  .ps-card {
    width: calc(50% - 18px);
  }

  .ps-image-box {
    width: 160px;
    height: 160px;
    margin-bottom: 20px;
  }

  .ps-prod-img {
    border-radius: 12px;
  }

  .ps-title {
    width: 100%;
    min-height: 52px;

    font-size: 16px;
    line-height: 26px;
  }

  .ps-price .rupee {
    font-size: 16px;
    transform: translateY(4px);
  }

  .ps-price .amount {
    font-size: 28px;
  }

  .ps-view-all {
    min-width: 220px;
    height: 58px;
    font-size: 15px;
  }

  .ps-card.hidden {
    display: none !important;
  }
}
{%- endstyle -%}

<section class="product-selection-{{ section.id }}" id="ShoppingGrid">
  <div class="ps-container">

    <h2 class="ps-heading ps-heading-desktop">
      {{ section.settings.heading | replace: "shopping", "<span>shopping</span>" }}
    </h2>
    <h2 class="ps-heading ps-heading-mobile">
      {%- if section.settings.heading_mobile != blank -%}
        {{ section.settings.heading_mobile | replace: "shopping", "<span>shopping</span>" }}
      {%- else -%}
        {{ section.settings.heading | replace: "shopping", "<span>shopping</span>" }}
      {%- endif -%}
    </h2>

    <div class="ps-tabs-wrapper" style="position: relative; width: 100%; max-width: 1280px; margin: 0 auto 72px;">
      
      <!-- Level 1 Tabs (Main Categories) -->
      <div class="ps-tabs" data-level="1">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category_tab' or block.type == 'collection_tab' -%}
            {%- assign block_title = block.settings.title | default: block.settings.tab_title -%}
            {%- assign block_icon = block.settings.tab_icon | default: block.settings.tab_image -%}
            {%- assign collection_handle = block.settings.collection -%}
            {%- assign current_collection = collections[collection_handle] -%}
            {%- assign tab_title_clean = block_title | default: current_collection.title | strip | downcase -%}
            
            <button class="ps-tab-btn {% if forloop.first %}active{% endif %}" 
                    data-match-key="{{ tab_title_clean }}"
                    data-target-collection="{{ collection_handle | default: 'all-products' }}" 
                    {{ block.shopify_attributes }}>
              <div class="ps-tab-icon-wrap">
                {%- if block_icon != blank -%}
                  <img src="{{ block_icon | image_url: width: 160 }}" alt="{{ block_title | escape }}" loading="lazy" class="ps-tab-icon-img">
                {%- else -%}
                  <div class="ps-tab-icon-placeholder"></div>
                {%- endif -%}
              </div>
              <span class="ps-tab-text">{{ block_title | default: current_collection.title }}</span>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Level 2 Subcategories -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'category_tab' or block.type == 'collection_tab' -%}
          {%- assign block_title = block.settings.title | default: block.settings.tab_title -%}
          {%- assign current_l1_title = block_title | default: collections[block.settings.collection].title | strip | downcase -%}
          
          {%- capture subcategories_l2 -%}
            {%- for sub_block in section.blocks -%}
              {%- assign sub_parent_clean = sub_block.settings.parent_category | strip | downcase -%}
              {%- if sub_block.type == 'subcategory_tab' and sub_parent_clean == current_l1_title -%}
                {%- assign sub_title = sub_block.settings.title | default: sub_block.settings.tab_title -%}
                {%- assign sub_icon = sub_block.settings.tab_icon | default: sub_block.settings.tab_image -%}
                {%- assign sub_collection_handle = sub_block.settings.collection -%}
                {%- assign sub_collection = collections[sub_collection_handle] -%}
                {%- assign sub_title_clean = sub_title | default: sub_collection.title | strip | downcase -%}
                <button class="ps-tab-btn" 
                        data-match-key="{{ sub_title_clean }}"
                        data-target-collection="{{ sub_collection_handle | default: 'all-products' }}">
                  <div class="ps-tab-icon-wrap">
                    {%- if sub_icon != blank -%}
                      <img src="{{ sub_icon | image_url: width: 160 }}" alt="{{ sub_title | escape }}" loading="lazy" class="ps-tab-icon-img">
                    {%- else -%}
                      <div class="ps-tab-icon-placeholder"></div>
                    {%- endif -%}
                  </div>
                  <span class="ps-tab-text">{{ sub_title | default: sub_collection.title }}</span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}

          {%- if subcategories_l2 != blank -%}
            <div class="ps-subcategories-container ps-tabs hidden" data-level="2" data-parent-group="{{ current_l1_title }}">
              {{ subcategories_l2 }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      <!-- Level 3 Subcategories -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'subcategory_tab' -%}
          {%- assign sub_title = block.settings.title | default: block.settings.tab_title -%}
          {%- assign current_l2_title = sub_title | default: collections[block.settings.collection].title | strip | downcase -%}
          
          {%- capture subcategories_l3 -%}
            {%- for nested_block in section.blocks -%}
              {%- assign nested_parent_clean = nested_block.settings.parent_subcategory | strip | downcase -%}
              {%- if nested_block.type == 'nested_subcategory_tab' and nested_parent_clean == current_l2_title -%}
                {%- assign nest_title = nested_block.settings.title | default: nested_block.settings.tab_title -%}
                {%- assign nest_icon = nested_block.settings.tab_icon | default: nested_block.settings.tab_image -%}
                {%- assign nest_collection_handle = nested_block.settings.collection -%}
                {%- assign nest_collection = collections[nest_collection_handle] -%}
                <button class="ps-tab-btn" 
                        data-target-collection="{{ nest_collection_handle | default: 'all-products' }}">
                  <div class="ps-tab-icon-wrap">
                    {%- if nest_icon != blank -%}
                      <img src="{{ nest_icon | image_url: width: 160 }}" alt="{{ nest_title | escape }}" loading="lazy" class="ps-tab-icon-img">
                    {%- else -%}
                      <div class="ps-tab-icon-placeholder"></div>
                    {%- endif -%}
                  </div>
                  <span class="ps-tab-text">{{ nest_title | default: nest_collection.title }}</span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}

          {%- if subcategories_l3 != blank -%}
            <div class="ps-subcategories-container ps-tabs hidden" data-level="3" data-parent-group="{{ current_l2_title }}">
              {{ subcategories_l3 }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ps-content-wrapper">
      <div class="ps-grid-container active" id="ps-product-grid">
        {%- assign rendered_handles = "" -%}
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          {%- if collection != blank -%}
            {%- for product in collection.products limit: 40 -%}
              {%- unless rendered_handles contains product.handle -%}
                {%- assign rendered_handles = rendered_handles | append: product.handle | append: "," -%}
                
                <a href="{{ product.url }}" class="ps-card" data-collections='[{%- for c in product.collections -%}"{{ c.handle }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]'>
                  <div class="ps-image-box">
                    <img
                      src="{{ product.featured_image | img_url: '600x600' }}"
                      alt="{{ product.title }}"
                      class="ps-prod-img"
                      loading="lazy"
                    >
                  </div>
                  <div class="ps-info">
                    <h3 class="ps-title">
                      {% assign words = product.title | split: ' ' %}
                      {% for word in words %}
                        {% if forloop.index == 3 %}<br>{% endif %}
                        {{ word }}
                      {% endfor %}
                    </h3>
                    <p class="ps-price">
                      <span class="rupee">₹</span>
                      <span class="amount">
                        {{ product.price | divided_by: 100.0 | strip_trailing_zeros }}
                      </span>
                    </p>
                    <div class="ps-shop-btn">
                      SHOP NOW
                    </div>
                  </div>
                </a>
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <a
      href="{{ section.settings.view_all_link | default: '#' }}"
      class="ps-view-all"
    >
      VIEW ALL PRODUCTS
    </a>

  </div>
</section>

<script>
  function hasHomeChildren(tabEl) {
    if (!tabEl) return false;
    const matchKey = tabEl.getAttribute('data-match-key');
    if (!matchKey) return false;
    const parentContainer = tabEl.parentElement;
    const level = parseInt(parentContainer.getAttribute('data-level') || '1');
    if (level === 1) {
      return !!document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="2"][data-parent-group="${matchKey}"]`);
    } else if (level === 2) {
      return !!document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="3"][data-parent-group="${matchKey}"]`);
    }
    return false;
  }

  function getHomeCollectionPool(tabEl) {
    if (!tabEl) return [];
    
    const pool = new Set();
    
    // Add the tab's own target collection
    const selfCollection = tabEl.getAttribute('data-target-collection');
    if (selfCollection) {
      pool.add(selfCollection);
    }
    
    // Find children and grandchildren to pool their collections
    const matchKey = tabEl.getAttribute('data-match-key');
    const parentContainer = tabEl.parentElement;
    const level = parseInt(parentContainer.getAttribute('data-level') || '1');
    
    if (level === 1 && matchKey) {
      // Find Level 2 container
      const l2Container = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="2"][data-parent-group="${matchKey}"]`);
      if (l2Container) {
        const l2Tabs = l2Container.querySelectorAll('.ps-tab-btn:not(.ps-back-btn)');
        l2Tabs.forEach(l2Tab => {
          const l2Col = l2Tab.getAttribute('data-target-collection');
          if (l2Col) {
            pool.add(l2Col);
          }
          // For each Level 2 tab, check and add Level 3 grandchildren
          const l2Key = l2Tab.getAttribute('data-match-key');
          if (l2Key) {
            const l3Container = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="3"][data-parent-group="${l2Key}"]`);
            if (l3Container) {
              const l3Tabs = l3Container.querySelectorAll('.ps-tab-btn:not(.ps-back-btn)');
              l3Tabs.forEach(l3Tab => {
                const l3Col = l3Tab.getAttribute('data-target-collection');
                if (l3Col) {
                  pool.add(l3Col);
                }
              });
            }
          }
        });
      }
    } else if (level === 2 && matchKey) {
      // Find Level 3 container
      const l3Container = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="3"][data-parent-group="${matchKey}"]`);
      if (l3Container) {
        const l3Tabs = l3Container.querySelectorAll('.ps-tab-btn:not(.ps-back-btn)');
        l3Tabs.forEach(l3Tab => {
          const l3Col = l3Tab.getAttribute('data-target-collection');
          if (l3Col) {
            pool.add(l3Col);
          }
        });
      }
    }
    
    return Array.from(pool);
  }

  function injectHomeBackButtons() {
    const subContainers = document.querySelectorAll('#ShoppingGrid .ps-subcategories-container');
    subContainers.forEach(container => {
      if (container.querySelector('.ps-back-btn')) return;

      const backBtn = document.createElement('button');
      backBtn.type = 'button';
      backBtn.className = 'ps-tab-btn ps-back-btn';
      backBtn.innerHTML = `
        <div class="ps-tab-icon-wrap" style="border-color: #e5e5e5; background-color: #fafafa;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#c70e17" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
        </div>
        <span class="ps-tab-text" style="color: #c70e17; font-weight: 600;">Back</span>
      `;

      backBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        const level = parseInt(container.getAttribute('data-level' || '2'));
        if (level === 2) {
          // Go back to Level 1
          container.classList.add('hidden');
          const l1Container = document.querySelector('#ShoppingGrid .ps-tabs[data-level="1"]');
          if (l1Container) l1Container.classList.remove('hidden');
          
          // Deactivate all L2 tabs when going back to L1
          container.querySelectorAll('.ps-tab-btn').forEach(t => t.classList.remove('active'));
        } else if (level === 3) {
          // Go back to Level 2
          container.classList.add('hidden');
          const parentGroup = container.getAttribute('data-parent-group');
          const activeL2Tab = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="2"] .ps-tab-btn[data-match-key="${parentGroup}"]`);
          if (activeL2Tab) {
            const l2Container = activeL2Tab.parentElement;
            l2Container.classList.remove('hidden');
          }
          // Deactivate all L3 tabs when going back to L2
          container.querySelectorAll('.ps-tab-btn').forEach(t => t.classList.remove('active'));
        }
        filterHomeProducts();
      });

      container.insertBefore(backBtn, container.firstChild);
    });
  }

  function initHomeGrid() {
    injectHomeBackButtons();

    const allTabs = document.querySelectorAll('#ShoppingGrid .ps-tab-btn:not(.ps-back-btn)');
    
    allTabs.forEach(tab => {
      tab.removeEventListener('click', handleHomeTabClick);
      tab.addEventListener('click', handleHomeTabClick);
    });

    filterHomeProducts();

    const section = document.querySelector('.product-selection-{{ section.id }}');
    if (section) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            section.classList.add('ps-show');
          }
        });
      }, {
        threshold: 0.2
      });
      observer.observe(section);
    }
  }

  function handleHomeTabClick() {
    const parentContainer = this.parentElement;
    const currentLevel = parseInt(parentContainer.getAttribute('data-level') || '1');
    const matchKey = this.getAttribute('data-match-key');

    // Toggle active status within row
    parentContainer.querySelectorAll('.ps-tab-btn').forEach(t => t.classList.remove('active'));
    this.classList.add('active');

    if (currentLevel === 1) {
      const activeL2Container = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="2"][data-parent-group="${matchKey}"]`);
      if (activeL2Container) {
        parentContainer.classList.add('hidden');
        activeL2Container.classList.remove('hidden');
      }
    } 
    else if (currentLevel === 2) {
      const activeL3Container = document.querySelector(`#ShoppingGrid .ps-subcategories-container[data-level="3"][data-parent-group="${matchKey}"]`);
      if (activeL3Container) {
        parentContainer.classList.add('hidden');
        activeL3Container.classList.remove('hidden');
      }
    }

    filterHomeProducts();
  }

  function filterHomeProducts() {
    // 1. Find the Category Scope (active Level 1 tab collection)
    const activeL1 = document.querySelector('#ShoppingGrid .ps-tabs[data-level="1"] .ps-tab-btn.active');
    const scopeCollection = activeL1 ? activeL1.getAttribute('data-target-collection') : 'all-products';

    // 2. Find the deepest active tab across all containers
    let deepestActiveTab = null;
    const activeL3 = document.querySelector('#ShoppingGrid .ps-subcategories-container[data-level="3"] .ps-tab-btn.active');
    const activeL2 = document.querySelector('#ShoppingGrid .ps-subcategories-container[data-level="2"] .ps-tab-btn.active');

    if (activeL3) {
      deepestActiveTab = activeL3;
    } else if (activeL2) {
      deepestActiveTab = activeL2;
    } else if (activeL1) {
      deepestActiveTab = activeL1;
    }

    const activeCollections = getHomeCollectionPool(deepestActiveTab);
    const cards = document.querySelectorAll('#ps-product-grid .ps-card');

    let visibleCount = 0;
    cards.forEach(card => {
      const pCollections = JSON.parse(card.getAttribute('data-collections') || '[]');
      let show = true;

      // Filter by Category Scope (Level 1 category restriction)
      if (scopeCollection && scopeCollection !== 'all-products' && scopeCollection !== 'cats-copy-1') {
        if (!pCollections.includes(scopeCollection)) {
          show = false;
        }
      }

      // Filter by active collection pool (progressive aggregate filtering)
      if (show && activeCollections.length > 0 && !activeCollections.includes('all-products') && !activeCollections.includes('cats-copy-1')) {
        const matchCol = pCollections.some(col => activeCollections.includes(col));
        if (!matchCol) {
          show = false;
        }
      }

      if (show && visibleCount < 4) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });
  }

  // Run initialization immediately or on DOMContentLoaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHomeGrid);
  } else {
    initHomeGrid();
  }

  // Also hook into Shopify Theme Editor section load/reload event
  document.addEventListener("shopify:section:load", function(event) {
    if (event.detail.sectionId === "{{ section.id }}") {
      initHomeGrid();
    }
  });
</script>

