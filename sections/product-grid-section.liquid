{%- style -%}
.product-selection-{{ section.id }} {
  background-color: #FEEDDE;
  padding: 75px 0;
  font-family: "Degular Demo", -apple-system, BlinkMacSystemFont, sans-serif;
  text-align: center;
  overflow: hidden;
}

.ps-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 40px;
}

/* =========================
   HEADING
========================= */

.ps-heading {
  font-size: clamp(32px, 5vw, 62px);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: #000;
  margin: 0 0 72px;
  font-family: 'Degular Demo', sans-serif !important;
}

.ps-heading span {
  color: #EE3E34;
}

.ps-heading-desktop {
  display: block;
}

.ps-heading-mobile {
  display: none;
}

/* =========================
   TABS
========================= */

.ps-tabs {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto 72px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 56px;
  position: relative;
  border-bottom: none;
}

.ps-tab-icon-wrap {
  display: flex;
  width: 90px;
  height: 90px;
  border-radius: 50%;
  align-items: center;
  justify-content: center;
  background: #EADCD6;
  transition: all 0.25s ease;
  overflow: hidden;
}

.ps-tab-btn.active .ps-tab-icon-wrap {
  background: #EE3E34;
}

.ps-tab-icon-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ps-tab-icon-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.1;
}

.ps-tab-btn {
  width: auto;
  height: auto;
  position: relative;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  font-family: 'Degular Demo' !important;
  color: #111111;
  transition: color 0.25s ease;
  text-align: center;
}

.ps-tab-btn.active {
  color: #EE3E34;
}

.ps-tab-text {
  font-size: 20px;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

/* =========================
   GRID
========================= */

.ps-grid-container {
  display: none;
}

.ps-grid-container.active {
  display: flex;
  justify-content: center;
  gap: 56px;
  flex-wrap: wrap;
  margin-bottom: 72px;
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =========================
   PRODUCT CARD
========================= */

.ps-card {
  width: 220px;
  text-decoration: none;
  color: #000;

  display: flex;
  flex-direction: column;
  align-items: center;

  transition:
    transform 0.35s ease,
    opacity 0.9s ease;
}

.ps-card:hover {
  transform: translateY(-4px);
}

.ps-image-box {
  position: relative;

  width: 220px;
  height: 220px;

  display: flex;
  align-items: center;
  justify-content: center;

  margin-bottom: 26px;
}

.ps-prod-img {
  position: relative;
  z-index: 2;

  width: 88%;
  height: 88%;

  object-fit: contain;
  transition: transform 0.25s ease;
}

.ps-card:hover .ps-prod-img {
  transform: scale(1.04);
}

/* =========================
   PRODUCT INFO
========================= */

.ps-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0 !important;
}

/* TITLE */

.ps-title {
  width: 220px;
  min-height: 78px;

  margin: -6px 0 14px 0 !important;

  text-align: center;

  font-family: 'Degular Demo' !important;
  font-size: 24px;
  font-weight: 700;
  line-height: 28px;
  letter-spacing: -0.02em;

  color: #111111;

  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* PRICE */

.ps-price {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 2px;

  margin: 0 0 18px 0;

  font-family: 'Degular Demo' !important;
  color: #1E1E1E;
}

.ps-price .rupee {
  font-size: 22px;
  line-height: 1;
  transform: translateY(6px);
}

.ps-price .amount {
  font-size: 34px;
  line-height: 1;
  font-weight: 400;
  letter-spacing: -0.03em;
}

/* =========================
   SHOP BUTTON
========================= */

.ps-shop-btn {
  width: 112px;
  height: 34px;

  background-color: #EE3E34;
  color: #fff;

  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.02em;

  border-radius: 100px;

  display: flex;
  align-items: center;
  justify-content: center;

  transition: all 0.25s ease;
  font-family: 'Degular Demo' !important;
}

.ps-card:hover .ps-shop-btn {
  background: #000;
}

/* =========================
   VIEW ALL BUTTON
========================= */

.ps-view-all {
  min-width: 250px;
  height: 66px;
  border-radius: 999px;

  background: #000;
  color: #fff;

  text-decoration: none;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;

  font-family: 'Degular Demo' !important;

  transition:
    transform 0.25s ease,
    background 0.25s ease;
}

.ps-view-all:hover {
  transform: scale(1.04);
  background: #EE3E34;
}

/* =========================
   SCROLL ANIMATION
========================= */

.ps-heading,
.ps-tabs,
.ps-card,
.ps-view-all {
  opacity: 0;
  transform: translateY(60px);

  transition:
    opacity 0.9s ease,
    transform 0.9s ease;

  will-change: transform, opacity;
}

.product-selection-{{ section.id }}.ps-show .ps-heading,
.product-selection-{{ section.id }}.ps-show .ps-tabs,
.product-selection-{{ section.id }}.ps-show .ps-card,
.product-selection-{{ section.id }}.ps-show .ps-view-all {
  opacity: 1;
  transform: translateY(0);
}

/* =========================
   MOBILE
========================= */

@media (max-width: 768px) {

  .product-selection-{{ section.id }} {
    padding: 72px 0;
  }

  .ps-container {
    padding: 0 20px;
  }

  .ps-heading {
    margin-bottom: 52px;
  }

  .ps-heading-desktop {
    display: none !important;
  }

  .ps-heading-mobile {
    display: block !important;
    font-size: 56px !important;
    line-height: 0.9;
  }

  .ps-tabs {
    margin-bottom: 46px;
    border-bottom: none !important;
    justify-content: center !important;
    gap: 12px !important;
    align-items: flex-start !important;
  }

  .ps-tab-btn {
    width: auto !important;
    height: auto !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 0 !important;
    margin: 0 !important;
    border-bottom: none !important;
    color: #555555 !important;
  }

  .ps-tab-btn.active {
    color: #EE3E34 !important;
  }

  .ps-tab-btn::after {
    display: none !important;
  }

  .ps-tab-icon-wrap {
    display: flex !important;
    width: 76px;
    height: 76px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    background: #EADCD6;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .ps-tab-btn.active .ps-tab-icon-wrap {
    background: #EE3E34;
  }

  .ps-tab-icon-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ps-tab-icon-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.1;
  }

  .ps-tab-text {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
  }

  .ps-grid-container.active {
    gap: 36px;
  }

  .ps-card {
    width: calc(50% - 18px);
  }

  .ps-image-box {
    width: 160px;
    height: 160px;
    margin-bottom: 20px;
  }

  .ps-title {
    width: 100%;
    min-height: 52px;

    font-size: 16px;
    line-height: 26px;
  }

  .ps-price .rupee {
    font-size: 16px;
    transform: translateY(4px);
  }

  .ps-price .amount {
    font-size: 28px;
  }

  .ps-view-all {
    min-width: 220px;
    height: 58px;
    font-size: 15px;
  }
}
{%- endstyle -%}

<section class="product-selection-{{ section.id }}" id="ShoppingGrid">
  <div class="ps-container">

    <h2 class="ps-heading ps-heading-desktop">
      {{ section.settings.heading | replace: "shopping", "<span>shopping</span>" }}
    </h2>
    <h2 class="ps-heading ps-heading-mobile">
      {%- if section.settings.heading_mobile != blank -%}
        {{ section.settings.heading_mobile | replace: "shopping", "<span>shopping</span>" }}
      {%- else -%}
        {{ section.settings.heading | replace: "shopping", "<span>shopping</span>" }}
      {%- endif -%}
    </h2>

    <div class="ps-tabs">
      {% for block in section.blocks %}
        <button
          class="ps-tab-btn {% if forloop.first %}active{% endif %}"
          data-tab="tab-{{ block.id }}"
        >
          <div class="ps-tab-icon-wrap">
            {% if block.settings.tab_icon != blank %}
              <img
                src="{{ block.settings.tab_icon | image_url: width: 160 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                class="ps-tab-icon-img"
              >
            {% else %}
              <div class="ps-tab-icon-placeholder"></div>
            {% endif %}
          </div>
          <span class="ps-tab-text">{{ block.settings.title }}</span>
        </button>
      {% endfor %}
    </div>

    <div class="ps-content-wrapper">

      {% for block in section.blocks %}
        <div
          class="ps-grid-container {% if forloop.first %}active{% endif %}"
          id="tab-{{ block.id }}"
        >

          {% assign collection = block.settings.collection %}

          {% if collection != blank %}

            {% for product in collection.products limit: 4 %}

              <a href="{{ product.url }}" class="ps-card">

                <div class="ps-image-box">
                  <img
                    src="{{ product.featured_image | img_url: '600x600' }}"
                    alt="{{ product.title }}"
                    class="ps-prod-img"
                    loading="lazy"
                  >
                </div>

                <div class="ps-info">

                  <h3 class="ps-title">

                    {% assign words = product.title | split: ' ' %}

                    {% for word in words %}
                      {% if forloop.index == 3 %}
                        <br>
                      {% endif %}
                      {{ word }}
                    {% endfor %}

                  </h3>

                  <p class="ps-price">
                    <span class="rupee">₹</span>

                    <span class="amount">
                      {{ product.price | divided_by: 100.0 | strip_trailing_zeros }}
                    </span>
                  </p>

                  <div class="ps-shop-btn">
                    SHOP NOW
                  </div>

                </div>

              </a>

            {% endfor %}

          {% endif %}

        </div>
      {% endfor %}

    </div>

    <a
      href="{{ section.settings.view_all_link | default: '#' }}"
      class="ps-view-all"
    >
      VIEW ALL PRODUCTS
    </a>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const tabs = document.querySelectorAll('.ps-tab-btn');
  const grids = document.querySelectorAll('.ps-grid-container');

  tabs.forEach(tab => {

    tab.addEventListener('click', () => {

      const tabId = tab.getAttribute('data-tab');

      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      grids.forEach(grid => {

        if (grid.id === tabId) {
          grid.classList.add('active');
        } else {
          grid.classList.remove('active');
        }

      });

    });

  });

  const section = document.querySelector('.product-selection-{{ section.id }}');

  const observer = new IntersectionObserver((entries) => {

    entries.forEach(entry => {

      if (entry.isIntersecting) {
        section.classList.add('ps-show');
      }

    });

  }, {
    threshold: 0.2
  });

  observer.observe(section);

});
</script>

{% schema %}
{
  "name": "Product Grid Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Desktop Heading",
      "default": "Who are we shopping for today?"
    },
    {
      "type": "text",
      "id": "heading_mobile",
      "label": "Mobile Heading",
      "default": "Who are we shopping for today?"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Products Link"
    }
  ],
  "blocks": [
    {
      "type": "category_tab",
      "name": "Category Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Label",
          "default": "For Dogs"
        },
        {
          "type": "image_picker",
          "id": "tab_icon",
          "label": "Tab Icon"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Grid Tabs",
      "blocks": [
        {
          "type": "category_tab",
          "settings": {
            "title": "All"
          }
        },
        {
          "type": "category_tab",
          "settings": {
            "title": "For Dogs"
          }
        },
        {
          "type": "category_tab",
          "settings": {
            "title": "For Cats"
          }
        }
      ]
    }
  ]
}
{% endschema %}