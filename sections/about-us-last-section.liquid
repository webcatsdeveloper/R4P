{%- style -%}
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  /* Typography Dynamic Controls */
  #section-{{ section.id }} .purp-heading-black {
    color: {{ section.settings.color_heading_1 }};
  }
  #section-{{ section.id }} .purp-heading-red {
    color: {{ section.settings.color_heading_2 }};
  }
  
  /* SVG Stroke Colors */
  #section-{{ section.id }} .purp-sparkle path {
    stroke: {{ section.settings.color_heading_2 }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}" class="purp-thinking-section">
  <div class="purp-container">

    <div class="purp-col-left purp-scroll-animate stagger-1">
      <h2 class="purp-main-title">
        <span class="purp-heading-black">
          {%- if section.settings.title_top == 'Today, the thinking' -%}
            Today, the<br class="purp-mobile-br"> thinking
          {%- else -%}
            {{ section.settings.title_top }}
          {%- endif -%}
        </span><br class="purp-desktop-br">
        <span class="purp-heading-red">
          {%- if section.settings.title_bottom == 'remains the same.' -%}
            remains<br class="purp-mobile-br"> the same.
          {%- else -%}
            {{ section.settings.title_bottom }}
          {%- endif -%}
        </span>
      </h2>
      
      {% comment %} <div class="purp-sparkle-wrapper">
        <svg class="purp-sparkle" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M30 10 Q35 30 55 35 Q35 40 30 60 Q25 40 5 35 Q25 30 30 10Z" stroke-width="4" stroke-linejoin="round"/>
          <path d="M75 50 Q78 65 90 68 Q78 71 75 85 Q72 71 60 68 Q72 65 75 50Z" stroke-width="4" stroke-linejoin="round"/>
        </svg>
      </div> {% endcomment %}
    </div>

    <div class="purp-col-center purp-scroll-animate stagger-2">
      <svg class="purp-sunburst" viewBox="0 0 120 60" fill="none" stroke="#000" stroke-width="3" stroke-linecap="round">
        <path d="M30 50 L10 20" />
        <path d="M60 40 L55 5" />
        <path d="M90 50 L105 25" />
      </svg>

      <div class="purp-image-wrap">
        {% if section.settings.mobile_image != blank %}
          {{ section.settings.mobile_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.mobile_image.alt, class: 'purp-dog-img purp-mobile-img-only' }}
        {% endif %}
        {% if section.settings.main_image != blank %}
          {%- assign img_class = 'purp-dog-img' -%}
          {%- if section.settings.mobile_image != blank -%}
            {%- assign img_class = 'purp-dog-img purp-desktop-img-only' -%}
          {%- endif -%}
          {{ section.settings.main_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.main_image.alt, class: img_class }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'purp-placeholder' }}
        {% endif %}
      </div>
    </div>

    <div class="purp-col-right purp-scroll-animate stagger-3">
      <ul class="purp-features-list">
        
        <li class="purp-feature-item">
          <svg class="purp-drawn-arrow purp-arrow-1" viewBox="0 0 60 30" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 25 C 20 15, 40 10, 55 15" />
            <path d="M45 5 L55 15 L42 22" />
          </svg>
          <span class="purp-feature-text">{{ section.settings.point_1 }}</span>
        </li>

        <li class="purp-feature-item">
          <svg class="purp-drawn-arrow purp-arrow-2" viewBox="0 0 60 30" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 15 Q 30 5, 55 15" />
            <path d="M45 5 L55 15 L45 25" />
          </svg>
          <span class="purp-feature-text">{{ section.settings.point_2 }}</span>
        </li>

        <li class="purp-feature-item">
          <svg class="purp-drawn-arrow purp-arrow-3" viewBox="0 0 60 40" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 5 C 20 20, 35 30, 55 25" />
            <path d="M45 35 L55 25 L45 15" />
          </svg>
          <span class="purp-feature-text">{{ section.settings.point_3 }}</span>
        </li>

      </ul>

      <div class="purp-right-paragraph">
        {{ section.settings.paragraph_text }}
      </div>
    </div>

  </div>
</div>

<style>
  /* --- Structural Layout Baseline --- */
  .purp-thinking-section {
    width: 100%;
    padding: 100px 0 0 0; /* No bottom padding so banner sits flush */
    overflow: hidden;
    position: relative;
    font-family: inherit;
  }

  .purp-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 100px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 40px;
    position: relative;
    z-index: 10;
  }

  /* --- Left Column Typography --- */
  .purp-col-left {
    position: relative;
    padding-bottom: 40px;
  }

  .purp-main-title {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    line-height: 1.1;
    margin-top: -20px;
    letter-spacing: -0.02em;
  }

  .purp-sparkle-wrapper {
    position: absolute;
    bottom: -20px;
    right: 20px;
    width: 80px;
    height: 80px;
  }

  /* --- Center Column Image --- */
  .purp-col-center {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .purp-sunburst {
    display:none;
  }

  .purp-image-wrap {
    width: 320px;
    max-width: 100%;
    position: relative;
    z-index: 10;
  }

  .purp-dog-img, .purp-placeholder {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* --- Right Column Features --- */
  .purp-col-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 20px;
  }

  .purp-features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
    display: flex;
    flex-direction: column;
    gap: 45px;
  }

  .purp-feature-item {
    position: relative;
    font-size: 18px;
    font-weight: 700;
    color: #000;
  }

  /* Absolutely position the hand-drawn arrows pulling left */
  .purp-drawn-arrow {
    position: absolute;
    right: 100%; /* pushes it to the left of the text */
    margin-right: 15px;
    width: 50px;
    top: 50%;
    transform: translateY(-50%);
  }
  
  /* Slight offset adjustments to perfectly match the drawn look */
  .purp-arrow-1 { top: 60%; width: 55px; }
  .purp-arrow-2 { top: 50%; width: 60px; margin-right: 10px; }
  .purp-arrow-3 { top: 40%; width: 55px; }

  .purp-right-paragraph {
    font-size: 19px;
    line-height: 1.5;
    color: #555;
    max-width: 320px!important;
  }

  /* --- Staggered Scroll Animations --- */
  .purp-scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }

  .purp-scroll-animate.is-animated {
    opacity: 1;
    transform: translateY(0);
  }
  .purp-feature-text {
      font-size: 26px !important;}

  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.25s; }
  .stagger-3 { transition-delay: 0.4s; }

  /* --- Hide mobile-only elements on desktop --- */
  .purp-mobile-img-only,
  .purp-mobile-br {
    display: none;
  }

  /* --- Mobile Optimization Breakpoints --- */
  @media screen and (max-width: 989px) {
    .purp-thinking-section {
      padding: 60px 0 0 0 !important;
    }

    .purp-container {
      grid-template-columns: 1fr !important;
      text-align: center;
      gap: 40px !important;
      padding: 0 10px !important;
    }
    
    /* Order of stacking */
    .purp-col-left {
      order: 1 !important;
      padding-bottom: 0 !important;
      text-align: left !important;
      width: 100% !important;
    }

    .purp-col-right {
      order: 2 !important;
      padding: 13px !important;
      align-items: center !important;
      width: 100% !important;
    }

    .purp-col-center {
      order: 3 !important;
      position: relative !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-end !important;
      width: 100% !important;
      max-width: 300px !important;
      margin: 0 auto !important;
      padding-top: 0 !important;
    }

    /* Sparkle wrapper on title is hidden */
    .purp-sparkle-wrapper {
      display: none !important;
    }

    /* Main Title Mobile styling */
    .purp-main-title {
      font-size: 38px !important;
      line-height: 1.15 !important;
      font-weight: 900 !important;
      letter-spacing: -0.02em !important;
      text-align: left !important;
      margin-left: 15px !important;
    }

    .purp-desktop-br {
      display: none !important;
    }

    .purp-mobile-br {
      display: block !important;
    }

    /* Features List layout with dividers */
    .purp-features-list {
      width: 100% !important;
      align-items: center !important;
      gap: 0 !important;
      margin: 0 !important;
    }

    .purp-feature-item {
      width: 100% !important;
      padding: 20px 0 !important;
      border-bottom: 1px solid #000 !important;
      text-align: center !important;
      font-size: 18px !important;
      font-weight: 700 !important;
      margin: 0 !important;
      position: relative !important;
    }

    .purp-feature-item:last-child {
      border-bottom: none !important;
      padding-bottom: 0 !important;
    }

    .purp-feature-text {
      font-size: 35px !important;
      font-weight: 700 !important;
      color: #1F1F1F !important;
    }

    /* Hide default hand-drawn arrows in list items */
    .purp-drawn-arrow {
      display: none !important;
    }

    /* Hide the right column extra paragraph */
    .purp-right-paragraph {
      display: none !important;
    }

    /* Hide the sunburst SVG on mobile */
    .purp-sunburst {
      display: none !important;
    }

    .purp-image-wrap {
      width: 100% !important;
      z-index: 10 !important;
      margin: 0 !important;
    }

    .purp-dog-img {
      width: 100% !important;
      height: auto !important;
      display: block !important;
    }

    /* Mobile/Desktop image toggling */
    .purp-desktop-img-only {
      display: none !important;
    }

    .purp-mobile-img-only {
      display: block !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = { root: null, threshold: 0.15, rootMargin: '0px 0px -50px 0px' };
    
    const elementsToAnimate = document.querySelectorAll('#section-{{ section.id }} .purp-scroll-animate');
    
    const purpObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-animated');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    elementsToAnimate.forEach(el => purpObserver.observe(el));
  });
</script>

{% schema %}
{
  "name": "Thinking Features Split",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_heading_1",
      "label": "Top Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "color_heading_2",
      "label": "Bottom Heading & Banner Color",
      "default": "#D32F2F"
    },
    {
      "type": "header",
      "content": "Left Column Content"
    },
    {
      "type": "text",
      "id": "title_top",
      "label": "Top Heading Text",
      "default": "Today, the thinking"
    },
    {
      "type": "text",
      "id": "title_bottom",
      "label": "Bottom Heading Text",
      "default": "remains the same."
    },
    {
      "type": "header",
      "content": "Center Column Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Center Main Image (Transparent PNG recommended)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Main Image (Will use desktop image if blank)"
    },
    {
      "type": "header",
      "content": "Right Column Features"
    },
    {
      "type": "text",
      "id": "point_1",
      "label": "Feature Point 1",
      "default": "Do what's right for them."
    },
    {
      "type": "text",
      "id": "point_2",
      "label": "Feature Point 2",
      "default": "Make it simple."
    },
    {
      "type": "text",
      "id": "point_3",
      "label": "Feature Point 3",
      "default": "Make it something you can trust."
    },
    {
      "type": "richtext",
      "id": "paragraph_text",
      "label": "Bottom Subtext Paragraph",
      "default": "<p>Because when it comes to them, getting it right shouldn't feel complicated.</p>"
    }
  ],
  "presets": [
    {
      "name": "Thinking Features Split"
    }
  ]
}
{% endschema %}