{% comment %}
  Real Pets / Real Outcomes Section
  Auto Scroll + Scroll Animation
{% endcomment %}

{%- style -%}

.reels-{{ section.id }}{
  position:relative;
  width:100%;
  background:#FEEDDE;
  overflow:hidden;
  padding:70px 0 80px;
  font-family:'Degular Demo', sans-serif;

  opacity:0;
  transform:translateY(80px);
  transition:all .9s ease;
}

.reels-{{ section.id }}.show{
  opacity:1;
  transform:translateY(0);
}

/* CONTAINER */
.reels-container{
  width:100%;
  max-width:1280px;
  margin:0 auto;
  padding:0 40px;
  position:relative;
  z-index:5;
  box-sizing:border-box;
}

/* HEADER */
.reels-header{
  display:grid;
  grid-template-columns:1fr 360px;
  align-items:start;
  column-gap:90px;
  margin-bottom:58px;
}

/* TITLE */
.reels-heading{
  margin:0;
  font-size:76px;
  line-height:0.92;
  font-weight:700;
  letter-spacing:-3px;
  color:#000;
  font-family:'Degular Demo'!important;

  opacity:0;
  transform:translateX(-80px);
  transition:all .8s ease .2s;
}

.reels-{{ section.id }}.show .reels-heading{
  opacity:1;
  transform:translateX(0);
}

.reels-heading span{
  display:block;
  color:#E1262B;
}

/* DESCRIPTION */
.reels-subtext{
  margin:18px 0 0;
  max-width:340px;
  font-size:20px;
  line-height:1.45;
  font-weight:400;
  color:#444;
  font-family:'Degular Demo'!important;

  opacity:0;
  transform:translateX(80px);
  transition:all .8s ease .35s;
}

.reels-{{ section.id }}.show .reels-subtext{
  opacity:1;
  transform:translateX(0);
}

/* CAROUSEL */
.reels-carousel-outer{
  position:relative;
  width:100%;
  overflow:hidden;

  opacity:0;
  transform:translateY(60px);
  transition:all .9s ease .45s;
}

.reels-{{ section.id }}.show .reels-carousel-outer{
  opacity:1;
  transform:translateY(0);
}

/* AUTO SCROLL TRACK */
.reels-track{
  display:flex;
  gap:36px;
  width:max-content;
  animation:autoScroll 20s linear infinite;
  padding-bottom:34px;
}

.reels-track:hover{
  animation-play-state:paused;
}

@keyframes autoScroll{
  from{
    transform:translateX(0);
  }
  to{
    transform:translateX(calc(-50% - 18px));
  }
}

/* CARD */
.reel-card{
  position:relative;
  width:290px;
  min-width:290px;
  height:390px;
  border-radius:18px;
  overflow:hidden;
  background:#ddd;
  flex-shrink:0;
}

.reel-card img,
.reel-card video{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

/* WAVE */
.reels-wave-bg{
  position:absolute;
  left:50%;
  top:60%;
  transform:translate(-50%,-50%);
  width:1700px;
  z-index:1;
  pointer-events:none;

  opacity:0;
  transition:opacity 1.2s ease .4s;
}

.reels-{{ section.id }}.show .reels-wave-bg{
  opacity:1;
}

.reels-wave-bg svg{
  width:100%;
  height:auto;
}

/* DOTS */
.reels-dots{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:7px;
  margin-top:4px;
}

.reels-dot{
  width:6px;
  height:6px;
  border-radius:50%;
  background:#CFCFCF;
}

.reels-dot.active{
  background:#E1262B;
}

/* LAPTOP */
@media screen and (max-width:1100px){

  .reels-header{
    grid-template-columns:1fr;
    row-gap:22px;
  }

  .reels-subtext{
    margin:0;
    max-width:100%;
  }

  .reels-heading{
    font-size:62px;
  }

  .reels-track{
    gap:24px;
  }

}

/* MOBILE */
@media screen and (max-width:768px){

  .reels-{{ section.id }}{
    padding:60px 0;
  }

  .reels-container{
    padding:0 20px;
  }

  .reels-heading{
    font-size:46px;
    letter-spacing:-1px;
    line-height:0.96;
  }

  .reels-subtext{
    font-size:16px;
    line-height:1.5;
  }

  .reels-track{
    gap:18px;
  }

  .reel-card{
    width:220px;
    min-width:220px;
    height:390px;
  }

  .reels-wave-bg{
    width:1400px;
    top:62%;
  }

}

{%- endstyle -%}

<section class="reels-{{ section.id }}" id="reels-section-{{ section.id }}">

  <!-- WAVE -->
  <div class="reels-wave-bg">
    <svg viewBox="0 0 2039 273" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M-50 150C200 50 400 250 650 180C900 110 1100 280 1350 200C1600 120 1800 220 2100 140"
        stroke="#7B79B0"
        stroke-width="12"
        stroke-linecap="round"/>
    </svg>
  </div>

  <div class="reels-container">

    <!-- HEADER -->
    <div class="reels-header">

      <h2 class="reels-heading">
        {{ section.settings.heading | replace: 'Real outcomes.', '<span>Real outcomes.</span>' }}
      </h2>

      <div class="reels-subtext">
        {{ section.settings.subtext | newline_to_br }}
      </div>

    </div>

    <!-- VIDEOS -->
    <div class="reels-carousel-outer">

      <div class="reels-track">

        {% for i in (1..2) %}
          {% for block in section.blocks limit: 4 %}

            <div class="reel-card" {{ block.shopify_attributes }}>

              {% if block.settings.video_url != blank %}

                <video
                  src="{{ block.settings.video_url }}"
                  autoplay
                  muted
                  loop
                  playsinline>
                </video>

              {% elsif block.settings.image != blank %}

                <img
                  src="{{ block.settings.image | img_url: '700x1200' }}"
                  alt="Pet video"
                  loading="lazy">

              {% endif %}

            </div>

          {% endfor %}
        {% endfor %}

      </div>

      <!-- DOTS -->
      <div class="reels-dots">
        <span class="reels-dot active"></span>
        <span class="reels-dot"></span>
        <span class="reels-dot"></span>
        <span class="reels-dot"></span>
      </div>

    </div>

  </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", function(){

  const section = document.querySelector("#reels-section-{{ section.id }}");

  const observer = new IntersectionObserver((entries)=>{
    entries.forEach((entry)=>{
      if(entry.isIntersecting){
        section.classList.add("show");
      }
    });
  },{
    threshold:0.2
  });

  observer.observe(section);

});
</script>

{% schema %}
{
  "name": "Real Outcomes Reels",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real pets. Real outcomes."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Description",
      "default": "From improved energy to visible health changes, here’s what pet parents have experienced over time with Right 4 Paws."
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Outcomes Reels",
      "blocks": [
        {
          "type": "reel"
        },
        {
          "type": "reel"
        },
        {
          "type": "reel"
        },
        {
          "type": "reel"
        }
      ]
    }
  ]
}
{% endschema %}