<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: visible;
    margin-top:-20px;
  }

  .oab-wrapper {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    {% comment %} background-color: #F6C45E; {% endcomment %}
    overflow: visible;
    display: flex;
    flex-direction: column;
  }

  .oab-container {
    position: relative;
    max-width: 1200px;
    height: 100%;
    margin: 0 auto;
    padding: 0 40px;
    box-sizing: border-box;
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  /* TOP BLOCK STYLING */
  .oab-top-block {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9.5;
    {% if section.settings.top_bg_image %}
      background-image: url('{{ section.settings.top_bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .oab-top-heading {
    position: absolute;
    top: 5%;
    right: 0px;
    width: 45%;
    font-size: clamp(24px, 2.6vw, 26px);
    font-weight: 800;
    line-height: 1.2;
    color: #111111;
    text-align: right;
  }

  .oab-text-red {
    color: #d92b2b !important;
  }

  /* BOTTOM BLOCK STYLING */
  .oab-bottom-block {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    {% if section.settings.bg_image %}
      background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center bottom;
      background-repeat: no-repeat;
    {% endif %}
  }

  .oab-text-1 {
    position: absolute;
    top: 15%;
    right: 40px;
    width: 50%;
    font-size: clamp(24px, 2.5vw, 26px);
    font-weight: 800;
    line-height: 1.25;
    color: #111111;
    text-align: left;
  }

  .oab-text-2 {
    position: absolute;
    top: 32%;
    left: 50%;
    transform: translateX(-50%);
    width: 63%;
    font-size: clamp(14px, 1.2vw, 16px);
    font-weight: 500;
    line-height: 1.6;
    color: #111111;
    text-align: center;
  }

  .oab-text-3 {
    position: absolute;
    bottom: 12%;
    left: 40px;
    width: 32%;
    font-size: clamp(14px, 1.2vw, 16px);
    font-weight: 200;
    line-height: 1.4;
    color: #111111;
    text-align: left;
  }

  /* Desktop-only positioning adjustments for attaching sections */
  @media screen and (min-width: 990px) {
    .oab-mobile-only {
      display: none !important;
    }
    .oab-top-heading {
      display: none !important; /* Hide duplicate top heading on desktop */
    }
    .oab-top-block {
      z-index: 5;
      margin-bottom: -13vw; /* Overlaps bottom block to hide the gap */
    }
    .oab-bottom-block {
      z-index: 2;
    }
  }

  @media screen and (max-width: 989px) {
    .oab-desktop-only {
      display: none !important;
    }

    .oab-wrapper {
      width: 100%;
      left: 0;
      transform: none;
    }

    /* TOP BLOCK RESPONSIVE */
    .oab-top-block {
      aspect-ratio: auto;
      width: 100%;
      background-color: #FECC66;
      background-blend-mode: multiply;
      {% if section.settings.top_bg_image_mobile %}
        background-image: url('{{ section.settings.top_bg_image_mobile | img_url: 'master' }}');
      {% elsif section.settings.top_bg_image %}
        background-image: url('{{ section.settings.top_bg_image | img_url: 'master' }}');
      {% else %}
        background-image: none;
      {% endif %}
      background-position: center center;
      background-size: 100% auto;
      background-repeat: no-repeat;
    }

    .oab-top-block .oab-container {
      padding: 0px 20px clamp(600px, 60vw, 380px) 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .oab-top-heading {
      position: static !important;
      width: 100% !important;
      transform: none !important;
      text-align: center !important;
      font-size: clamp(20px, 6vw, 28px);
    }

    /* BOTTOM BLOCK RESPONSIVE */
    .oab-bottom-block {
      aspect-ratio: auto;
      width: 100%;
      background-color: transparent;
      background-image: 
        {% if section.settings.bg_image_mobile %}
          url('{{ section.settings.bg_image_mobile | img_url: 'master' }}'),
        {% elsif section.settings.bg_image %}
          url('{{ section.settings.bg_image | img_url: 'master' }}'),
        {% endif %}
        linear-gradient(to bottom, #FECC66 0%, #FECC66 calc(100% - 230px), #ffffff calc(100% - 90px), #ffffff 100%);
      background-position: center bottom, center top;
      background-size: 100% auto, 100% 100%;
      background-repeat: no-repeat, no-repeat;
    }

    .oab-bottom-block .oab-container {
      padding: 40px 20px clamp(320px, 92vw, 520px) 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 14px;
      height: auto;
      position: relative;
    }

    .oab-text-1, .oab-text-2, .oab-text-3 {
      position: static;
      width: 100% !important;
      transform: none !important;
      text-align: center !important;
    }

    .oab-text-1 {
      font-size: 20px;
      font-weight: 800;
    }

    .oab-text-2 {
      font-size: 15px;
      font-weight: 400;
      color: #333333;
    }
  }

  /* Purple Left and Right curves positioning */
  .oab-curve-left {
    position: absolute;
    left: {{ section.settings.left_curve_x }}%;
    top: {{ section.settings.left_curve_y }}px;
    width: {{ section.settings.left_curve_width }}px;
    z-index: 10;
    pointer-events: none;
  }
  .oab-curve-left img {
    width: 100%;
    height: auto;
    display: block;
  }

  .oab-curve-right {
    position: absolute;
    right: {{ section.settings.right_curve_x }}%;
    top: {{ section.settings.right_curve_y }}px;
    width: {{ section.settings.right_curve_width }}px;
    z-index: 10;
    pointer-events: none;
  }
  .oab-curve-right img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 767px) {
    .oab-curve-left, .oab-curve-right {
      display: none !important;
    }
  }
</style>

<div class="oab-wrapper">
  
  {%- if section.settings.left_curve_image != blank -%}
    <div class="oab-curve-left">
      {{ section.settings.left_curve_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: 'Left Purple Curve' }}
    </div>
  {%- endif -%}

  {%- if section.settings.right_curve_image != blank -%}
    <div class="oab-curve-right">
      {{ section.settings.right_curve_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: 'Right Purple Curve' }}
    </div>
  {%- endif -%}
  
  <!-- TOP BLOCK (BOWL GRAPHIC + RIGHT HEADING) -->
  <div class="oab-top-block">
    <div class="oab-container">
      {% if section.settings.top_heading != blank %}
        <div class="oab-top-heading oab-desktop-only">
          {{ section.settings.top_heading }}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- BOTTOM BLOCK (RAW FOOD BOWL + THREE TEXTS) -->
  <div class="oab-bottom-block">
    <div class="oab-container">
      {% if section.settings.text_1 != blank %}
        <div class="oab-text-1">
          {{ section.settings.text_1 }}
        </div>
      {% endif %}

      {% if section.settings.text_2 != blank %}
        <div class="oab-text-2">
          {{ section.settings.text_2 }}
        </div>
      {% endif %}

      {% if section.settings.text_3 != blank %}
        <div class="oab-text-3 oab-desktop-only">
          {{ section.settings.text_3 }}
        </div>
      {% endif %}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Our Approach Bottom",
  "settings": [
    {
      "type": "header",
      "content": "Top Block Settings"
    },
    {
      "type": "image_picker",
      "id": "top_bg_image",
      "label": "Top Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "top_bg_image_mobile",
      "label": "Top Background Image (Mobile)"
    },
    {
      "type": "textarea",
      "id": "top_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class=\"oab-text-red\">real food</span>,<br class=\"oab-desktop-only\">not processed science experiments"
    },
    {
      "type": "header",
      "content": "Bottom Block Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Bottom Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Bottom Background Image (Mobile)"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Bottom Top Right Heading",
      "default": "Our formulations have human-grade, bioavailable <br class=\"oab-desktop-only\">ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Bottom Middle Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and <br class=\"oab-desktop-only\">immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Bottom Left List (Desktop)",
      "default": "No GMO, No Fillers, No Synthetic <br class=\"oab-desktop-only\">Chemicals, No Preservatives, No Binders"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Decorative Purple Curves"
    },
    {
      "type": "image_picker",
      "id": "left_curve_image",
      "label": "Left Purple Curve Image"
    },
    {
      "type": "range",
      "id": "left_curve_x",
      "min": -20,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Left Curve X Position (From Left Edge)",
      "default": -5
    },
    {
      "type": "range",
      "id": "left_curve_y",
      "min": -200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Left Curve Y Position (From Top Edge)",
      "default": 100
    },
    {
      "type": "range",
      "id": "left_curve_width",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Left Curve Width",
      "default": 150
    },
    {
      "type": "image_picker",
      "id": "right_curve_image",
      "label": "Right Purple Curve Image"
    },
    {
      "type": "range",
      "id": "right_curve_x",
      "min": -20,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Right Curve X Position (From Right Edge)",
      "default": -5
    },
    {
      "type": "range",
      "id": "right_curve_y",
      "min": -200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Right Curve Y Position (From Top Edge)",
      "default": 300
    },
    {
      "type": "range",
      "id": "right_curve_width",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Right Curve Width",
      "default": 150
    }
  ],
  "presets": [
    {
      "name": "Our Approach Bottom"
    }
  ]
}
{% endschema %}
