{% comment %}
  Blog Post Grid Section - Exact Reference Layout
{% endcomment %}

{%- style -%}
.blog-grid-{{ section.id }} {
  background: {{ section.settings.bg_color | default: '#D71920' }};
  padding: {{ section.settings.padding_top | default: 78 }}px 0 110px;
  overflow: hidden;
}

.blog-grid-container {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 32px;
  width: 100%;
  box-sizing: border-box;
}

/* =========================
   TOP ROW
========================= */
.blog-top-row {
  display: grid;
  grid-template-columns: 2.08fr 1fr;
  gap: 38px;
  margin-bottom: 42px;
}

.blog-card {
  position: relative;
  border-radius: 22px;
  overflow: hidden;
  border: 2px solid rgba(255,255,255,0.75);
  background: #000;

  /* ANIMATION */
  opacity: 0;
  transform: translateY(80px);
  transition:
    opacity 0.9s ease,
    transform 0.9s ease;
  will-change: transform, opacity;
}

.blog-card.show {
  opacity: 1;
  transform: translateY(0);
}

.blog-card.feature {
  height: 392px;
}

.blog-card.secondary {
  height: 392px;
}

/* =========================
   BOTTOM ROW
========================= */
.blog-middle-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 38px;
  margin-bottom: 72px;
}

.blog-middle-row .blog-card {
  height: 270px;
}

/* =========================
   IMAGE
========================= */
.blog-card-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;

  /* IMAGE ZOOM EFFECT */
  transform: scale(1.12);
  transition: transform 1.6s ease;
}

.blog-card.show .blog-card-img {
  transform: scale(1);
}

.blog-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.04) 10%,
    rgba(0,0,0,0.52) 100%
  );
  z-index: 1;
}

/* =========================
   CONTENT
========================= */
.blog-card-content {
  position: relative;
  z-index: 2;
  height: 100%;
  padding: 34px 36px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  box-sizing: border-box;
}

.blog-card-title {
  margin: 0;
  color: #fff;
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.14;
  font-family: 'Degular Demo', sans-serif !important;

  /* TITLE ANIMATION */
  opacity: 0;
  transform: translateY(24px);
  transition:
    opacity 0.8s ease,
    transform 0.8s ease;
}

.blog-card.show .blog-card-title {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.2s;
}

/* Feature Card */
.blog-card.feature .blog-card-title {
  font-size: 28px;
  max-width: 610px;
}

/* Top Right Card */
.blog-top-row .blog-card.secondary .blog-card-title {
  font-size: 26px;
  max-width: 280px;
}

/* Bottom Cards */
.blog-middle-row .blog-card-title {
  font-size: 23px;
  max-width: 250px;
}

/* =========================
   BUTTON
========================= */
.blog-read-more {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 162px;
  height: 52px;
  border-radius: 999px;
  background: #000;
  color: #fff;
  text-decoration: none;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.04em;
  flex-shrink: 0;

  opacity: 0;
  transform: translateY(24px);
  transition:
    opacity 0.8s ease,
    transform 0.8s ease;
}

.blog-card.show .blog-read-more {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.35s;
}

/* =========================
   ICON CIRCLE
========================= */
.blog-icon-circle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  flex-shrink: 0;
  transition:
    all 0.25s ease,
    opacity 0.8s ease,
    transform 0.8s ease;

  opacity: 0;
  transform: translateY(24px);
}

.mobile-only-icon {
  display: none !important;
}

.blog-card.show .blog-icon-circle {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.35s;
}

.blog-card:hover .blog-icon-circle {
  background: #fff;
  color: #000;
}

/* =========================
   STAGGER DELAYS
========================= */
.blog-top-row .blog-card:nth-child(1) {
  transition-delay: 0.1s;
}

.blog-top-row .blog-card:nth-child(2) {
  transition-delay: 0.25s;
}

.blog-middle-row .blog-card:nth-child(1) {
  transition-delay: 0.15s;
}

.blog-middle-row .blog-card:nth-child(2) {
  transition-delay: 0.3s;
}

.blog-middle-row .blog-card:nth-child(3) {
  transition-delay: 0.45s;
}

/* =========================
   VIEW MORE
========================= */
.blog-view-more-wrap {
  display: flex;
  justify-content: center;
}

.blog-view-more-btn {
  min-width: 250px;
  height: 66px;
  border-radius: 999px;
  background: #000;
  color: #fff;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 0.04em;
  font-family:'Degular Demo'!important;

  opacity: 0;
  transform: translateY(80px);
  transition:
    opacity 0.9s ease,
    transform 0.9s ease;
}

.blog-view-more-btn.show {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.5s;
}

/* =========================
   RESPONSIVE
========================= */
@media screen and (max-width: 1200px) {

  .blog-top-row {
    grid-template-columns: 1fr;
  }

  .blog-middle-row {
    grid-template-columns: 1fr;
  }

  .blog-card.feature,
  .blog-card.secondary,
  .blog-middle-row .blog-card {
    height: 420px;
  }
}

@media screen and (max-width: 768px) {

  .blog-grid-{{ section.id }} {
    padding: 50px 0 80px;
  }

  .blog-grid-container {
    padding: 0 18px;
  }

  .blog-top-row,
  .blog-middle-row {
    gap: 22px;
  }

  .blog-top-row {
    margin-bottom: 22px !important;
  }

  .blog-card.feature,
  .blog-card.secondary,
  .blog-middle-row .blog-card {
    height: 230px !important;
  }

  .blog-card {
    border: 2px solid #ffffff !important;
  }

  .blog-card-content {
    padding: 24px;
  }

  .blog-card-title {
    font-size: 22px !important;
    line-height: 1.2 !important;
    max-width: calc(100% - 60px) !important;
  }

  .blog-read-more {
    display: none !important;
  }

  .mobile-only-icon {
    display: flex !important;
  }
}
{%- endstyle -%}

<section class="blog-grid-{{ section.id }}">
  <div class="blog-grid-container">

    <!-- TOP ROW -->
    <div class="blog-top-row">

      {%- for block in section.blocks limit: 2 -%}

        {%- assign article = block.settings.article -%}
        {%- assign card_title = block.settings.title | default: article.title | default: "Select Article" -%}

        {%- assign card_image = block.settings.image -%}
        {%- if card_image == blank and article.image != blank -%}
          {%- assign card_image = article.image -%}
        {%- endif -%}

        <div class="blog-card {% if forloop.first %}feature{% else %}secondary{% endif %}" {{ block.shopify_attributes }}>

          {% if card_image != blank %}
            <img
              class="blog-card-img"
              src="{{ card_image | img_url: '1400x' }}"
              alt="{{ card_title }}"
            >
          {% endif %}

          <div class="blog-card-overlay"></div>

          <div class="blog-card-content">

            <h3 class="blog-card-title">
              {{ card_title }}
            </h3>

            {% if forloop.first %}

              <a href="{{ article.url | default: '#' }}" class="blog-read-more">
                READ MORE
              </a>

              <div class="blog-icon-circle mobile-only-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.4"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </div>

            {% else %}

              <div class="blog-icon-circle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.4"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7"></line>
                  <polyline points="7 7 17 7 17 17"></polyline>
                </svg>
              </div>

            {% endif %}

          </div>
        </div>

      {%- endfor -%}

    </div>

    <!-- BOTTOM ROW -->
    <div class="blog-middle-row">

      {%- for block in section.blocks offset: 2 limit: 3 -%}

        {%- assign article = block.settings.article -%}
        {%- assign card_title = block.settings.title | default: article.title | default: "Blog Title" -%}

        {%- assign card_image = block.settings.image -%}
        {%- if card_image == blank and article.image != blank -%}
          {%- assign card_image = article.image -%}
        {%- endif -%}

        <div class="blog-card" {{ block.shopify_attributes }}>

          {% if card_image != blank %}
            <img
              class="blog-card-img"
              src="{{ card_image | img_url: '1000x' }}"
              alt="{{ card_title }}"
            >
          {% endif %}

          <div class="blog-card-overlay"></div>

          <div class="blog-card-content">

            <h3 class="blog-card-title">
              {{ card_title }}
            </h3>

            <div class="blog-icon-circle">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.4"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </div>

          </div>
        </div>

      {%- endfor -%}

    </div>

    <!-- VIEW MORE -->
    <div class="blog-view-more-wrap">
      <a
        href="{{ section.settings.view_more_link | default: '/blogs/news' }}"
        class="blog-view-more-btn"
      >
        VIEW MORE
      </a>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const elements = document.querySelectorAll(
    ".blog-card, .blog-view-more-btn"
  );

  const observer = new IntersectionObserver(
    (entries) => {

      entries.forEach((entry) => {

        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }

      });

    },
    {
      threshold: 0.18
    }
  );

  elements.forEach((el) => {
    observer.observe(el);
  });

});
</script>

{% schema %}
{
  "name": "Blog Post Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#D71920"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "url",
      "id": "view_more_link",
      "label": "View More Link"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Select Article"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Post Grid",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}