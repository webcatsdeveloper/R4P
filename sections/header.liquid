{% liquid
  # Capture blocks from section settings
  capture logo
    content_for 'block', type: '_header-logo', id: 'header-logo'
  endcapture

  capture menu
    content_for 'block', type: '_header-menu', id: 'header-menu'
  endcapture
%}

<header-component id="header-component" class="header-floating-bar">
  <div class="header-pill-wrapper">
    
    <!-- LOGO COLUMN - LEFT ALIGNED -->
    <div class="header-column column-left">
      <div class="header-logo">
        <a href="/" class="header-logo-link">
          {{ logo }}
        </a>
      </div>
    </div>
    
    <!-- NAVIGATION COLUMN - CENTERED -->
    <div class="header-column column-center">
      <nav class="header-menu-nav">
        {{ menu }}
      </nav>
    </div>
    
    <!-- ICONS/ACTIONS COLUMN - RIGHT ALIGNED -->
    <div class="header-column column-right">
      <div class="header-actions-group">

        <!-- MOBILE MENU DRAWER -->
        <div class="header-mobile-menu-wrapper">
          {{ menu }}
        </div>

        <!-- CART ICON -->
        <a href="/cart" class="header-icon-action custom-icon-link cart-icon-wrapper">

          <img 
            src="https://cdn.shopify.com/s/files/1/0684/4959/9593/files/cartmain.png?v=1778496051"
            alt="Cart"
            class="header-custom-icon"
          >

          <!-- CART COUNT -->
          {% if cart.item_count > 0 %}
            <span class="cart-count-badge">
              {{ cart.item_count }}
            </span>
          {% endif %}

        </a>

      </div>
    </div>
  </div>
</header-component>

<style>

/* ======================================= */
/* ORIGINAL HEADER (UNCHANGED) */
/* ======================================= */

#header-component {
    position: absolute;
    top: 32px;
    left: 50%;
    transform: translateX(-50%);
    width: 95%;
    max-width: 1725px;
    height: 70px;
    background: #ffffff !important;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    z-index: 1000;
    display: flex;
    align-items: center;

    transition:
      background 0.4s ease,
      backdrop-filter 0.4s ease,
      border 0.4s ease,
      box-shadow 0.4s ease,
      top 0.4s ease;
}

/* ======================================= */
/* GLASS EFFECT ONLY AFTER STICKY */
/* ======================================= */

#header-component.scrolled {
    position: fixed;
    top: 16px;

    background: rgba(255,255,255,0.12) !important;

    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);

    border: 1px solid rgba(255,255,255,0.18);

    box-shadow:
      0 8px 32px rgba(0,0,0,0.12),
      inset 0 1px 1px rgba(255,255,255,0.25);

    overflow: hidden;
}

/* GLASS LIGHT EFFECT */
#header-component.scrolled::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;

    background:
      linear-gradient(
        180deg,
        rgba(255,255,255,0.28) 0%,
        rgba(255,255,255,0.08) 45%,
        rgba(255,255,255,0.02) 100%
      );

    pointer-events: none;
}

/* SOFT GLOW */
#header-component.scrolled::after {
    content: "";
    position: absolute;

    width: 40%;
    height: 120%;

    top: -10%;
    left: -20%;

    background:
      radial-gradient(
        circle,
        rgba(255,255,255,0.18) 0%,
        transparent 70%
      );

    pointer-events: none;
}

/* ======================================= */
/* LAYOUT */
/* ======================================= */

.header-pill-wrapper {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    padding: 0 30px;
    position: relative;
    z-index: 2;
}

.header-column.column-left {
    justify-content: flex-start;
    display: flex;
    width:100%!important;
}

.header-logo {
    display: flex;
    align-items: center;
}

.header-logo img {
    height: 90px !important;
    width: 75px !important;
    max-height: none !important;
    max-width: none !important;
    display: block;
    object-fit: contain;
    margin-left:20px;
}

/* ICONS STYLING */
.header-actions-group {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
}

.custom-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    position: relative;
}

.custom-icon-link:hover {
    transform: scale(1.08);
}

.header-custom-icon {
    width: 19.2px;
    height: 19.2px;
    object-fit: contain;
    display: block;
}

/* CART RED BADGE */
.cart-icon-wrapper {
    position: relative;
}

.cart-count-badge {
    position: absolute;
    top: -9px;
    right: -11px;
    width: 16px;
    height: 16px;
    background: #D72329;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 2px 6px rgba(0,0,0,0.18);
}

/* NAVIGATION */
.menu-list__link {
    font-size: 15px !important;
    font-weight: 950 !important;
    letter-spacing: 0.05em !important;
    padding: 10px 24px;
    color: #1F1F1F !important;
    text-transform: uppercase;
}

/* RESPONSIVE */
@media screen and (max-width: 1200px) {

    .header-pill-wrapper { 
        padding: 0 30px; 
    }

    .header-logo img { 
        max-height: 75px !important; 
    }
}

@media screen and (max-width: 768px) {

    #header-component { 
        height: 80px; 
        top: 15px; 
    }

    #header-component.scrolled {
        top: 10px;
    }

    .header-logo img { 
        max-height: 50px !important; 
    }

    .header-pill-wrapper { 
        padding: 0 20px; 
    }

    .header-column.column-center { 
        display: none; 
    }

    .header-pill-wrapper { 
        grid-template-columns: 1fr 1fr; 
    }

    .header-custom-icon {
        width: 19.2px;
        height: 19.2px;
    }

    .cart-count-badge {
        width: 18px;
        height: 18px;
        font-size: 9px;
        top: -8px;
        right: -10px;
    }
}

/* ======================================= */
/* CUSTOM MOBILE HEADER DESIGN */
/* ======================================= */

.header-mobile-menu-wrapper {
    display: none !important;
}

@media screen and (max-width: 768px) {
    /* Layout */
    .header-mobile-menu-wrapper {
        display: block !important;
    }
    .header-mobile-menu-wrapper .header-menu {
        display: none !important;
    }
    .header-mobile-menu-wrapper .header__drawer {
        display: flex !important;
        min-height: 0 !important;
        height: auto !important;
        align-items: center !important;
    }

    /* Red Circle Toggle Buttons on Mobile */
    .header-actions-group {
        gap: 12px !important;
    }

    /* 1. Hamburger Toggle Button */
    .header-mobile-menu-wrapper .header__icon--menu {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        background-color: #D92B2B !important;
        width: 44px !important;
        height: 44px !important;
        border-radius: 50% !important;
        cursor: pointer !important;
        padding: 0 !important;
        transition: transform 0.2s ease !important;
        outline: none !important;
        border: none !important;
        list-style: none !important;
    }
    
    .header-mobile-menu-wrapper .header__icon--menu::-webkit-details-marker {
        display: none !important;
    }
    
    .header-mobile-menu-wrapper .header__icon--menu::after {
        display: none !important;
    }

    .header-mobile-menu-wrapper .header-drawer-icon {
        width: 18px !important;
        height: 18px !important;
        margin: 0 !important;
    }

    .header-mobile-menu-wrapper details:not(.menu-open) .header-drawer-icon--close {
        display: none !important;
    }
    .header-mobile-menu-wrapper details.menu-open .header-drawer-icon--open {
        display: none !important;
    }

    .header-mobile-menu-wrapper .header-drawer-icon svg {
        width: 18px !important;
        height: 18px !important;
        color: #ffffff !important;
        stroke: #ffffff !important;
        fill: none !important;
        display: block !important;
    }

    /* 2. Cart Icon Button */
    .cart-icon-wrapper {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        background-color: #D92B2B !important;
        width: 44px !important;
        height: 44px !important;
        border-radius: 50% !important;
        cursor: pointer !important;
        position: relative !important;
    }

    .cart-icon-wrapper .header-custom-icon {
        width: 18px !important;
        height: 18px !important;
        filter: brightness(0) invert(1) !important; /* Turns black PNG cart icon white */
    }

    /* 3. Cart Badge Yellow Dot */
    .cart-icon-wrapper .cart-count-badge {
        font-size: 0 !important; /* Hide number */
        color: transparent !important;
        width: 12px !important;
        height: 12px !important;
        background: #FFCD68 !important; /* Warm vibrant yellow matching site scheme */
        border: 2px solid #D92B2B !important; /* Match red circle border */
        border-radius: 50% !important;
        top: -1px !important;
        right: -1px !important;
        box-shadow: none !important;
        position: absolute !important;
        display: block !important;
    }

    /* ======================================= */
    /* MOBILE MENU DRAWER OVERRIDES */
    /* ======================================= */

    /* 1. Website Font Family on Menu Links */
    .menu-drawer__menu-item {
        font-family: 'Degular Demo', sans-serif !important;
        font-size: 24px !important;
        font-weight: 900 !important;
        letter-spacing: -0.02em !important;
        text-transform: uppercase !important;
        color: #1F1F1F !important;
        padding-left: 10px !important;
    }

    /* 2. Positioning the X Close Button to the Top Right */
    .menu-drawer__close-button {
        position: absolute !important;
        top: 20px !important;
        right: 20px !important;
        left: auto !important;
        width: 44px !important;
        height: 44px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        background: transparent !important;
        border: none !important;
        cursor: pointer !important;
        padding: 0 !important;
        z-index: 99 !important;
    }

    .header-mobile-menu-wrapper .menu-drawer__close-button svg,
    .header-mobile-menu-wrapper .menu-drawer__close-button .header-drawer-icon svg {
        width: 24px !important;
        height: 24px !important;
        stroke: #1F1F1F !important;
        color: #1F1F1F !important;
    }

    /* Ensure navigation starts below the X button */
    .menu-drawer__navigation {
        padding-top: 70px !important;
    }

    /* 3. Smooth Open/Close Slide Animation & Backdrop Blur */
    .menu-drawer {
        --drawer-animation-speed: 0.45s !important;
        transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important, 
                    visibility 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important, 
                    opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }

    .menu-drawer__backdrop {
        --drawer-animation-speed: 0.45s !important;
        backdrop-filter: blur(5px) brightness(0.75) !important;
        -webkit-backdrop-filter: blur(5px) brightness(0.75) !important;
        transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }

    /* Staggered Item Slide-up Entrance Animation */
    .menu-drawer-container.menu-open .menu-drawer__animated-element {
        animation: menu-drawer-nav-open-custom 0.5s cubic-bezier(0.16, 1, 0.3, 1) both !important;
        animation-delay: calc(0.18s + (var(--menu-drawer-animation-index) - 1) * 0.06s) !important;
    }

    @keyframes menu-drawer-nav-open-custom {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const header = document.getElementById("header-component");

    window.addEventListener("scroll", function () {

        if (window.scrollY > 40) {
            header.classList.add("scrolled");
        } else {
            header.classList.remove("scrolled");
        }

    });

});
</script>