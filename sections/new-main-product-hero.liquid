<script>
  let currentPetImageIndex = 0;

  function syncActivePetThumbnail(element) {
    if (!element) return;
    const targetUrl = element.getAttribute('data-src');
    const index = parseInt(element.getAttribute('data-index')) || 0;
    currentPetImageIndex = index;

    const nodes = document.querySelectorAll('.pet-prod-thumbnail-node');
    nodes.forEach(n => n.classList.remove('active'));
    element.classList.add('active');

    const displayImg = document.getElementById('PetHeroPrimaryImageDisplay');
    if (displayImg && targetUrl) {
      displayImg.style.opacity = '0.4';
      setTimeout(() => {
        displayImg.src = targetUrl;
        displayImg.style.opacity = '1';
      }, 120);
    }

    const dots = document.querySelectorAll('.pet-prod-carousel-dot');
    dots.forEach((dot, dIdx) => {
      if (dIdx === index) dot.classList.add('active');
      else dot.classList.remove('active');
    });
  }

  function jumpToPetImageIndex(index) {
    const matchingThumb = document.querySelector(`.pet-prod-thumbnail-node[data-index="${index}"]`);
    if (matchingThumb) syncActivePetThumbnail(matchingThumb);
  }

  /* --- Review Slider Functionality Core --- */
  function switchReviewSlide(targetIndex) {
    const slides = document.querySelectorAll('.pet-prod-review-slide');
    const dots = document.querySelectorAll('.pet-prod-review-pagination-dot');
    
    slides.forEach((slide) => {
      slide.classList.remove('is-active');
      if (parseInt(slide.getAttribute('data-review-index')) === targetIndex) {
        // Delayed layout call forces transition slide rendering mechanisms to activate
        setTimeout(() => {
          slide.classList.add('is-active');
        }, 50);
      }
    });

    dots.forEach((dot) => {
      dot.classList.remove('is-active');
      if (parseInt(dot.getAttribute('data-target-review')) === targetIndex) {
        dot.classList.add('is-active');
      }
    });
  }

  function executeLocalQuantityOffset(amount) {
    const inputNode = document.getElementById('PetHeroFormQuantityInput');
    if (!inputNode) return;
    let computedVal = parseInt(inputNode.value) || 1;
    computedVal += amount;
    if (computedVal < 1) computedVal = 1;
    inputNode.value = computedVal;
  }

  function triggerAddToCartAjaxAction(buttonElement) {
    const originalText = buttonElement.innerText;
    buttonElement.innerText = "ADDING TO CART...";
    
    const variantId = document.getElementById('PetVariantHiddenIdField').value;
    const qty = document.getElementById('PetHeroFormQuantityInput').value;

    let formData = { 'items': [{ 'id': parseInt(variantId), 'quantity': parseInt(qty) }] };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
      buttonElement.innerText = "ADDED TO CART!";
      document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: data }));
      setTimeout(() => { buttonElement.innerText = originalText; }, 1800);
    })
    .catch((error) => {
      console.error('Ajax operational asset error:', error);
      buttonElement.innerText = originalText;
    });
  }

  function triggerDirectInstantCheckoutAction() {
    const cartForm = document.getElementById('PetProductCoreFormElement');
    if (cartForm) {
      const inputCheckout = document.createElement('input');
      inputCheckout.type = 'hidden';
      inputCheckout.name = 'return_to';
      inputCheckout.value = '/checkout';
      cartForm.appendChild(inputCheckout);
      cartForm.submit();
    }
  }

  function triggerSubscribeAction(isCustomerLoggedIn) {
    if (!isCustomerLoggedIn) {
      window.location.href = "/account/login?return_to=" + encodeURIComponent(window.location.pathname);
    } else {
      alert("Redirecting to your automated recurrent subscription account configurations dashboard line panel.");
    }
  }

  function executeAccordionToggleTrigger(buttonNode) {
    const containerNode = buttonNode.closest('.pet-accordion-element-node');
    const displayPanel = containerNode.querySelector('.pet-accordion-element-panel-slider');
    const chevronIcon = buttonNode.querySelector('.pet-accordion-element-chevron-icon');

    if (containerNode.classList.contains('is-open')) {
      displayPanel.style.maxHeight = '0px';
      containerNode.classList.remove('is-open');
      chevronIcon.innerText = '▼';
    } else {
      displayPanel.style.maxHeight = displayPanel.scrollHeight + "px";
      containerNode.classList.add('is-open');
      chevronIcon.innerText = '▲';
    }
  }
</script>

