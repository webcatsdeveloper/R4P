<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&family=Caveat:wght@700&display=swap" rel="stylesheet">

<style>

  @media screen and (max-width: 749px) {
  .pet-hero__decor.decor-wave-left,
  .pet-hero__decor.decor-wave-right {
    display: none !important;
  }
}
  /* --- BASE SECTION AND CONTAINER STRUCTURE --- */
  #PetHero-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    /* 3-Point Gradient Background Engine */
    background: linear-gradient(
      180deg, 
      {{ section.settings.bg_gradient_top }} 0%, 
      {{ section.settings.bg_gradient_mid }} 50%, 
      {{ section.settings.bg_gradient_bottom }} 100%
    );
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .pet-hero__container {
    width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .pet-hero__content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 20px;
    position: relative;
  }

  /* --- TYPOGRAPHY ENGINE & LAYOUT --- */
  .pet-hero__heading {
    font-family: 'Degular Demo', sans-serif !important;
    font-weight: 600;
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: {{ section.settings.heading_line_height }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px 0;
    max-width: 950px;
    letter-spacing: -0.03em;
  }

  .pet-hero__heading-main,
  .pet-hero__heading-sub,
  .pet-hero__heading-line4 {
    display: block;
    position: relative;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .pet-hero__heading-sub-inner {
    display: inline-block;
    position: relative;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .pet-hero__heading-line3 {
    display: block;
    position: relative;
    font-size: {{ section.settings.l3_font_size }}px;
    font-weight: {{ section.settings.l3_font_weight }};
    font-style: {{ section.settings.l3_font_style }};
    color: {{ section.settings.l3_color }};
    margin-top: {{ section.settings.l3_margin_top }}px;
    margin-bottom: {{ section.settings.l3_margin_bottom }}px;
    font-family: 'Degular Demo', sans-serif !important;
  }

  .pet-hero__heading-highlight {
    display: block;
    font-family: 'Degular Demo', sans-serif !important;
    font-size: {{ section.settings.highlight_font_size }}px;
    margin-top: 5px;
    color: {{ section.settings.accent_color_red }};
    line-height: 0.95;
    font-weight: 700;
  }

  /* --- ABSOLUTE CANVASSING ENGINE --- */
  .pet-hero__decor {
    position: absolute;
    z-index: 3;
    pointer-events: none;
  }
  .pet-hero__decor img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* 1. Yellow Wave Left */
  .decor-wave-left {
    width: {{ section.settings.wl_width }}px;
    {% if section.settings.wl_top != "unset" %}top: {{ section.settings.wl_top }}%;{% else %}top: auto;{% endif %}
    {% if section.settings.wl_bottom != "unset" %}bottom: {{ section.settings.wl_bottom }}%;{% else %}bottom: auto;{% endif %}
    {% if section.settings.wl_left != "unset" %}left: {{ section.settings.wl_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.wl_right != "unset" %}right: {{ section.settings.wl_right }}%;{% else %}right: auto;{% endif %}
  }

  /* 2. Yellow Wave Right */
  .decor-wave-right {
    width: {{ section.settings.wr_width }}px;
    {% if section.settings.wr_top != "unset" %}top: {{ section.settings.wr_top }}%;{% else %}top: auto;{% endif %}
    {% if section.settings.wr_bottom != "unset" %}bottom: {{ section.settings.wr_bottom }}%;{% else %}bottom: auto;{% endif %}
    {% if section.settings.wr_left != "unset" %}left: {{ section.settings.wr_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.wr_right != "unset" %}right: {{ section.settings.wr_right }}%;{% else %}right: auto;{% endif %}
  }

  .decor-sparkle-left {
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%) translate(-12px, 0);
    width: {{ section.settings.sl_width }}px;
  }

  /* 4. Sparkle Star Right */
  .decor-sparkle-right {
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%) translate(12px, 0);
    width: {{ section.settings.sr_width }}px;
  }

  /* 5. Bowl Burst Left */
  .decor-burst-left {
    width: {{ section.settings.bl_width }}px;
    {% if section.settings.bl_top != "unset" %}top: {{ section.settings.bl_top }}%;{% else %}top: auto;{% endif %}
    {% if section.settings.bl_bottom != "unset" %}bottom: {{ section.settings.bl_bottom }}%;{% else %}bottom: auto;{% endif %}
    left: {{ section.settings.bl_left_range }}%;
  }

  /* 6. Bowl Burst Right */
  .decor-burst-right {
    width: {{ section.settings.br_width }}px;
    {% if section.settings.br_top != "unset" %}top: {{ section.settings.br_top }}%;{% else %}top: auto;{% endif %}
    {% if section.settings.br_bottom != "unset" %}bottom: {{ section.settings.br_bottom }}%;{% else %}bottom: auto;{% endif %}
    right: {{ section.settings.br_right_range }}%;
  }

  /* Central Midground Wrapper & Absolute Bowl Engine */
  .pet-hero__graphics-wrapper {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.bowl_max_width }}px;
    margin: 0 auto {{ section.settings.bowl_margin_bottom }}px auto;
    
    {% if section.settings.bowl_top != "unset" %}top: {{ section.settings.bowl_top }}px;{% endif %}
    {% if section.settings.bowl_bottom != "unset" %}bottom: {{ section.settings.bowl_bottom }}px;{% endif %}
    {% if section.settings.bowl_left != "unset" %}left: {{ section.settings.bowl_left }}%;{% endif %}
    {% if section.settings.bowl_right != "unset" %}right: {{ section.settings.bowl_right }}%;{% endif %}
  }

  /* Dynamic Custom Flakes Micro-Positioning Engine */
  .pet-hero__flake {
    position: absolute;
    pointer-events: none;
    z-index: 4;
    will-change: transform;
  }
  .pet-hero__flake img {
    width: 100%;
    height: auto;
    display: block;
  }

  .flake-1 {
    width: {{ section.settings.flake_1_size }}px;
    {% if section.settings.flake_1_top != "unset" %}top: {{ section.settings.flake_1_top }}px;{% else %}top: auto;{% endif %}
    {% if section.settings.flake_1_bottom != "unset" %}bottom: {{ section.settings.flake_1_bottom }}px;{% else %}bottom: auto;{% endif %}
    {% if section.settings.flake_1_left != "unset" %}left: {{ section.settings.flake_1_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.flake_1_right != "unset" %}right: {{ section.settings.flake_1_right }}%;{% else %}right: auto;{% endif %}
    transform: rotate({{ section.settings.flake_1_rotation }}deg);
  }

  .flake-2 {
    width: {{ section.settings.flake_2_size }}px;
    {% if section.settings.flake_2_top != "unset" %}top: {{ section.settings.flake_2_top }}px;{% else %}top: auto;{% endif %}
    {% if section.settings.flake_2_bottom != "unset" %}bottom: {{ section.settings.flake_2_bottom }}px;{% else %}bottom: auto;{% endif %}
    {% if section.settings.flake_2_left != "unset" %}left: {{ section.settings.flake_2_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.flake_2_right != "unset" %}right: {{ section.settings.flake_2_right }}%;{% else %}right: auto;{% endif %}
    transform: rotate({{ section.settings.flake_2_rotation }}deg);
  }

  .flake-3 {
    width: {{ section.settings.flake_3_size }}px;
    {% if section.settings.flake_3_top != "unset" %}top: {{ section.settings.flake_3_top }}px;{% else %}top: auto;{% endif %}
    {% if section.settings.flake_3_bottom != "unset" %}bottom: {{ section.settings.flake_3_bottom }}px;{% else %}bottom: auto;{% endif %}
    {% if section.settings.flake_3_left != "unset" %}left: {{ section.settings.flake_3_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.flake_3_right != "unset" %}right: {{ section.settings.flake_3_right }}%;{% else %}right: auto;{% endif %}
    transform: rotate({{ section.settings.flake_3_rotation }}deg);
  }

  .flake-4 {
    width: {{ section.settings.flake_4_size }}px;
    {% if section.settings.flake_4_top != "unset" %}top: {{ section.settings.flake_4_top }}px;{% else %}top: auto;{% endif %}
    {% if section.settings.flake_4_bottom != "unset" %}bottom: {{ section.settings.flake_4_bottom }}px;{% else %}bottom: auto;{% endif %}
    {% if section.settings.flake_4_left != "unset" %}left: {{ section.settings.flake_4_left }}%;{% else %}left: auto;{% endif %}
    {% if section.settings.flake_4_right != "unset" %}right: {{ section.settings.flake_4_right }}%;{% else %}right: auto;{% endif %}
    transform: rotate({{ section.settings.flake_4_rotation }}deg);
  }

  .pet-hero__bowl-img {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 2;
  }

  /* Footer Description Text Area */
  .pet-hero__description p {
    font-family: 'Degular Demo', sans-serif;
    font-size: {{ section.settings.desc_font_size }}px;
    color: {{ section.settings.desc_color }};
    max-width: {{ section.settings.desc_max_width }}px;
    margin: 0 auto;
    line-height: 1.5;
    font-weight: 900;
  }

  /* Native Scroll Animations Engine */
  @keyframes heroFadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes waveLeftIn { from { opacity: 0; transform: translateX(-40px) rotate(-5deg); } to { opacity: 1; transform: translateX(0) rotate(0deg); } }
  @keyframes waveRightIn { from { opacity: 0; transform: translateX(40px) rotate(5deg); } to { opacity: 1; transform: translateX(0) rotate(0deg); } }
  @keyframes popScale { from { opacity: 0; transform: scale(0.75); } to { opacity: 1; transform: scale(1); } }
  
  /* Attractive continuous floating keyframes */
  @keyframes gentleFloatLeft {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(-1.5deg); }
  }
  @keyframes gentleFloatRight {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(1.5deg); }
  }

  @keyframes floatKibble1 {
    0%, 100% { transform: translateY(0) rotate({{ section.settings.flake_1_rotation }}deg); }
    50% { transform: translateY(-8px) rotate({{ section.settings.flake_1_rotation | plus: 6 }}deg); }
  }
  @keyframes floatKibble2 {
    0%, 100% { transform: translateY(0) rotate({{ section.settings.flake_2_rotation }}deg); }
    50% { transform: translateY(-6px) rotate({{ section.settings.flake_2_rotation | minus: 8 }}deg); }
  }
  @keyframes floatKibble3 {
    0%, 100% { transform: translateY(0) rotate({{ section.settings.flake_3_rotation }}deg); }
    50% { transform: translateY(-10px) rotate({{ section.settings.flake_3_rotation | plus: 5 }}deg); }
  }
  @keyframes floatKibble4 {
    0%, 100% { transform: translateY(0) rotate({{ section.settings.flake_4_rotation }}deg); }
    50% { transform: translateY(-5px) rotate({{ section.settings.flake_4_rotation | minus: 4 }}deg); }
  }

  .pet-hero__heading-main { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.1s; }
  .pet-hero__heading-sub  { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.2s; }
  .pet-hero__heading-line3 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.3s; }
  .pet-hero__heading-line4 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.4s; }
  .pet-hero__heading-highlight { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.5s; }
  
  .pet-hero__bowl-image-container { animation: heroFadeUp 1.1s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.5s; }
  .pet-hero__description { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: 0.7s; }

  .decor-wave-left  { animation: waveLeftIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) both, gentleFloatLeft 6s ease-in-out infinite alternate 1.2s; }
  .decor-wave-right { animation: waveRightIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) both, gentleFloatRight 7s ease-in-out infinite alternate 1.2s; }

  .decor-sparkle-left  { animation: popScale 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.6s; }
  .decor-sparkle-right { animation: popScale 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.7s; }
  .decor-burst-left    { animation: popScale 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.8s; }
  .decor-burst-right   { animation: popScale 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.8s; }

  .flake-1 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both, floatKibble1 5s ease-in-out infinite alternate 0.9s; }
  .flake-2 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both, floatKibble2 6s ease-in-out infinite alternate 0.9s; }
  .flake-3 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both, floatKibble3 7s ease-in-out infinite alternate 0.9s; }
  .flake-4 { animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both, floatKibble4 5.5s ease-in-out infinite alternate 0.9s; }

  @media screen and (max-width: 768px) {
    .pet-hero__heading {
      font-size: 28px !important;
      letter-spacing: -0.02em !important;
      line-height: 1.1 !important;
      font-weight: 900 !important;
    }
    .pet-hero__heading-main,
    .pet-hero__heading-sub,
    .pet-hero__heading-line3,
    .pet-hero__heading-line4 {
      font-size: 40px !important;
      font-weight: 900 !important;
      line-height: 0.9 !important;
    }
    .pet-hero__heading-highlight {
      font-size: 85px !important;
      font-weight: 700 !important;
      margin-top: 5px !important;
      line-height: 0.95 !important;
      font-family: 'Caveat', cursive !important;
    }
    .pet-hero__decor { transform: scale(0.7) ; animation: none !important; }
    .decor-sparkle-left { transform: translateY(-50%) translate(-8px, 0) scale(0.7) !important; }
    .decor-sparkle-right { transform: translateY(-50%) translate(8px, 0) scale(0.7) !important; }
    .pet-hero__flake {
      animation: none !important;
    }
    .flake-1 {
      width: 28px !important;
      top: -125px !important;
      left: 49% !important;
      right: auto !important;
      transform: rotate(-35deg) !important;
    }
    .flake-2 {
      width: 22px !important;
      top: -46px !important;
      left: 49% !important;
      right: auto !important;
      transform: rotate(45deg) !important;
    }
    .flake-3 {
      width: 26px !important;
      top: 5px !important;
      left: 57% !important;
      right: auto !important;
      transform: rotate(-35deg) !important;
    }
    .flake-4 {
      width: 24px !important;
      top: 26px !important;
      left: 21% !important;
      right: auto !important;
      transform: rotate(-25deg) !important;
    }
    .pet-hero__description{
      color:#1E1E1E;
      
    }
    .pet-hero__graphics-wrapper { top: auto !important; bottom: auto !important; left: auto !important; right: auto !important; margin: 0 auto 20px auto !important; }
  }
</style>

<div id="PetHero-{{ section.id }}">
  
  {% if section.settings.wave_left != blank %}
    <div class="pet-hero__decor decor-wave-left"><img src="{{ section.settings.wave_left | image_url: width: 400 }}" alt=""></div>
  {% endif %}
  {% if section.settings.wave_right != blank %}
    <div class="pet-hero__decor decor-wave-right"><img src="{{ section.settings.wave_right | image_url: width: 400 }}" alt=""></div>
  {% endif %}

  <div class="pet-hero__container">
    <div class="pet-hero__content">

      <h2 class="pet-hero__heading">
        <span class="pet-hero__heading-main">{{ section.settings.heading_line_1 }}</span>
        <span class="pet-hero__heading-sub">
          <span class="pet-hero__heading-sub-inner">
            {% if section.settings.sparkle_left != blank %}
              <span class="pet-hero__decor decor-sparkle-left"><img src="{{ section.settings.sparkle_left | image_url: width: 150 }}" alt=""></span>
            {% endif %}
            right by them
            {% if section.settings.sparkle_right != blank %}
              <span class="pet-hero__decor decor-sparkle-right"><img src="{{ section.settings.sparkle_right | image_url: width: 150 }}" alt=""></span>
            {% endif %}
          </span>
        </span>
        {% if section.settings.heading_line_3 != blank %}
          <span class="pet-hero__heading-line3">
            {%- if section.settings.heading_highlight != blank -%}
              {{ section.settings.heading_line_3 | remove: "Bowl?" | remove: "bowl?" | remove: "Bowl" | remove: "bowl" | strip }}
            {%- else -%}
              {{ section.settings.heading_line_3 }}
            {%- endif -%}
          </span>
        {% endif %}
        <span class="pet-hero__heading-line4">
          {%- if section.settings.heading_highlight != blank -%}
            {{ section.settings.heading_line_4 | remove: "Bowl?" | remove: "bowl?" | remove: "Bowl" | remove: "bowl" | strip }}
          {%- else -%}
            {{ section.settings.heading_line_4 }}
          {%- endif -%}
        </span>
        {%- if section.settings.heading_highlight != blank -%}
          <span class="pet-hero__heading-highlight">{{ section.settings.heading_highlight }}</span>
        {%- endif -%}
      </h2>

      <div class="pet-hero__graphics-wrapper">
        {% if section.settings.food_flake_image != blank %}
          <div class="pet-hero__flake flake-1" style="--base-rot: {{ section.settings.flake_1_rotation }}deg;"><img src="{{ section.settings.food_flake_image | image_url: width: 100 }}" alt=""></div>
          <div class="pet-hero__flake flake-2" style="--base-rot: {{ section.settings.flake_2_rotation }}deg;"><img src="{{ section.settings.food_flake_image | image_url: width: 100 }}" alt=""></div>
          <div class="pet-hero__flake flake-3" style="--base-rot: {{ section.settings.flake_3_rotation }}deg;"><img src="{{ section.settings.food_flake_image | image_url: width: 100 }}" alt=""></div>
          <div class="pet-hero__flake flake-4" style="--base-rot: {{ section.settings.flake_4_rotation }}deg;"><img src="{{ section.settings.food_flake_image | image_url: width: 100 }}" alt=""></div>
        {% endif %}

        {% if section.settings.burst_left != blank %}
          <div class="pet-hero__decor decor-burst-left"><img src="{{ section.settings.burst_left | image_url: width: 200 }}" alt=""></div>
        {% endif %}
        {% if section.settings.burst_right != blank %}
          <div class="pet-hero__decor decor-burst-right"><img src="{{ section.settings.burst_right | image_url: width: 200 }}" alt=""></div>
        {% endif %}

        <div class="pet-hero__bowl-image-container">
          {%- if section.settings.bowl_image != blank -%}
            <img src="{{ section.settings.bowl_image | image_url: width: 1200 }}" alt="Pet Bowl Product" class="pet-hero__bowl-img">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'pet-hero__bowl-img' }}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.description != blank -%}
        <div class="pet-hero__description">
          <p>{{ section.settings.description }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Pet Food Hero Canvas Pro",
  "settings": [
    {
      "type": "header",
      "content": "1. Section Architecture"
    },
    {
      "type": "color",
      "id": "bg_gradient_top",
      "label": "Gradient Position: Top",
      "default": "#EBEBFF"
    },
    {
      "type": "color",
      "id": "bg_gradient_mid",
      "label": "Gradient Position: Middle",
      "default": "#EBEBFF"
    },
    {
      "type": "color",
      "id": "bg_gradient_bottom",
      "label": "Gradient Position: Bottom",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Top Spacing",
      "default": 90
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Bottom Spacing",
      "default": 90
    },
    {
      "type": "header",
      "content": "2. Main Heading Base Configs"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "What if doing"
    },

    {
      "type": "text",
      "id": "heading_line_4",
      "label": "Heading Line 4",
      "default": "their"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Base Lines Font Size",
      "default": 68
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Base Color",
      "default": "#111111"
    },
    {
      "type": "text",
      "id": "heading_line_height",
      "label": "Line Height Ratio",
      "default": "1.05"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Margin Below Entire Heading",
      "default": 36
    },
    {
      "type": "header",
      "content": "2b. Heading Line 3 Settings"
    },
    {
      "type": "text",
      "id": "heading_line_3",
      "label": "Heading Line 3 Text",
      "default": "starts with what goes into"
    },
    {
      "type": "select",
      "id": "l3_font_family",
      "label": "Font Family",
      "options": [
        { "value": "outfit", "label": "Outfit (Geometric Sans)" },
        { "value": "caveat", "label": "Caveat (Handwritten/Script)" },
        { "value": "georgia", "label": "Georgia (Classic Serif)" }
      ],
      "default": "outfit"
    },
    {
      "type": "range",
      "id": "l3_font_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
