<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  .our-solution-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }
  .our-solution-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: top center;
  }

  .our-solution-container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  .os-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 76px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 32px;
    line-height: 1.05;
    color: #111111;
    letter-spacing: -0.01em;
  }
  .os-title-red {
    color: #d92b2b;
  }

  /* Master Desktop Grid: Grid items are columns */
  .os-desktop-layout-grid {
    display: grid;
    grid-template-columns: 1fr 520px 1fr;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 40px;
    margin: 0 auto;
    position: relative;
  }

  /* Left Side Texts Column */
  .os-left-column {
    display: flex;
    flex-direction: column;
    gap: 120px;
    text-align: right;
    justify-content: center;
    height: 100%;
  }

  /* Center Graphical Stack Column */
  .os-center-column-stack {
    width: 520px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 3;
    margin-top: -60px; /* Adjusts top bowl overlap over white background wave */
  }

  .os-combined-image-wrapper {
    width: 100%;
  }
  .os-combined-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Right Side Texts Column */
  .os-right-column {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: 100%;
    text-align: left;
  }

  .os-sub-text {
    font-size: 16px;
    line-height: 1.5;
    font-weight: 500;
    color: #111111;
  }

  /* Line wrapping containers to match layout styles perfectly */
  .wrap-box-mid-left {
    max-width: 260px;
    margin-left: auto;
  }
  
  .wrap-box-bot-left {
    max-width: 240px;
    margin-left: auto;
  }

  .wrap-box-top-right {
    max-width: 420px;
    margin-top: 40px;
  }
  
  .wrap-box-top-right .os-bold-text {
    font-size: 24px;
    line-height: 1.25;
    font-weight: 700;
    color: #111111;
    margin-bottom: 12px;
  }
  .os-bold-text-red {
    color: #d92b2b;
  }

  /* Bottom Central Main Headline Layout */
  .os-bottom-text-area {
    text-align: center;
    max-width: 860px; 
    margin: 40px auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    z-index: 4;
  }

  .os-bottom-text-area .os-bold-text {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.3;
    color: #111111;
  }

  .os-bottom-text-area .os-sub-text {
    max-width: 720px; 
    margin: 0 auto;
  }

  /* ******************************************
     Mobile Layout Fallback overrides
     ****************************************** */
  @media screen and (max-width: 900px) {
    .os-title { font-size: 50px; }

    .os-desktop-layout-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    .os-left-column, .os-right-column, .os-center-column-stack {
      width: 100% !important;
      max-width: 100% !important;
      text-align: center !important;
      padding: 0 !important;
      height: auto !important;
    }

    .wrap-box-mid-left, .wrap-box-bot-left, .wrap-box-top-right {
      max-width: 100% !important;
      margin: 20px auto !important;
      text-align: center !important;
    }

    .os-center-column-stack {
      margin-top: 20px !important;
      order: 2;
    }
    .os-right-column { order: 1; }
    .os-left-column { order: 3; }

    .os-combined-image-wrapper {
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

{% if section.settings.bg_image %}
  <div class="our-solution-bg">
    <img src="{{ section.settings.bg_image | img_url: 'master' }}" alt="Background Curves">
  </div>
{% endif %}

<div class="our-solution-container">
  <div class="os-title">
    <span class="os-title-black">{{ section.settings.title_black }}</span>
    <span class="os-title-red">&nbsp;{{ section.settings.title_red }}</span>
  </div>

  <div class="os-desktop-layout-grid">
    
    <div class="os-left-column">
      <div class="wrap-box-mid-left">
        <div class="os-sub-text">{{ section.settings.mid_left_text }}</div>
      </div>
      <div class="wrap-box-bot-left">
        <div class="os-sub-text">{{ section.settings.bot_left_text }}</div>
      </div>
    </div>

    <div class="os-center-column-stack">
      <div class="os-combined-image-wrapper">
        {% if section.settings.mid_image %}
          <img src="{{ section.settings.mid_image | img_url: 'master' }}" alt="Our Solutions Graphic Component">
        {% endif %}
      </div>
    </div>

    <div class="os-right-column">
      <div class="wrap-box-top-right">
        <div class="os-bold-text">{{ section.settings.top_right_heading }}</div>
        <div class="os-sub-text">{{ section.settings.top_right_subtext }}</div>
      </div>
    </div>

  </div>

  <div class="os-bottom-text-area">
    <div class="os-bold-text">{{ section.settings.bot_heading }}</div>
    <div class="os-sub-text">{{ section.settings.bot_subtext }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Yellow shape)"
    },
    {
      "type": "text",
      "id": "title_black",
      "label": "Title (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_red",
      "label": "Title (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Middle Section (Image + Text)"
    },
    {
      "type": "textarea",
      "id": "top_right_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class='os-bold-text-red'>real food</span>, <br>not processed science experiments"
    },
    {
      "type": "textarea",
      "id": "top_right_subtext",
      "label": "Top Right Subtext",
      "default": "Real Foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "header",
      "content": "Middle Grid"
    },
    {
      "type": "textarea",
      "id": "mid_left_text",
      "label": "Middle Left Text",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Middle Combined Image Asset (Both Bowls + Text)"
    },
    {
      "type": "header",
      "content": "Bottom Text Area"
    },
    {
      "type": "textarea",
      "id": "bot_heading",
      "label": "Bottom Heading",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "bot_subtext",
      "label": "Bottom Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "textarea",
      "id": "bot_left_text",
      "label": "Bottom Left Text",
      "default": "No GMO, No Fillers, No Synthetic Chemicals, No Preservatives, No Binders"
    }
  ],
  "presets": [
    {
      "name": "Our Solution"
    }
  ]
}
{% endschema %}