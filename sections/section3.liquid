{%- style -%}
  .safety-sourcing-{{ section.id }} {
    --bg-accent-color: {{ section.settings.bg_accent_color }};
    --text-main: {{ section.settings.text_color_main }};
    --text-brand: {{ section.settings.text_color_brand }};
    padding: 0 0 80px 0;
    background-color: #ffffff;
    font-family: inherit;
    position: relative;
    overflow: hidden;
  }

  /* Curved Top Wave Background */
  .safety-sourcing-{{ section.id }} .curved-header-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 320px;
    background-color: var(--bg-accent-color);
    border-bottom-left-radius: 50% 40%;
    border-bottom-right-radius: 50% 40%;
    z-index: 1;
  }

  .safety-sourcing-{{ section.id }} .section-inner-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  /* Asymmetric Top Row: Left Text & Centered Plate */
  .safety-sourcing-{{ section.id }} .top-showcase-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    margin-top: 40px;
    gap: 20px;
  }

  .safety-sourcing-{{ section.id }} .left-exclusion-tags {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-main);
    font-weight: 500;
    opacity: 0.85;
    padding-top: 60px;
  }

  .safety-sourcing-{{ section.id }} .center-plate-media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .safety-sourcing-{{ section.id }} .center-plate-media img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0px 15px 30px rgba(0,0,0,0.12));
  }

  /* Sourcing Primary Statement */
  .safety-sourcing-{{ section.id }} .sourcing-statement-block p {
    text-align: center;
    max-width: 850px;
    margin: 60px auto 40px auto;
    font-size: 1.65rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text-main);
    letter-spacing: -0.02em;
  }

  .safety-sourcing-{{ section.id }} .sourcing-statement-block strong {
    color: var(--text-brand);
    font-weight: 800;
  }

  /* Safety Subtext Paragraph Block */
  .safety-sourcing-{{ section.id }} .safety-compliance-body {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #4a4a4a;
    font-weight: 400;
  }

  /* Mobile Responsive Adaptations */
  @media (max-width: 768px) {
    .safety-sourcing-{{ section.id }} .curved-header-bg {
      height: 180px;
      border-bottom-left-radius: 50% 20%;
      border-bottom-right-radius: 50% 20%;
    }
    .safety-sourcing-{{ section.id }} .top-showcase-grid {
      grid-template-columns: 1fr;
      text-align: center;
      margin-top: 20px;
      gap: 30px;
    }
    .safety-sourcing-{{ section.id }} .left-exclusion-tags {
      padding-top: 0;
      order: 2;
    }
    .safety-sourcing-{{ section.id }} .center-plate-media {
      order: 1;
      max-width: 280px;
      margin: 0 auto;
    }
    .safety-sourcing-{{ section.id }} .sourcing-statement-block p {
      font-size: 1.25rem;
      padding: 0 10px;
    }
  }
{%- endstyle -%}

<section class="safety-sourcing-{{ section.id }}">
  <div class="curved-header-bg"></div>

  <div class="section-inner-wrapper">
    
    <div class="top-showcase-grid">
      <div class="left-exclusion-tags">
        {{ section.settings.left_tags | newline_to_br }}
      </div>

      <div class="center-plate-media">
        {%- if section.settings.plate_image != blank -%}
          {{ section.settings.plate_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.plate_image.alt }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="right-spacer-column" aria-hidden="true"></div>
    </div>

    <!-- Outputs the rich text block safely with permitted HTML line breaks -->
    <div class="sourcing-statement-block">
      {{ section.settings.main_statement }}
    </div>

    <div class="safety-compliance-body">
      {{ section.settings.safety_body_text | newline_to_br }}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Safety & Sourcing Panel",
  "settings": [
    {
      "type": "header",
      "content": "Color Setup"
    },
    {
      "type": "color",
      "id": "bg_accent_color",
      "label": "Top Curved Accent Background",
      "default": "#fcd36a"
    },
    {
      "type": "color",
      "id": "text_color_main",
      "label": "Dark Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_brand",
      "label": "Red Brand Color Focus",
      "default": "#d93829"
    },
    {
      "type": "header",
      "content": "Visual Assets & Side Copy"
    },
    {
      "type": "image_picker",
      "id": "plate_image",
      "label": "Center Sourcing Ingredient Plate Graphic"
    },
    {
      "type": "textarea",
      "id": "left_tags",
      "label": "Left Side Exclusion Taglines",
      "default": "No GMO, No Fillers, No Synthetic\nChemicals, No Preservatives, No Binders"
    },
    {
      "type": "header",
      "content": "Typography Content Layouts"
    },
    {
      "type": "richtext",
      "id": "main_statement",
      "label": "Main Central Highlight Statement",
      "default": "<p>The meats we use are from <strong>HACCP approved, ISO certified plants</strong><br>with full traceability and are <strong>anti-biotic residue free</strong><br>The fish we use are <strong>wild caught</strong></p>"
    },
    {
      "type": "textarea",
      "id": "safety_body_text",
      "label": "Safety Compliance Subtext",
      "default": "Safety is non-negotiable, which is why we enforce a strict kill step at every stage of our process including Bacteriophages, traditional Curing agents (vinegar/citric acid), low temperature long duration pasteurization and UV exposure before packing.\nAs a final protective barrier, the packs are vacuum-sealed and flushed with modified atmospheric gases."
    }
  ],
  "presets": [
    {
      "name": "Safety & Sourcing Panel"
    }
  ]
}
{% endschema %}