<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  /* White wave graphic container layer to match 1919x155 overlay bounds */
  .os-desktop-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }
  .os-desktop-bg-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: top center;
  }

  .os-desktop-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  /* Our Solution Top Header Title */
  .os-desktop-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 76px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 20px;
    line-height: 1.05;
    color: #111111;
    letter-spacing: -0.01em;
  }
  .os-desktop-title .text-red {
    color: #d92b2b;
  }

  /* Right-aligned Subtitle Callout Box */
  .os-desktop-subtitle-box {
    width: 100%;
    max-width: 960px;
    margin: 0 auto 15px auto;
    display: flex;
    justify-content: flex-end;
  }
  .os-desktop-subtitle-box .os-subtitle-content {
    max-width: 420px;
    text-align: right;
    font-size: 24px;
    line-height: 1.25;
    font-weight: 700;
    color: #111111;
  }
  .os-subtitle-content .text-red {
    color: #d92b2b;
  }

  /* Main Graphical Layout Map Base Area */
  .os-desktop-interactive-stage {
    position: relative;
    width: 100%;
    max-width: 960px;
    height: 640px;
    margin: 0 auto;
  }

  /* Fine paragraphs configurations */
  .os-desktop-paragraph {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 15px;
    line-height: 1.45;
    font-weight: 500;
    color: #111111;
    position: absolute;
    z-index: 5;
  }

  /* Real Foods 26000 bio-active compounds block position */
  .os-desktop-paragraph.top-right-block {
    right: 5%;
    top: 65px;
    max-width: 235px;
    text-align: left;
  }

  /* Whole food entourage effects block position */
  .os-desktop-paragraph.bottom-left-block {
    left: 2%;
    bottom: 180px;
    max-width: 210px;
    text-align: right;
  }

  /* Absolute Layout Placements for Component Images */
  .img-layer-fresh-plate {
    position: absolute;
    top: 0;
    left: 120px;
    width: {{ section.settings.fresh_plate_width }}px;
    height: auto;
    z-index: 3;
  }

  .img-layer-text-ribbon {
    position: absolute;
    top: 245px;
    left: 85px;
    width: {{ section.settings.ribbon_width }}px;
    height: auto;
    z-index: 4;
  }

  .img-layer-final-bowl {
    position: absolute;
    bottom: 30px;
    left: 285px;
    width: {{ section.settings.final_bowl_width }}px;
    height: auto;
    z-index: 2;
  }

  /* Little hand-drawn pointing vector arrows */
  .vector-arrow-top {
    position: absolute;
    top: 175px;
    left: 450px;
    width: 44px;
    height: auto;
    z-index: 3;
  }

  .vector-arrow-bottom {
    position: absolute;
    bottom: 275px;
    left: 235px;
    width: 44px;
    height: auto;
    z-index: 3;
  }

  /* Bottom Statement Footer Area Typography */
  .os-desktop-footer-summary {
    text-align: center;
    max-width: 820px;
    margin: 40px auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .os-desktop-footer-summary .bold-headline {
    font-size: 26px;
    font-weight: 800;
    line-height: 1.3;
    color: #111111;
  }

  .os-desktop-footer-summary .fine-description {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.5;
    color: #222222;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Strictly hide everything on mobile/tablet to protect desktop environment view */
  @media screen and (max-width: 900px) {
    #shopify-section-{{ section.id }} {
      display: none !important;
    }
  }
</style>

<!-- White Wavy Layout Overlay Graphic -->
{% if section.settings.bg_shape_wave != blank %}
  <div class="os-desktop-bg-wrapper">
    <img src="{{ section.settings.bg_shape_wave | img_url: 'master' }}" alt="Background Shape Layer">
  </div>
{% endif %}

<div class="os-desktop-container">
  <!-- Main Row Title -->
  <h2 class="os-desktop-title">
    <span>{{ section.settings.title_part_1 }}</span>
    <span class="text-red">{{ section.settings.title_part_2 }}</span>
  </h2>

  <!-- Subtitle right-hand alignment callout block -->
  <div class="os-desktop-subtitle-box">
    <div class="os-subtitle-content">
      We feed your pet <span class="text-red">real food</span>,<br>
      not processed science experiments
    </div>
  </div>

  <!-- Interactive Graphic Stage -->
  <div class="os-desktop-interactive-stage">
    
    <!-- Fresh Ingredients Plate Graphic Component -->
    {% if section.settings.fresh_plate_img != blank %}
      <img class="img-layer-fresh-plate" src="{{ section.settings.fresh_plate_img | img_url: 'master' }}" alt="Fresh plate contents">
    {% endif %}

    <!-- Top Right Descriptive Box (Over 26000 bio-active compounds...) -->
    <div class="os-desktop-paragraph top-right-block">
      {{ section.settings.top_right_paragraph }}
    </div>

    <!-- Hand-drawn Arrow Vector Asset (Top) -->
    {% if section.settings.arrow_vector_top != blank %}
      <img class="vector-arrow-top" src="{{ section.settings.arrow_vector_top | img_url: 'master' }}" alt="">
    {% endif %}

    <!-- Curved Text Ribbon Overlay Image Graphic -->
    {% if section.settings.text_ribbon_img != blank %}
      <img class="img-layer-text-ribbon" src="{{ section.settings.text_ribbon_img | img_url: 'master' }}" alt="Our diets are made from real foods ribbon text banner">
    {% endif %}

    <!-- Hand-drawn Arrow Vector Asset (Bottom) -->
    {% if section.settings.arrow_vector_bottom != blank %}
      <img class="vector-arrow-bottom" src="{{ section.settings.arrow_vector_bottom | img_url: 'master' }}" alt="">
    {% endif %}

    <!-- Finished Bowled Food Product Image Component -->
    {% if section.settings.final_bowl_img != blank %}
      <img class="img-layer-final-bowl" src="{{ section.settings.final_bowl_img | img_url: 'master' }}" alt="Completed formulated bowl layout">
    {% endif %}

    <!-- Bottom Left Descriptive Box (Whole food also brings entourage effect...) -->
    <div class="os-desktop-paragraph bottom-left-block">
      {{ section.settings.bottom_left_paragraph }}
    </div>

  </div>

  <!-- Footnote Suitability Summary Blocks -->
  <div class="os-desktop-footer-summary">
    <div class="bold-headline">{{ section.settings.footer_headline }}</div>
    <div class="fine-description">{{ section.settings.footer_subtext }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution (Desktop)",
  "settings": [
    {
      "type": "header",
      "content": "Section Core Margins"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Spacing",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Spacing",
      "default": 100
    },
    {
      "type": "header",
      "content": "Main Heading Texts"
    },
    {
      "type": "text",
      "id": "title_part_1",
      "label": "Title Prefix (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_part_2",
      "label": "Title Suffix (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Plate Graphics Sizing Controls"
    },
    {
      "type": "range",
      "id": "fresh_plate_width",
      "min": 200,
      "max": 450,
      "step": 5,
      "unit": "px",
      "label": "Fresh Plate Graphic Width",
      "default": 320
    },
    {
      "type": "range",
      "id": "ribbon_width",
      "min": 300,
      "max": 650,
      "step": 5,
      "unit": "px",
      "label": "Curved Text Ribbon Width",
      "default": 470
    },
    {
      "type": "range",
      "id": "final_bowl_width",
      "min": 200,
      "max": 450,
      "step": 5,
      "unit": "px",
      "label": "Final Food Bowl Width",
      "default": 340
    },
    {
      "type": "header",
      "content": "Media Library Graphic Pickers"
    },
    {
      "type": "image_picker",
      "id": "bg_shape_wave",
      "label": "White Wave Background Shape Layer"
    },
    {
      "type": "image_picker",
      "id": "fresh_plate_img",
      "label": "Fresh Plate Layer Image Component"
    },
    {
      "type": "image_picker",
      "id": "text_ribbon_img",
      "label": "Our Diets Banner Image Component"
    },
    {
      "type": "image_picker",
      "id": "final_bowl_img",
      "label": "Final Food Bowl Image Component"
    },
    {
      "type": "image_picker",
      "id": "arrow_vector_top",
      "label": "Handdrawn Arrow Vector (Top Right)"
    },
    {
      "type": "image_picker",
      "id": "arrow_vector_bottom",
      "label": "Handdrawn Arrow Vector (Bottom Left)"
    },
    {
      "type": "header",
      "content": "Side Body Descriptions Texts"
    },
    {
      "type": "textarea",
      "id": "top_right_paragraph",
      "label": "Top Right Information text block",
      "default": "Real Foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "textarea",
      "id": "bottom_left_paragraph",
      "label": "Bottom Left Information text block",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "header",
      "content": "Footer Footer Summaries Blocks"
    },
    {
      "type": "textarea",
      "id": "footer_headline",
      "label": "Bold Suitability Statement Summary",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "footer_subtext",
      "label": "Nutrient Fine Print Detail",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    }
  ],
  "presets": [
    {
      "name": "Our Solution (Desktop ONLY)"
    }
  ]
}
{% endschema %}