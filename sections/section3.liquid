{%- style -%}
  .our-solution-{{ section.id }} {
    --bg-blob-color: {{ section.settings.bg_blob_color }};
    --text-dark: {{ section.settings.text_color_dark }};
    --text-accent: {{ section.settings.text_color_accent }};
    padding: 60px 0;
    font-family: inherit;
    overflow: hidden;
    background-color: #ffffff;
  }

  .our-solution-{{ section.id }} .solution-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  /* Main Title Styling */
  .our-solution-{{ section.id }} .solution-main-heading {
    font-size: 3.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: -20px;
    color: var(--text-dark);
    position: relative;
    z-index: 3;
  }
  .our-solution-{{ section.id }} .solution-main-heading span {
    color: var(--text-accent);
  }

  /* Wavy Organic Blob Background Simulation */
  .our-solution-{{ section.id }} .blob-background-wrapper {
    background-color: var(--bg-blob-color);
    border-radius: 40% 50% 45% 55% / 20% 25% 45% 50%;
    padding: 80px 60px;
    margin-top: 40px;
    position: relative;
    z-index: 1;
  }

  /* Content Row Layouts */
  .our-solution-{{ section.id }} .solution-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 50px;
    gap: 40px;
  }
  .our-solution-{{ section.id }} .solution-row.reverse {
    flex-direction: row-reverse;
  }

  .our-solution-{{ section.id }} .solution-col-media {
    flex: 1;
    max-width: 400px;
    display: flex;
    justify-content: center;
    position: relative;
  }
  .our-solution-{{ section.id }} .solution-col-media img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 50%;
  }

  .our-solution-{{ section.id }} .solution-col-text {
    flex: 1;
    color: var(--text-dark);
  }

  /* Specific Row Highlights */
  .our-solution-{{ section.id }} .top-intro-text {
    text-align: right;
    max-width: 500px;
    margin-left: auto;
    margin-bottom: 30px;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
  }
  .our-solution-{{ section.id }} .top-intro-text span {
    color: var(--text-accent);
  }

  /* Responsive SVG Curved Text Engine */
  .our-solution-{{ section.id }} .curved-text-divider {
    width: 100%;
    max-width: 600px;
    margin: -20px auto 20px auto;
    display: block;
    position: relative;
    z-index: 2;
  }
  .our-solution-{{ section.id }} .curved-text-divider text {
    font-size: 26px;
    font-weight: 800;
    fill: var(--text-accent);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Central Highlight Copy Block */
  .our-solution-{{ section.id }} .center-highlight-block {
    text-align: center;
    max-width: 800px;
    margin: 60px auto;
  }
  .our-solution-{{ section.id }} .center-highlight-block h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 15px;
    color: var(--text-dark);
    line-height: 1.5;
  }
  .our-solution-{{ section.id }} .center-highlight-block p {
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  /* Footer Section Styling */
  .our-solution-{{ section.id }} .solution-footer-text {
    text-align: center;
    margin-top: 50px;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.6;
    color: var(--text-dark);
    z-index: 2;
    position: relative;
  }
  .our-solution-{{ section.id }} .solution-footer-text strong {
    color: var(--text-accent);
    font-weight: 800;
  }

  /* Arrows/Decorators Positioning styling */
  .our-solution-{{ section.id }} .arrow-indicator {
    font-size: 24px;
    margin: 10px 0;
    display: inline-block;
    opacity: 0.7;
  }

  /* Responsive Stacking Logic */
  @media (max-width: 768px) {
    .our-solution-{{ section.id }} .solution-main-heading {
      font-size: 2.5rem;
    }
    .our-solution-{{ section.id }} .blob-background-wrapper {
      border-radius: 20px;
      padding: 40px 20px;
    }
    .our-solution-{{ section.id }} .solution-row, 
    .our-solution-{{ section.id }} .solution-row.reverse {
      flex-direction: column;
      text-align: center;
      gap: 20px;
    }
    .our-solution-{{ section.id }} .top-intro-text {
      text-align: center;
      margin: 0 auto 30px auto;
    }
    .our-solution-{{ section.id }} .curved-text-divider {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<section class="our-solution-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="solution-container">
    
    <!-- Section Main Header -->
    <h2 class="solution-main-heading">
      {{ section.settings.heading_start }} <span>{{ section.settings.heading_accent }}</span>
    </h2>

    <!-- Blob Content Wrapper Container -->
    <div class="blob-background-wrapper">
      
      <!-- Top Intro Sub-Banner Statement -->
      <div class="top-intro-text">
        {{ section.settings.intro_text }}
      </div>

      <!-- Item Row 1: Fresh Ingredients Group -->
      <div class="solution-row">
        <div class="solution-col-media">
          {%- if section.settings.image_1 != blank -%}
            {{ section.settings.image_1 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_1.alt }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="solution-col-text">
          <span class="arrow-indicator">⤷</span>
          <p>{{ section.settings.row_1_text }}</p>
        </div>
      </div>

      <!-- Dynamic SVG Curving Typography Separator Intersecting Rows -->
      {%- if section.settings.arched_text != blank -%}
        <svg class="curved-text-divider" viewBox="0 0 600 120" xmlns="http://www.w3.org/2000/svg">
          <path id="textCurve-{{ section.id }}" d="M 50 110 Q 300 20 550 110" fill="transparent" />
          <text>
            <textPath href="#textCurve-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.arched_text }}
            </textPath>
          </text>
        </svg>
      {%- endif -%}

      <!-- Item Row 2: Finished Bowl / Processing Content Group -->
      <div class="solution-row reverse">
        <div class="solution-col-media">
          {%- if section.settings.image_2 != blank -%}
            {{ section.settings.image_2 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_2.alt }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="solution-col-text">
          <span class="arrow-indicator">⤶</span>
          <p>{{ section.settings.row_2_text }}</p>
        </div>
      </div>

      <!-- Mid-Lower Informational Text Callout Box -->
      <div class="center-highlight-block">
        <h3>{{ section.settings.highlight_title }}</h3>
        <p>{{ section.settings.highlight_body }}</p>
      </div>

      <!-- Item Row 3: Divided Tray / Raw Sourcing Components Section -->
      <div class="solution-row">
        <div class="solution-col-text" style="font-weight: 600; font-size: 0.95rem;">
          {{ section.settings.row_3_left_text | newline_to_br }}
        </div>
        <div class="solution-col-media">
          {%- if section.settings.image_3 != blank -%}
            {{ section.settings.image_3 | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.image_3.alt }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

    </div> <!-- End of Blob background container wrapper -->

    <!-- Section Outro Base Layout Typography Footer Block -->
    <div class="solution-footer-text">
      {{ section.settings.footer_text | newline_to_br }}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Our Solution Section",
  "settings": [
    {
      "type": "header",
      "content": "Color Palette Configuration"
    },
    {
      "type": "color",
      "id": "bg_blob_color",
      "label": "Organic Blob Background Color",
      "default": "#fcd36a"
    },
    {
      "type": "color",
      "id": "text_color_dark",
      "label": "Main Typography Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_accent",
      "label": "Accent Text Color (Red)",
      "default": "#d93829"
    },
    {
      "type": "header",
      "content": "Header Block Content"
    },
    {
      "type": "text",
      "id": "heading_start",
      "label": "Heading Prefix Text",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading Accent Text",
      "default": "Solution"
    },
    {
      "type": "inline_richtext",
      "id": "intro_text",
      "label": "Top Right Intro Callout",
      "default": "We Feed your pet <span>real food</span>, not processed science experiments"
    },
    {
      "type": "header",
      "content": "Row 1 Settings (Top Bowl Group)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Row 1 Circular Component Graphic"
    },
    {
      "type": "textarea",
      "id": "row_1_text",
      "label": "Row 1 Main Text Block",
      "default": "Real foods contain over 25000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease."
    },
    {
      "type": "header",
      "content": "Middle Segment Arched Typography Divider"
    },
    {
      "type": "text",
      "id": "arched_text",
      "label": "Arched Text Banner Wording",
      "default": "Our diets are made from real foods"
    },
    {
      "type": "header",
      "content": "Row 2 Settings (Middle Bowl Group)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Row 2 Circular Component Graphic"
    },
    {
      "type": "textarea",
      "id": "row_2_text",
      "label": "Row 2 Main Text Block",
      "default": "Whole food also bring in the benefits of co-factors also called 'The Entourage Effect' bringing the synergistic benefit of real food."
    },
    {
      "type": "header",
      "content": "Central Callout Information Text Layout Block"
    },
    {
      "type": "text",
      "id": "highlight_title",
      "label": "Callout Block Title Text",
      "default": "Our Formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "highlight_body",
      "label": "Callout Description Text Paragraph",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "header",
      "content": "Row 3 Settings (Bottom Divided Tray Group)"
    },
    {
      "type": "textarea",
      "id": "row_3_left_text",
      "label": "Row 3 Left Side Taglines list",
      "default": "No GMO, No Fillers, No Synthetic\nChemicals, No Preservatives, No Binders"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Row 3 Segment Divided Container Graphic"
    },
    {
      "type": "header",
      "content": "Footer Layout Bottom Elements Settings"
    },
    {
      "type": "inline_richtext",
      "id": "footer_text",
      "label": "Footer Banner Baseline Copy",
      "default": "The meats we use are from <strong>HACCP approved, ISO certified plants</strong>\nwith full traceability and are <strong>anti-biotic residue free</strong>\nThe fish we use are <strong>wild caught</strong>"
    }
  ],
  "presets": [
    {
      "name": "Our Solution Section",
      "category": "Custom Conceptual Blocks"
    }
  ]
}
{% endschema %}