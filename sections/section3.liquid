<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Chettan+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
    overflow: hidden;
  }
  
  .our-solution-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }
  .our-solution-bg img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: top center;
  }

  .our-solution-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    font-family: 'Baloo Chettan 2', sans-serif;
  }

  .os-title {
    font-family: 'Baloo Chettan 2', sans-serif;
    font-size: 76px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 24px;
    line-height: 1.05;
    color: #111111;
    letter-spacing: -0.01em;
  }
  .os-title-red {
    color: #d92b2b;
  }

  /* Helper visibility classes */
  .mobile-only-heading {
    display: none !important;
  }
  .desktop-only-heading {
    display: block !important;
  }

  /* Top Right Text (Mobile only layout helper) */
  .os-top-right-text {
    width: 100%;
    max-width: 820px;
    margin: 0 auto 10px auto;
    display: flex;
    justify-content: flex-end;
  }
  .os-top-right-text .os-bold-text {
    max-width: 380px;
    text-align: right;
    font-size: 24px;
    line-height: 1.25;
    font-weight: 700;
    color: #111111;
  }
  .os-bold-text-red {
    color: #d92b2b;
  }

  /* Middle Section Flex Layout */
  .os-middle-section {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto 0px auto;
  }

  .os-middle-image-wrapper {
    position: relative;
    width: 460px;
    max-width: 100%;
    flex-shrink: 0;
    z-index: 3;
  }
  .os-middle-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Desktop Position for side texts */
  @media screen and (min-width: 901px) {
    .os-side-text-left {
      position: absolute;
      right: 106%;
      bottom: 12%;
      width: 210px; /* Constrained to wrap exactly as in layout */
      text-align: right; 
      z-index: 5;
    }

    .os-side-content-right {
      position: absolute;
      left: 100%; 
      top: -15%; 
      width: 420px; /* Allowed width for single line experiments phrase */
      text-align: right; 
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: flex-end; 
      gap: 16px;
    }
    .os-side-content-right .os-bold-text {
      font-size: 24px;
      line-height: 1.25;
      font-weight: 700;
      color: #111111;
      text-align: right; 
    }
    .os-side-content-right .os-sub-text {
      max-width: 240px; /* Constrained to match layout paragraph shape */
      text-align: left; /* Text alignment left below right-aligned headline matching layout map */
    }
  }

  .os-sub-text {
    font-size: 15px;
    line-height: 1.45;
    font-weight: 500;
    color: #111111;
  }

  /* Bottom Text Area */
  .os-bottom-text-area {
    text-align: center;
    max-width: 820px; 
    margin: 40px auto 20px auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    z-index: 4;
  }

  .os-bottom-text-area .os-bold-text {
    font-size: 26px;
    font-weight: 800;
    line-height: 1.3;
    color: #111111;
  }

  .os-bottom-text-area .os-sub-text {
    max-width: 680px; 
    margin: 0 auto;
  }

  /* Bottom Section Flex Layout */
  .os-bottom-section {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: -160px auto 0 auto; /* Negative push pull layout elements together precisely */
    display: flex;
    justify-content: center;
    align-items: flex-end;
    z-index: 2;
  }

  .os-bottom-image-wrapper {
    width: 440px;
    max-width: 100%;
    flex-shrink: 0;
    z-index: 2;
    margin-bottom: -60px; /* Overlaps bottom canvas curves exactly like configuration overlay */
  }
  .os-bottom-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .os-bottom-left-text {
    position: absolute;
    left: 40px;
    bottom: 20px; 
    max-width: 220px; 
    text-align: right;
    z-index: 5;
  }
  .os-bottom-left-text .os-sub-text {
    font-size: 15px;
    line-height: 1.45;
    font-weight: 500;
    color: #111111;
  }

  @media screen and (max-width: 900px) {
    .os-title { font-size: 50px; }
    
    .mobile-only-heading {
      display: flex !important;
    }
    .desktop-only-heading {
      display: none !important;
    }
    
    .os-top-right-text {
      justify-content: center;
    }
    .os-top-right-text .os-bold-text {
      text-align: center;
      font-size: 20px;
    }
    
    .os-middle-image-wrapper {
      width: 100%;
      max-width: 380px;
      margin: 20px auto;
    }
    
    .os-side-text-left, .os-side-content-right {
      position: static;
      width: 100%;
      text-align: center;
      margin: 20px auto;
      padding: 0 10px;
    }
    
    .os-side-content-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }
    .os-side-content-right .os-bold-text {
      font-size: 20px;
      text-align: center;
    }
    .os-side-content-right .os-sub-text {
      text-align: center;
      max-width: 100%;
    }
    
    .os-bottom-section {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      margin-top: 20px;
    }
    
    .os-bottom-image-wrapper {
      margin-bottom: 0;
    }
    
    .os-bottom-left-text {
      position: static;
      text-align: center;
      margin: 10px auto;
    }
    .os-bottom-left-text .os-sub-text {
      font-size: 14px;
    }
    .os-bottom-text-area .os-bold-text {
      font-size: 24px;
    }
  }
</style>

{% if section.settings.bg_image %}
  <img class="our-solution-bg" src="{{ section.settings.bg_image | img_url: 'master' }}" alt="Background">
{% endif %}

<div class="our-solution-container">
  <div class="os-title">
    <span class="os-title-black">{{ section.settings.title_black }}</span>
    <span class="os-title-red">&nbsp;{{ section.settings.title_red }}</span>
  </div>

  <div class="os-top-right-text mobile-only-heading">
    <div class="os-bold-text">{{ section.settings.top_right_heading }}</div>
  </div>

  <div class="os-middle-section">
    <div class="os-middle-image-wrapper">
      {% if section.settings.mid_image %}
        <img src="{{ section.settings.mid_image | img_url: 'master' }}" alt="Middle Graphic">
      {% endif %}
      
      <div class="os-side-text-left">
        <div class="os-sub-text">{{ section.settings.mid_left_text }}</div>
      </div>
      
      <div class="os-side-content-right">
        <div class="os-bold-text desktop-only-heading">{{ section.settings.top_right_heading }}</div>
        <div class="os-sub-text">{{ section.settings.top_right_subtext }}</div>
      </div>
    </div>
  </div>

  <div class="os-bottom-text-area">
    <div class="os-bold-text">{{ section.settings.bot_heading }}</div>
    <div class="os-sub-text">{{ section.settings.bot_subtext }}</div>
  </div>

  <div class="os-bottom-section">
    <div class="os-bottom-image-wrapper">
      {% if section.settings.bot_image %}
        <img src="{{ section.settings.bot_image | img_url: 'master' }}" alt="Bottom Bowl">
      {% endif %}
    </div>
    
    <div class="os-bottom-left-text">
      <div class="os-sub-text">{{ section.settings.bot_left_text }}</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Solution",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Yellow shape)"
    },
    {
      "type": "text",
      "id": "title_black",
      "label": "Title (Black text)",
      "default": "Our"
    },
    {
      "type": "text",
      "id": "title_red",
      "label": "Title (Red text)",
      "default": "Solution"
    },
    {
      "type": "header",
      "content": "Middle Section (Image + Text)"
    },
    {
      "type": "textarea",
      "id": "top_right_heading",
      "label": "Top Right Heading",
      "default": "We feed your pet <span class='os-bold-text-red'>real food</span>, <br>not processed science experiments"
    },
    {
      "type": "textarea",
      "id": "top_right_subtext",
      "label": "Top Right Subtext",
      "default": "Real Foods contain over 26000 distinct bio-active compounds, these compounds play critical roles in modulating inflammation, supporting gut microbiome and preventing chronic disease"
    },
    {
      "type": "header",
      "content": "Middle Grid"
    },
    {
      "type": "textarea",
      "id": "mid_left_text",
      "label": "Middle Left Text",
      "default": "Whole food also bring in the benefits of co-factors also called \"The Entourage Effect\" bringing the synergistic benefit of real food"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Middle Image (Kibble bowl)"
    },
    {
      "type": "header",
      "content": "Bottom Text Area"
    },
    {
      "type": "textarea",
      "id": "bot_heading",
      "label": "Bottom Heading",
      "default": "Our formulations have human-grade, bioavailable ingredients best suited to your pet's digestive system."
    },
    {
      "type": "textarea",
      "id": "bot_subtext",
      "label": "Bottom Subtext",
      "default": "Since all nutrients are not equal, we source specific amino acid profiles to build muscle and immunity, and strictly use anti-inflammatory fats that fight disease rather than fuel it."
    },
    {
      "type": "header",
      "content": "Bottom Grid"
    },
    {
      "type": "image_picker",
      "id": "bot_image",
      "label": "Bottom Center Image (Divided raw bowl)"
    },
    {
      "type": "textarea",
      "id": "bot_left_text",
      "label": "Bottom Left Text",
      "default": "No GMO, No Fillers, No Synthetic Chemicals, No Preservatives, No Binders"
    }
  ],
  "presets": [
    {
      "name": "Our Solution"
    }
  ]
}
{% endschema %}