{%- style -%}
  .safety-sourcing-v2-{{ section.id }} {
    --text-main: {{ section.settings.text_color_main }};
    --text-brand: {{ section.settings.text_color_brand }};
    padding: 0 0 80px 0;
    background-color: #ffffff;
    font-family: inherit;
    position: relative;
    overflow: hidden;
  }

  /* Absolute Top Layer Vector/Graphic Placement */
  .safety-sourcing-v2-{{ section.id }} .graphic-bg-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1;
    pointer-events: none;
    display: block;
  }
  .safety-sourcing-v2-{{ section.id }} .graphic-bg-layer img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content Wrapper Container sitting safely above background layer */
  .safety-sourcing-v2-{{ section.id }} .content-interactive-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
    position: relative;
    z-index: 2;
  }

  /* Grid structure to lock asymmetrical text and plate asset placement */
  .safety-sourcing-v2-{{ section.id }} .asymmetric-asset-grid {
    display: grid;
    grid-template-columns: 1.2fr 2fr 1.2fr;
    align-items: center;
    padding-top: 40px;
    gap: 30px;
  }

  /* Left Exclusions Taglines Copy Placement (Desktop Only) */
  .safety-sourcing-v2-{{ section.id }} .left-tags-column {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-main);
    font-weight: 500;
    opacity: 0.9;
    padding-top: 120px;
  }

  /* Center Stage Plate Asset Handler */
  .safety-sourcing-v2-{{ section.id }} .center-plate-column {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .safety-sourcing-v2-{{ section.id }} .center-plate-column .plate-image-wrapper {
    width: 100%;
    max-width: 520px;
    position: relative;
  }
  .safety-sourcing-v2-{{ section.id }} .center-plate-column img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    position: relative;
    z-index: 2;
    margin-top: -37px;
    margin-left: 8px;
  }

  /* Hidden on Desktop by Default */
  .safety-sourcing-v2-{{ section.id }} .mobile-text-ring {
    display: none;
  }

  /* Central Main Headings Typography Block */
  .safety-sourcing-v2-{{ section.id }} .main-statement-typography p {
    text-align: center;
    max-width: 900px;
    margin: 50px auto 35px auto;
    font-size: 1.65rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text-main);
    letter-spacing: -0.01em;
  }
  .safety-sourcing-v2-{{ section.id }} .main-statement-typography strong {
    color: var(--text-brand);
    font-weight: 800;
  }

  /* Footnote Process details block */
  .safety-sourcing-v2-{{ section.id }} .fineprint-compliance-text {
    text-align: center;
    max-width: 850px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
    color: #4a4a4a;
    font-weight: 400;
    opacity: 0.95;
  }

  /* Mobile Responsive Realization matching image_190638.png perfectly */
  @media (max-width: 768px) {
    .safety-sourcing-v2-{{ section.id }} .asymmetric-asset-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 0;
      padding-top: 35px;
    }
    .safety-sourcing-v2-{{ section.id }} .left-tags-column {
      display: none;
    }
    .safety-sourcing-v2-{{ section.id }} .center-plate-column .plate-image-wrapper {
      max-width: 290px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    /* Perfect center-aligned automatic spinning configuration */
    .safety-sourcing-v2-{{ section.id }} .mobile-text-ring {
      display: block;
      position: absolute;
      top: 50%;
      left: 50%;
      width: 126%; 
      height: 126%;
      z-index: 1;
      pointer-events: none;
      transform-origin: center center;
      animation: smoothSpinRing 35s linear infinite;
      will-change: transform;
    }

    .safety-sourcing-v2-{{ section.id }} .main-statement-typography p {
      font-size: 1.55rem;
      line-height: 1.4;
      padding: 0 15px;
      margin: 40px auto 25px auto;
    }
    .safety-sourcing-v2-{{ section.id }} .fineprint-compliance-text {
      font-size: 14px;
      line-height: 1.55;
      padding: 0 20px;
    }
  }

  /* Anti-wobble rotation matrix calculation */
  @keyframes smoothSpinRing {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
{%- endstyle -%}

<section class="safety-sourcing-v2-{{ section.id }}">
  
  <!-- Adaptive Background Image System -->
  <picture class="graphic-bg-layer">
    {%- if section.settings.yellow_bg_image_mobile != blank -%}
      <source media="(max-width: 768px)" srcset="{{ section.settings.yellow_bg_image_mobile | image_url: width: 768 }}">
    {%- endif -%}
    
    {%- if section.settings.yellow_bg_image != blank -%}
      <img src="{{ section.settings.yellow_bg_image | image_url: width: 2000 }}" loading="eager" alt="Background Layer Curve">
    {%- elsif section.settings.yellow_bg_image_mobile != blank -%}
      <img src="{{ section.settings.yellow_bg_image_mobile | image_url: width: 768 }}" loading="eager" alt="Background Layer Curve">
    {%- endif -%}
  </picture>

  <div class="content-interactive-container">
    
    <!-- Plate Showcase Row Layout Grid -->
    <div class="asymmetric-asset-grid">
      
      <!-- Left Column text strings (Desktop Only) -->
      <div class="left-tags-column">
        {{ section.settings.left_tags | newline_to_br }}
      </div>

      <!-- Center Segment Plate Image Container -->
      <div class="center-plate-column">
        <div class="plate-image-wrapper">
          {%- if section.settings.plate_image != blank -%}
            {{ section.settings.plate_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.plate_image.alt }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}

          <!-- Mathematical exact 1:1 circle path to prevent geometric distortion -->
          <svg class="mobile-text-ring" viewBox="0 0 500 500" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <path id="mobileCirclePath-{{ section.id }}" d="M 250,250 m -222,0 a 222,222 0 1,1 444,0 a 222,222 0 1,1 -444,0" fill="transparent" />
            <text fill="{{ section.settings.text_color_main }}" font-size="14" font-weight="700" letter-spacing="4px">
              <textPath href="#mobileCirclePath-{{ section.id }}" startOffset="0%">
                • No GMO • No Fillers • No Synthetic Chemicals • No Preservatives • No Binders • No GMO • No Fillers • No Synthetic Chemicals • No Preservatives • No Binders
              </textPath>
            </text>
          </svg>
        </div>
      </div>

      <!-- Right Spacer to push structure naturally into asymmetric layout look -->
      <div class="right-empty-spacer" aria-hidden="true"></div>
    </div>

    <!-- Multi-Line Dynamic Accent Brand Copy Typography Block -->
    <div class="main-statement-typography">
      {{ section.settings.main_statement }}
    </div>

    <!-- Production Sourcing Fineprint Copy Container -->
    <div class="fineprint-compliance-text">
      {{ section.settings.safety_body_text | newline_to_br }}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Sourcing Layout (Manual)",
  "settings": [
    {
      "type": "header",
      "content": "Custom Image Asset Managers"
    },
    {
      "type": "image_picker",
      "id": "yellow_bg_image",
      "label": "Yellow Arc Background Graphic Asset (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "yellow_bg_image_mobile",
      "label": "Yellow Arc Background Graphic Asset (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "plate_image",
      "label": "Central Plate Food Graphic Asset (688x688)"
    },
    {
      "type": "header",
      "content": "Global Theme Color Overrides"
    },
    {
      "type": "color",
      "id": "text_color_main",
      "label": "Dark Baseline Typography Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color_brand",
      "label": "Red Focal Highlight Color",
      "default": "#d93829"
    },
    {
      "type": "header",
      "content": "Section Typography Settings"
    },
    {
      "type": "textarea",
      "id": "left_tags",
      "label": "Left Side Exclusion Phrases",
      "default": "No GMO, No Fillers, No Synthetic\nChemicals, No Preservatives, No Binders"
    },
    {
      "type": "richtext",
      "id": "main_statement",
      "label": "Center Large Copy Block Statement",
      "default": "<p>The meats we use are from <strong>HACCP approved, ISO certified plants</strong><br>with full traceability and are <strong>anti-biotic residue free</strong><br>The fish we use are <strong>wild caught</strong></p>"
    },
    {
      "type": "textarea",
      "id": "safety_body_text",
      "label": "Compliance Safety Footnote Content",
      "default": "Safety is non-negotiable, which is why we enforce a strict kill step at every stage of our process including Bacteriophages, traditional Curing agents (vinegar/citric acid), low temperature long duration pasteurization and UV exposure before packing.\nAs a final protective barrier, the packs are vacuum-sealed and flushed with modified atmospheric gases."
    }
  ],
  "presets": [
    {
      "name": "Sourcing Layout (Manual)"
    }
  ]
}
{% endschema %}